
<header class="admin-topnav sticky-top">
    <div class="d-flex align-items-center gap-3">

        <!-- Mobile hamburger — triggers offcanvas sidebar -->
        <button class="btn btn-link d-lg-none text-white p-0 me-1"
                type="button"
                data-bs-toggle="offcanvas"
                data-bs-target="#mobileSidebar"
                aria-controls="mobileSidebar"
                aria-label="Open sidebar">
            <i class="bi bi-list fs-4"></i>
        </button>

        <!-- Desktop sidebar toggle (icon only) -->
        <button class="btn btn-link d-none d-lg-inline-flex text-white p-0 me-1"
                type="button"
                onclick="toggleDesktopSidebar()"
                aria-label="Collapse sidebar">
            <i class="bi bi-layout-sidebar fs-5"></i>
        </button>

        <!-- Page title / breadcrumb area -->
        <div class="d-none d-sm-block">
            <nav aria-label="breadcrumb">
                <ol class="breadcrumb mb-0">
                    <li class="breadcrumb-item"><a href="/admin/dashboard" class="text-info text-decoration-none">Admin</a></li>
                    <li class="breadcrumb-item active text-Black" aria-current="page"><SectionOutlet SectionName="NavTitle" /></li>
                </ol>
            </nav>
        </div>
    </div>

    <!-- Right side controls -->
    <div class="d-flex align-items-center gap-2 gap-sm-3 ms-auto">

