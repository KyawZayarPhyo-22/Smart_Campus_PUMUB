    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            // 🌟 ၁။ အရင်ဆုံး Session Storage ကို စစ်ပါမယ်
            var isLogined = await JS.InvokeAsync<string>("sessionStorage.getItem", "islogined");
            var roleName = await JS.InvokeAsync<string>("sessionStorage.getItem", "rolename");

            // Login မဝင်ထားဘူး (သို့) Role က admin/tutor မဟုတ်ဘူးဆိုရင်
            if (isLogined != "true" || (roleName?.ToLower() != "admin" && roleName?.ToLower() != "tutor"))
            {
                // Home page ဆီ ပြန်ကန်ချမယ်
                NavigationManager.NavigateTo("/");
                return; // ⚠️ အရေးကြီးသည် - အောက်က Chart ဆွဲတဲ့ Code တွေ ဆက်မလုပ်တော့ဘဲ ဒီမှာတင် ရပ်လိုက်ပါမယ်
            }

            // 🌟 ၂။ မင်းရဲ့ မူလ Chart Render လုပ်တဲ့ အပိုင်း
            _isRendered = true;
            try
            {
                await JS.InvokeVoidAsync("initCharts", RoleDistributionData);
            }
            catch
            {
                // initCharts may not be loaded yet - wait and retry once
                try
                {
                    await Task.Delay(500);
                    await JS.InvokeVoidAsync("initCharts", RoleDistributionData);
                }
                catch (Exception ex)
                {
                    // If still not found, log and continue - do NOT let this kill the circuit
                    Console.WriteLine($"initCharts JS error (chart will not render): {ex.Message}");
                }
            }
        }
    }

    private async Task LoadRoleDistributionAsync()
    {
        try
        {
            var apiData = await HttpClientService.ExecuteAsync<List<RoleDistributionChartPoint>>(
                "user/count/by-role",
                Smart_Campus_PUMUB.BlazorServer.Frontend.Services.EnumHttpMethod.Get);

            if (apiData is not null && apiData.Any())
            {
                RoleDistributionData.Clear();
                RoleDistributionData.AddRange(apiData);
                return;
            }
        }
        catch (Exception ex)
        {
            Console.WriteLine($"Error loading data: {ex.Message}");
        }

        // Error တက်လျှင် Default data သုံးရန်
        if (!RoleDistributionData.Any())
        {
            RoleDistributionData.Clear();
            RoleDistributionData.AddRange(GetDefaultRoleDistribution());
        }
    }

