@inject IJSRuntime JS
@rendermode InteractiveServer
@using Newtonsoft.Json
@inject IHttpClientFactory ClientFactory
@inject Smart_Campus_PUMUB.BlazorServer.Frontend.Services.HttpClientService HttpClientService
<style>
    .stat-icon {
        display: flex;
        align-items: center;
        /* ဒေါင်လိုက် အလယ် */
        justify-content: center;
        /* အလျားလိုက် အလယ် */
        width: 36px;
        height: 36px;
        border-radius: 8px;
        /* ပိုလှအောင် ထောင့်လေးဝိုင်းပေးပါ */
    }
</style>
