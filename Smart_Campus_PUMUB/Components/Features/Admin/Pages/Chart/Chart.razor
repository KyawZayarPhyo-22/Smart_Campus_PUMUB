@page "/admin/dashboard"
@using Microsoft.AspNetCore.Mvc
@layout AdminLayout
@inject IJSRuntime JS

<SectionContent SectionName="NavTitle">
    Dashboard
</SectionContent>

<!-- Page Header -->
<div class="page-header">
    <div class="d-flex align-items-center justify-content-between flex-wrap gap-2">
        <div>
            <h3><i class="bi bi-speedometer2 me-2 text-info"></i>Command Center</h3>
            <p>System Overview, Charts, and Live Telemetry.</p>
        </div>
        <span class="badge bg-success bg-opacity-25 text-success border border-success border-opacity-25 px-3 py-2">
            <i class="bi bi-circle-fill me-1" style="font-size:0.5rem;"></i> System Online
        </span>
    </div>
</div>

<!-- KPI Stat Cards -->
<div class="row g-3 mb-4">
    <div class="col-6 col-lg-3">
        <div class="stat-card" style="--card-accent:#22d3ee;">
            <div class="d-flex align-items-center justify-content-between mb-3">
                <div class="stat-icon" style="background:rgba(34,211,238,0.12);">
                    <i class="bi bi-people-fill text-info"></i>
                </div>
                <span class="badge bg-info bg-opacity-25 text-info border border-info border-opacity-25 stat-change">
                    <i class="bi bi-arrow-up-short"></i>+12%
                </span>
            </div>
            <div class="stat-value text-info">4,520</div>
            <div class="stat-label mt-1">Active Students</div>
        </div>
    </div>
    <div class="col-6 col-lg-3">
        <div class="stat-card" style="--card-accent:#8b5cf6;">
            <div class="d-flex align-items-center justify-content-between mb-3">
                <div class="stat-icon" style="background:rgba(139,92,246,0.12);">
                    <i class="bi bi-person-workspace" style="color:#8b5cf6;"></i>
                </div>
                <span class="badge border stat-change"
                    style="background:rgba(139,92,246,0.15);color:#8b5cf6;border-color:rgba(139,92,246,0.3)!important;">
                    <i class="bi bi-arrow-up-short"></i>+5%
                </span>
            </div>
            <div class="stat-value" style="color:#8b5cf6;">315</div>
            <div class="stat-label mt-1">Total Tutors</div>
        </div>
    </div>
    <div class="col-6 col-lg-3">
        <div class="stat-card" style="--card-accent:#10b981;">
            <div class="d-flex align-items-center justify-content-between mb-3">
                <div class="stat-icon" style="background:rgba(16,185,129,0.12);">
                    <i class="bi bi-book-fill text-success"></i>
                </div>
                <span
                    class="badge bg-success bg-opacity-25 text-success border border-success border-opacity-25 stat-change">
                    <i class="bi bi-arrow-up-short"></i>+8%
                </span>
            </div>
            <div class="stat-value text-success">1,240</div>
            <div class="stat-label mt-1">Library PDF Files</div>
        </div>
    </div>
    <div class="col-6 col-lg-3">
        <div class="stat-card" style="--card-accent:#ef4444;">
            <div class="d-flex align-items-center justify-content-between mb-3">
                <div class="stat-icon" style="background:rgba(239,68,68,0.12);">
                    <i class="bi bi-megaphone-fill text-danger"></i>
                </div>
                <span
                    class="badge bg-danger bg-opacity-25 text-danger border border-danger border-opacity-25 stat-change">
                    <i class="bi bi-exclamation-circle"></i> Live
                </span>
            </div>
            <div class="stat-value text-danger">2</div>
            <div class="stat-label mt-1">Active Alerts</div>
        </div>
    </div>
</div>

<!-- ═══════════════════════════════════════════════════════════════════
     Charts Row — Highcharts (div-based, Blazor SPA safe)
     ═══════════════════════════════════════════════════════════════════ -->
<div class="row g-3 mb-4">

    <!-- Pie / Donut — Students by Major -->
    <div class="col-12 col-lg-5">
        <div class="tech-card h-100">
            <div class="tech-card-header">
                <h6 class="tech-card-title">
                    <i class="bi bi-pie-chart-fill me-2 text-info"></i>Students by Major
                </h6>
                <span class="badge bg-info text-dark">2026</span>
            </div>
            <!-- Highcharts renders into this div — NO canvas needed -->
            <div id="hc-pie-chart" style="min-height:260px; width:100%;"></div>
        </div>
    </div>

    <!-- Column — Library Books & Tutors by Dept -->
    <div class="col-12 col-lg-7">
        <div class="tech-card h-100">
            <div class="tech-card-header">
                <h6 class="tech-card-title">
                    <i class="bi bi-bar-chart-fill me-2 text-info"></i>Library Books &amp; Tutors by Dept.
                </h6>
                <span class="badge bg-info text-dark">2026</span>
            </div>
            <!-- Highcharts renders into this div — NO canvas needed -->
            <div id="hc-bar-chart" style="min-height:260px; width:100%;"></div>

        </div>
    </div>

</div>

<!-- Quick Stats Row -->
<div class="row g-3">
    <!-- Recent Activity -->
    <div class="col-12 col-md-6">
        <div class="tech-card h-100">
            <div class="tech-card-header">
                <h6 class="tech-card-title">
                    <i class="bi bi-clock-history me-2 text-info"></i>Recent Activity
                </h6>
            </div>
            <ul class="list-unstyled mb-0">
                <li class="d-flex align-items-center gap-3 py-2 border-bottom"
                    style="border-color:var(--border)!important;">
                    <span class="stat-icon flex-shrink-0"
                        style="width:36px;height:36px;background:rgba(34,211,238,0.1);font-size:0.9rem;">
                        <i class="bi bi-person-plus text-info"></i>
                    </span>
                    <div class="flex-grow-1 min-w-0">
                        <p class="mb-0 fw-semibold small">New student registered</p>
                        <p class="mb-0 text-muted" style="font-size:0.75rem;">Mg Mg — ME-2026-001</p>
                    </div>
                    <small class="text-muted flex-shrink-0">2m ago</small>
                </li>
                <li class="d-flex align-items-center gap-3 py-2 border-bottom"
                    style="border-color:var(--border)!important;">
                    <span class="stat-icon flex-shrink-0"
                        style="width:36px;height:36px;background:rgba(16,185,129,0.1);font-size:0.9rem;">
                        <i class="bi bi-book text-success"></i>
                    </span>
                    <div class="flex-grow-1 min-w-0">
                        <p class="mb-0 fw-semibold small">New book uploaded</p>
                        <p class="mb-0 text-muted" style="font-size:0.75rem;">Advanced Engineering Math</p>
                    </div>
                    <small class="text-muted flex-shrink-0">1h ago</small>
                </li>
                <li class="d-flex align-items-center gap-3 py-2 border-bottom"
                    style="border-color:var(--border)!important;">
                    <span class="stat-icon flex-shrink-0"
                        style="width:36px;height:36px;background:rgba(239,68,68,0.1);font-size:0.9rem;">
                        <i class="bi bi-megaphone text-danger"></i>
                    </span>
                    <div class="flex-grow-1 min-w-0">
                        <p class="mb-0 fw-semibold small">Alert posted</p>
                        <p class="mb-0 text-muted" style="font-size:0.75rem;">Server maintenance tonight</p>
                    </div>
                    <small class="text-muted flex-shrink-0">3h ago</small>
                </li>
                <li class="d-flex align-items-center gap-3 py-2">
                    <span class="stat-icon flex-shrink-0"
                        style="width:36px;height:36px;background:rgba(139,92,246,0.1);font-size:0.9rem;">
                        <i class="bi bi-calendar-event" style="color:#8b5cf6;"></i>
                    </span>
                    <div class="flex-grow-1 min-w-0">
                        <p class="mb-0 fw-semibold small">Event published</p>
                        <p class="mb-0 text-muted" style="font-size:0.75rem;">Fresher Welcome Ceremony</p>
                    </div>
                    <small class="text-muted flex-shrink-0">5h ago</small>
                </li>
            </ul>
        </div>
    </div>

    <!-- System Summary -->
    <div class="col-12 col-md-6">
        <div class="tech-card h-100">
            <div class="tech-card-header">
                <h6 class="tech-card-title">
                    <i class="bi bi-grid me-2 text-info"></i>System Summary
                </h6>
            </div>
            <div class="row g-2">
                <div class="col-6">
                    <div class="p-3 rounded-2 text-center"
                        style="background:rgba(34,211,238,0.06);border:1px solid rgba(34,211,238,0.15);">
                        <div class="fw-bold fs-4 text-info">8</div>
                        <div class="text-muted small">Faculties</div>
                    </div>
                </div>
                <div class="col-6">
                    <div class="p-3 rounded-2 text-center"
                        style="background:rgba(139,92,246,0.06);border:1px solid rgba(139,92,246,0.15);">
                        <div class="fw-bold fs-4" style="color:#8b5cf6;">24</div>
                        <div class="text-muted small">Departments</div>
                    </div>
                </div>
                <div class="col-6">
                    <div class="p-3 rounded-2 text-center"
                        style="background:rgba(16,185,129,0.06);border:1px solid rgba(16,185,129,0.15);">
                        <div class="fw-bold fs-4 text-success">120</div>
                        <div class="text-muted small">Subjects</div>
                    </div>
                </div>
                <div class="col-6">
                    <div class="p-3 rounded-2 text-center"
                        style="background:rgba(245,158,11,0.06);border:1px solid rgba(245,158,11,0.15);">
                        <div class="fw-bold fs-4 text-warning">6</div>
                        <div class="text-muted small">Semesters</div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

@code
{
    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        // Highcharts is div-based so there are no canvas race conditions.
        // We call initCharts() every time this component renders so charts
        // always appear correctly after Blazor SPA navigation.
        await JS.InvokeVoidAsync("initCharts");
    }
}