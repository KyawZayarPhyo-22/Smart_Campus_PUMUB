<!-- Completed Students Section -->
<div class="row g-3 mb-4 mt-2">
    <div class="col-12">
        <div class="tech-card">
            <div class="tech-card-header d-flex align-items-center justify-content-between">
                <h6 class="tech-card-title mb-0">
                    <i class="bi bi-mortarboard-fill me-2" style="color:#fbbf24;"></i>Completed Students
                    <span class="badge ms-2" style="background:rgba(251,191,36,0.15);color:#f59e0b;border:1px solid rgba(251,191,36,0.3);font-size:0.75rem;">All 9 Semesters Passed</span>
                </h6>
                <span class="badge" style="background:rgba(16,185,129,0.15);color:#10b981;border:1px solid rgba(16,185,129,0.3);font-size:0.85rem;">
                    @completedStudents.Count Graduates
                </span>
            </div>
            @if (completedStudents.Any())
            {
                <div class="table-responsive">
                    <table class="table table-hover mb-0" style="font-size:0.9rem;">
                        <thead style="background:rgba(251,191,36,0.06);">
                            <tr>
                                <th style="color:#94a3b8;font-weight:600;padding:14px 16px;border-bottom:1px solid rgba(255,255,255,0.06);">No.</th>
                                <th style="color:#94a3b8;font-weight:600;padding:14px 16px;border-bottom:1px solid rgba(255,255,255,0.06);">Roll No</th>
                                <th style="color:#94a3b8;font-weight:600;padding:14px 16px;border-bottom:1px solid rgba(255,255,255,0.06);">Full Name</th>
                                <th style="color:#94a3b8;font-weight:600;padding:14px 16px;border-bottom:1px solid rgba(255,255,255,0.06);">Major</th>
                                <th style="color:#94a3b8;font-weight:600;padding:14px 16px;border-bottom:1px solid rgba(255,255,255,0.06);">Class Year</th>
                                <th style="color:#94a3b8;font-weight:600;padding:14px 16px;border-bottom:1px solid rgba(255,255,255,0.06);">Status</th>
                            </tr>
                        </thead>
                        <tbody>
                            @for (int i = 0; i < completedStudents.Count; i++)
                            {
                                var stu = completedStudents[i];
                                var rowNum = i + 1;
                                <tr style="border-bottom:1px solid rgba(255,255,255,0.04);transition:background 0.15s;">
                                    <td style="padding:12px 16px;color:#64748b;">@rowNum</td>
                                    <td style="padding:12px 16px;color:#e2e8f0;font-weight:600;">@(stu.CurrentRollNo ?? "-")</td>
                                    <td style="padding:12px 16px;color:#e2e8f0;">@(stu.FullName ?? stu.UserName ?? "-")</td>
                                    <td style="padding:12px 16px;color:#94a3b8;">@(stu.CurrentMajor ?? "-")</td>
                                    <td style="padding:12px 16px;color:#94a3b8;">@(stu.CurrentClassYear ?? "-")</td>
                                    <td style="padding:12px 16px;">
                                        <span class="badge" style="background:rgba(251,191,36,0.15);color:#f59e0b;border:1px solid rgba(251,191,36,0.25);">
                                            <i class="bi bi-mortarboard me-1"></i>Graduated
                                        </span>
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            }
            else
            {
                <div style="text-align:center;padding:48px 24px;color:#64748b;">
                    <i class="bi bi-mortarboard" style="font-size:2.5rem;opacity:0.3;"></i>
                    <p class="mt-3 mb-0" style="font-size:0.95rem;">No students have completed all 9 semesters yet.</p>
                </div>
            }
        </div>
    </div>
</div>

