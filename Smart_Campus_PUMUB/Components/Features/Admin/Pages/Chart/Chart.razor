    private string GetTimeAgo(DateTime createdAt)
    {
        var timeSpan = DateTime.UtcNow - createdAt;
        if (timeSpan.TotalMinutes < 1) return "Just now";
        if (timeSpan.TotalMinutes < 60) return $"{(int)timeSpan.TotalMinutes}m ago";
        if (timeSpan.TotalHours < 24) return $"{(int)timeSpan.TotalHours}h ago";
        return createdAt.ToString("MMM dd");
    }
    private string GetIconColor(string title)
    {
        title = title.ToLower();
        return title switch
        {
            _ when title.Contains("book") => "text-primary", // Book အတွက် အပြာ
            _ when title.Contains("tutor") => "text-success", // Tutor အတွက် အစိမ်း
            _ when title.Contains("student") => "text-warning",
            _ when title.Contains("role") => "text-danger",// Student အတွက် အဝါ
            _ => "text-info" // ကျန်တာတွေအတွက် မီးခိုးရောင်
        };

    }
