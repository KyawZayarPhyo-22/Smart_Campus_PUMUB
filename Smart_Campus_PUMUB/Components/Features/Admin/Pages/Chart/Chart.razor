@code
{
    private readonly List<RoleDistributionChartPoint> RoleDistributionData = new();
    private Timer? _timer;
    private List<ActivityItem> recentActivities = new();
    private bool _isRendered = false; // JS Interop အတွက် အရေးကြီးသည်

    private int activeStudentCount = 0;
    private int previousStudentCount = 2;
    private double percentage = 0;
    private int totalTutorCount = 0;
    private int previousTutorCount = 4;
    private double tutorPercentage = 0;
    private int bookCount = 0;
    private int previousBookCount = 1100;
    private double bookPercentage = 0;
    private int activeAlertCount = 0;
    private SystemSummary summary = new();

    protected override async Task OnInitializedAsync()
    {
        try
        {
            _timer = new Timer(TimerCallback, null, 0, 60000);
            var client = ClientFactory.CreateClient("SmartCampusApi");
            // Data များကို တစ်ပြိုင်နက်တည်း Fetch လုပ်ခြင်းက ပိုမြန်သည်
            var task1 = client.GetFromJsonAsync<StudentCountResponse>("student/count/active");
            var task2 = client.GetFromJsonAsync<TutorCountResponse>("tutor/count/active");
            var task3 = client.GetFromJsonAsync<BookCountResponse>("book/count/active");
            var task4 = client.GetFromJsonAsync<ActivityCountResponse>("activity/count/active");
            summary = await client.GetFromJsonAsync<SystemSummary>("Home/summary");
            @* await Task.WhenAll(task1, task2, task3, task4); *@

            activeStudentCount = task1.Result?.Count ?? 0;
            totalTutorCount = task2.Result?.Count ?? 0;
            bookCount = task3.Result?.Count ?? 0;
            activeAlertCount = task4.Result?.Count ?? 0;

            // Calculations
            percentage = previousStudentCount > 0 ? ((double)(activeStudentCount - previousStudentCount) / previousStudentCount) *
    100 : 0;
            tutorPercentage = previousTutorCount > 0 ? ((double)(totalTutorCount - previousTutorCount) / previousTutorCount) * 100 :
    0;
            bookPercentage = previousBookCount > 0 ? ((double)(bookCount - previousBookCount) / previousBookCount) * 100 : 0;

        }
        catch (Exception ex)
        {
            Console.WriteLine($"Error: {ex.Message}");
        }
        // Component စတင်ချိန်တွင် Timer ကို စတင်ပါ

    }

    private async void TimerCallback(object? state)
    {
        @* await LoadRoleDistributionAsync();

        // UI ကို Update လုပ်ရန်
        await InvokeAsync(StateHasChanged);

        // Chart ကို ပြန်ဆွဲရန် (Render ဖြစ်ပြီးမှသာ ခေါ်ပါ)
        if (_isRendered)
        {
            await InvokeAsync(async () =>
            {
                await JS.InvokeVoidAsync("initCharts", RoleDistributionData);
            });
        } *@
        try
        {
            await LoadActivities();
            await LoadRoleDistributionAsync();
            await InvokeAsync(StateHasChanged);
            if (_isRendered)
            {
                await InvokeAsync(async () => await JS.InvokeVoidAsync("initCharts", RoleDistributionData));
            }
        }
        catch (Exception ex)
        {
            Console.WriteLine($"Timer Error: {ex.Message}");
        }
    }

    public void Dispose()
    {
        _timer?.Dispose();
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            _isRendered = true; // JS အဆင်သင့်ဖြစ်ပြီဟု သတ်မှတ်လိုက်သည်
            try
            {
                await JS.InvokeVoidAsync("initCharts", RoleDistributionData);
            }
            catch
            {
                await Task.Delay(250);
                await JS.InvokeVoidAsync("initCharts", RoleDistributionData);
            }
        }
    }

    private async Task LoadRoleDistributionAsync()
    {
        try
        {
            var apiData = await HttpClientService.ExecuteAsync<List<RoleDistributionChartPoint>>(
                "user/count/by-role",
                Smart_Campus_PUMUB.BlazorServer.Frontend.Services.EnumHttpMethod.Get);

            if (apiData is not null && apiData.Any())
            {
                RoleDistributionData.Clear();
                RoleDistributionData.AddRange(apiData);
                return;
            }
        }
        catch (Exception ex)
        {
            Console.WriteLine($"Error loading data: {ex.Message}");
        }

        // Error တက်လျှင် Default data သုံးရန်
        if (!RoleDistributionData.Any())
        {
            RoleDistributionData.Clear();
            RoleDistributionData.AddRange(GetDefaultRoleDistribution());
        }
    }

    private static List<RoleDistributionChartPoint> GetDefaultRoleDistribution()
    {
        return new()
        {
            new RoleDistributionChartPoint { name = "Admin", y = 10, color = "#22d3ee" },
            new RoleDistributionChartPoint { name = "Student", y = 70, color = "#10b981" },
            new RoleDistributionChartPoint { name = "Tutor", y = 20, color = "#8b5cf6" }
        };
    }
    private async Task LoadActivities()
    {
        var data = await HttpClientService.ExecuteAsync<List<ActivityItem>>(
            "activity/recent",
            Smart_Campus_PUMUB.BlazorServer.Frontend.Services.EnumHttpMethod.Get);
        if (data != null) recentActivities = data;
    }
    public class StudentCountResponse { public int Count { get; set; } }
    public class RoleData { public string Name { get; set; } public int Y { get; set; } }
