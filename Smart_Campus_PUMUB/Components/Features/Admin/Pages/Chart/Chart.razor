                    s.Sem8_Result, s.Sem9_Result }.Any(r => string.Equals(r, "Fail", StringComparison.OrdinalIgnoreCase))),

                "AllPass" => q.Where(s =>
                    string.Equals(s.Sem1_Result, "Pass", StringComparison.OrdinalIgnoreCase) &&
                    string.Equals(s.Sem2_Result, "Pass", StringComparison.OrdinalIgnoreCase) &&
                    string.Equals(s.Sem3_Result, "Pass", StringComparison.OrdinalIgnoreCase) &&
                    string.Equals(s.Sem4_Result, "Pass", StringComparison.OrdinalIgnoreCase) &&
                    string.Equals(s.Sem5_Result, "Pass", StringComparison.OrdinalIgnoreCase) &&
                    string.Equals(s.Sem6_Result, "Pass", StringComparison.OrdinalIgnoreCase) &&
                    string.Equals(s.Sem7_Result, "Pass", StringComparison.OrdinalIgnoreCase) &&
                    string.Equals(s.Sem8_Result, "Pass", StringComparison.OrdinalIgnoreCase) &&
                    string.Equals(s.Sem9_Result, "Pass", StringComparison.OrdinalIgnoreCase)),

                "NoResult" => q.Where(s => new[] { s.Sem1_Result, s.Sem2_Result, s.Sem3_Result,
                    s.Sem4_Result, s.Sem5_Result, s.Sem6_Result, s.Sem7_Result,
                    s.Sem8_Result, s.Sem9_Result }.All(r => string.IsNullOrEmpty(r))),

                _ => q  // "All"
            };

            return q.ToList();
        }
    }

    protected override async Task OnInitializedAsync()
    {
        _timer = new Timer(TimerCallback, null, 0, 60000);
        var client = ClientFactory.CreateClient("SmartCampusApi");

        try
        {
            var res = await client.GetFromJsonAsync<StudentCountResponse>("student/count/active");
            activeStudentCount = res?.Count ?? 0;
        }
        catch (Exception ex) { Console.WriteLine($"Error student count: {ex.Message}"); }

        try
        {
            var res = await client.GetFromJsonAsync<TutorCountResponse>("tutor/count/active");
            totalTutorCount = res?.Count ?? 0;
        }
        catch (Exception ex) { Console.WriteLine($"Error tutor count: {ex.Message}"); }

        try
        {
            var res = await client.GetFromJsonAsync<BookCountResponse>("book/count/active");
            bookCount = res?.Count ?? 0;
        }
        catch (Exception ex) { Console.WriteLine($"Error book count: {ex.Message}"); }

        try
        {
            var res = await client.GetFromJsonAsync<ActivityCountResponse>("activity/count/active");
            activeAlertCount = res?.Count ?? 0;
        }
        catch (Exception ex) { Console.WriteLine($"Error activity count: {ex.Message}"); }

        try
        {
            summary = await client.GetFromJsonAsync<SystemSummary>("Home/summary") ?? new();
        }
        catch (Exception ex) { Console.WriteLine($"Error summary: {ex.Message}"); }

        // Load all students (used for both the Directory and Completed Students sections)
        try
        {
            var studentData = await HttpClientService.ExecuteAsync<List<StudentModel>>(
                "student",
                Smart_Campus_PUMUB.BlazorServer.Frontend.Services.EnumHttpMethod.Get);

            if (studentData != null)
            {
                allStudents = studentData;
                completedStudents = studentData.Where(s =>
                    string.Equals(s.Sem1_Result, "Pass", StringComparison.OrdinalIgnoreCase) &&
                    string.Equals(s.Sem2_Result, "Pass", StringComparison.OrdinalIgnoreCase) &&
                    string.Equals(s.Sem3_Result, "Pass", StringComparison.OrdinalIgnoreCase) &&
                    string.Equals(s.Sem4_Result, "Pass", StringComparison.OrdinalIgnoreCase) &&
                    string.Equals(s.Sem5_Result, "Pass", StringComparison.OrdinalIgnoreCase) &&
                    string.Equals(s.Sem6_Result, "Pass", StringComparison.OrdinalIgnoreCase) &&
                    string.Equals(s.Sem7_Result, "Pass", StringComparison.OrdinalIgnoreCase) &&
                    string.Equals(s.Sem8_Result, "Pass", StringComparison.OrdinalIgnoreCase) &&
                    string.Equals(s.Sem9_Result, "Pass", StringComparison.OrdinalIgnoreCase)
                ).ToList();
            }
        }
        catch (Exception ex) { Console.WriteLine($"Error loading students: {ex.Message}"); }

        // Calculations
        percentage = previousStudentCount > 0 ? ((double)(activeStudentCount - previousStudentCount) / previousStudentCount) * 100 : 0;
        tutorPercentage = previousTutorCount > 0 ? ((double)(totalTutorCount - previousTutorCount) / previousTutorCount) * 100 : 0;
        bookPercentage = previousBookCount > 0 ? ((double)(bookCount - previousBookCount) / previousBookCount) * 100 : 0;
    }

