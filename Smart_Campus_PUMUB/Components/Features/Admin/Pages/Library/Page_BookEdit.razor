@page "/admin/book/edit/{BookId:int}"
@layout AdminLayout
@namespace Smart_Campus_PUMUB.Components.Admin.Pages.Book
@using Smart_Campus_PUMUB.WebApi.Models
@rendermode InteractiveServer

<div class="modal-dialog modal-md mt-5">
    <div class="modal-content tech-card">
        <div class="modal-header border-0 pb-0">
            <h5 class="modal-title fw-bold text-white">Edit Book</h5>
        </div>
        <EditForm Model="bookRequest" OnValidSubmit="UpdateBook" FormName="EditBookForm">
            <DataAnnotationsValidator />
            <div class="modal-body">
                <div class="col-12 mb-3">
                    <label class="form-label text-light">Category</label>
                    <InputSelect @bind-Value="bookRequest.CategoryId" class="form-select">
                        <option value="0">-- Select Category --</option>
                        @foreach (var cat in CategoryList) {
                            <option value="@cat.CategoryId">@cat.CategoryName</option>
                        }
                    </InputSelect>
                </div>

                <div class="col-12 mb-3">
                    <label class="form-label text-light">Book Name</label>
                    <InputText @bind-Value="bookRequest.BookName" class="form-control" />
                </div>

                <div class="col-12 mb-3">
                    <label class="form-label text-light">Book Cover Image</label>
                    <InputFile OnChange="HandleFileSelected" class="form-control" accept=".jpg,.jpeg,.png,.webp" />
                    <div class="mt-2 text-center">
                        <img src="@(!string.IsNullOrEmpty(PreviewImageUrl) ? PreviewImageUrl : $"https://localhost:7297{bookRequest.ExistingImage}")" 
                             class="rounded img-thumbnail" style="max-height: 150px; object-fit: cover;" />
                    </div>
                </div>

                @if (!string.IsNullOrEmpty(statusMessage)) {
                    <div class="small text-info mt-2">@statusMessage</div>
                }
            </div>
            <div class="modal-footer border-0 pt-0">
                <NavLink href="/admin/books" class="nav-link me-3"><span class="sidebar-text text-muted">Cancel</span></NavLink>
                <button type="submit" class="btn btn-primary" disabled="@isProcessing">
                    @(isProcessing ? "Updating..." : "Update Book")
                </button>
            </div>
        </EditForm>
    </div>
</div>