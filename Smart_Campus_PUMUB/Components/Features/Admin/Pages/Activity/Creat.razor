@page "/admin/activity/create"
@layout AdminLayout

<div class="tab-pane fade show active" id="addActivityContainer" tabindex="-1">
    <div class="modal-dialog modal-lg">
        <div class="modal-content tech-card">

            <div class="modal-header border-0 pb-0">
                <h5 class="modal-title fw-bold">
                    Add New Activity
                </h5>
            </div>

            <div class="modal-body">
                <div class="row g-3">
                    
                    <div class="col-md-6 mb-2">
                        <label class="form-label text-light">Activity Title</label>
                        <input type="text" class="form-control" placeholder="Enter Activity Title">
                    </div>

                    <div class="col-md-6 mb-2">
                        <label class="form-label text-light">Location</label>
                        <input type="text" class="form-control" placeholder="Enter Location">
                    </div>

                    <div class="col-12 mb-2">
                        <label class="form-label text-light">Activity Image</label>
                        <input type="file" class="form-control" accept="image/*">
                        <div class="form-text text-muted mt-1"><i class="bi bi-info-circle me-1"></i> Recommended size: 800x600px (Max 5MB)</div>
                    </div>

                    <div class="col-12 mb-2">
                        <label class="form-label text-light">Description</label>
                        <textarea class="form-control" rows="5" placeholder="Write activity details here..."></textarea>
                    </div>

                </div>
            </div>

            <div class="modal-footer border-0 pt-0">
                <NavLink href="/admin/activities" class="nav-link me-3">
                    <span class="sidebar-text text-muted">Cancel</span>
                </NavLink>

                <button type="button" class="btn btn-primary">
                    Create Activity
                </button>
            </div>

        </div>
    </div>
</div>