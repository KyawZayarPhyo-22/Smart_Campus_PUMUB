@page "/admin/activity/edit"
@layout AdminLayout

<div class="tab-pane fade show active" id="editActivityContainer" tabindex="-1">
    <div class="modal-dialog modal-lg">
        <div class="modal-content tech-card">

            <div class="modal-header border-0 pb-0">
                <h5 class="modal-title fw-bold">
                    Edit Activity
                </h5>
            </div>

            <div class="modal-body">
                <div class="row g-3">

                    <div class="col-md-6 mb-2">
                        <label class="form-label text-light">Activity Title</label>
                        <input type="text" class="form-control" value="Annual Tech Symposium"
                            placeholder="Enter Activity Title">
                    </div>

                    <div class="col-md-6 mb-2">
                        <label class="form-label text-light">Location</label>
                        <input type="text" class="form-control" value="Main Auditorium" placeholder="Enter Location">
                    </div>

                    <div class="col-12 mb-2">
                        <label class="form-label text-light">Activity Image</label>
                        <div class="d-flex align-items-center mb-2">
                            <img src="https://via.placeholder.com/100x70" class="rounded me-3" alt="Current Image"
                                style="object-fit: cover;">
                            <span class="text-muted small">Current Image</span>
                        </div>
                        <input type="file" class="form-control" accept="image/*">
                        <div class="form-text text-muted mt-1"><i class="bi bi-info-circle me-1"></i> Upload a new file
                            to replace the existing image.</div>
                    </div>

                    <div class="col-12 mb-2">
                        <label class="form-label text-light">Description</label>
                        <textarea class="form-control" rows="5"
                            placeholder="Write activity details here...">Join us for the annual gathering of engineering and IT students showcasing their final year projects.</textarea>
                    </div>

                </div>
            </div>

            <div class="modal-footer border-0 pt-0">
                <NavLink href="/admin/activities" class="nav-link me-3">
                    <span class="sidebar-text text-muted">Cancel</span>
                </NavLink>

                <button type="button" class="btn btn-primary">
                    Save Changes
                </button>
            </div>

        </div>
    </div>
</div>