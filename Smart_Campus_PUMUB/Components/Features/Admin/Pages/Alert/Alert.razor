@layout AdminLayout
@page "/admin/alert"

<!-- 5. IMPORTANT ALERTS -->
<div class="tab-pane fade show active" id="v-pills-alert">
    <div class="mb-4">
        <h3 class="fw-bold mb-1">Important Alerts</h3>
    </div>
    <div class="tech-card">
        <!-- RESTORED: Search & Filter -->
        <div class="row g-3 mb-4 align-items-center">
            <div class="col">
                <div class="position-relative">
                    <i class="bi bi-search position-absolute top-50 start-0 translate-middle-y ms-3 text-muted"></i>
                    <input type="text" class="form-control material-input w-100 ps-5" placeholder="Search headlines...">
                </div>
            </div>
            <div class="col-md-3">
                <select class="form-select material-input">
                    <option value="">Severity Level...</option>
                    <option>High (Urgent)</option>
                    <option>Medium</option>
                </select>
            </div>
            <div class="col-auto">
                <div class="d-flex gap-2 justify-content-end">
                    <button class="btn btn-primary d-flex align-items-center justify-content-center" style="width: 40px; height: 38px;" type="button" title="Search">
                        <i class="bi bi-search"></i>
                    </button>
                    <button class="btn btn-secondary d-flex align-items-center justify-content-center" style="width: 40px; height: 38px;" type="button" title="Reset">
                        <i class="bi bi-arrow-clockwise"></i>
                    </button>
                    <button class="btn btn-danger d-flex align-items-center justify-content-center" style="width: 40px; height: 38px;" data-bs-toggle="modal" data-bs-target="#addAlertModal" title="Post Alert">
                        <i class="bi bi-megaphone-fill"></i>
                    </button>
                </div>
            </div>
        </div>

        <div class="table-responsive">
            <table class="table table-tech align-middle mb-0">
                <thead>
                    <tr>
                        <th>Headline</th>
                        <th>Audience</th>
                        <th>Severity</th>
                        <th class="text-end">Actions</th>
                    </tr>
                </thead>
                <tbody>
                    <tr>
                        <td class="fw-bold">Main Server Maintenance Tonight</td>
                        <td>All Staff & Students</td>
                        <td><span class="text-danger"><i class="bi bi-exclamation-circle-fill me-1"></i>
                                High</span></td>
                        <td class="text-end">
                            <button class="btn btn-sm btn-outline-primary me-1" data-bs-toggle="modal"
                                data-bs-target="#editAlertModal"><i class="bi bi-pencil"></i></button>
                            <button class="btn btn-sm btn-outline-danger" data-bs-toggle="modal"
                                data-bs-target="#deleteConfirmModal"><i class="bi bi-trash"></i></button>
                        </td>
                    </tr>
                </tbody>
            </table>
        </div>
    </div>
</div>