@layout AdminLayout
@page "/admin/alert"

<!-- 5. IMPORTANT ALERTS -->
<div class="tab-pane fade show active" id="v-pills-alert">
    <div class="mb-4">
        <h3 class="fw-bold mb-1">Important Alerts</h3>
    </div>
    <div class="tech-card">
        <!-- RESTORED: Search & Filter -->
        <div class="row g-3 mb-4">
            <div class="col-md-4">
                <div class="input-group">
                    <span class="input-group-text search-icon-bg border-end-0"><i class="bi bi-search"></i></span>
                    <input type="text" class="form-control border-start-0" placeholder="Search headlines...">
                </div>
            </div>
            <div class="col-md-3">
                <select class="form-select">
                    <option value="">Severity Level...</option>
                    <option>High (Urgent)</option>
                    <option>Medium</option>
                </select>
            </div>
            <div class="col-md-5 text-end">
                <button class="btn btn-danger" data-bs-toggle="modal" data-bs-target="#addAlertModal"><i
                        class="bi bi-megaphone-fill me-2"></i> Post Alert</button>
            </div>
        </div>

        <div class="table-responsive">
            <table class="table table-tech align-middle mb-0">
                <thead>
                    <tr>
                        <th>Headline</th>
                        <th>Audience</th>
                        <th>Severity</th>
                        <th class="text-end">Actions</th>
                    </tr>
                </thead>
                <tbody>
                    <tr>
                        <td class="fw-bold">Main Server Maintenance Tonight</td>
                        <td>All Staff & Students</td>
                        <td><span class="text-danger"><i class="bi bi-exclamation-circle-fill me-1"></i>
                                High</span></td>
                        <td class="text-end">
                            <button class="btn btn-sm btn-outline-primary me-1" data-bs-toggle="modal"
                                data-bs-target="#editAlertModal"><i class="bi bi-pencil"></i></button>
                            <button class="btn btn-sm btn-outline-danger" data-bs-toggle="modal"
                                data-bs-target="#deleteConfirmModal"><i class="bi bi-trash"></i></button>
                        </td>
                    </tr>
                </tbody>
            </table>
        </div>
    </div>
</div>