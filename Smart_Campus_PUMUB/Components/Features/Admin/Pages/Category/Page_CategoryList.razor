@page "/admin/categories"
@layout AdminLayout
@namespace Smart_Campus_PUMUB.Components.Admin.Pages.Category
@using Smart_Campus_PUMUB.WebApi.Models
@rendermode InteractiveServer

<style>
    .custom-table {
        background: rgba(20, 24, 33, 0.6);
        border-radius: 12px;
        overflow: hidden;
        border: 1px solid rgba(255, 255, 255, 0.05);
    }

        .custom-table thead {
            background: rgba(13, 110, 253, 0.1);
            border-bottom: 2px solid rgba(13, 110, 253, 0.2);
        }

        .custom-table th {
            font-weight: 600;
            text-transform: uppercase;
            font-size: 0.85rem;
            color: #0d6efd;
            padding: 16px 20px;
        }

        .custom-table td {
            padding: 16px 20px;
            color: #e2e8f0;
            border-bottom: 1px solid rgba(255, 255, 255, 0.05);
        }

    .table-row-hover:hover {
        background: rgba(255, 255, 255, 0.02);
        box-shadow: inset 4px 0 0 #0d6efd;
    }

    .btn-action-edit {
        background: rgba(13, 110, 253, 0.1);
        color: #39b5ff;
        border: 1px solid rgba(13, 110, 253, 0.3);
        border-radius: 6px;
        padding: 6px 14px;
        transition: all 0.2s ease;
    }

        .btn-action-edit:hover {
            background: #0d6efd;
            color: #ffffff;
        }

    .btn-action-delete {
        background: rgba(220, 53, 69, 0.1);
        color: #ff6b6b;
        border: 1px solid rgba(220, 53, 69, 0.3);
        border-radius: 6px;
        padding: 6px 14px;
        transition: all 0.2s ease;
    }

        .btn-action-delete:hover {
            background: #dc3545;
            color: #ffffff;
        }
</style>

<div class="tab-pane fade show active" id="v-pills-category">
    <div class="mb-4">
        <h3 class="fw-bold mb-1" style="color: #ffffff;">Category Directory</h3>
    </div>

    <div class="tech-card p-4">
        <div class="row g-3 mb-4 align-items-center">
            <div class="col-md-7 col-lg-6">
                <div class="input-group">
                    <span class="input-group-text search-icon-bg border-end-0"><i class="bi bi-search text-muted"></i></span>
                    <input type="text" class="form-control border-start-0 text-white" placeholder="Search by Category Name..." @bind-value="SearchInput" @onkeyup="HandleKeyUp">
                    <button class="btn btn-primary" type="button" @onclick="ApplyFilter" title="Search">
                        <i class="bi bi-search"></i> Search
                    </button>
                    <button class="btn btn-secondary" type="button" @onclick="ResetFilter" title="Reset">
                        <i class="bi bi-arrow-clockwise"></i> Reset
                    </button>
                </div>
            </div>
            <div class="col-md-5 col-lg-6 text-end">
                <NavLink href="/admin/category/create" class="btn btn-primary nav-link d-inline-block text-white">
                    <span class="sidebar-text"><i class="bi bi-plus-lg me-1"></i> Add Category</span>
                </NavLink>
            </div>
        </div>

        @if (IsLoading)
        {
            <div class="text-center my-5">
                <div class="spinner-border text-primary" role="status"></div>
                <div class="text-muted mt-2">Category စာရင်းများကို ဆွဲယူနေပါသည်...</div>
            </div>
        }
        else
        {
            <div class="table-responsive custom-table">
                <table class="table align-middle mb-0">
                    <thead>
                        <tr>
                            <th>No.</th>
                            <th>Category Name</th>
                            <th class="text-center">Actions</th>
                        </tr>
                    </thead>
                    <tbody>
                        @{
                            int count = (CurrentPage - 1) * PageSize + 1;
                        }
                        @foreach (var category in FilteredCategories)
                        {
                            <tr class="table-row-hover">
                                <td class="fw-bold text-muted">@count.ToString("D2")</td>
                                <td class="fw-semibold">@category.CategoryName</td>
                                <td>
                                    <div class="d-flex justify-content-center align-items-center gap-2">
                                        <NavLink href="@($"/admin/category/edit/{category.CategoryId}")" class="btn btn-action-edit"><i class="bi bi-pencil me-1.5"></i> Edit</NavLink>
                                        <button class="btn btn-action-delete" @onclick="() => OpenDeleteModal(category)"><i class="bi bi-trash me-1.5"></i> Delete</button>
                                    </div>
                                </td>
                            </tr>
                            count++;
                        }
                    </tbody>
                </table>
            </div>

            <PaginationComponent CurrentPage="CurrentPage" TotalPages="TotalPages" OnPageChanged="OnPageChanged" />
        }
    </div>
</div>

@* Delete Confirmation Modal *@
@if (ShowModal)
{
    <div class="modal show d-block" style="background: rgba(0,0,0,0.5);">
        <div class="modal-dialog modal-dialog-centered">
            <div class="modal-content tech-card">

                <div class="modal-header border-0">
                    <h5 class="text-danger">Confirm Delete</h5>
                </div>

                <div class="modal-body text-center">
                    Are you sure to delete <strong>@SelectedCategory?.CategoryName</strong>?

                    @if (!string.IsNullOrEmpty(statusMessage))
                    {
                        <div class="mt-3 p-3 rounded"
                             style="background: @(IsSuccess ? "rgba(25, 135, 84, 0.15)" : "rgba(220, 53, 69, 0.15)");
                            border: 1px solid @(IsSuccess ? "#198754" : "#dc3545");">

                            <span style="color: @(IsSuccess ? "#75b798" : "#ea868f"); font-size: 0.9rem;">
                                <i class="bi @(IsSuccess ? "bi-check-circle" : "bi-exclamation-circle") me-2"></i>
                                @statusMessage
                            </span>
                        </div>
                    }
                </div>

                <div class="modal-footer border-0">
                    <button class="btn btn-secondary"
                            @onclick="CloseDeleteModal"
                            disabled="@IsProcessing">
                        Cancel
                    </button>

                    <button class="btn btn-danger"
                            @onclick="DeleteCategory"
                            disabled="@(IsProcessing || IsSuccess)">
                        @(IsProcessing ? "Deleting..." : "Yes, Delete")
                    </button>
                </div>

            </div>
        </div>
    </div>
}