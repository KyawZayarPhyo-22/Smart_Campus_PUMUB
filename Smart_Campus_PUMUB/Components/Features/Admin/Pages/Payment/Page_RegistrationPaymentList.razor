@page "/admin/payments"
@layout AdminLayout
@namespace Smart_Campus_PUMUB.Components.Admin.Pages.Payment
@using Smart_Campus_PUMUB.WebApi.Models
@rendermode InteractiveServer

<style>
    /* Activity Page မှ CSS များအားလုံးကို ဒီမှာ သုံးထားပါသည် */
    .custom-table { background: rgba(20, 24, 33, 0.6); border-radius: 12px; overflow: hidden; border: 1px solid rgba(255, 255, 255, 0.05); }
    .custom-table thead { background: rgba(13, 110, 253, 0.1); border-bottom: 2px solid rgba(13, 110, 253, 0.2); }
    .custom-table th { font-weight: 600; text-transform: uppercase; font-size: 0.85rem; color: #0d6efd; padding: 16px 20px; }
    .custom-table td { padding: 16px 20px; color: #e2e8f0; border-bottom: 1px solid rgba(255, 255, 255, 0.05); }
    .table-row-hover:hover { background: rgba(255, 255, 255, 0.02); box-shadow: inset 4px 0 0 #0d6efd; }
    .btn-action-edit { background: rgba(13, 110, 253, 0.1); color: #39b5ff; border: 1px solid rgba(13, 110, 253, 0.3); border-radius: 6px; padding: 6px 14px; transition: all 0.2s ease; }
    .btn-action-edit:hover { background: #0d6efd; color: #ffffff; }
    .btn-action-delete { background: rgba(220, 53, 69, 0.1); color: #ff6b6b; border: 1px solid rgba(220, 53, 69, 0.3); border-radius: 6px; padding: 6px 14px; transition: all 0.2s ease; }
    .btn-action-delete:hover { background: #dc3545; color: #ffffff; }
</style>

<div class="tab-pane fade show active">
    <div class="mb-4">
        <h3 class="fw-bold mb-1" style="color: #ffffff;">Payment Directory</h3>
    </div>

    <div class="tech-card p-4">
        <div class="row g-3 mb-4 align-items-center">
            <div class="col-md-5">
                <div class="input-group">
                    <span class="input-group-text search-icon-bg border-end-0"><i class="bi bi-search text-muted"></i></span>
                    <input type="text" class="form-control border-start-0 text-white" placeholder="Search by Registration ID..." @bind-value="SearchTerm" @bind-value:event="oninput">
                </div>
            </div>
            <div class="col-md-7 text-end">
                <NavLink href="/admin/payment/create" class="btn btn-primary text-white">
                    <i class="bi bi-plus-lg me-1"></i> Add Payment
                </NavLink>
            </div>
        </div>

        @if (IsLoading)
        {
            <div class="text-center my-5">
                <div class="spinner-border text-primary" role="status"></div>
                <div class="text-muted mt-2">Data များ ဆွဲယူနေပါသည်...</div>
            </div>
        }
        else
        {
            <div class="table-responsive custom-table">
                <table class="table align-middle mb-0">
                    <thead>
                        <tr>
                            <th>No.</th>
                            <th>Receipt</th>
                            <th>Reg ID</th>
                            <th>Amount</th>
                            <th>Method</th>
                            <th>Status</th>
                            <th class="text-center">Actions</th>
                        </tr>
                    </thead>
                    <tbody>
                        @{
                            int count = 1;
                        }
                        @foreach (var p in FilteredPayments)
                        {
                            <tr class="table-row-hover">
                                <td class="fw-bold text-muted">@count</td>
                                <td>
                                    <img src="@($"https://localhost:7297/{p.ReceiptImage}")" class="rounded" style="width: 50px; height: 50px; object-fit: cover;" />
                                </td>
                                <td>@p.RegistrationId</td>
                                <td class="fw-semibold">$ @p.AmountPaid</td>
                                <td>@p.PaymentMethod</td>
                                <td>
                                    <span class="badge @(p.Status == "Approved" ? "bg-success" : p.Status == "Rejected" ? "bg-danger" : "bg-warning")">
                                        @p.Status
                                    </span>
                                </td>
                                <td>
                                    <div class="d-flex justify-content-center gap-2">
                                        <NavLink href="@($"/admin/payment/edit/{p.PaymentId}")" class="btn btn-action-edit">
                                            <i class="bi bi-pencil"></i> Edit
                                        </NavLink>
                                        <button class="btn btn-action-delete" @onclick="() => OpenDeleteModal(p)">
                                            <i class="bi bi-trash"></i> Delete
                                        </button>
                                    </div>
                                </td>
                            </tr>
                            count++;
                        }
                    </tbody>
                </table>
            </div>
        }
    </div>
</div>

@* Delete Modal (Activity Page ပုံစံအတိုင်း) *@
<div class="modal fade @(ShowModal ? "show d-block" : "")" tabindex="-1" style="background: rgba(10, 14, 22, 0.85); backdrop-filter: blur(4px);">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content tech-card" style="border: 1px solid rgba(220, 53, 69, 0.2);">
            <div class="modal-header border-0 pb-0">
                <h5 class="modal-title text-danger fw-bold"><i class="bi bi-exclamation-triangle-fill"></i> Confirm Delete</h5>
            </div>
            <div class="modal-body text-center py-4">
                <h4 class="fw-bold text-white">Delete Payment?</h4>
                <p class="text-light opacity-75">ဒီငွေသွင်းမှတ်တမ်းကို ဖျက်ရန် သေချာပါသလား?</p>
            </div>
            <div class="modal-footer border-0 justify-content-center">
                <button class="btn btn-secondary px-4" @onclick="CloseDeleteModal">Cancel</button>
                <button class="btn btn-danger px-4" @onclick="DeletePayment" disabled="@IsProcessing">Yes, Delete</button>
            </div>
        </div>
    </div>
</div>