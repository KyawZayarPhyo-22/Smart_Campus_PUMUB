@page "/admin/payments"
@layout AdminLayout
@namespace Smart_Campus_PUMUB.Components.Admin.Pages.Payment
@using Smart_Campus_PUMUB.WebApi.Models
@rendermode InteractiveServer

<div class="container-fluid py-4" style="background: transparent; min-height: 100vh; color: #ffffff;">
    <!-- ── HEADER SECTION ──────────────────────────── -->
    <div class="d-flex justify-content-between align-items-center mb-4 pb-3" style="border-bottom: 1px solid rgba(255, 255, 255, 0.08);">
        <div>
            <h3 style="font-weight: 800; color: #ffffff; letter-spacing: -0.5px; margin: 0;">Payment Directory</h3>
            <p class="small mt-1 mb-0" style="color: #a1a5b7;"><i class="bi bi-cash-stack text-success me-1"></i> Polytechnic University (Maubin) - Finance</p>
        </div>
        <!-- 💡 Add Payment Button အား ဖြုတ်လိုက်ပါပြီ -->
    </div>

    <!-- ── SEARCH BAR (DARK INNER SHADOW DESIGN) ────────────────── -->
    <div class="d-flex mb-4">
        <div class="card w-100" style="max-width: 380px; border-radius: 12px; border: none; background: #1e1e2d; box-shadow: 0 4px 15px rgba(0, 0, 0, 0.3);">
            <div class="card-body p-2">
                <div class="input-group dark-inner-shadow" style="border-radius: 8px; background: #151521; border: 1px solid rgba(255, 255, 255, 0.05);">
                    <span class="input-group-text bg-transparent border-0 pe-1" style="padding: 6px 10px;"><i class="bi bi-search" style="color: #6b7280; font-size: 0.88rem;"></i></span>
                    <input type="text" class="form-control bg-transparent border-0 dark-placeholder" placeholder="Search by Reg ID or Method..." @bind="SearchTerm" @bind:event="oninput" style="color: #ffffff; box-shadow: none; font-size: 0.88rem; padding: 6px 10px 6px 0;" />
                </div>
            </div>
        </div>
    </div>

    <!-- ── DATA LIST CARD (DARK THEME) ─────────────────────────── -->
    <div class="card" style="border-radius: 16px; border: 1px solid rgba(255, 255, 255, 0.05); background: #1e1e2d; box-shadow: 0 10px 30px rgba(0, 0, 0, 0.4); overflow: hidden;">
        <div class="card-body p-0">
            @if (IsLoading)
            {
                <div class="text-center py-5">
                    <div class="spinner-border text-info mb-3" role="status" style="width: 2.5rem; height: 2.5rem;"></div>
                    <p class="mb-0 fw-medium" style="color: #a1a5b7;">အချက်အလက်များ ဆွဲယူနေပါသည်၊ ခေတ္တစောင့်ဆိုင်းပေးပါဦးနော်ကိုကို...</p>
                </div>
            }
            else if (FilteredPayments == null || !FilteredPayments.Any())
            {
                <div class="text-center py-5">
                    <i class="bi bi-folder-x" style="font-size: 3rem; color: #475569;"></i>
                    <p class="mt-3 mb-0 fw-bold" style="color: #a1a5b7;">ငွေသွင်းမှတ်တမ်းများ ရှာမတွေ့ပါ။</p>
                </div>
            }
            else
            {
                <div class="table-responsive">
                    <table class="table align-middle mb-0 custom-dark-table">
                        <thead style="background: #151521; color: #a1a5b7; font-weight: 700; font-size: 0.9rem;">
                            <tr>
                                <th style="padding: 18px 20px; border-bottom: 1px solid rgba(255,255,255,0.05);">No.</th>
                                <th style="border-bottom: 1px solid rgba(255,255,255,0.05);">Receipt</th>
                                <th style="border-bottom: 1px solid rgba(255,255,255,0.05);">Reg ID</th>
                                <th style="border-bottom: 1px solid rgba(255,255,255,0.05);">Amount</th>
                                <th style="border-bottom: 1px solid rgba(255,255,255,0.05);">Method</th>
                                <th class="text-center" style="border-bottom: 1px solid rgba(255,255,255,0.05);">Status</th>
                                <th class="text-end" style="padding-right: 24px; border-bottom: 1px solid rgba(255,255,255,0.05);">Actions</th>
                            </tr>
                        </thead>
                        <tbody style="border-top: none;">
                            @{
                                int count = 1;
                            }
                            @foreach (var p in FilteredPayments)
                            {
                                <tr class="dark-hover-row">
                                    <td style="padding: 18px 20px; font-weight: 700; color: #64748b; border-bottom: 1px solid rgba(255,255,255,0.05);">@count</td>
                                    <td style="border-bottom: 1px solid rgba(255,255,255,0.05);">
                                        <div style="width: 50px; height: 50px; border-radius: 8px; border: 1px solid rgba(255,255,255,0.1); overflow: hidden; cursor: pointer;" @onclick="() => OpenDetailModal(p.PaymentId)">
                                            <img src="@($"https://localhost:7297/{p.ReceiptImage}")" style="width: 100%; height: 100%; object-fit: cover;" onerror="this.onerror=null; this.src='/images/placeholder.jpg';" />
                                        </div>
                                    </td>
                                    <td style="border-bottom: 1px solid rgba(255,255,255,0.05);">
                                        <span class="badge px-2.5 py-1.5 fw-semibold font-monospace" style="background: #2b2b40; color: #ffffff; border: 1px solid rgba(255,255,255,0.1); border-radius: 6px;">@p.RegistrationId</span>
                                    </td>
                                    <td style="border-bottom: 1px solid rgba(255,255,255,0.05);">
                                        <span class="fw-bold text-success" style="font-size: 0.95rem;">$ @p.AmountPaid</span>
                                    </td>
                                    <td style="border-bottom: 1px solid rgba(255,255,255,0.05);">
                                        <span style="color: #a1a5b7;">@p.PaymentMethod</span>
                                    </td>
                                    <td class="text-center" style="border-bottom: 1px solid rgba(255,255,255,0.05);">
                                        @if (p.Status == "Approved")
                                        {
                                            <span class="badge px-3 py-1.5 fw-bold" style="background: rgba(16, 185, 129, 0.15); color: #34d399; border-radius: 20px; border: 1px solid rgba(16, 185, 129, 0.25);"><i class="bi bi-check-circle-fill me-1"></i> Approved</span>
                                        }
                                        else if (p.Status == "Rejected")
                                        {
                                            <span class="badge px-3 py-1.5 fw-bold" style="background: rgba(239, 68, 68, 0.15); color: #f87171; border-radius: 20px; border: 1px solid rgba(239, 68, 68, 0.25);"><i class="bi bi-x-circle-fill me-1"></i> Rejected</span>
                                        }
                                        else
                                        {
                                            <span class="badge px-3 py-1.5 fw-bold" style="background: rgba(245, 158, 11, 0.15); color: #fbbf24; border-radius: 20px; border: 1px solid rgba(245, 158, 11, 0.25);"><i class="bi bi-clock-history me-1"></i> Pending</span>
                                        }
                                    </td>
                                    <td class="text-end" style="padding-right: 24px; border-bottom: 1px solid rgba(255,255,255,0.05);">
                                        <div class="d-flex justify-content-end gap-2">
                                            <!-- 💡 Edit အစား View ခလုတ်ကို ပြောင်းလဲပေးထားပါသည် -->
                                            <button class="btn btn-sm px-3 py-1.5 fw-bold text-white" style="border-radius: 8px; background: linear-gradient(135deg, #0ea5e9, #0284c7); border: none; box-shadow: 0 4px 10px rgba(14, 165, 233, 0.3);" @onclick="() => OpenDetailModal(p.PaymentId)">
                                                <i class="bi bi-eye me-1"></i> View
                                            </button>
                                            <button class="btn btn-sm px-3 py-1.5 fw-bold text-white" style="border-radius: 8px; background: linear-gradient(135deg, #ef4444, #b91c1c); border: none; box-shadow: 0 4px 10px rgba(239, 68, 68, 0.3);" @onclick="() => OpenDeleteModal(p)">
                                                <i class="bi bi-trash me-1"></i> Delete
                                            </button>
                                        </div>
                                    </td>
                                </tr>
                                count++;
                            }
                        </tbody>
                    </table>
                </div>
            }
        </div>
    </div>
</div>

<!-- ================================================================= -->
<!-- 🌟 VIEW DETAILS & STATUS CHANGE MODAL (NEW)                       -->
<!-- ================================================================= -->
@if (ShowDetailModal && SelectedPaymentDetail != null)
{
    <div class="modal fade show d-block" tabindex="-1" style="background: rgba(0, 0, 0, 0.7); backdrop-filter: blur(8px); transition: all 0.3s ease; z-index: 1050;">
        <div class="modal-dialog modal-dialog-centered">
            <div class="modal-content" style="border-radius: 24px; border: 1px solid rgba(255, 255, 255, 0.1); box-shadow: 0 25px 50px rgba(0, 0, 0, 0.5); background: #1e1e2d; overflow: hidden;">

                <div class="modal-header px-4 py-3" style="background: #151521; border-bottom: 1px solid rgba(255, 255, 255, 0.08);">
                    <div class="d-flex align-items-center gap-2">
                        <div style="width: 8px; height: 20px; background: #00f2fe; border-radius: 4px; box-shadow: 0 0 8px rgba(0, 242, 254, 0.5);"></div>
                        <h5 class="modal-title" style="font-weight: 800; color: #ffffff; font-size: 1.15rem;">ငွေသွင်းမှတ်တမ်း အသေးစိတ်</h5>
                    </div>
                    <button type="button" class="btn-close" @onclick="CloseDetailModal" style="filter: invert(1) grayscale(100%) brightness(200%); box-shadow: none;"></button>
                </div>

                <div class="modal-body px-4 py-4" style="background: #1e1e2d;">

                    <!-- 📸 စလစ်ပုံ ပြကွက် -->
                    <div class="text-center mb-4 p-2" style="background: #151521; border-radius: 16px; border: 1px solid rgba(255,255,255,0.05);">
                        <img src="@($"https://localhost:7297/{SelectedPaymentDetail.ReceiptImage}")" style="max-width: 100%; max-height: 350px; border-radius: 12px; object-fit: contain;" onerror="this.onerror=null; this.src='/images/placeholder.jpg';" />
                    </div>

                    <div class="p-3 style-grid-box-dark">
                        <div class="row g-3">
                            <div class="col-sm-6">
                                <span class="d-block small-label-dark">Registration ID</span>
                                <span class="info-value-dark font-monospace" style="color: #00f2fe;">@SelectedPaymentDetail.RegistrationId</span>
                            </div>
                            <div class="col-sm-6">
                                <span class="d-block small-label-dark">Amount Paid</span>
                                <span class="info-value-dark text-success">$ @SelectedPaymentDetail.AmountPaid</span>
                            </div>
                            <div class="col-sm-6">
                                <span class="d-block small-label-dark">Payment Method</span>
                                <span class="info-value-dark">@SelectedPaymentDetail.PaymentMethod</span>
                            </div>
                            <div class="col-sm-6">
                                <span class="d-block small-label-dark">Current Status</span>
                                @if (SelectedPaymentDetail.Status == "Approved")
                                {
                                    <span class="badge mt-1 px-2.5 py-1" style="background: rgba(16, 185, 129, 0.15); color: #34d399; border: 1px solid rgba(16, 185, 129, 0.25);">Approved</span>
                                }
                                else if (SelectedPaymentDetail.Status == "Rejected")
                                {
                                    <span class="badge mt-1 px-2.5 py-1" style="background: rgba(239, 68, 68, 0.15); color: #f87171; border: 1px solid rgba(239, 68, 68, 0.25);">Rejected</span>
                                }
                                else
                                {
                                    <span class="badge mt-1 px-2.5 py-1" style="background: rgba(245, 158, 11, 0.15); color: #fbbf24; border: 1px solid rgba(245, 158, 11, 0.25);">Pending</span>
                                }
                            </div>
                        </div>
                    </div>

                </div>

                <div class="modal-footer px-4 py-3 d-flex justify-content-between" style="background: #151521; border-top: 1px solid rgba(255, 255, 255, 0.08);">
                    @* <button type="button" class="btn px-4 py-2 fw-bold text-white" @onclick="CloseDetailModal" style="border-radius: 10px; background: #2b2b40; border: 1px solid rgba(255,255,255,0.1);">
                        <i class="bi bi-x-lg me-1"></i> ပိတ်မည်
                    </button> *@

                    <div class="d-flex gap-2">
                        @if (IsProcessing)
                        {
                            <button class="btn px-4 py-2 fw-bold text-white" disabled style="border-radius: 10px; background: #475569;">
                                <span class="spinner-border spinner-border-sm me-1" role="status" aria-hidden="true"></span> လုပ်ဆောင်နေပါသည်...
                            </button>
                        }
                        else
                        {
                            <button type="button" class="btn px-4 py-2 fw-bold text-white" @onclick='() => UpdatePaymentStatus(SelectedPaymentDetail.PaymentId, "Rejected")' style="border-radius: 10px; background: linear-gradient(135deg, #ef4444, #b91c1c); border: none; box-shadow: 0 4px 12px rgba(239, 68, 68, 0.3);">
                                <i class="bi bi-shield-x me-1"></i> Reject (ငြင်းပယ်မည်)
                            </button>
                            <button type="button" class="btn px-4 py-2 fw-bold text-white" @onclick='() => UpdatePaymentStatus(SelectedPaymentDetail.PaymentId, "Approved")' style="border-radius: 10px; background: linear-gradient(135deg, #10b981, #047857); border: none; box-shadow: 0 4px 12px rgba(16, 185, 129, 0.3);">
                                <i class="bi bi-shield-check me-1"></i> Approve (လက်ခံမည်)
                            </button>
                        }
                    </div>
                </div>
            </div>
        </div>
    </div>
}

<!-- ================================================================= -->
<!-- 🌟 DARK MODE DELETE CONFIRMATION MODAL                            -->
<!-- ================================================================= -->
<div class="modal fade @(ShowModal ? "show d-block" : "")" tabindex="-1" style="background: rgba(0, 0, 0, 0.7); backdrop-filter: blur(8px); transition: all 0.3s ease; z-index: 1050;">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content" style="border-radius: 24px; border: 1px solid rgba(255, 255, 255, 0.1); box-shadow: 0 25px 50px rgba(0, 0, 0, 0.5); background: #1e1e2d; overflow: hidden;">
            <div class="modal-header border-0 pb-0 justify-content-center pt-4">
                <div style="width: 60px; height: 60px; border-radius: 50%; background: rgba(239, 68, 68, 0.15); display: flex; align-items: center; justify-content: center; color: #f87171; font-size: 1.8rem; border: 1px solid rgba(239, 68, 68, 0.25);">
                    <i class="bi bi-exclamation-triangle-fill"></i>
                </div>
            </div>
            <div class="modal-body text-center py-4">
                <h4 class="fw-bold text-white mb-2">Delete Payment?</h4>
                <p style="color: #a1a5b7; font-size: 0.95rem;">ဒီငွေသွင်းမှတ်တမ်းကို ဖျက်ရန် သေချာပါသလား?</p>
            </div>
            <div class="modal-footer border-0 justify-content-center pb-4">
                <button class="btn px-4 py-2 fw-bold text-white" @onclick="CloseDeleteModal" style="border-radius: 10px; background: #2b2b40; border: 1px solid rgba(255,255,255,0.1);">
                    Cancel
                </button>
                <button class="btn px-4 py-2 fw-bold text-white" @onclick="DeletePayment" disabled="@IsProcessing" style="border-radius: 10px; background: linear-gradient(135deg, #ef4444, #b91c1c); border: none; box-shadow: 0 4px 12px rgba(239, 68, 68, 0.3);">
                    Yes, Delete
                </button>
            </div>
        </div>
    </div>
</div>

<!-- ── CUSTOM INNER CSS FOR PREMIUM DARK MATERIAL LOOK ────────────────── -->
<style>
    .dark-inner-shadow {
        box-shadow: inset 0 2px 6px rgba(0, 0, 0, 0.5);
    }

    .dark-placeholder::placeholder {
        color: #6b7280 !important;
        opacity: 1;
    }

    .custom-dark-table {
        color: #ffffff;
    }

        .custom-dark-table td {
            background: transparent;
            vertical-align: middle;
        }

    .dark-hover-row {
        transition: all 0.2s ease;
    }

        .dark-hover-row:hover {
            background-color: rgba(255, 255, 255, 0.03) !important;
            transform: scale(0.998);
        }

    .style-grid-box-dark {
        background: #151521;
        border: 1px solid rgba(255, 255, 255, 0.05);
        border-radius: 16px;
        box-shadow: inset 0 4px 10px rgba(0, 0, 0, 0.3);
    }

    .small-label-dark {
        font-size: 0.78rem;
        font-weight: 700;
        color: #64748b !important;
        text-transform: uppercase;
        letter-spacing: 0.3px;
        margin-bottom: 2px;
    }

    .info-value-dark {
        font-size: 0.92rem;
        font-weight: 600;
        color: #ffffff;
    }
</style>