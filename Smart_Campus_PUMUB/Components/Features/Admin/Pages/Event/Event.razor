@layout AdminLayout
@page "/admin/events"
<!-- 4. ACTIVITIES & EVENTS -->
<div class="tab-pane fade show active" id="v-pills-activity">
    <div class="mb-4">
        <h3 class="fw-bold mb-1">Activities & Events</h3>
    </div>
    <div class="tech-card">
        <!-- RESTORED: Search & Filter -->
        <div class="row g-3 mb-4 align-items-center">
            <div class="col">
                <div class="position-relative">
                    <i class="bi bi-search position-absolute top-50 start-0 translate-middle-y ms-3 text-muted"></i>
                    <input type="text" class="form-control material-input w-100 ps-5" placeholder="Search event name...">
                </div>
            </div>
            <div class="col-md-3">
                <select class="form-select material-input">
                    <option value="">All Event Types...</option>
                    <option>Ceremony</option>
                    <option>Seminar / Workshop</option>
                </select>
            </div>
            <div class="col-auto">
                <div class="d-flex gap-2 justify-content-end">
                    <button class="btn btn-primary d-flex align-items-center justify-content-center" style="width: 40px; height: 38px;" type="button" title="Search">
                        <i class="bi bi-search"></i>
                    </button>
                    <button class="btn btn-secondary d-flex align-items-center justify-content-center" style="width: 40px; height: 38px;" type="button" title="Reset">
                        <i class="bi bi-arrow-clockwise"></i>
                    </button>
                    <button class="btn btn-primary d-flex align-items-center justify-content-center" style="width: 40px; height: 38px;" data-bs-toggle="modal" data-bs-target="#addActivityModal" title="Create Event">
                        <i class="bi bi-plus-lg"></i>
                    </button>
                </div>
            </div>
        </div>

        <div class="table-responsive">
            <table class="table table-tech align-middle mb-0">
                <thead>
                    <tr>
                        <th>Date</th>
                        <th>Event Title</th>
                        <th>Location</th>
                        <th>Status</th>
                        <th class="text-end">Actions</th>
                    </tr>
                </thead>
                <tbody>
                    <tr>
                        <td>Dec 15, 2026</td>
                        <td class="fw-bold">Fresher Welcome Ceremony</td>
                        <td>Main Assembly Hall</td>
                        <td><span class="badge bg-success">Upcoming</span></td>
                        <td class="text-end">
                            <button class="btn btn-sm btn-outline-primary me-1" data-bs-toggle="modal"
                                data-bs-target="#editActivityModal"><i class="bi bi-pencil"></i></button>
                            <button class="btn btn-sm btn-outline-danger" data-bs-toggle="modal"
                                data-bs-target="#deleteConfirmModal"><i class="bi bi-trash"></i></button>
                        </td>
                    </tr>
                </tbody>
            </table>
        </div>
    </div>
</div>