@page "/admin/user/edit/{id:int}"
@layout AdminLayout

<div class="page-header">
    <div class="d-flex align-items-center gap-2">
        <NavLink href="/admin/users" class="btn btn-sm btn-outline-secondary">
            <i class="bi bi-arrow-left"></i>
        </NavLink>
        <div>
            <h3><i class="bi bi-person-gear me-2 text-warning"></i>Edit User</h3>
            <p>Update user account details and role assignment.</p>
        </div>
    </div>
</div>

<div class="row justify-content-center">
    <div class="col-12 col-md-8 col-lg-7">
        <div class="tech-card">

            <div class="mb-4 pb-3 border-bottom" style="border-color: var(--border) !important;">
                <h5 class="fw-bold mb-0">
                    <i class="bi bi-pencil-square me-2 text-warning"></i>User Account Details
                </h5>
                <p class="text-muted small mb-0 mt-1">Fields marked with <span class="text-danger">*</span> are required.</p>
            </div>

            <div class="row g-3">

                <!-- Role FK Dropdown -->
                <div class="col-12">
                    <label class="form-label">
                        Role <span class="text-danger">*</span>
                    </label>
                    <select class="form-select">
                        <option value="">-- Select Role --</option>
                        <option value="1" selected>Super Admin</option>
                        <option value="2">Admin</option>
                        <option value="3">Staff</option>
                        <option value="4">Viewer</option>
                    </select>
                    <div class="form-text">Change the access role for this user account.</div>
                </div>

                <!-- Full Name -->
                <div class="col-12">
                    <label class="form-label">
                        Full Name <span class="text-danger">*</span>
                    </label>
                    <input type="text"
                           class="form-control"
                           value="Kyaw Zayar Phyo"
                           placeholder="e.g., Kyaw Zayar Phyo" />
                    <div class="form-text">Enter the user's full name (max 100 characters).</div>
                </div>

                <!-- Username -->
                <div class="col-12 col-sm-6">
                    <label class="form-label">
                        Username <span class="text-danger">*</span>
                    </label>
                    <div class="input-group">
                        <span class="input-group-text">
                            <i class="bi bi-at"></i>
                        </span>
                        <input type="text"
                               class="form-control"
                               value="admin.ops"
                               placeholder="e.g., admin.ops" />
                    </div>
                    <div class="form-text">Must be unique. Max 50 characters.</div>
                </div>

                <!-- Password Info -->
                <div class="col-12 col-sm-6 d-flex align-items-end">
                    <div class="alert alert-info border-0 mb-0 py-2 px-3 w-100"
                         style="background: rgba(34,211,238,0.08); border-color: rgba(34,211,238,0.2) !important;">
                        <i class="bi bi-info-circle me-1 text-info"></i>
                        <small class="text-muted">Leave password fields empty to keep the current password.</small>
                    </div>
                </div>

                <!-- New Password -->
                <div class="col-12 col-sm-6">
                    <label class="form-label">New Password</label>
                    <div class="input-group">
                        <input type="password"
                               class="form-control"
                               id="editNewPassword"
                               placeholder="New password (optional)" />
                        <button class="btn btn-outline-secondary"
                                type="button"
                                onclick="togglePassword('editNewPassword', this)"
                                tabindex="-1">
                            <i class="bi bi-eye"></i>
                        </button>
                    </div>
                    <div class="form-text">Min 8 characters. Leave empty to keep current password.</div>
                </div>

                <!-- Confirm New Password -->
                <div class="col-12 col-sm-6">
                    <label class="form-label">Confirm New Password</label>
                    <div class="input-group">
                        <input type="password"
                               class="form-control"
                               id="editConfirmPassword"
                               placeholder="Confirm new password" />
                        <button class="btn btn-outline-secondary"
                                type="button"
                                onclick="togglePassword('editConfirmPassword', this)"
                                tabindex="-1">
                            <i class="bi bi-eye"></i>
                        </button>
                    </div>
                    <div class="form-text">Both passwords must match.</div>
                </div>

            </div>

            <!-- Actions -->
            <div class="d-flex justify-content-end gap-2 mt-4 pt-3 border-top" style="border-color: var(--border) !important;">
                <NavLink href="/admin/users" class="btn btn-secondary">
                    <i class="bi bi-x-lg me-1"></i>Cancel
                </NavLink>
                <button type="button" class="btn btn-warning text-dark fw-semibold">
                    <i class="bi bi-save me-1"></i>Save Changes
                </button>
            </div>

        </div>
    </div>
</div>

<script>
    function togglePassword(inputId, btn) {
        const input = document.getElementById(inputId);
        const icon = btn.querySelector('i');
        if (input.type === 'password') {
            input.type = 'text';
            icon.classList.replace('bi-eye', 'bi-eye-slash');
        } else {
            input.type = 'password';
            icon.classList.replace('bi-eye-slash', 'bi-eye');
        }
    }
</script>

@code {
    [Parameter] public int Id { get; set; }
}
