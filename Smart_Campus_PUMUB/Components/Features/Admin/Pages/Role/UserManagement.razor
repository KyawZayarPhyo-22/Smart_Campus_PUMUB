@page "/admin/users"
@layout AdminLayout

<div class="page-header">
    <div class="d-flex align-items-center justify-content-between flex-wrap gap-2">
        <div>
            <h3><i class="bi bi-person-badge me-2 text-info"></i>User Management</h3>
            <p>Manage all system users and their role assignments.</p>
        </div>
        <NavLink href="/admin/user/create" class="btn btn-sm btn-info text-dark fw-semibold">
            <i class="bi bi-person-plus me-1"></i> Add User
        </NavLink>
    </div>
</div>

<div class="tech-card">

    <div class="tech-card-header">
        <h6 class="tech-card-title">
            <i class="bi bi-table me-2 text-info"></i>All Users
        </h6>
        <span class="badge bg-info text-dark">3 Records</span>
    </div>

    <!-- Search & Filter -->
    <div class="row g-2 mb-3">
        <div class="col-12 col-md-4">
            <div class="input-group input-group-sm">
                <span class="input-group-text search-icon-bg">
                    <i class="bi bi-search"></i>
                </span>
                <input type="text" class="form-control border-start-0"
                       placeholder="Search by Username or Full Name..." />
            </div>
        </div>
        <div class="col-12 col-md-3">
            <select class="form-select form-select-sm">
                <option value="">Filter by Role...</option>
                <option>Super Admin</option>
                <option>Admin</option>
                <option>Staff</option>
            </select>
        </div>
    </div>

    <!-- Table -->
    <div class="table-responsive">
        <table class="table table-tech table-hover align-middle mb-0">
            <thead>
                <tr>
                    <th>ID</th>
                    <th>User</th>
                    <th class="d-none d-sm-table-cell">Username</th>
                    <th class="d-none d-md-table-cell">Role</th>
                    <th class="d-none d-lg-table-cell">Created Date</th>
                    <th class="text-end">Actions</th>
                </tr>
            </thead>
            <tbody>
                <tr>
                    <td class="text-muted">1</td>
                    <td>
                        <div class="d-flex align-items-center gap-2">
                            <img src="https://ui-avatars.com/api/?name=Kyaw+Zayar&background=22d3ee&color=0d1117&size=32"
                                 width="32" height="32" class="rounded-circle" alt="User" />
                            <span class="fw-semibold">Kyaw Zayar Phyo</span>
                        </div>
                    </td>
                    <td class="d-none d-sm-table-cell"><code class="text-info">admin.ops</code></td>
                    <td class="d-none d-md-table-cell">
                        <span class="badge bg-danger bg-opacity-25 text-danger border border-danger border-opacity-25">
                            Super Admin
                        </span>
                    </td>
                    <td class="d-none d-lg-table-cell text-secondary">Jun 10, 2026</td>
                    <td class="text-end">
                        <div class="d-flex justify-content-end gap-1">
                            <NavLink href="/admin/user/edit/1" class="btn btn-sm btn-outline-info">
                                <i class="bi bi-pencil"></i>
                                <span class="d-none d-sm-inline ms-1">Edit</span>
                            </NavLink>
                            <button class="btn btn-sm btn-outline-danger"
                                    data-bs-toggle="modal"
                                    data-bs-target="#deleteUserModal">
                                <i class="bi bi-trash"></i>
                                <span class="d-none d-sm-inline ms-1">Delete</span>
                            </button>
                        </div>
                    </td>
                </tr>
                <tr>
                    <td class="text-muted">2</td>
                    <td>
                        <div class="d-flex align-items-center gap-2">
                            <img src="https://ui-avatars.com/api/?name=Su+Su&background=8b5cf6&color=fff&size=32"
                                 width="32" height="32" class="rounded-circle" alt="User" />
                            <span class="fw-semibold">Su Su Myat</span>
                        </div>
                    </td>
                    <td class="d-none d-sm-table-cell"><code class="text-info">staff.lib</code></td>
                    <td class="d-none d-md-table-cell">
                        <span class="badge bg-warning bg-opacity-25 text-warning border border-warning border-opacity-25">
                            Admin
                        </span>
                    </td>
                    <td class="d-none d-lg-table-cell text-secondary">Jun 10, 2026</td>
                    <td class="text-end">
                        <div class="d-flex justify-content-end gap-1">
                            <NavLink href="/admin/user/edit/2" class="btn btn-sm btn-outline-info">
                                <i class="bi bi-pencil"></i>
                                <span class="d-none d-sm-inline ms-1">Edit</span>
                            </NavLink>
                            <button class="btn btn-sm btn-outline-danger"
                                    data-bs-toggle="modal"
                                    data-bs-target="#deleteUserModal">
                                <i class="bi bi-trash"></i>
                                <span class="d-none d-sm-inline ms-1">Delete</span>
                            </button>
                        </div>
                    </td>
                </tr>
                <tr>
                    <td class="text-muted">3</td>
                    <td>
                        <div class="d-flex align-items-center gap-2">
                            <img src="https://ui-avatars.com/api/?name=Myo+Min&background=10b981&color=fff&size=32"
                                 width="32" height="32" class="rounded-circle" alt="User" />
                            <span class="fw-semibold">Myo Min Aung</span>
                        </div>
                    </td>
                    <td class="d-none d-sm-table-cell"><code class="text-info">staff.reg</code></td>
                    <td class="d-none d-md-table-cell">
                        <span class="badge bg-success bg-opacity-25 text-success border border-success border-opacity-25">
                            Staff
                        </span>
                    </td>
                    <td class="d-none d-lg-table-cell text-secondary">Jun 11, 2026</td>
                    <td class="text-end">
                        <div class="d-flex justify-content-end gap-1">
                            <NavLink href="/admin/user/edit/3" class="btn btn-sm btn-outline-info">
                                <i class="bi bi-pencil"></i>
                                <span class="d-none d-sm-inline ms-1">Edit</span>
                            </NavLink>
                            <button class="btn btn-sm btn-outline-danger"
                                    data-bs-toggle="modal"
                                    data-bs-target="#deleteUserModal">
                                <i class="bi bi-trash"></i>
                                <span class="d-none d-sm-inline ms-1">Delete</span>
                            </button>
                        </div>
                    </td>
                </tr>
            </tbody>
        </table>
    </div>

    <!-- Pagination -->
    <div class="d-flex align-items-center justify-content-between mt-3 flex-wrap gap-2">
        <small class="text-muted">Showing 3 of 3 records</small>
        <nav aria-label="User pagination">
            <ul class="pagination pagination-sm mb-0">
                <li class="page-item disabled">
                    <a class="page-link" href="#"><i class="bi bi-chevron-left"></i></a>
                </li>
                <li class="page-item active"><a class="page-link" href="#">1</a></li>
                <li class="page-item disabled">
                    <a class="page-link" href="#"><i class="bi bi-chevron-right"></i></a>
                </li>
            </ul>
        </nav>
    </div>
</div>

<!-- Delete Modal -->
<div class="modal fade" id="deleteUserModal" tabindex="-1" aria-labelledby="deleteUserModalLabel" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered modal-sm">
        <div class="modal-content">
            <div class="modal-header border-0 pb-0">
                <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>
            <div class="modal-body text-center px-4 pb-2">
                <i class="bi bi-exclamation-triangle-fill text-danger" style="font-size:3.5rem;"></i>
                <h5 class="fw-bold mt-3 mb-1">Delete User?</h5>
                <p class="text-muted small mb-0">This action cannot be undone. The user account will be permanently removed.</p>
            </div>
            <div class="modal-footer border-0 justify-content-center gap-2 pt-2">
                <button type="button" class="btn btn-sm btn-secondary px-4" data-bs-dismiss="modal">Cancel</button>
                <button type="button" class="btn btn-sm btn-danger px-4">
                    <i class="bi bi-trash me-1"></i>Yes, Delete
                </button>
            </div>
        </div>
    </div>
</div>
