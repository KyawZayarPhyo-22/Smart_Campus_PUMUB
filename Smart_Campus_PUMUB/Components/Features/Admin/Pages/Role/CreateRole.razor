@page "/admin/role/create"
@layout AdminLayout

<div class="tab-pane fade show active" id="addRoleContainer" tabindex="-1">
    <div class="modal-dialog modal-md">
        <div class="modal-content tech-card">

            <div class="modal-header border-0 pb-0">
                <h5 class="modal-title fw-bold">
                    Add New Role
                </h5>
            </div>

            <div class="modal-body">
                <div class="row g-3">
                    <div class="col-12 mb-2">
                        <label class="form-label text-light">Role Name</label>
                        <input type="text" class="form-control" placeholder="Enter Role Name (e.g., Admin, User)">
                    </div>
                </div>
            </div>

            <div class="modal-footer border-0 pt-0">
                <NavLink href="/admin/roles" class="nav-link me-3">
                    <span class="sidebar-text text-muted">Cancel</span>
                </NavLink>

                <button type="button" class="btn btn-primary">
                    Create Role
                </button>
            </div>

        </div>
    </div>
</div>