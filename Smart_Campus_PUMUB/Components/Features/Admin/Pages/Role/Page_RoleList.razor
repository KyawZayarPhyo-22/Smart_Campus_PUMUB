@page "/admin/roles"
@layout AdminLayout
@namespace Smart_Campus_PUMUB.Components.Admin.Pages.Role
@using Smart_Campus_PUMUB.Components.Admin.Pages.Role
@rendermode InteractiveServer

@* 🎨 ဤစာမျက်နှာအတွက် သီးသန့် Modern Table & Button Styles များ *@
<style>
    .custom-table {
        background: rgba(20, 24, 33, 0.6);
        border-radius: 12px;
        overflow: hidden;
        border: 1px solid rgba(255, 255, 255, 0.05);
    }

    .custom-table thead {
        background: rgba(13, 110, 253, 0.1);
        border-bottom: 2px solid rgba(13, 110, 253, 0.2);
    }

    .custom-table th {
        font-weight: 600;
        text-transform: uppercase;
        font-size: 0.85rem;
        letter-spacing: 0.5px;
        color: #0d6efd;
        padding: 16px 20px;
    }

    .custom-table td {
        padding: 16px 20px;
        color: #e2e8f0;
        border-bottom: 1px solid rgba(255, 255, 255, 0.05);
        transition: all 0.2s ease;
    }

    .table-row-hover:hover {
        background: rgba(255, 255, 255, 0.02);
        box-shadow: inset 4px 0 0 #0d6efd;
    }

    .role-badge {
        font-size: 0.8rem;
        font-weight: 500;
        padding: 6px 12px;
        border-radius: 6px;
        background: rgba(13, 202, 240, 0.1) !important;
        color: #0dcaf0 !important;
        border: 1px solid rgba(13, 202, 240, 0.2);
    }

    .btn-action-edit {
        background: rgba(13, 110, 253, 0.1);
        color: #39b5ff;
        border: 1px solid rgba(13, 110, 253, 0.3);
        border-radius: 6px;
        padding: 6px 14px;
        font-size: 0.85rem;
        transition: all 0.2s ease;
    }

    .btn-action-edit:hover {
        background: #0d6efd;
        color: #ffffff;
        box-shadow: 0 0 12px rgba(13, 110, 253, 0.4);
    }

    .btn-action-delete {
        background: rgba(220, 53, 69, 0.1);
        color: #ff6b6b;
        border: 1px solid rgba(220, 53, 69, 0.3);
        border-radius: 6px;
        padding: 6px 14px;
        font-size: 0.85rem;
        transition: all 0.2s ease;
    }

    .btn-action-delete:hover {
        background: #dc3545;
        color: #ffffff;
        box-shadow: 0 0 12px rgba(220, 53, 69, 0.4);
    }

    .btn-add-modern {
        background: linear-gradient(135deg, #0d6efd, #0052cc);
        border: none;
        border-radius: 8px;
        padding: 10px 20px;
        font-weight: 500;
        box-shadow: 0 4px 15px rgba(13, 110, 253, 0.2);
        transition: all 0.2s ease;
    }

    .btn-add-modern:hover {
        transform: translateY(-1px);
        box-shadow: 0 6px 20px rgba(13, 110, 253, 0.4);
    }
</style>

<div class="tab-pane fade show active" id="v-pills-role">
    <div class="d-flex align-items-center justify-content-between mb-4 mt-2">
        <div class="d-flex align-items-center">
            <div class="bg-primary rounded p-2 me-3 shadow-sm">
                <i class="bi bi-shield-check fs-5 text-white"></i>
            </div>
            <div>
                <h4 class="fw-bolder text-white mb-0" style="letter-spacing: 0.5px;">Role Directory</h4>
                <p class="text-muted small mb-0">Manage and configure system access levels</p>
            </div>
        </div>
    </div>

    <!-- 🔹 Filter Section -->
    <div class="material-card p-3 mb-4">
        <div class="row g-3 align-items-center">
            <!-- Search Input -->
            <div class="col">
                <div class="position-relative">
                    <i class="bi bi-search position-absolute text-muted" style="top: 50%; left: 12px; transform: translateY(-50%);"></i>
                    <input type="text" class="form-control material-input w-100" style="padding-left: 2.2rem;" placeholder="Search by Role Name..." @bind="SearchInput" @onkeyup="HandleKeyUp" />
                </div>
            </div>

            <!-- Search and Reset Buttons -->
            <div class="col-md-2 d-flex gap-2">
                <button class="btn btn-primary w-50 d-flex align-items-center justify-content-center" type="button" @onclick="ApplyFilter" title="Search">
                    <i class="bi bi-search"></i>
                </button>
                <button class="btn btn-secondary w-50 d-flex align-items-center justify-content-center" type="button" @onclick="ResetFilter" title="Reset">
                    <i class="bi bi-arrow-clockwise"></i>
                </button>
            </div>

            <!-- Add Button -->
            <div class="col-auto">
                <NavLink href="/admin/role/create" class="btn btn-primary d-flex align-items-center justify-content-center" style="width: 40px; height: 38px;" title="Add Role">
                    <i class="bi bi-plus-lg"></i>
                </NavLink>
            </div>
        </div>
    </div>

    <div class="tech-card p-4">

            @if (IsLoading)
            {
                <div class="text-center my-5">
                    <div class="spinner-border text-primary" role="status">
                        <span class="visually-hidden">Loading...</span>
                    </div>
                    <div class="text-muted mt-3 small">Roles စာရင်းများကို ဆွဲယူနေပါသည်...</div>
                </div>
            }

            else if (!string.IsNullOrEmpty(ErrorMessage))
            {
                <div class="alert alert-danger border-0 rgba-red-bg" role="alert">
                    <i class="bi bi-exclamation-octagon-fill me-2"></i> @ErrorMessage
                </div>
            }

            else if (FilteredRoles == null || !FilteredRoles.Any())
            {
                <div class="text-center my-5 text-muted">
                    <i class="bi bi-folder-x display-4 text-secondary"></i>
                    <p class="mt-3 mb-0 small">ပြသရန် Role မရှိသေးပါ သို့မဟုတ် ရှာဖွေမှုမတွေ့ပါ။</p>
                </div>
            }
            else
            {
                <div class="table-responsive custom-table">
                    <table class="table align-middle mb-0">
                        <thead>
                            <tr>
                                <th style="width: 15%;">No.</th>
                                <th style="width: 50%;">Role Name</th>
                                <th style="width: 35%; text-align: center;">Actions</th>
                            </tr>
                        </thead>
                        <tbody>
                            @{
                                int count = (CurrentPage - 1) * PageSize + 1;
                            }
                            @foreach (var role in FilteredRoles)
                            {
                                <tr class="table-row-hover">
                                    <td class="fw-bold text-muted">@count.ToString("D2")</td>
                                    <td class="">
                                        <span class="badge role-badge">@role.RoleName</span>
                                    </td>
                                    <td>
                                        <div class="d-flex justify-content-center align-items-center gap-2">
                                            <NavLink href="@($"/admin/role/edit/{role.RoleId}")"
                                                     class="btn btn-action-edit d-inline-flex align-items-center">
                                                <i class="bi bi-pencil me-1.5"></i> Edit
                                            </NavLink>

                                            <button class="btn btn-action-delete d-inline-flex align-items-center"
                                                    @onclick="() => OpenDeleteModal(role)">
                                                <i class="bi bi-trash me-1.5"></i> Delete
                                            </button>
                                        </div>
                                    </td>
                                </tr>
                                count++;
                            }
                        </tbody>
                    </table>
                </div>

                <PaginationComponent CurrentPage="CurrentPage" TotalPages="TotalPages" OnPageChanged="OnPageChanged" />
            }
        </div>
    </div>

    @* 🛠️ Custom Blazor Modal (Bootstrap Class ဖြင့် Dynamic ထိန်းချုပ်ခြင်း) *@
@* 🛠️ Custom Blazor Modal *@
@if (ShowModal)
{
    <div class="modal show d-block" style="background: rgba(0,0,0,0.5);">
        <div class="modal-dialog modal-dialog-centered">
            <div class="modal-content tech-card">

                <div class="modal-header border-0">
                    <h5 class="text-danger">Confirm Delete</h5>
                </div>

                <div class="modal-body text-center">
                    Are you sure to delete <strong>@SelectedRole?.RoleName</strong>?

                    @if (!string.IsNullOrEmpty(statusMessage))
                    {
                        <div class="mt-3 p-3 rounded"
                             style="background: @(IsSuccess ? "rgba(25, 135, 84, 0.15)" : "rgba(220, 53, 69, 0.15)");
                            border: 1px solid @(IsSuccess ? "#198754" : "#dc3545");">

                            <span style="color: @(IsSuccess ? "#75b798" : "#ea868f"); font-size: 0.9rem;">
                                <i class="bi @(IsSuccess ? "bi-check-circle" : "bi-exclamation-circle") me-2"></i>
                                @statusMessage
                            </span>

                        </div>
                    }
                </div>

                <div class="modal-footer border-0">
                    <button class="btn btn-secondary"
                            @onclick="CloseDeleteModal"
                            disabled="@IsProcessing">
                        Cancel
                    </button>

                    <button class="btn btn-danger"
                            @onclick="DeleteRole"
                            disabled="@(IsProcessing || IsSuccess)">
                        @(IsProcessing ? "Deleting..." : "Yes, Delete")
                    </button>
                </div>

            </div>
        </div>
    </div>
}