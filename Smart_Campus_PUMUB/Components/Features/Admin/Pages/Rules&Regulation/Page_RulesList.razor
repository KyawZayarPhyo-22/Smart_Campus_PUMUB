@page "/admin/rules"
@layout AdminLayout
@namespace Smart_Campus_PUMUB.Components.Admin.Pages.Rules
@using Smart_Campus_PUMUB.WebApi.Models
@rendermode InteractiveServer

<style>
    .description {
        display: -webkit-box;
        -webkit-line-clamp: 2; /* 1 or 2 lines */
        -webkit-box-orient: vertical;
        overflow: hidden;
    }

    .custom-table {
        background: rgba(20, 24, 33, 0.6);
        border-radius: 12px;
        overflow: hidden;
        border: 1px solid rgba(255, 255, 255, 0.05);
    }

    .custom-table thead {
        background: rgba(13, 110, 253, 0.1);
        border-bottom: 2px solid rgba(13, 110, 253, 0.2);
    }

    .custom-table th {
        font-weight: 600;
        text-transform: uppercase;
        font-size: 0.85rem;
        color: #0d6efd;
        padding: 16px 20px;
    }

    .custom-table td {
        padding: 16px 20px;
        color: #e2e8f0;
        border-bottom: 1px solid rgba(255, 255, 255, 0.05);
    }

    .table-row-hover:hover {
        background: rgba(255, 255, 255, 0.02);
        box-shadow: inset 4px 0 0 #0d6efd;
    }

    .btn-action-edit {
        background: rgba(13, 110, 253, 0.1);
        color: #39b5ff;
        border: 1px solid rgba(13, 110, 253, 0.3);
        border-radius: 6px;
        padding: 6px 14px;
        transition: all 0.2s ease;
    }

    .btn-action-edit:hover {
        background: #0d6efd;
        color: #ffffff;
    }

    .btn-action-delete {
        background: rgba(220, 53, 69, 0.1);
        color: #ff6b6b;
        border: 1px solid rgba(220, 53, 69, 0.3);
        border-radius: 6px;
        padding: 6px 14px;
        transition: all 0.2s ease;
    }

    .btn-action-delete:hover {
        background: #dc3545;
        color: #ffffff;
    }
    .btn-action-edit, .btn-action-delete {
        padding: 4px 10px !important; /* Padding လျှော့လိုက်ပါ */
        font-size: 0.8rem !important;  /* Font size သေးသွားအောင် */
        line-height: 1.2;
        border-radius: 4px;
        display: inline-flex;
        align-items: center;
    }

    /* Icon တွေအတွက် spacing */
    .btn-action-edit i, .btn-action-delete i {
        margin-right: 4px !important;
        font-size: 0.85rem;
    }
</style>

<div class="tab-pane fade show active" id="v-pills-rules">
    <div class="d-flex align-items-center justify-content-between mb-4 mt-2">
        <div class="d-flex align-items-center">
            <div class="rounded p-2 me-3 shadow-sm" style="background: #5A4FCF;">
                <i class="bi bi-file-earmark-ruled fs-5 text-white"></i>
            </div>
            <div>
                <h4 class="fw-bolder text-white mb-0" style="letter-spacing: 0.5px;">Rules & Regulations Directory</h4>
            </div>
        </div>
    </div>

    <div class="tech-card p-4">
        <div class="row g-3 mb-4 align-items-center">
            <div class="col">
                <div class="position-relative">
                    <i class="bi bi-search position-absolute top-50 start-0 translate-middle-y ms-3 text-muted"></i>
                    <input type="text" class="form-control material-input w-100 ps-5" placeholder="Search by Title..."
                           @bind-value="SearchInput" @onkeyup="HandleKeyUp">
                </div>
            </div>
            
            <!-- Search and Reset Buttons -->
            <div class="col-md-2 d-flex gap-2">
                <button class="btn btn-primary w-50 d-flex align-items-center justify-content-center" type="button" @onclick="ApplyFilter" title="Search">
                    <i class="bi bi-search"></i>
                </button>
                <button class="btn btn-secondary w-50 d-flex align-items-center justify-content-center" type="button" @onclick="ResetFilter" title="Reset">
                    <i class="bi bi-arrow-clockwise"></i>
                </button>
            </div>

            <!-- Add Button -->
            <div class="col-auto">
                <NavLink href="/admin/rule/create" class="btn btn-primary d-flex align-items-center justify-content-center" style="width: 40px; height: 38px;" title="Add Rule">
                    <i class="bi bi-plus-lg"></i>
                </NavLink>
            </div>
        </div>

            @if (IsLoading)
            {
                <div class="text-center my-5">
                    <div class="spinner-border text-primary" role="status"></div>
                    <div class="text-muted mt-2">Data များ ဆွဲယူနေပါသည်...</div>
                </div>
            }
            else if (!string.IsNullOrEmpty(ErrorMessage))
            {
                <div class="alert alert-danger">@ErrorMessage</div>
            }
            else if (FilteredRules == null || !FilteredRules.Any())
            {
                <div class="text-center my-5 text-muted">
                    <i class="bi bi-folder-x display-4"></i>
                    <p class="mt-2">ပြသရန် Rule မရှိသေးပါ။</p>
                </div>
            }
            else
            {
                <div class="table-responsive custom-table">
                    <table class="table align-middle mb-0">
                        <thead>
                            <tr>
                                <th style="width: 10%;">No.</th>
                                <th style="width: 40%;">Rule Title</th>
                                <th style="width: 25%;">Penalty</th>
                                <th style="width: 25%;">Description</th>
                                <th style="width: 25%; text-align: center;">Actions</th>
                            </tr>
                        </thead>
                        <tbody>
                            @{
                                int count = (CurrentPage - 1) * PageSize + 1;
                            }
                            @foreach (var rule in FilteredRules)
                            {
                                <tr class="table-row-hover">
                                    <td class="fw-bold text-muted">@count.ToString("D2")</td>
                                    <td class="fw-semibold">@rule.Title</td>
                                <td>
                                    @if (decimal.TryParse(rule.Penalty, out var penaltyVal))
                                    {
                                        @($"{penaltyVal.ToString("N0")} MMK")
                                    }
                                    else
                                    {
                                        @($"{rule.Penalty} MMK")
                                    }
                                </td>
                                <td>
                                    <span class="description text-muted" title="@rule.Description">
                                        @rule.Description
                                    </span>
                                </td>

                                    <td>
                                        <div class="d-flex justify-content-center align-items-center gap-2">
                                            <NavLink href="@($"/admin/rule/edit/{rule.RuleId}")" class="btn btn-action-edit">
                                                <i class="bi bi-pencil me-1.5"></i> Edit
                                            </NavLink>
                                            <button class="btn btn-action-delete" @onclick="() => OpenDeleteModal(rule)">
                                                <i class="bi bi-trash me-1.5"></i> Delete
                                            </button>
                                        </div>
                                    </td>
                                </tr>
                                count++;
                            }
                        </tbody>
                    </table>
                </div>

                <PaginationComponent CurrentPage="CurrentPage" TotalPages="TotalPages" OnPageChanged="OnPageChanged" />
            }
        </div>
    </div>

    @* Delete Confirmation Modal *@
@if (ShowModal)
{
    <div class="modal show d-block" style="background: rgba(0,0,0,0.5);">
        <div class="modal-dialog modal-dialog-centered">
            <div class="modal-content tech-card">

                <div class="modal-header border-0">
                    <h5 class="text-danger">Confirm Delete</h5>
                </div>

                <div class="modal-body text-center">
                    Are you sure to delete <strong>@SelectedRule?.Title</strong>?

                    @if (!string.IsNullOrEmpty(statusMessage))
                    {
                        <div class="mt-3 p-3 rounded"
                             style="background: @(IsSuccess ? "rgba(25, 135, 84, 0.15)" : "rgba(220, 53, 69, 0.15)");
                            border: 1px solid @(IsSuccess ? "#198754" : "#dc3545");">

                            <span style="color: @(IsSuccess ? "#75b798" : "#ea868f"); font-size: 0.9rem;">
                                <i class="bi @(IsSuccess ? "bi-check-circle" : "bi-exclamation-circle") me-2"></i>
                                @statusMessage
                            </span>
                        </div>
                    }
                </div>

                <div class="modal-footer border-0">
                    <button class="btn btn-secondary"
                            @onclick="CloseDeleteModal"
                            disabled="@IsProcessing">
                        Cancel
                    </button>

                    <button class="btn btn-danger"
                            @onclick="DeleteRule"
                            disabled="@(IsProcessing || IsSuccess)">
                        @(IsProcessing ? "Deleting..." : "Yes, Delete")
                    </button>
                </div>

            </div>
        </div>
    </div>
}

