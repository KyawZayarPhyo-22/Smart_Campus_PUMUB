@page "/admin/rules"
@layout AdminLayout
@namespace Smart_Campus_PUMUB.Components.Admin.Pages.Rules
@using Smart_Campus_PUMUB.WebApi.Models
@rendermode InteractiveServer

<style>
    .custom-table {
        background: rgba(20, 24, 33, 0.6);
        border-radius: 12px;
        overflow: hidden;
        border: 1px solid rgba(255, 255, 255, 0.05);
    }

    .custom-table thead {
        background: rgba(13, 110, 253, 0.1);
        border-bottom: 2px solid rgba(13, 110, 253, 0.2);
    }

    .custom-table th {
        font-weight: 600;
        text-transform: uppercase;
        font-size: 0.85rem;
        color: #0d6efd;
        padding: 16px 20px;
    }

    .custom-table td {
        padding: 16px 20px;
        color: #e2e8f0;
        border-bottom: 1px solid rgba(255, 255, 255, 0.05);
    }

    .table-row-hover:hover {
        background: rgba(255, 255, 255, 0.02);
        box-shadow: inset 4px 0 0 #0d6efd;
    }

    .btn-action-edit {
        background: rgba(13, 110, 253, 0.1);
        color: #39b5ff;
        border: 1px solid rgba(13, 110, 253, 0.3);
        border-radius: 6px;
        padding: 6px 14px;
        transition: all 0.2s ease;
    }

    .btn-action-edit:hover {
        background: #0d6efd;
        color: #ffffff;
    }

    .btn-action-delete {
        background: rgba(220, 53, 69, 0.1);
        color: #ff6b6b;
        border: 1px solid rgba(220, 53, 69, 0.3);
        border-radius: 6px;
        padding: 6px 14px;
        transition: all 0.2s ease;
    }

    .btn-action-delete:hover {
        background: #dc3545;
        color: #ffffff;
    }
    .btn-action-edit, .btn-action-delete {
        padding: 4px 10px !important; /* Padding လျှော့လိုက်ပါ */
        font-size: 0.8rem !important;  /* Font size သေးသွားအောင် */
        line-height: 1.2;
        border-radius: 4px;
        display: inline-flex;
        align-items: center;
    }

    /* Icon တွေအတွက် spacing */
    .btn-action-edit i, .btn-action-delete i {
        margin-right: 4px !important;
        font-size: 0.85rem;
    }
</style>

<div class="tab-pane fade show active" id="v-pills-rules">
    <div class="mb-4">
        <h3 class="fw-bold mb-1" style="color: #ffffff;">Rules & Regulations Directory</h3>
    </div>

    <div class="tech-card p-4">
        <div class="row g-3 mb-4 align-items-center">
            <div class="col-md-5">
                <div class="input-group">
                    <span class="input-group-text search-icon-bg border-end-0"><i
                        class="bi bi-search text-muted"></i></span>
                        <input type="text" class="form-control border-start-0 text-white" placeholder="Search by Title..."
                               @bind-value="SearchTerm" @bind-value:event="oninput">
                    </div>
                </div>
                <div class="col-md-7 text-end">
                    <NavLink href="/admin/rule/create" class="btn btn-primary nav-link d-inline-block text-white">
                        <i class="bi bi-plus-lg me-1"></i> Add Rule
                    </NavLink>
                </div>
            </div>

            @if (IsLoading)
            {
                <div class="text-center my-5">
                    <div class="spinner-border text-primary" role="status"></div>
                    <div class="text-muted mt-2">Data များ ဆွဲယူနေပါသည်...</div>
                </div>
            }
            else if (!string.IsNullOrEmpty(ErrorMessage))
            {
                <div class="alert alert-danger">@ErrorMessage</div>
            }
            else if (FilteredRules == null || !FilteredRules.Any())
            {
                <div class="text-center my-5 text-muted">
                    <i class="bi bi-folder-x display-4"></i>
                    <p class="mt-2">ပြသရန် Rule မရှိသေးပါ။</p>
                </div>
            }
            else
            {
                <div class="table-responsive custom-table">
                    <table class="table align-middle mb-0">
                        <thead>
                            <tr>
                                <th style="width: 10%;">No.</th>
                                <th style="width: 40%;">Rule Title</th>
                                <th style="width: 25%;">Penalty</th>
                                <th style="width: 25%;">Description</th>
                                <th style="width: 25%; text-align: center;">Actions</th>
                            </tr>
                        </thead>
                        <tbody>
                            @{
                                int count = 1;
                            }
                            @foreach (var rule in FilteredRules)
                            {
                                <tr class="table-row-hover">
                                    <td class="fw-bold text-muted">@count.ToString("D2")</td>
                                    <td class="fw-semibold">@rule.Title</td>
                                    <td><span class="badge bg-warning text-dark">@rule.Penalty</span></td>
                                    <td><span class="badge bg-warning text-dark">@rule.Description</span></td>

                                    <td>
                                        <div class="d-flex justify-content-center align-items-center gap-2">
                                            <NavLink href="@($"/admin/rule/edit/{rule.RuleId}")" class="btn btn-action-edit">
                                                <i class="bi bi-pencil me-1.5"></i> Edit
                                            </NavLink>
                                            <button class="btn btn-action-delete" @onclick="() => OpenDeleteModal(rule)">
                                                <i class="bi bi-trash me-1.5"></i> Delete
                                            </button>
                                        </div>
                                    </td>
                                </tr>
                                count++;
                            }
                        </tbody>
                    </table>
                </div>
            }
        </div>
    </div>

    @* Delete Confirmation Modal *@
    <div class="modal fade @(ShowModal ? "show d-block" : "")" tabindex="-1"
         style="background: @(ShowModal ? "rgba(10, 14, 22, 0.85)" : "none"); backdrop-filter: blur(4px);">
        <div class="modal-dialog modal-dialog-centered">
            <div class="modal-content tech-card" style="border: 1px solid rgba(220, 53, 69, 0.2);">
                <div class="modal-header border-0 pb-0">
                    <h5 class="modal-title text-danger fw-bold d-flex align-items-center">
                        <i class="bi bi-exclamation-triangle-fill me-2"></i> Confirm Delete
                    </h5>
                    <button type="button" class="btn-close btn-close-white" @onclick="CloseDeleteModal"></button>
                </div>
                <div class="modal-body text-center py-4">
                    <i class="bi bi-trash-fill text-danger display-3 mb-3"></i>
                    <h4 class="fw-bold text-white">Delete Rule?</h4>
                    <p class="text-light opacity-75">စာရင်းဖျက်ရန် သေချာပါသလား? <br /> Rule အမည်: <strong
                        class="text-info">@SelectedRule?.Title</strong></p>
                    </div>
                    <div class="modal-footer border-0 justify-content-center pt-0">
                        <button type="button" class="btn btn-secondary px-4" @onclick="CloseDeleteModal"
                                disabled="@IsProcessing">Cancel</button>
                        <button type="button" class="btn btn-danger px-4" @onclick="DeleteRule" disabled="@IsProcessing">
                            @(IsProcessing ? "Deleting..." : "Yes, Delete")
                        </button>
                    </div>
                </div>
            </div>
        </div>