@page "/admin/departments"
@layout AdminLayout
@namespace Smart_Campus_PUMUB.Components.Admin.Pages.Department
@using Smart_Campus_PUMUB.WebApi.Models
@rendermode InteractiveServer

<style>
    /* Category စာမျက်နှာမှ ဒီဇိုင်းများကို ယူသုံးထားသည် */
    .custom-table {
        background: rgba(20, 24, 33, 0.6);
        border-radius: 12px;
        overflow: hidden;
        border: 1px solid rgba(255, 255, 255, 0.05);
    }

    .custom-table thead {
        background: rgba(13, 110, 253, 0.1);
        border-bottom: 2px solid rgba(13, 110, 253, 0.2);
    }

    .custom-table th {
        font-weight: 600;
        text-transform: uppercase;
        font-size: 0.85rem;
        color: #0d6efd;
        padding: 16px 20px;
    }

    .custom-table td {
        padding: 16px 20px;
        color: #e2e8f0;
        border-bottom: 1px solid rgba(255, 255, 255, 0.05);
    }

    .table-row-hover:hover {
        background: rgba(255, 255, 255, 0.02);
        box-shadow: inset 4px 0 0 #0d6efd;
    }

    .btn-action-edit {
        background: rgba(13, 110, 253, 0.1);
        color: #39b5ff;
        border: 1px solid rgba(13, 110, 253, 0.3);
        border-radius: 6px;
        padding: 6px 14px;
        transition: all 0.2s ease;
    }

    .btn-action-edit:hover {
        background: #0d6efd;
        color: #ffffff;
    }

    .btn-action-delete {
        background: rgba(220, 53, 69, 0.1);
        color: #ff6b6b;
        border: 1px solid rgba(220, 53, 69, 0.3);
        border-radius: 6px;
        padding: 6px 14px;
        transition: all 0.2s ease;
    }

    .btn-action-delete:hover {
        background: #dc3545;
        color: #ffffff;
    }

    .btn-action-edit {
        background: rgba(13, 110, 253, 0.1);
        color: #39b5ff;
        border: 1px solid rgba(13, 110, 253, 0.3);
        border-radius: 6px;
        padding: 4px 10px;
        font-size: 0.85rem;
        transition: all 0.2s ease;
    }

    .btn-action-delete {
        background: rgba(220, 53, 69, 0.1);
        color: #ff6b6b;
        border: 1px solid rgba(220, 53, 69, 0.3);
        border-radius: 6px;
        padding: 4px 10px;
        font-size: 0.85rem;
        transition: all 0.2s ease;
    }
</style>

<div class="mb-4">
    <h3 class="fw-bold mb-1" style="color: #ffffff;">Department Directory</h3>
</div>

<div class="tech-card p-4">
        <div class="row g-3 mb-4 align-items-center">
            <div class="col-md-7 col-lg-6">
                <div class="input-group">
                    <span class="input-group-text search-icon-bg"><i class="bi bi-search text-muted"></i></span>
                    <input type="text" class="form-control text-white" 
                           placeholder="Search by Department Name..." @bind="SearchInput" @onkeyup="HandleKeyUp">
                    <button class="btn btn-primary" type="button" @onclick="ApplyFilter" title="Search">
                        <i class="bi bi-search"></i> Search
                    </button>
                    <button class="btn btn-secondary" type="button" @onclick="ResetFilter" title="Reset">
                        <i class="bi bi-arrow-clockwise"></i> Reset
                    </button>
                </div>
            </div>
            <div class="col-md-5 col-lg-6 text-end">
                <NavLink href="/admin/department/create" class="btn btn-primary text-white">
                    <i class="bi bi-plus-lg me-1"></i> Add Department
                </NavLink>
            </div>
        </div>

        @if (IsLoading)
        {
            <div class="text-center my-5">
                <div class="spinner-border text-primary"></div>
            </div>
        }
        else
        {
            <div class="table-responsive custom-table">
                <table class="table align-middle mb-0">
                    <thead>
                        <tr>
                            <th style="width: 10%;">No.</th>
                            <th style="width: 45%;">Department Name</th>
                            <th style="width: 25%;">Faculty</th>
                            <th style="width: 20%; text-align: center;">Actions</th>
                        </tr>
                    </thead>
                    @* <tbody>
                    @{ int count = 1; }
                    @foreach (var item in FilteredDepartments)
                    {
                        <tr class="table-row-hover">
                            <td class="fw-bold text-muted">@count.ToString("D2")</td>
                            <td class="fw-semibold">@item.DepartmentName</td>
                            <td><span class="badge bg-primary bg-opacity-10 text-primary">@item.FacultyName</span></td>
                            <td>
                                <div class="d-flex justify-content-center align-items-center gap-2">
                                    <NavLink href="@($"/admin/department/edit/{item.DepartmentId}")" class="btn btn-action-edit">
                                        <i class="bi bi-pencil me-1"></i> Edit
                                    </NavLink>
                                    <button class="btn btn-action-delete" @onclick="() => OpenDeleteModal(item)">
                                        <i class="bi bi-trash me-1"></i> Delete
                                    </button>
                                </div>
                            </td>
                        </tr>
                        count++;
                    }
                </tbody> *@
                    <tbody>
                        @{
                            int count = (CurrentPage - 1) * PageSize + 1;
                        }
                        @foreach (var item in FilteredDepartments)
                        {
                            <tr class="table-row-hover">
                                <td class="fw-bold text-muted">@count.ToString("D2")</td>
                                <td class="fw-semibold">@item.DepartmentName</td>

                                @* 💡 Faculty Name ကို text-info သို့ ပြောင်းထားပါသည် *@
                                <td><span class="badge bg-info bg-opacity-10 text-info">@item.FacultyName</span></td>

                                <td>
                                    <div class="d-flex justify-content-center align-items-center gap-2">
                                        <NavLink href="@($"/admin/department/edit/{item.DepartmentId}")"
                                                 class="btn btn-action-edit">
                                            <i class="bi bi-pencil me-1"></i> Edit
                                        </NavLink>
                                        <button class="btn btn-action-delete" @onclick="() => OpenDeleteModal(item)">
                                            <i class="bi bi-trash me-1"></i> Delete
                                        </button>
                                    </div>
                                </td>
                            </tr>
                            count++;
                        }
                    </tbody>
                </table>
            </div>

            <PaginationComponent CurrentPage="CurrentPage" TotalPages="TotalPages" OnPageChanged="OnPageChanged" />
        }
    </div>

    @* Delete Modal (Category ပုံစံအတိုင်း) *@
    <div class="modal fade @(ShowModal ? "show d-block" : "")" tabindex="-1"
         style="background: @(ShowModal ? "rgba(10, 14, 22, 0.85)" : "none"); backdrop-filter: blur(4px);">
        <div class="modal-dialog modal-dialog-centered">
            <div class="modal-content tech-card" style="border: 1px solid rgba(220, 53, 69, 0.2);">
                <div class="modal-header border-0 pb-0">
                    <h5 class="modal-title text-danger fw-bold"><i class="bi bi-exclamation-triangle-fill me-2"></i> Confirm
                        Delete</h5>
                    </div>
                   <div class="modal-body text-center py-4">

    <i class="bi bi-trash-fill text-danger display-3 mb-3"></i>

    <h4 class="fw-bold text-white">Delete Department?</h4>

    <p class="text-light opacity-75">
        ဒီဌာနခွဲကို ဖျက်ရန် သေချာပါသလား? <br />
        Name: <strong class="text-info">@SelectedDepartment?.DepartmentName</strong>
    </p>

    @* 👇 HERE IS THE PLACE *@
    @if (!string.IsNullOrEmpty(statusMessage))
    {
        <div class="mt-3 p-3 rounded"
             style="background: @(IsSuccess ? "rgba(25, 135, 84, 0.15)" : "rgba(220, 53, 69, 0.15)");
                    border: 1px solid @(IsSuccess ? "#198754" : "#dc3545");">

            <span style="color: @(IsSuccess ? "#75b798" : "#ea868f"); font-size: 0.9rem;">
                <i class="bi @(IsSuccess ? "bi-check-circle" : "bi-exclamation-circle") me-2"></i>
                @statusMessage
            </span>
        </div>
    }

</div>
                        <div class="modal-footer border-0 justify-content-center pt-0">
                            <button class="btn btn-secondary px-4" @onclick="CloseDeleteModal">Cancel</button>
                            <button class="btn btn-danger px-4" @onclick="DeleteDepartment" disabled="@IsProcessing">
                                @(IsProcessing ? "Deleting..." : "Yes, Delete")
                            </button>
                        </div>
                    </div>
                </div>
            </div>