@page "/admin/permission/create"
@layout AdminLayout
@namespace Smart_Campus_PUMUB.Components.Admin.Pages.Permission
@using Smart_Campus_PUMUB.Components.Admin.Services
@using Smart_Campus_PUMUB.Database.AppDbContext
@inject PermissionService PermissionService
@inject NavigationManager Nav

<div class="tech-card p-4">
    <h3 class="text-white mb-4">Create New Permission</h3>
    
    <div class="form-group mb-3">
        <label class="text-muted mb-2">Permission Name (e.g., Edit_Tutor)</label>
        <input type="text" class="form-control" @bind="newPermission.PermissionName" placeholder="Enter permission name" />
    </div>

    <div class="mt-4">
        <button class="btn btn-primary" @onclick="SavePermission">Save</button>
        <button class="btn btn-secondary ms-2" @onclick='() => Nav.NavigateTo("/admin/permissions")'>Cancel</button>
    </div>
</div>

@code {
    private Permission newPermission = new Permission();

    private async Task SavePermission()
    {
        if (!string.IsNullOrWhiteSpace(newPermission.PermissionName))
        {
            await PermissionService.CreatePermissionAsync(newPermission);
            Nav.NavigateTo("/admin/permissions");
        }
    }
}