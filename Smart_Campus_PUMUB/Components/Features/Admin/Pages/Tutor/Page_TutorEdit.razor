@page "/admin/tutor/edit/{Id:int}"
@layout AdminLayout
@using Smart_Campus_PUMUB.WebApi.Models
@using Microsoft.AspNetCore.Components.Forms

<div class="tech-card p-4">
    <h3 class="fw-bold mb-4">Edit Tutor</h3>

    @if (createModel == null)
    {
        <div class="spinner-border text-primary" role="status"></div>
    }
    else
    {
        @if (!string.IsNullOrEmpty(statusMessage))
        {
            <div class="alert alert-warning">@statusMessage</div>
        }

        <div class="row">
            <div class="col-md-6 mb-3">
                <label class="form-label">Tutor Name</label>
                <input type="text" class="form-control" @bind="createModel.Tutor_Name" />
            </div>
            <div class="col-md-6 mb-3">
                <label class="form-label">Email</label>
                <input type="email" class="form-control" @bind="createModel.Email" />
            </div>
            <div class="col-md-6 mb-3">
                <label class="form-label">Phone</label>
                <input type="text" class="form-control" @bind="createModel.Phone" />
            </div>
            <div class="col-md-6 mb-3">
                <label class="form-label">Position</label>
                <select class="form-select" @bind="createModel.PositionId">
                    @foreach (var pos in PositionList) { <option value="@pos.PositionId">@pos.PositionName</option> }
                </select>
            </div>
            <div class="col-md-6 mb-3">
                <label class="form-label">Assign User</label>
                <select class="form-select" @bind="createModel.UserId">
                    @foreach (var user in UserList) { <option value="@user.User_Id">@user.UserName</option> }
                </select>
            </div>
            <div class="col-md-6 mb-3">
                <label class="form-label">Department</label>
                <select class="form-select" @bind="createModel.DepartmentId">
                    @foreach (var dept in DepartmentList) { <option value="@dept.DepartmentId">@dept.DepartmentName</option> }
                </select>
            </div>
            <div class="col-md-6 mb-3">
                <label class="form-label">Update Profile Image (Optional)</label>
                <InputFile class="form-control" OnChange="HandleFileSelected" />
            </div>
            <div class="col-12 mb-3">
                <label class="form-label">About</label>
                <textarea class="form-control" rows="3" @bind="createModel.About"></textarea>
            </div>
        </div>

        <div class="d-flex gap-2">
            <button class="btn btn-success" @onclick="UpdateTutor" disabled="@isProcessing">
                @(isProcessing ? "Updating..." : "Update Tutor")
            </button>
            <NavLink href="/admin/tutors" class="btn btn-outline-secondary">Cancel</NavLink>
        </div>
    }
</div>