@page "/admin/tutors"
@layout AdminLayout
@namespace Smart_Campus_PUMUB.Components.Admin.Pages.Tutor
@using Smart_Campus_PUMUB.WebApi.Models
@rendermode InteractiveServer

<div class="d-flex align-items-center justify-content-between mb-4 mt-2">
    <div class="d-flex align-items-center">
        <div class="bg-primary rounded p-2 me-3 shadow-sm">
            <i class="bi bi-person-workspace fs-5 text-white"></i>
        </div>
        <h4 class="fw-bolder text-white mb-0" style="letter-spacing: 0.5px;">Tutor Directory</h4>
    </div>
</div>

<!-- 🔹 Filter Section -->
<div class="material-card p-3 mb-4">
    <div class="row g-3 align-items-center">
        <!-- Search Input -->
        <div class="col">
            <div class="position-relative">
                <i class="bi bi-search position-absolute text-muted" style="top: 50%; left: 12px; transform: translateY(-50%);"></i>
                <input type="text" class="form-control material-input w-100" style="padding-left: 2.2rem;" placeholder="Search by Name..." @bind="SearchInput" @onkeyup="HandleKeyUp" />
            </div>
        </div>

        <!-- Role Dropdown -->
        <div class="col-md-3">
            <select class="form-select material-input" @bind="SelectedRoleInput">
                <option value="All">All Roles</option>
                @foreach (var role in TutorList.Select(t => t.RoleName).Distinct().Where(r => !string.IsNullOrEmpty(r)))
                {
                    <option value="@role">@role</option>
                }
            </select>
        </div>

        <!-- Search and Reset Buttons -->
        <div class="col-md-2 d-flex gap-2">
            <button class="btn btn-primary w-50 d-flex align-items-center justify-content-center" type="button" @onclick="ApplyFilter" title="Search">
                <i class="bi bi-search"></i>
            </button>
            <button class="btn btn-secondary w-50 d-flex align-items-center justify-content-center" type="button" @onclick="ResetFilter" title="Reset">
                <i class="bi bi-arrow-clockwise"></i>
            </button>
        </div>

        <!-- Add Button -->
        <div class="col-auto">
            <NavLink href="/admin/tutor/create" class="btn btn-primary d-flex align-items-center justify-content-center" style="width: 40px; height: 38px;" title="Add Tutor">
                <i class="bi bi-plus-lg"></i>
            </NavLink>
        </div>
    </div>
</div>

<div class="tech-card p-4">

    @if (IsLoading) { <div class="text-center text-white">Loading...</div> }
    else
    {
        <div class="table-responsive">
            <table class="table table-tech align-middle text-white">
                <thead>
                    <tr>
                        <th>No.</th>
                        <th>Profile</th>
                        <th>Name</th>
                        <th>Role</th>
                        <th>Email</th>
                        <th>Phone</th>
                        <th class="text-center">Actions</th>
                    </tr>
                </thead>
                <tbody>
                    @{ int count = (CurrentPage - 1) * PageSize + 1; }
                    @foreach (var tutor in FilteredTutors)
                    {
                        <tr>
                            <td>@count</td>
                            <td>
                                <img src="@(string.IsNullOrEmpty(tutor.Profile) ? "https://via.placeholder.com/50" : $"https://localhost:7297/{tutor.Profile}")" 
                                     class="rounded-circle" width="50" height="50" style="object-fit: cover;">
                            </td>
                            <td>@tutor.TutorName</td>
                            <td>@tutor.RoleName</td>
                            <td>@tutor.Email</td>
                            <td>@tutor.Phone</td>
                            <td class="text-center">
                                <NavLink href="@($"/admin/tutor/edit/{tutor.TutorId}")" class="btn btn-sm btn-outline-info me-2"><i class="bi bi-pencil me-1.5"></i> Edit</NavLink>
                                <button class="btn btn-sm btn-outline-danger" @onclick="() => OpenDeleteModal(tutor)"><i class="bi bi-trash me-1.5"></i> Delete</button>
                            </td>
                        </tr>
                        count++;
                    }
                </tbody>
            </table>
        </div>

        <PaginationComponent CurrentPage="CurrentPage" TotalPages="TotalPages" OnPageChanged="OnPageChanged" />
    }
</div>

@* Modal *@
@if (ShowModal)
{
    <div class="modal show d-block" style="background: rgba(0,0,0,0.5);">
        <div class="modal-dialog modal-dialog-centered">
            <div class="modal-content tech-card">
                <div class="modal-header border-0"><h5 class="text-danger">Confirm Delete</h5></div>
                <div class="modal-body text-center">Are you sure to delete @SelectedTutor?.TutorName?</div>
                <div class="modal-footer border-0">
                    <button class="btn btn-secondary" @onclick="() => ShowModal = false">Cancel</button>
                    <button class="btn btn-danger" @onclick="DeleteTutor" disabled="@IsProcessing">Yes, Delete</button>
                </div>
            </div>
        </div>
    </div>
}