@page "/admin/tutor/create"
@layout AdminLayout
@namespace Smart_Campus_PUMUB.Components.Admin.Pages.Tutor
@using Smart_Campus_PUMUB.WebApi.Models
@using Microsoft.AspNetCore.Components.Forms
@using Microsoft.AspNetCore.Components.Authorization
@rendermode InteractiveServer

<AuthorizeView Policy="Create_Tutor" Context="authContext">
    <Authorized>
        <div class="tech-card p-4">
            <h3 class="fw-bold mb-4">Add New Tutor</h3>

            <EditForm Model="createModel" OnValidSubmit="SaveTutor" FormName="CreateTutorForm">
                <DataAnnotationsValidator />

                <div class="row">
                    <div class="col-md-6 mb-3">
                        <label class="form-label fw-bold">Role No / Roll No</label>
                        <div class="input-group">
                            <input type="text" class="form-control" value="@roleNo" @onchange="OnRoleNoChanged" placeholder="Enter Role No (e.g. T-101) to auto-fill" />
                        </div>
                        @if (!string.IsNullOrEmpty(roleNoValidationMessage))
                        {
                            <div class="form-text @(roleNoValidationMessage.Contains("✅") ? "text-success" : "text-danger") fw-bold mt-1">
                                @roleNoValidationMessage
                            </div>
                        }
                    </div>
                    <div class="col-md-6 mb-3">
                        <label class="form-label">Tutor Name</label>
                        <InputText class="form-control" @bind-Value="createModel.TutorName" />
                    </div>
                    <div class="col-md-6 mb-3">
                        <label class="form-label">Email</label>
                        <InputText type="email" class="form-control" @bind-Value="createModel.Email" />
                    </div>
                    <div class="col-md-6 mb-3">
                        <label class="form-label">Phone</label>
                        <InputText class="form-control" @bind-Value="createModel.Phone" />
                    </div>
                    <div class="col-md-6 mb-3">
                        <label class="form-label">Position</label>
                        <InputSelect class="form-select" @bind-Value="createModel.PositionId">
                            <option value="0">Select Position</option>
                            @if (PositionList != null)
                            {
                                @foreach (var pos in PositionList)
                                {
                                    <option value="@pos.PositionId">@pos.PositionName</option>
                                }
                            }
                        </InputSelect>
                    </div>
                    <div class="col-md-6 mb-3">
                        <label class="form-label">Assign User</label>
                        <InputSelect class="form-select" @bind-Value="createModel.UserId">
                            <option value="0">Select User</option>
                            @if (UserList != null)
                            {
                                @foreach (var user in UserList.DistinctBy(u => u.RoleName))
                                {
                                    <option value="@user.UserId">
                                        @user.RoleName
                                    </option>
                                }
                            }
                        </InputSelect>
                    </div>
                    <div class="col-md-6 mb-3">
                        <label class="form-label">Department</label>
                        <InputSelect class="form-select" @bind-Value="createModel.DepartmentId">
                            <option value="0">Select Department</option>
                            @if (DepartmentList != null)
                            {
                                @foreach (var dept in DepartmentList)
                                {
                                    <option value="@dept.DepartmentId">
                                        @dept.DepartmentName
                                    </option>
                                }
                            }
                        </InputSelect>
                    </div>
                    <div class="col-md-6 mb-3">
                        <label class="form-label">Profile Image</label>
                        <InputFile class="form-control" OnChange="HandleFileSelected" accept=".jpg,.jpeg,.png" />
                    </div>
                    <div class="col-12 mb-3">
                        <label class="form-label">About</label>
                        <InputTextArea class="form-control" rows="3" @bind-Value="createModel.About"></InputTextArea>
                    </div>
                </div>

                @if (!string.IsNullOrEmpty(statusMessage))
                {
                    <div class="alert alert-info">@statusMessage</div>
                }

                <div class="d-flex gap-2 mt-2">
                    <NavLink href="/admin/tutors" class="btn btn-secondary">Cancel</NavLink>
                    <button type="submit" class="btn btn-primary" disabled="@isProcessing">
                        @(isProcessing ? "Saving..." : "Create Tutor")
                    </button>
                </div>
            </EditForm>
        </div>
    </Authorized>
    
    <NotAuthorized>
        @* 💡 Permission မရှိဘဲ URL ကနေ အတင်းဝင်လာသူများကို ပြမည့် Error Layout *@
        <div class="text-center mt-5 p-5 tech-card">
            <i class="bi bi-shield-slash text-danger fs-1"></i>
            <h2 class="text-danger fw-bold mt-3">Access Denied</h2>
            <p class="text-muted">သင့်တွင် ဤစာမျက်နှာကို ဝင်ရောက်ကြည့်ရှုရန် ခွင့်ပြုချက် (Create_Tutor Policy) မရှိပါ။</p>
            <NavLink href="/admin/tutors" class="btn btn-primary mt-2">
                <i class="bi bi-arrow-left"></i> Back to Directory
            </NavLink>
        </div>
    </NotAuthorized>
</AuthorizeView>