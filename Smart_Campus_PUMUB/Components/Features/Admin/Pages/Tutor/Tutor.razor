<!-- 2. TUTOR DIRECTORY -->
@page "/admin/tutors"
@layout AdminLayout
<div class="tab-pane fade show active" id="v-pills-tutor">
    <div class="mb-4">
        <h3 class="fw-bold mb-1">Tutor Directory</h3>
    </div>
    <div class="tech-card">
        <!-- RESTORED: Search & Filter -->
        <div class="row g-3 mb-4">
            <div class="col-md-4">
                <div class="input-group">
                    <span class="input-group-text search-icon-bg border-end-0"><i class="bi bi-search"></i></span>
                    <input type="text" class="form-control border-start-0" placeholder="Search by Tutor ID or Name...">
                </div>
            </div>
            <div class="col-md-3">
                <select class="form-select">
                    <option value="">All Departments...</option>
                    <option>Mechanical Eng.</option>
                    <option>Civil Eng.</option>
                    <option>Information Tech.</option>
                </select>
            </div>
            <div class="col-md-5 text-end">

                <NavLink href="/admin/tutor/create" class="nav-link">
                    <span class="sidebar-text">Add Tutor</span>
                </NavLink>
            </div>
        </div>

        <div class="table-responsive">
            <table class="table table-tech align-middle mb-0" style="color: aliceblue;">
                <thead>
                    <tr>

                        <th>ID</th>
                        <th>Profile</th>
                        <th>Name</th>
                        <th>Position</th>
                        <th>Department</th>
                        <th>Email</th>
                        <th>Phone</th>
                        <th>Actions</th>

                    </tr>
                </thead>
                <tbody>
                    <tr>
                        <td>1</td>

                        <td>
                            <img src="https://via.placeholder.com/50" class="rounded-circle" width="50">
                        </td>

                        <td>Dr. John Smith</td>

                        <td>Professor</td>

                        <td>Mechanical Engineering</td>

                        <td>john@university.edu</td>

                        <td>09123456789</td>

                        <td>
                            <NavLink href="/admin/tutor/edit" class="nav-link">
                                <span class="sidebar-text">Edit</span>
                            </NavLink>
                            <button class="btn btn-sm btn-danger" data-bs-toggle="modal"
                                data-bs-target="#deleteTutorModal">
                                <i class="bi bi-trash"></i>
                                Delete
                            </button>
                        </td>
                    </tr>
                </tbody>
            </table>
        </div>
    </div>
</div>


<div class="modal fade" id="deleteTutorModal" tabindex="-1">
    <div class="modal-dialog modal-dialog-centered">

        <div class="modal-content tech-card">

            <div class="modal-header border-0">
                <h5 class="modal-title text-danger fw-bold">
                    <i class="bi bi-exclamation-triangle-fill me-2"></i>
                    Confirm Delete
                </h5>

                <button type="button"
                        class="btn-close btn-close-white"
                        data-bs-dismiss="modal">
                </button>
            </div>

            <div class="modal-body text-center">

                <div class="mb-3">
                    <i class="bi bi-trash-fill"
                       style="font-size:4rem;color:#dc3545;">
                    </i>
                </div>

                <h4 class="fw-bold">
                    Delete Tutor?
                </h4>

                <p class="text-muted">
                    This action cannot be undone.
                    The tutor information will be permanently removed.
                </p>

            </div>

            <div class="modal-footer border-0 justify-content-center">

                <button type="button"
                        class="btn btn-secondary"
                        data-bs-dismiss="modal">
                    Cancel
                </button>

                <button type="button"
                        class="btn btn-danger">
                    <i class="bi bi-trash me-2"></i>
                    Yes, Delete
                </button>

            </div>

        </div>

    </div>
</div>