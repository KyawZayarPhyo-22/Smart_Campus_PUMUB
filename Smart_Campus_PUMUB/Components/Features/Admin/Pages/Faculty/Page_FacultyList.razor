@page "/admin/faculties"
@layout AdminLayout
@namespace Smart_Campus_PUMUB.Components.Admin.Pages.Faculty
@using Smart_Campus_PUMUB.WebApi.Models
@rendermode InteractiveServer

<style>
    .custom-table {
        background: rgba(20, 24, 33, 0.6);
        border-radius: 12px;
        overflow: hidden;
        border: 1px solid rgba(255, 255, 255, 0.05);
    }
    .custom-table thead {
        background: rgba(13, 110, 253, 0.1);
        border-bottom: 2px solid rgba(13, 110, 253, 0.2);
    }
    .custom-table th {
        font-weight: 600;
        text-transform: uppercase;
        font-size: 0.85rem;
        color: #0d6efd;
        padding: 16px 20px;
    }
    .custom-table td {
        padding: 16px 20px;
        color: #e2e8f0;
        border-bottom: 1px solid rgba(255, 255, 255, 0.05);
    }
    .table-row-hover:hover {
        background: rgba(255, 255, 255, 0.02);
        box-shadow: inset 4px 0 0 #0d6efd;
    }
    .btn-action-edit {
        background: rgba(13, 110, 253, 0.1);
        color: #39b5ff;
        border: 1px solid rgba(13, 110, 253, 0.3);
        border-radius: 6px;
        padding: 6px 14px;
        transition: all 0.2s ease;
    }
    .btn-action-edit:hover {
        background: #0d6efd;
        color: #ffffff;
    }
    .btn-action-delete {
        background: rgba(220, 53, 69, 0.1);
        color: #ff6b6b;
        border: 1px solid rgba(220, 53, 69, 0.3);
        border-radius: 6px;
        padding: 6px 14px;
        transition: all 0.2s ease;
    }
    .btn-action-delete:hover {
        background: #dc3545;
        color: #ffffff;
    }
</style>

<div class="d-flex align-items-center justify-content-between mb-4 mt-2">
    <div class="d-flex align-items-center">
        <div class="rounded p-2 me-3 shadow-sm" style="background: #5A4FCF;">
            <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" id="Apartment--Streamline-Outlined-Material" height="24" width="24" >
                <path fill="#ffffff" d="M3 21V7.125h4.125V3h9.75v8.25H21V21H13.325v-4.125h-2.65V21H3Zm1.5 -1.5h2.625v-2.625H4.5V19.5Zm0 -4.125h2.625V12.75H4.5v2.625Zm0 -4.125h2.625v-2.625H4.5v2.625Zm4.125 4.125h2.625V12.75h-2.625v2.625Zm0 -4.125h2.625v-2.625h-2.625v2.625Zm0 -4.125h2.625V4.5h-2.625v2.625Zm4.125 8.25h2.625V12.75H12.75v2.625Zm0 -4.125h2.625v-2.625H12.75v2.625Zm0 -4.125h2.625V4.5H12.75v2.625ZM16.875 19.5H19.5v-2.625h-2.625V19.5Zm0 -4.125H19.5V12.75h-2.625v2.625Z" stroke-width="0.5"></path>
            </svg>
        </div>
        <h4 class="fw-bolder text-white mb-0" style="letter-spacing: 0.5px;">Faculty Directory</h4>
    </div>
</div>

<!-- 🔹 Filter Section -->
<div class="material-card p-3 mb-4">
    <div class="row g-3 align-items-center">
        <!-- Search Input -->
        <div class="col">
            <div class="position-relative">
                <i class="bi bi-search position-absolute text-muted" style="top: 50%; left: 12px; transform: translateY(-50%);"></i>
                <input type="text" class="form-control material-input w-100" style="padding-left: 2.2rem;" placeholder="Search by Faculty Name..." @bind="SearchInput" @onkeyup="HandleKeyUp" />
            </div>
        </div>

        <!-- Search and Reset Buttons -->
        <div class="col-md-2 d-flex gap-2">
            <button class="btn btn-primary w-50 d-flex align-items-center justify-content-center" type="button" @onclick="ApplyFilter" title="Search">
                <i class="bi bi-search"></i>
            </button>
            <button class="btn btn-secondary w-50 d-flex align-items-center justify-content-center" type="button" @onclick="ResetFilter" title="Reset">
                <i class="bi bi-arrow-clockwise"></i>
            </button>
        </div>

        <!-- Add Button -->
        <div class="col-auto">
            <NavLink href="/admin/faculty/create" class="btn btn-primary d-flex align-items-center justify-content-center" style="width: 40px; height: 38px;" title="Add Faculty">
                <i class="bi bi-plus-lg"></i>
            </NavLink>
        </div>
    </div>
</div>

<div class="tech-card p-4">

        @if (IsLoading)
        {
            <div class="text-center my-5">
                <div class="spinner-border text-primary" role="status"></div>
                <div class="text-muted mt-2">Faculty စာရင်းများကို ဆွဲယူနေပါသည်...</div>
            </div>
        }
        else if (!string.IsNullOrEmpty(ErrorMessage))
        {
            <div class="alert alert-danger" role="alert">@ErrorMessage</div>
        }
        else if (FilteredFaculties == null || !FilteredFaculties.Any())
        {
            <div class="text-center my-5 text-muted">
                <i class="bi bi-folder-x display-4"></i>
                <p class="mt-2">ပြသရန် Faculty မရှိသေးပါ သို့မဟုတ် ရှာဖွေမှုမတွေ့ပါ။</p>
            </div>
        }
        else
        {
            <div class="table-responsive custom-table">
                <table class="table align-middle mb-0">
                    <thead>
                        <tr>
                            <th style="width: 15%;">No.</th>
                            <th style="width: 50%;">Faculty Name</th>
                            <th style="width: 35%; text-align: center;">Actions</th>
                        </tr>
                    </thead>
                    <tbody>
                        @{ int count = (CurrentPage - 1) * PageSize + 1; }
                        @foreach (var faculty in FilteredFaculties)
                        {
                            <tr class="table-row-hover">
                                <td class="fw-bold text-muted">@count.ToString("D2")</td>
                                <td class="fw-semibold">@faculty.FacultyName</td>
                                <td>
                                    <div class="d-flex justify-content-center align-items-center gap-2">
                                        <NavLink href="@($"/admin/faculty/edit/{faculty.FacultyId}")" class="btn btn-action-edit d-inline-flex align-items-center">
                                            <i class="bi bi-pencil me-1.5"></i> Edit
                                        </NavLink>
                                        <button class="btn btn-action-delete d-inline-flex align-items-center" @onclick="() => OpenDeleteModal(faculty)">
                                            <i class="bi bi-trash me-1.5"></i> Delete
                                        </button>
                                    </div>
                                </td>
                            </tr>
                            count++;
                        }
                    </tbody>
                </table>
            </div>

            <PaginationComponent CurrentPage="CurrentPage" TotalPages="TotalPages" OnPageChanged="OnPageChanged" />
        }
    </div>

@* ... (မူလ table အပိုင်းတွေပြီးရင်) ... *@

@if (ShowModal)
{
    @* Modal ကို Conditional rendering လုပ်ခြင်း (ShowModal true ဖြစ်မှပဲ DOM မှာပေါ်မယ်) *@
    @if (ShowModal)
    {
        <div class="modal show d-block" style="background: rgba(0,0,0,0.5);">
            <div class="modal-dialog modal-dialog-centered">
                <div class="modal-content tech-card">

                    <div class="modal-header border-0">
                        <h5 class="text-danger">Confirm Delete</h5>
                    </div>

                    <div class="modal-body text-center">
                        Are you sure to delete <strong>@SelectedFaculty?.FacultyName</strong>?

                        @if (!string.IsNullOrEmpty(statusMessage))
                        {
                            <div class="mt-3 p-3 rounded"
                                 style="background: @(IsSuccess ? "rgba(25, 135, 84, 0.15)" : "rgba(220, 53, 69, 0.15)");
                                border: 1px solid @(IsSuccess ? "#198754" : "#dc3545");">

                                <span style="color: @(IsSuccess ? "#75b798" : "#ea868f"); font-size: 0.9rem;">
                                    <i class="bi @(IsSuccess ? "bi-check-circle" : "bi-exclamation-circle") me-2"></i>
                                    @statusMessage
                                </span>

                            </div>
                        }
                    </div>

                    <div class="modal-footer border-0">
                        <button class="btn btn-secondary"
                                @onclick="CloseDeleteModal"
                                disabled="@IsProcessing">
                            Cancel
                        </button>

                        <button class="btn btn-danger"
                                @onclick="DeleteFaculty"
                                disabled="@(IsProcessing || IsSuccess)">
                            @(IsProcessing ? "Deleting..." : "Yes, Delete")
                        </button>
                    </div>

                </div>
            </div>
        </div>
    }
}