@page "/admin/faculty/edit"
@layout AdminLayout

<div class="tab-pane fade show active" id="editFacultyContainer" tabindex="-1">
    <div class="modal-dialog modal-md">
        <div class="modal-content tech-card">

            <div class="modal-header border-0 pb-0">
                <h5 class="modal-title fw-bold">
                    Edit Faculty
                </h5>
            </div>

            <div class="modal-body">
                <div class="row g-3">
                    <div class="col-12 mb-2">
                        <label class="form-label text-light">Faculty Name</label>
                        <input type="text" class="form-control" value="Engineering" placeholder="Enter Faculty Name">
                    </div>
                </div>
            </div>

            <div class="modal-footer border-0 pt-0">
                <NavLink href="/admin/faculties" class="nav-link me-3">
                    <span class="sidebar-text text-muted">Cancel</span>
                </NavLink>

                <button type="button" class="btn btn-primary">
                    Save Changes
                </button>
            </div>

        </div>
    </div>
</div>