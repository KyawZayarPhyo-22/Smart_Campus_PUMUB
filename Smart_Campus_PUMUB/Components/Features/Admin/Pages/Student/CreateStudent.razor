@page "/admin/student/create"
@layout AdminLayout
<SectionContent SectionName="NavTitle">
    Student Create
</SectionContent>
<div class="page-header">
    <div class="d-flex align-items-center gap-2">
        <NavLink href="/admin/student" class="btn btn-sm btn-outline-secondary">
            <i class="bi bi-arrow-left"></i>
        </NavLink>
        <div>
            <h3><i class="bi bi-person-plus me-2 text-info"></i>Add New Student</h3>
            <p>Register a student by linking to an existing user account.</p>
        </div>
    </div>
</div>

<div class="row justify-content-center">
    <div class="col-12 col-md-10 col-lg-8">
        <div class="tech-card">

            <div class="mb-4 pb-3 border-bottom" style="border-color: var(--border) !important;">
                <h5 class="fw-bold mb-0">
                    <i class="bi bi-plus-circle me-2 text-info"></i>Student Details
                </h5>
                <p class="text-muted small mb-0 mt-1">Fields marked with <span class="text-danger">*</span> are required.</p>
            </div>

            <div class="row g-3">

                <!-- User_Id FK Dropdown -->
                <div class="col-12">
                    <label class="form-label">
                        User Account <span class="text-danger">*</span>
                    </label>
                    <select class="form-select">
                        <option value="">-- Select User Account --</option>
                        <option value="1">admin.ops — Kyaw Zayar Phyo (Super Admin)</option>
                        <option value="2">staff.lib — Su Su Myat (Admin)</option>
                        <option value="3">staff.reg — Myo Min Aung (Staff)</option>
                        <option value="4">mg.mg — Mg Mg (Staff)</option>
                        <option value="5">su.su — Su Su (Viewer)</option>
                    </select>
                    <div class="form-text">Link this student record to an existing user account (User_Id FK).</div>
                </div>

                <!-- Current Roll No -->
                <div class="col-12 col-sm-6">
                    <label class="form-label">Roll Number</label>
                    <div class="input-group">
                        <span class="input-group-text">
                            <i class="bi bi-hash"></i>
                        </span>
                        <input type="text"
                               class="form-control"
                               placeholder="e.g., ME-2026-001"
                               style="text-transform: uppercase;" />
                    </div>
                    <div class="form-text">Optional. Max 20 characters.</div>
                </div>

                <!-- Status -->
                <div class="col-12 col-sm-6">
                    <label class="form-label">
                        Status <span class="text-danger">*</span>
                    </label>
                    <select class="form-select">
                        <option value="Active" selected>Active</option>
                        <option value="Suspended">Suspended</option>
                        <option value="Graduated">Graduated</option>
                        <option value="Leave">Leave</option>
                    </select>
                    <div class="form-text">Default: Active.</div>
                </div>

                <!-- Current Class Year -->
                <div class="col-12 col-sm-6">
                    <label class="form-label">
                        Current Class Year <span class="text-danger">*</span>
                    </label>
                    <select class="form-select">
                        <option value="">-- Select Year --</option>
                        <option value="First Year">First Year</option>
                        <option value="Second Year">Second Year</option>
                        <option value="Third Year">Third Year</option>
                        <option value="Fourth Year">Fourth Year</option>
                        <option value="Fifth Year">Fifth Year</option>
                    </select>
                    <div class="form-text">Max 50 characters.</div>
                </div>

                <!-- Current Major -->
                <div class="col-12 col-sm-6">
                    <label class="form-label">
                        Current Major <span class="text-danger">*</span>
                    </label>
                    <select class="form-select">
                        <option value="">-- Select Major --</option>
                        <option value="Mechanical Engineering">Mechanical Engineering</option>
                        <option value="Civil Engineering">Civil Engineering</option>
                        <option value="Electrical Engineering">Electrical Engineering</option>
                        <option value="Information Technology">Information Technology</option>
                        <option value="Mathematics">Mathematics</option>
                        <option value="Physics">Physics</option>
                        <option value="Chemistry">Chemistry</option>
                    </select>
                    <div class="form-text">Max 100 characters.</div>
                </div>

            </div>

            <!-- Info note -->
            <div class="alert mt-3 mb-0 py-2 px-3"
                 style="background:rgba(34,211,238,0.07);border:1px solid rgba(34,211,238,0.2);border-radius:0.5rem;">
                <i class="bi bi-info-circle me-2 text-info"></i>
                <small class="text-muted">
                    <strong class="text-info">Note:</strong> Student record links to a <strong>User</strong> account via <code>User_Id</code>.
                    Make sure the user account exists first.
                </small>
            </div>

            <!-- Actions -->
            <div class="d-flex justify-content-end gap-2 mt-4 pt-3 border-top" style="border-color: var(--border) !important;">
                <NavLink href="/admin/student" class="btn btn-secondary">
                    <i class="bi bi-x-lg me-1"></i>Cancel
                </NavLink>
                <button type="button" class="btn btn-info text-dark fw-semibold">
                    <i class="bi bi-save me-1"></i>Create Student
                </button>
            </div>

        </div>
    </div>
</div>