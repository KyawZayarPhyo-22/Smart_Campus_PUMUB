@page "/admin/student/edit/{id:int}"
@layout AdminLayout
@namespace Smart_Campus_PUMUB.Components.Admin.Pages.Student
@using Smart_Campus_PUMUB.WebApi.Models
@* @using Smart_Campus_PUMUB.Components.Admin.Pages.Student *@
@rendermode InteractiveServer

<div class="page-header">
    <div class="d-flex align-items-center gap-2">
        <NavLink href="/admin/student" class="btn btn-sm btn-outline-secondary"><i class="bi bi-arrow-left"></i>
        </NavLink>
        <h3><i class="bi bi-person-gear me-2 text-warning"></i>Edit Student</h3>
    </div>
</div>

@if (studentModel == null)
{
    <div class="text-center text-white">Loading...</div>
}
else
{
    <div class="row justify-content-center">
        <div class="col-12 col-md-10 col-lg-8">
            <EditForm Model="updateModel" OnValidSubmit="UpdateStudent" FormName="EditStudentForm">
                <DataAnnotationsValidator />
                <div class="tech-card p-4">
                    <div class="mb-4 pb-3 border-bottom">
                        <h5 class="fw-bold mb-0">Student Details for @studentModel.CurrentRollNo</h5>
                    </div>

                    <div class="row g-3">
                        <div class="col-12">
                            <label class="form-label">User Account <span class="text-danger">*</span></label>
                            <InputSelect @bind-Value="updateModel.UserId" class="form-select" disabled>
                                @foreach (var user in UserList)
                                {
                                    <option value="@user.UserId">@user.UserName</option>
                                }
                            </InputSelect>
                        </div>
                        <div class="col-12 col-sm-6">
                            <label class="form-label">Roll Number</label>
                            <InputText @bind-Value="updateModel.CurrentRollNo" class="form-control" />
                        </div>
                        <div class="col-12 col-sm-6">
                            <label class="form-label">Status</label>
                            <InputSelect @bind-Value="updateModel.Status" class="form-select">
                                <option value="Active">Active</option>
                                <option value="Suspended">Suspended</option>
                                <option value="Graduated">Graduated</option>
                            </InputSelect>
                        </div>
                        <div class="col-12 col-sm-6">
                            <label class="form-label">Class Year</label>
                            <InputSelect @bind-Value="updateModel.CurrentClassYear" class="form-select">
                                <option value="First Year">First Year</option>
                                <option value="Second Year">Second Year</option>
                                <option value="Third Year">Third Year</option>
                            </InputSelect>
                        </div>
                        <div class="col-12 col-sm-6">
                            <label class="form-label">Major</label>
                            <InputText @bind-Value="updateModel.CurrentMajor" class="form-control" />
                        </div>
                    </div>

                    @if (!string.IsNullOrEmpty(statusMessage))
                    {
                        <div class="alert alert-warning mt-3">@statusMessage</div>
                    }

                    <div class="d-flex justify-content-end gap-2 mt-4">
                        <NavLink href="/admin/student" class="btn btn-secondary">Cancel</NavLink>
                        <button type="submit" class="btn btn-warning" disabled="@isProcessing">
                            @(isProcessing ? "Saving..." : "Save Changes")
                        </button>
                    </div>
                </div>
            </EditForm>
        </div>
    </div>
}
