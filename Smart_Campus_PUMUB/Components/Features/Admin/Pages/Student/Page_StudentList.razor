@page "/admin/student"
@layout AdminLayout
@rendermode InteractiveServer

<style>
    /* Material Card & Shadows */
    .material-card {
        background-color: #1e1e2d;
        border-radius: 12px;
        box-shadow: 0 4px 15px rgba(0, 0, 0, 0.2);
        border: 1px solid rgba(255, 255, 255, 0.05);
    }

    .material-input {
        background-color: #2b2b40;
        border: 1px solid #323248;
        color: #e4e6ef;
        border-radius: 8px;
        padding: 0.5rem 1rem;
        font-size: 0.9rem;
        transition: all 0.3s ease;
    }

        .material-input:focus {
            background-color: #323248;
            border-color: #696cff;
            box-shadow: 0 0 0 0.2rem rgba(105, 108, 255, 0.25);
            color: #ffffff;
            outline: none;
        }

    .table-container {
        border-radius: 12px;
        overflow: hidden;
    }

    .custom-table {
        margin-bottom: 0;
        background-color: transparent;
    }

        .custom-table thead th {
            background-color: #1a1a27;
            color: #a1a5b7;
            font-size: 0.75rem;
            font-weight: 600;
            text-transform: uppercase;
            letter-spacing: 1px;
            border-bottom: 1px solid #2b2b40;
            padding: 1rem;
        }

        .custom-table tbody tr {
            border-bottom: 1px solid #2b2b40;
            transition: all 0.2s ease;
        }

            .custom-table tbody tr:hover {
                background-color: rgba(255, 255, 255, 0.04);
            }

        .custom-table td {
            padding: 0.85rem 1rem;
            color: #cdcdde;
            vertical-align: middle;
            border: none;
            font-size: 0.9rem;
        }

    .badge-modern {
        padding: 0.4em 0.7em;
        font-weight: 500;
        border-radius: 6px;
        letter-spacing: 0.5px;
    }

    .btn-action {
        border-radius: 6px;
        padding: 0.4rem 1.2rem;
        font-size: 0.9rem;
        font-weight: 500;
        transition: transform 0.2s;
    }

        .btn-action:hover:not(:disabled) {
            transform: translateY(-2px);
        }

        .btn-action:disabled {
            opacity: 0.5;
            cursor: not-allowed;
        }
</style>

<div class="d-flex align-items-center mb-4 mt-2">
    <div class="bg-primary rounded p-2 me-3 shadow-sm">
        <i class="bi bi-people fs-5 text-white"></i>
    </div>
    <h4 class="fw-bolder text-white mb-0" style="letter-spacing: 0.5px;">Student Databank</h4>
</div>

<!-- 🔹 Filter Section -->
<div class="material-card p-3 mb-4">
    <div class="row g-3 align-items-center">
        <!-- Search Input -->
        <div class="col-md-3">
            <div class="position-relative">
                <i class="bi bi-search position-absolute text-muted" style="top: 50%; left: 12px; transform: translateY(-50%);"></i>
                <input type="text" class="form-control material-input w-100" style="padding-left: 2.2rem;" placeholder="Search by name or roll no..." @bind="SearchInput" @onkeyup="HandleKeyUp" />
            </div>
        </div>

        <!-- Level Dropdown -->
        <div class="col-md-3">
            <select class="form-select material-input" @bind="SelectedLevelInput">
                <option value="All">All Academic Levels</option>
                @foreach (var level in StudentList.Select(s => s.AcademicYearLevel).Distinct().Where(l => !string.IsNullOrEmpty(l)))
                {
                    <option value="@level">@level</option>
                }
            </select>
        </div>

        <!-- 💡 From Date & To Date Range Picker -->
        <div class="col-md-4">
            <div class="d-flex align-items-center gap-2">
                <div class="flex-grow-1 position-relative">
                    <span class="position-absolute text-muted" style="font-size: 0.75rem; top: -8px; left: 10px; background: #ffffff; padding: 0 4px; color: #6b7280 !important;">From</span>
                    <input type="date" class="form-control material-input w-100" @bind="FromDateInput" />
                </div>
                <span class="text-muted fw-bold">~</span>
                <div class="flex-grow-1 position-relative">
                    <span class="position-absolute text-muted" style="font-size: 0.75rem; top: -8px; left: 10px; background: #ffffff; padding: 0 4px; color: #6b7280 !important;">To</span>
                    <input type="date" class="form-control material-input w-100" @bind="ToDateInput" />
                </div>
            </div>
        </div>

        <!-- Search and Reset Buttons -->
        <div class="col-md-2 text-end d-flex gap-2 justify-content-end">
            <button class="btn btn-primary w-50 d-flex align-items-center justify-content-center" type="button" @onclick="ApplyFilter" title="Search">
                <i class="bi bi-search"></i>
            </button>
            <button class="btn btn-secondary w-50 d-flex align-items-center justify-content-center" type="button" @onclick="ResetFilter" title="Reset">
                <i class="bi bi-arrow-clockwise"></i>
            </button>
        </div>
    </div>
</div>

<!-- 🔹 Table Section -->
<div class="material-card table-container mb-5">
    <div class="table-responsive">
        <table class="table custom-table align-middle">
            <thead>
                <tr>
                    <th class="text-center">No.</th>
                    <th>Date</th>
                    <th>Roll No</th>
                    <th>Name</th>
                    <th>Major</th>
                    <th>Year</th>
                    <th>Amount</th>
                    <th class="text-center">Pay Status</th>
                    <th class="text-center">Reg Status</th>
                    <th class="text-center">Actions</th>
                </tr>
            </thead>
            <tbody>
                @if (IsLoading)
                {
                    <tr>
                        <td colspan="10" class="text-center py-5">
                            <div class="spinner-border text-primary" role="status" style="width: 1.5rem; height: 1.5rem;">
                                <span class="visually-hidden">Loading...</span>
                            </div>
                            <div class="text-muted mt-2 fs-6">Fetching data...</div>
                        </td>
                    </tr>
                }
                else
                {
                    int count = 1;
                    @foreach (var s in FilteredStudents)
                    {
                        <tr>
                            <td class="text-center text-muted fw-bold">@count</td>
                            <td><i class="bi bi-calendar2-event me-2 text-muted"></i>@s.CreatedDatetime.ToString("dd-MM-yyyy")</td>
                            <td class="fw-bold text-info">@s.RollNo</td>
                            <td class="fw-bold text-white">@s.StudentNameMm</td>
                            <td>@s.Major</td>
                            <td><span class="badge bg-primary bg-opacity-25 text-primary border border-primary badge-modern">@s.AcademicYearLevel</span></td>

                            <td class="text-success fw-bold">
                                @(s.RegistrationPayments.FirstOrDefault()?.AmountPaid.ToString("N0") ?? "-") Ks
                            </td>

                            <td class="text-center">
                                @if (s.RegistrationPayments.Any())
                                {
                                    <span class="badge badge-modern @GetStatusClass(s.RegistrationPayments.First().Status)">
                                        @s.RegistrationPayments.First().Status
                                    </span>
                                }
                                else
                                {
                                    <span class="text-muted">-</span>
                                }
                            </td>

                            <td class="text-center">
                                <span class="badge badge-modern @GetStatusClass(s.Status)">@s.Status</span>
                            </td>

                            <td class="text-center">
                                <button class="btn btn-outline-info btn-action" style="padding: 0.25rem 0.6rem;" @onclick="() => OpenViewModal(s.RegistrationId)">
                                    <i class="bi bi-eye me-1"></i> View
                                </button>
                            </td>
                        </tr>
                        count++;
                    }
                }
            </tbody>
        </table>
    </div>
    
    <!-- 🔹 Pagination Component -->
    <PaginationComponent CurrentPage="CurrentPage" TotalPages="TotalPages" OnPageChanged="OnPageChanged" />
</div>

<!-- 🔹 View Modal Section -->
@if (ShowDetailModal && SelectedDetail != null)
{
    var payment = SelectedDetail.RegistrationPayments?.FirstOrDefault();

    <div class="modal show d-block" tabindex="-1" style="background-color: rgba(0,0,0,0.5); backdrop-filter: blur(4px); z-index: 1050; overflow-y: auto;">
        <div class="modal-dialog modal-xl modal-dialog-centered" style="z-index: 1051; max-width: 1100px;">
            <div class="modal-content border-0 shadow-lg" style="border-radius: 16px; background-color: #ffffff; color: #1f2937;">

                <!-- Modal Header -->
                <div class="modal-header border-bottom px-4 py-3 d-flex align-items-center justify-content-between" style="background-color: #f8fafc; border-top-left-radius: 16px; border-top-right-radius: 16px;">
                    <h5 class="modal-title fw-bold text-dark d-flex align-items-center mb-0" style="font-size: 1.25rem;">
                        <i class="bi bi-file-earmark-person-fill text-success me-2 fs-4"></i>
                        ကျောင်းသား/သူ စာရင်းသွင်းမှုဖောင် အချက်အလက်များ (Registration Details)
                    </h5>
                    <button type="button" class="btn-close" style="filter: none; opacity: 0.8;" @onclick="CloseViewModal"></button>
                </div>

                <!-- Modal Body (Styled Form Layout) -->
                <div class="modal-body p-4" style="background-color: #f1f5f9;">
                    <!-- Stepper Mockup (Shows completed state) -->
                    <div class="d-flex justify-content-around align-items-center mb-4 bg-white p-3 rounded shadow-sm">
                        <div class="d-flex align-items-center gap-2">
                            <span class="rounded-circle bg-success text-white d-flex align-items-center justify-content-center fw-bold" style="width: 28px; height: 28px; font-size: 0.85rem;">1</span>
                            <span class="fw-semibold text-secondary" style="font-size: 0.9rem;">Personal Info</span>
                        </div>
                        <div class="text-muted" style="font-size: 1.2rem;">➔</div>
                        <div class="d-flex align-items-center gap-2">
                            <span class="rounded-circle bg-success text-white d-flex align-items-center justify-content-center fw-bold" style="width: 28px; height: 28px; font-size: 0.85rem;">2</span>
                            <span class="fw-semibold text-secondary" style="font-size: 0.9rem;">Academic Info</span>
                        </div>
                        <div class="text-muted" style="font-size: 1.2rem;">➔</div>
                        <div class="d-flex align-items-center gap-2">
                            <span class="rounded-circle bg-success text-white d-flex align-items-center justify-content-center fw-bold" style="width: 28px; height: 28px; font-size: 0.85rem;">3</span>
                            <span class="fw-semibold text-secondary" style="font-size: 0.9rem;">Family & Guardian Info</span>
                        </div>
                        <div class="text-muted" style="font-size: 1.2rem;">➔</div>
                        <div class="d-flex align-items-center gap-2">
                            <span class="rounded-circle bg-success text-white d-flex align-items-center justify-content-center fw-bold" style="width: 28px; height: 28px; font-size: 0.85rem;">4</span>
                            <span class="fw-semibold text-secondary" style="font-size: 0.9rem;">Payment Info</span>
                        </div>
                    </div>

                    <div class="row g-4">
                        <!-- Left Side: Registration Form Fields -->
                        <div class="col-lg-8">
                            <!-- SECTION 1: Personal Info -->
                            <div class="bg-white p-4 mb-4 border rounded shadow-sm">
                                <h6 class="fw-bold mb-3 pb-2 border-bottom text-success d-flex align-items-center">
                                    <i class="bi bi-person-fill me-2 fs-5"></i> ၁။ ကိုယ်ရေးအချက်အလက် (Personal Info)
                                </h6>
                                
                                <div class="row g-3">
                                    <!-- Passport Photo Alignment -->
                                    <div class="col-12 d-flex justify-content-center mb-3">
                                        <div class="border rounded p-1 bg-light text-center" style="width: 120px; height: 150px; overflow: hidden; display: flex; align-items: center; justify-content: center;">
                                            @if (!string.IsNullOrEmpty(SelectedDetail.StudentImage))
                                            {
                                                <img src="@($"https://localhost:7297{SelectedDetail.StudentImage}")" alt="Student Profile" class="img-fluid" style="height: 100%; width: 100%; object-fit: cover;" />
                                            }
                                            else
                                            {
                                                <div class="text-muted">
                                                    <i class="bi bi-person-bounding-box fs-1 d-block mb-1"></i>
                                                    <span style="font-size: 0.75rem;">No Photo</span>
                                                </div>
                                            }
                                        </div>
                                    </div>

                                    <!-- Myanmar Name -->
                                    <div class="col-md-6">
                                        <label class="form-label fw-bold text-secondary mb-1" style="font-size: 0.8rem;">အမည် (မြန်မာစာဖြင့်)</label>
                                        <input type="text" class="form-control bg-light text-dark fw-medium" style="border: 1px solid #cbd5e1; border-radius: 8px; padding: 10px 12px;" readonly value="@SelectedDetail.StudentNameMm" />
                                    </div>

                                    <!-- English Name -->
                                    <div class="col-md-6">
                                        <label class="form-label fw-bold text-secondary mb-1" style="font-size: 0.8rem;">အမည် (အင်္ဂလိပ်စာဖြင့်)</label>
                                        <input type="text" class="form-control bg-light text-dark fw-medium" style="border: 1px solid #cbd5e1; border-radius: 8px; padding: 10px 12px;" readonly value="@SelectedDetail.StudentNameEn" />
                                    </div>

                                    <!-- NRC Number -->
                                    <div class="col-md-6">
                                        <label class="form-label fw-bold text-secondary mb-1" style="font-size: 0.8rem;">မှတ်ပုံတင်အမှတ် (NRC)</label>
                                        <input type="text" class="form-control bg-light text-dark fw-medium" style="border: 1px solid #cbd5e1; border-radius: 8px; padding: 10px 12px;" readonly value="@SelectedDetail.StudentNrcNo" />
                                    </div>

                                    <!-- Roll No -->
                                    <div class="col-md-6">
                                        <label class="form-label fw-bold text-secondary mb-1" style="font-size: 0.8rem;">ခုံအမှတ် / Roll No</label>
                                        <input type="text" class="form-control bg-light text-success fw-bold" style="border: 1px solid #cbd5e1; border-radius: 8px; padding: 10px 12px;" readonly value="@SelectedDetail.RollNo" />
                                    </div>
                                </div>
                            </div>

                            <!-- SECTION 2: Academic Info -->
                            <div class="bg-white p-4 mb-4 border rounded shadow-sm">
                                <h6 class="fw-bold mb-3 pb-2 border-bottom text-success d-flex align-items-center">
                                    <i class="bi bi-mortarboard-fill me-2 fs-5"></i> ၂။ ပညာရေးအချက်အလက် (Academic Info)
                                </h6>

                                <div class="row g-3">
                                    <!-- Major -->
                                    <div class="col-md-6">
                                        <label class="form-label fw-bold text-secondary mb-1" style="font-size: 0.8rem;">အထူးပြုဘာသာ (Major)</label>
                                        <input type="text" class="form-control bg-light text-dark fw-medium" style="border: 1px solid #cbd5e1; border-radius: 8px; padding: 10px 12px;" readonly value="@SelectedDetail.Major" />
                                    </div>

                                    <!-- Academic Year Level -->
                                    <div class="col-md-6">
                                        <label class="form-label fw-bold text-secondary mb-1" style="font-size: 0.8rem;">သင်တန်းနှစ် (Academic Year Level)</label>
                                        <input type="text" class="form-control bg-light text-dark fw-medium" style="border: 1px solid #cbd5e1; border-radius: 8px; padding: 10px 12px;" readonly value="@SelectedDetail.AcademicYearLevel" />
                                    </div>

                                    <!-- Permanent Address -->
                                    <div class="col-12">
                                        <label class="form-label fw-bold text-secondary mb-1" style="font-size: 0.8rem;">အမြဲတမ်းနေရပ်လိပ်စာ (Permanent Address)</label>
                                        <textarea class="form-control bg-light text-dark fw-medium" style="border: 1px solid #cbd5e1; border-radius: 8px; padding: 10px 12px;" readonly rows="2">@SelectedDetail.PermanentAddressMm</textarea>
                                    </div>
                                </div>
                            </div>

                            <!-- SECTION 3: Family & Guardian Info -->
                            <div class="bg-white p-4 border rounded shadow-sm">
                                <h6 class="fw-bold mb-3 pb-2 border-bottom text-success d-flex align-items-center">
                                    <i class="bi bi-people-fill me-2 fs-5"></i> ၃။ မိဘ/အုပ်ထိန်းသူအချက်အလက် (Family & Guardian Info)
                                </h6>

                                <div class="row g-3">
                                    <!-- Father Name -->
                                    <div class="col-md-6">
                                        <label class="form-label fw-bold text-secondary mb-1" style="font-size: 0.8rem;">အဘအမည် (Father's Name)</label>
                                        <input type="text" class="form-control bg-light text-dark fw-medium" style="border: 1px solid #cbd5e1; border-radius: 8px; padding: 10px 12px;" readonly value="@SelectedDetail.FatherName" />
                                    </div>

                                    <!-- Mother Name -->
                                    <div class="col-md-6">
                                        <label class="form-label fw-bold text-secondary mb-1" style="font-size: 0.8rem;">အမိအမည် (Mother's Name)</label>
                                        <input type="text" class="form-control bg-light text-dark fw-medium" style="border: 1px solid #cbd5e1; border-radius: 8px; padding: 10px 12px;" readonly value="@SelectedDetail.MotherName" />
                                    </div>

                                    <!-- Guardian Name -->
                                    <div class="col-md-6">
                                        <label class="form-label fw-bold text-secondary mb-1" style="font-size: 0.8rem;">အုပ်ထိန်းသူအမည် (Guardian Name)</label>
                                        <input type="text" class="form-control bg-light text-dark fw-medium" style="border: 1px solid #cbd5e1; border-radius: 8px; padding: 10px 12px;" readonly value="@SelectedDetail.AppGuardianName" />
                                    </div>

                                    <!-- Guardian NRC -->
                                    <div class="col-md-6">
                                        <label class="form-label fw-bold text-secondary mb-1" style="font-size: 0.8rem;">အုပ်ထိန်းသူမှတ်ပုံတင် (Guardian NRC)</label>
                                        <input type="text" class="form-control bg-light text-dark fw-medium" style="border: 1px solid #cbd5e1; border-radius: 8px; padding: 10px 12px;" readonly value="@(string.IsNullOrEmpty(SelectedDetail.AppGuardianNrc) ? "-" : SelectedDetail.AppGuardianNrc)" />
                                    </div>

                                    <!-- Guardian Phone -->
                                    <div class="col-md-6">
                                        <label class="form-label fw-bold text-secondary mb-1" style="font-size: 0.8rem;">အုပ်ထိန်းသူဖုန်း (Guardian Phone)</label>
                                        <input type="text" class="form-control bg-light text-dark fw-medium" style="border: 1px solid #cbd5e1; border-radius: 8px; padding: 10px 12px;" readonly value="@SelectedDetail.AppGuardianPhone" />
                                    </div>

                                    <!-- Guardian Address -->
                                    <div class="col-md-6">
                                        <label class="form-label fw-bold text-secondary mb-1" style="font-size: 0.8rem;">အုပ်ထိန်းသူလိပ်စာ (Guardian Address)</label>
                                        <input type="text" class="form-control bg-light text-dark fw-medium" style="border: 1px solid #cbd5e1; border-radius: 8px; padding: 10px 12px;" readonly value="@SelectedDetail.AppGuardianAddress" />
                                    </div>

                                    <!-- Student Signature Image -->
                                    @if (!string.IsNullOrEmpty(SelectedDetail.SignatureImage))
                                    {
                                        <div class="col-12 mt-3">
                                            <label class="form-label fw-bold text-secondary mb-1" style="font-size: 0.8rem;">ကျောင်းသား/သူ လက်မှတ် (Signature)</label>
                                            <div class="text-start p-2 bg-light rounded border" style="max-width: 250px;">
                                                <img src="@($"https://localhost:7297{SelectedDetail.SignatureImage}")" alt="Signature" class="bg-white p-1 rounded" style="max-height: 80px; object-fit: contain; width: 100%;" />
                                            </div>
                                        </div>
                                    }
                                </div>
                            </div>
                        </div>

                        <!-- Right Side: Payment Details -->
                        <div class="col-lg-4">
                            <div class="bg-white p-4 border rounded shadow-sm h-100">
                                <h6 class="fw-bold mb-3 pb-2 border-bottom text-success d-flex align-items-center">
                                    <i class="bi bi-wallet2 me-2 fs-5"></i> ၄။ ငွေပေးချေမှုအခြေအနေ (Payment Info)
                                </h6>

                                @if (payment != null)
                                {
                                    <div class="mb-4 bg-light p-3 rounded border">
                                        <div class="mb-3">
                                            <small class="text-muted d-block mb-1">ပေးချေငွေပမာဏ (Amount Paid)</small>
                                            <strong class="text-success fs-5">@payment.AmountPaid.ToString("N0") MMK</strong>
                                        </div>
                                        <div>
                                            <small class="text-muted d-block mb-1">ငွေပေးချေသည့်စနစ် (Payment Method)</small>
                                            <strong class="text-dark">@payment.PaymentMethod</strong>
                                        </div>
                                    </div>

                                    <div class="text-center p-3 rounded bg-light" style="border: 1px dashed #cbd5e1;">
                                        <p class="text-muted small mb-2 text-uppercase fw-bold"><i class="bi bi-image me-1"></i> ငွေလွှဲပြေစာ (Receipt Slip)</p>
                                        @if (!string.IsNullOrEmpty(payment.ReceiptImage))
                                        {
                                            <a href="@($"https://localhost:7297{payment.ReceiptImage}")" target="_blank">
                                                <img src="@($"https://localhost:7297{payment.ReceiptImage}")" alt="Receipt" class="img-fluid rounded shadow-sm border bg-white" style="max-height: 300px; object-fit: contain;" />
                                            </a>
                                            <small class="text-muted d-block mt-2">Click to view full image</small>
                                        }
                                        else
                                        {
                                            <div class="text-danger p-4"><i class="bi bi-exclamation-circle me-2"></i> No Receipt Found</div>
                                        }
                                    </div>
                                }
                                else
                                {
                                    <div class="alert alert-warning border-0 d-flex align-items-center" role="alert">
                                        <i class="bi bi-exclamation-triangle-fill me-2 fs-5 text-warning"></i>
                                        <div class="text-dark" style="font-size: 0.85rem;">No payment record found for this student.</div>
                                    </div>
                                }
                            </div>
                        </div>
                    </div>
                </div>

                <!-- Modal Footer -->
                <div class="modal-footer border-top px-4 py-3 bg-light" style="border-bottom-left-radius: 16px; border-bottom-right-radius: 16px;">
                    <button type="button" class="btn btn-secondary me-auto" @onclick="CloseViewModal">ပိတ်ရန် (Close)</button>
                    
                    <button type="button" class="btn btn-danger btn-action me-2"
                            disabled="@(SelectedDetail.Status != "Pending")"
                            @onclick="@(() => PromptConfirm("Rejected"))">
                        <i class="bi bi-x-circle me-1"></i> ငြင်းပယ်ရန် (Reject)
                    </button>
                    <button type="button" class="btn btn-success btn-action px-4"
                            disabled="@(SelectedDetail.Status != "Pending")"
                            @onclick="@(() => PromptConfirm("Approved"))">
                        <i class="bi bi-check-circle me-1"></i> အတည်ပြုရန် (Approve)
                    </button>
                </div>
            </div>
        </div>
    </div>
}

<!-- 🔹 Confirmation Custom Modal Section -->
@if (ShowConfirmModal)
{
    <div class="modal show d-block" tabindex="-1" style="background-color: rgba(0,0,0,0.8); backdrop-filter: blur(8px); z-index: 1060;">
        <div class="modal-dialog modal-dialog-centered modal-sm" style="max-width: 380px;">
            <div class="modal-content material-card border-0 text-center p-4 position-relative">

                <button type="button" class="btn-close btn-close-white position-absolute top-0 end-0 m-3 opacity-75" style="font-size: 0.8rem;" @onclick="CancelConfirm"></button>

                <div class="mb-3 mt-2">
                    @if (ConfirmAction == "Approved")
                    {
                        <div class="d-inline-flex justify-content-center align-items-center rounded-circle bg-success bg-opacity-10" style="width: 80px; height: 80px;">
                            <i class="bi bi-check-circle-fill text-success" style="font-size: 3rem;"></i>
                        </div>
                    }
                    else
                    {
                        <div class="d-inline-flex justify-content-center align-items-center rounded-circle bg-danger bg-opacity-10" style="width: 80px; height: 80px;">
                            <i class="bi bi-exclamation-triangle-fill text-danger" style="font-size: 3rem;"></i>
                        </div>
                    }
                </div>

                <h5 class="fw-bold text-white mb-2">Are you sure?</h5>
                <p class="text-muted mb-4" style="font-size: 0.95rem;">@ConfirmMessage</p>

                <div class="d-flex justify-content-center gap-2">
                    <button type="button" class="btn btn-secondary btn-action w-50" @onclick="CancelConfirm">
                        Cancel
                    </button>
                    <button type="button" class="btn @(ConfirmAction == "Approved" ? "btn-success" : "btn-danger") btn-action w-50 text-white" @onclick="ExecuteConfirm">
                        Yes, @(ConfirmAction == "Approved" ? "Approve!" : "Reject!")
                    </button>
                </div>
            </div>
        </div>
    </div>
}