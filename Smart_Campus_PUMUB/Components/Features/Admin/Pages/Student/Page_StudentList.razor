@page "/admin/student"
@layout AdminLayout
@namespace Smart_Campus_PUMUB.Components.Features.Admin.Pages.Student
@using Smart_Campus_PUMUB.WebApi.Models
@rendermode InteractiveServer

<div class="mb-4">
    <h3 class="fw-bold text-white"><i class="bi bi-people me-2"></i>Student Databank</h3>
</div>

<div class="tech-card p-4">
    <div class="row g-3 mb-4">
        <div class="col-md-4">
            <div class="input-group">
                <span class="input-group-text search-icon-bg border-end-0"><i class="bi bi-search"></i></span>
                <input type="text" class="form-control border-start-0" placeholder="Search by Roll No..." 
                       @bind="SearchTerm" @bind:event="oninput" />
            </div>
        </div>
        <div class="col-md-8 text-end">
            <NavLink href="/admin/student/create" class="btn btn-primary">
                <i class="bi bi-plus-lg"></i> Add New Student
            </NavLink>
        </div>
    </div>

    @if (IsLoading) { <div class="text-center text-white"><div class="spinner-border text-info"></div></div> }
    else
    {
        <div class="table-responsive">
            <table class="table table-tech align-middle text-white">
                <thead>
                    <tr>
                        <th>No.</th>
                        <th>Roll No</th>
                        <th>User Name</th>
                        <th>Major</th>
                        <th>Year</th>
                        <th>Status</th>
                        <th class="text-center">Actions</th>
                    </tr>
                </thead>
                <tbody>
                    @{ int count = 1; }
                    @foreach (var s in FilteredStudents)
                    {
                        <tr>
                            <td>@count</td>
                            <td><code class="text-info">@s.CurrentRollNo</code></td>
                            <td>@s.UserName</td>
                            <td>@s.CurrentMajor</td>
                            <td>@s.CurrentClassYear</td>
                            <td>
                                <span class="badge @(s.Status == "Active" ? "bg-success" : "bg-warning")">@s.Status</span>
                            </td>
                            <td class="text-center">
                                <NavLink href="@($"/admin/student/edit/{s.StudentId}")" class="btn btn-sm btn-outline-info me-2">Edit</NavLink>
                                <button class="btn btn-sm btn-outline-danger" @onclick="() => OpenDeleteModal(s)">Delete</button>
                            </td>
                        </tr>
                        count++;
                    }
                </tbody>
            </table>
        </div>
    }
</div>

@* Modal *@
@if (ShowModal)
{
    <div class="modal show d-block" style="background: rgba(0,0,0,0.5);">
        <div class="modal-dialog modal-dialog-centered">
            <div class="modal-content tech-card">
                <div class="modal-header border-0"><h5 class="text-danger">Confirm Delete</h5></div>
                <div class="modal-body text-center">Are you sure to delete student <strong>@SelectedStudent?.CurrentRollNo</strong>?</div>
                <div class="modal-footer border-0">
                    <button class="btn btn-secondary" @onclick="CloseDeleteModal">Cancel</button>
                    <button class="btn btn-danger" @onclick="DeleteStudent" disabled="@IsProcessing">Yes, Delete</button>
                </div>
            </div>
        </div>
    </div>
}
