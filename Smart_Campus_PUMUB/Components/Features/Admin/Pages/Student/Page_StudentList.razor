@page "/admin/student"
@layout AdminLayout
@rendermode InteractiveServer

<style>
    /* Material Card & Shadows */
    .material-card {
        background-color: #1e1e2d;
        border-radius: 12px;
        box-shadow: 0 4px 15px rgba(0, 0, 0, 0.2);
        border: 1px solid rgba(255, 255, 255, 0.05);
    }

    .material-input {
        background-color: #2b2b40;
        border: 1px solid #323248;
        color: #e4e6ef;
        border-radius: 8px;
        padding: 0.5rem 1rem;
        font-size: 0.9rem;
        transition: all 0.3s ease;
    }

        .material-input:focus {
            background-color: #323248;
            border-color: #696cff;
            box-shadow: 0 0 0 0.2rem rgba(105, 108, 255, 0.25);
            color: #ffffff;
            outline: none;
        }

    .table-container {
        border-radius: 12px;
        overflow: hidden;
    }

    .custom-table {
        margin-bottom: 0;
        background-color: transparent;
    }

        .custom-table thead th {
            background-color: #1a1a27;
            color: #a1a5b7;
            font-size: 0.75rem;
            font-weight: 600;
            text-transform: uppercase;
            letter-spacing: 1px;
            border-bottom: 1px solid #2b2b40;
            padding: 1rem;
        }

        .custom-table tbody tr {
            border-bottom: 1px solid #2b2b40;
            transition: all 0.2s ease;
        }

            .custom-table tbody tr:hover {
                background-color: rgba(255, 255, 255, 0.04);
            }

        .custom-table td {
            padding: 0.85rem 1rem;
            color: #cdcdde;
            vertical-align: middle;
            border: none;
            font-size: 0.9rem;
        }

    .badge-modern {
        padding: 0.4em 0.7em;
        font-weight: 500;
        border-radius: 6px;
        letter-spacing: 0.5px;
    }

    .btn-action {
        border-radius: 6px;
        padding: 0.4rem 1.2rem;
        font-size: 0.9rem;
        font-weight: 500;
        transition: transform 0.2s;
    }

        .btn-action:hover:not(:disabled) {
            transform: translateY(-2px);
        }

        .btn-action:disabled {
            opacity: 0.5;
            cursor: not-allowed;
        }

    .view-input-group {
        display: flex;
        flex-direction: column;
        gap: 6px;
    }
    .view-input-label {
        font-size: 0.8rem;
        font-weight: 700;
        color: #a1a5b7;
        margin-bottom: 2px;
    }
    .view-modern-input {
        width: 100%;
        padding: 10px 14px;
        border: 1px solid #323248;
        border-radius: 8px;
        font-size: 0.9rem;
        color: #ffffff;
        background: #2b2b40;
    }
</style>

<div class="d-flex align-items-center mb-4 mt-2">
    <div class="bg-primary rounded p-2 me-3 shadow-sm">
        <i class="bi bi-people fs-5 text-white"></i>
    </div>
    <h4 class="fw-bolder text-white mb-0" style="letter-spacing: 0.5px;">Student Databank</h4>
</div>

<!-- 🔹 Filter Section -->
<div class="material-card p-3 mb-4">
    <div class="row g-3 align-items-center">
        <!-- Search Input -->
        <div class="col-md-4">
            <div class="position-relative">
                <i class="bi bi-search position-absolute text-muted" style="top: 50%; left: 12px; transform: translateY(-50%);"></i>
                <input type="text" class="form-control material-input w-100" style="padding-left: 2.2rem;" placeholder="Search by name or roll no..." @bind="SearchTerm" @bind:event="oninput" />
            </div>
        </div>

        <!-- Level Dropdown -->
        <div class="col-md-3">
            <select class="form-select material-input" @bind="SelectedLevel">
                <option value="All">All Academic Levels</option>
                @foreach (var level in StudentList.Select(s => s.AcademicYearLevel).Distinct().Where(l => !string.IsNullOrEmpty(l)))
                {
                    <option value="@level">@level</option>
                }
            </select>
        </div>

        <!-- 💡 From Date & To Date Range Picker -->
        <div class="col-md-5">
            <div class="d-flex align-items-center gap-2">
                <div class="flex-grow-1 position-relative">
                    <span class="position-absolute text-muted" style="font-size: 0.75rem; top: -8px; left: 10px; background: #1e1e2d; padding: 0 4px;">From</span>
                    <input type="date" class="form-control material-input w-100" @bind="FromDate" />
                </div>
                <span class="text-muted fw-bold">~</span>
                <div class="flex-grow-1 position-relative">
                    <span class="position-absolute text-muted" style="font-size: 0.75rem; top: -8px; left: 10px; background: #1e1e2d; padding: 0 4px;">To</span>
                    <input type="date" class="form-control material-input w-100" @bind="ToDate" />
                </div>
                <!-- 💡 Clear Dates Button (နှိပ်လိုက်လျှင် ToDate ကို ဒီနေ့ရက်စွဲသို့ ပြန်ပြောင်းပေးမည်) -->
                @if (FromDate != null || ToDate?.Date != DateTime.Today.Date)
                {
                    <button class="btn btn-sm btn-outline-danger border-0" title="Reset Filters" @onclick="() => { FromDate = null; ToDate = DateTime.Today; }">
                        <i class="bi bi-x-lg"></i>
                    </button>
                }
            </div>
        </div>
    </div>
</div>

<!-- 🔹 Table Section -->
<div class="material-card table-container mb-5">
    <div class="table-responsive">
        <table class="table custom-table align-middle">
            <thead>
                <tr>
                    <th class="text-center">No.</th>
                    <th>Date</th>
                    <th>Roll No</th>
                    <th>Name</th>
                    <th>Major</th>
                    <th>Year</th>
                    <th>Amount</th>
                    <th class="text-center">Pay Status</th>
                    <th class="text-center">Reg Status</th>
                    <th class="text-center">Actions</th>
                </tr>
            </thead>
            <tbody>
                @if (IsLoading)
                {
                    <tr>
                        <td colspan="10" class="text-center py-5">
                            <div class="spinner-border text-primary" role="status" style="width: 1.5rem; height: 1.5rem;">
                                <span class="visually-hidden">Loading...</span>
                            </div>
                            <div class="text-muted mt-2 fs-6">Fetching data...</div>
                        </td>
                    </tr>
                }
                else
                {
                    int count = 1;
                    @foreach (var s in FilteredStudents)
                    {
                        <tr>
                            <td class="text-center text-muted fw-bold">@count</td>
                            <td><i class="bi bi-calendar2-event me-2 text-muted"></i>@s.CreatedDatetime.ToString("dd-MM-yyyy")</td>
                            <td class="fw-bold text-info">@s.RollNo</td>
                            <td class="fw-bold text-white">@s.StudentNameMm</td>
                            <td>@s.Major</td>
                            <td><span class="badge bg-primary bg-opacity-25 text-primary border border-primary badge-modern">@s.AcademicYearLevel</span></td>

                            <td class="text-success fw-bold">
                                @(s.RegistrationPayments.FirstOrDefault()?.AmountPaid.ToString("N0") ?? "-") Ks
                            </td>

                            <td class="text-center">
                                @if (s.RegistrationPayments.Any())
                                {
                                    <span class="badge badge-modern @GetStatusClass(s.RegistrationPayments.First().Status)">
                                        @s.RegistrationPayments.First().Status
                                    </span>
                                }
                                else
                                {
                                    <span class="text-muted">-</span>
                                }
                            </td>

                            <td class="text-center">
                                <span class="badge badge-modern @GetStatusClass(s.Status)">@s.Status</span>
                            </td>

                            <td class="text-center">
                                <button class="btn btn-outline-info btn-action" style="padding: 0.25rem 0.6rem;" @onclick="() => OpenViewModal(s.RegistrationId)">
                                    <i class="bi bi-eye me-1"></i> View
                                </button>
                            </td>
                        </tr>
                        count++;
                    }
                }
            </tbody>
        </table>
    </div>
</div>

<!-- 🔹 View Modal Section -->
@if (ShowDetailModal && SelectedDetail != null)
{
    var payment = SelectedDetail.RegistrationPayments?.FirstOrDefault();

    <div class="modal show d-block" tabindex="-1" style="background-color: rgba(0,0,0,0.65); backdrop-filter: blur(5px); z-index: 1050; overflow-y: auto;">
        <div class="modal-dialog modal-xl modal-dialog-centered" style="z-index: 1051;">
            <div class="modal-content material-card border-0">

                <div class="modal-header border-bottom border-dark px-4 py-3">
                    <h5 class="modal-title fw-bold text-white d-flex align-items-center">
                        <div class="bg-primary rounded p-2 me-3 shadow-sm">
                            <i class="bi bi-file-earmark-person fs-5 text-white"></i>
                        </div>
                        Student Registration & Payment Profile
                    </h5>
                    <button type="button" class="btn-close btn-close-white opacity-75" @onclick="CloseViewModal"></button>
                </div>

                <div class="modal-body p-4">
                    <!-- Tab Controls -->
                    <ul class="nav nav-pills nav-justified mb-4" style="background: #2b2b40; padding: 6px; border-radius: 12px; gap: 8px;">
                        <li class="nav-item">
                            <button type="button" class="nav-link @(ActiveTab == "personal" ? "active bg-primary text-white" : "text-muted") fw-bold py-2 border-0 bg-transparent" @onclick='() => ActiveTab = "personal"'>
                                <i class="bi bi-person-circle me-2"></i>Personal Info
                            </button>
                        </li>
                        <li class="nav-item">
                            <button type="button" class="nav-link @(ActiveTab == "academic" ? "active bg-primary text-white" : "text-muted") fw-bold py-2 border-0 bg-transparent" @onclick='() => ActiveTab = "academic"'>
                                <i class="bi bi-book-half me-2"></i>Academic Info
                            </button>
                        </li>
                        <li class="nav-item">
                            <button type="button" class="nav-link @(ActiveTab == "family" ? "active bg-primary text-white" : "text-muted") fw-bold py-2 border-0 bg-transparent" @onclick='() => ActiveTab = "family"'>
                                <i class="bi bi-people-fill me-2"></i>Family & Guardian
                            </button>
                        </li>
                        <li class="nav-item">
                            <button type="button" class="nav-link @(ActiveTab == "payment" ? "active bg-primary text-white" : "text-muted") fw-bold py-2 border-0 bg-transparent" @onclick='() => ActiveTab = "payment"'>
                                <i class="bi bi-credit-card-2-back-fill me-2"></i>Payment Details
                            </button>
                        </li>
                    </ul>

                    <!-- Tab Contents -->
                    @if (ActiveTab == "personal")
                    {
                        <div class="row g-3 animate-fade">
                            <div class="col-md-6 view-input-group">
                                <span class="view-input-label">အမည် (မြန်မာစာဖြင့်)</span>
                                <input type="text" class="view-modern-input" readonly value="@SelectedDetail.StudentNameMm" />
                            </div>
                            <div class="col-md-6 view-input-group">
                                <span class="view-input-label">အမည် (အင်္ဂလိပ်စာဖြင့်)</span>
                                <input type="text" class="view-modern-input" readonly value="@SelectedDetail.StudentNameEn" />
                            </div>
                            <div class="col-md-6 view-input-group">
                                <span class="view-input-label">မှတ်ပုံတင် (NRC)</span>
                                <input type="text" class="view-modern-input" readonly value="@SelectedDetail.StudentNrcNo" />
                            </div>
                            <div class="col-md-6 view-input-group">
                                <span class="view-input-label">မွေးသက္ကရာဇ်</span>
                                <input type="text" class="view-modern-input" readonly value="@SelectedDetail.Dob?.ToString("dd-MM-yyyy")" />
                            </div>
                            <div class="col-md-4 view-input-group">
                                <span class="view-input-label">ကျား / မ</span>
                                <input type="text" class="view-modern-input" readonly value="@SelectedDetail.GenderRelation" />
                            </div>
                            <div class="col-md-4 view-input-group">
                                <span class="view-input-label">သွေးအုပ်စု</span>
                                <input type="text" class="view-modern-input" readonly value="@SelectedDetail.BloodType" />
                            </div>
                            <div class="col-md-4 view-input-group">
                                <span class="view-input-label">ကိုးကွယ်သည့်ဘာသာ / လူမျိုး</span>
                                <input type="text" class="view-modern-input" readonly value="@SelectedDetail.Religion / @SelectedDetail.Ethnicity" />
                            </div>
                            <div class="col-md-6 view-input-group">
                                <span class="view-input-label">နိုင်ငံသား အမျိုးအစား</span>
                                <input type="text" class="view-modern-input" readonly value="@SelectedDetail.NationalityStatus" />
                            </div>
                            <div class="col-md-6 view-input-group">
                                <span class="view-input-label">မွေးဖွားရာဇာတိ (မြို့နယ် / တိုင်း)</span>
                                <input type="text" class="view-modern-input" readonly value="@SelectedDetail.Pob (@SelectedDetail.BirthPlaceRegion)" />
                            </div>
                            <div class="col-md-6 view-input-group">
                                <span class="view-input-label">ဖုန်းနံပါတ်</span>
                                <input type="text" class="view-modern-input" readonly value="@SelectedDetail.AppStudentPhone" />
                            </div>
                            <div class="col-md-6 view-input-group">
                                <span class="view-input-label">Email Address</span>
                                <input type="text" class="view-modern-input" readonly value="@SelectedDetail.Email" />
                            </div>
                            <div class="col-md-6 view-input-group">
                                <span class="view-input-label">ကိုဗစ်ကာကွယ်ဆေးထိုးပြီးသည့်ရက်</span>
                                <input type="text" class="view-modern-input" readonly value="@SelectedDetail.CovidVaccineStatus" />
                            </div>
                        </div>
                    }
                    else if (ActiveTab == "academic")
                    {
                        <div class="row g-3 animate-fade">
                            <div class="col-md-6 view-input-group">
                                <span class="view-input-label">ပညာသင်နှစ် (Academic Year Range)</span>
                                <input type="text" class="view-modern-input" readonly value="@SelectedDetail.AcademicYearRange" />
                            </div>
                            <div class="col-md-6 view-input-group">
                                <span class="view-input-label">သင်တန်းနှစ် (Semester)</span>
                                <input type="text" class="view-modern-input" readonly value="@SelectedDetail.AcademicYearLevel" />
                            </div>
                            <div class="col-md-6 view-input-group">
                                <span class="view-input-label">အထူးပြုဘာသာ (Major)</span>
                                <input type="text" class="view-modern-input" readonly value="@SelectedDetail.Major" />
                            </div>
                            <div class="col-md-6 view-input-group">
                                <span class="view-input-label">ခုံအမှတ် (Roll No)</span>
                                <input type="text" class="view-modern-input" readonly value="@SelectedDetail.RollNo" />
                            </div>
                            <div class="col-md-6 view-input-group">
                                <span class="view-input-label">တက္ကသိုလ်မှတ်ပုံတင်အမှတ်</span>
                                <input type="text" class="view-modern-input" readonly value="@SelectedDetail.UniversityRegNo" />
                            </div>
                            <div class="col-md-6 view-input-group">
                                <span class="view-input-label">တက္ကသိုလ်ဝင်ရောက်သည့်နှစ်</span>
                                <input type="text" class="view-modern-input" readonly value="@SelectedDetail.AdmissionYear" />
                            </div>
                            <div class="col-md-6 view-input-group">
                                <span class="view-input-label">တက္ကသိုလ်ဝင်တန်းခုံအမှတ်</span>
                                <input type="text" class="view-modern-input" readonly value="@SelectedDetail.MatricRollNo" />
                            </div>
                            <div class="col-md-6 view-input-group">
                                <span class="view-input-label">တက္ကသိုလ်ဝင်တန်းအောင်မြင်သည့်နှစ်</span>
                                <input type="text" class="view-modern-input" readonly value="@SelectedDetail.MatricPassedYear" />
                            </div>
                            <div class="col-md-12 view-input-group">
                                <span class="view-input-label">စာစစ်ဌာန</span>
                                <input type="text" class="view-modern-input" readonly value="@SelectedDetail.ExamCenter" />
                            </div>
                        </div>
                    }
                    else if (ActiveTab == "family")
                    {
                        <div class="row g-3 animate-fade">
                            <div class="col-md-6 view-input-group">
                                <span class="view-input-label">အဘအမည်</span>
                                <input type="text" class="view-modern-input" readonly value="@SelectedDetail.FatherName" />
                            </div>
                            <div class="col-md-6 view-input-group">
                                <span class="view-input-label">အဘ၏ အလုပ်အကိုင် / ရာထူး</span>
                                <input type="text" class="view-modern-input" readonly value="@SelectedDetail.FatherOccupation" />
                            </div>
                            <div class="col-md-6 view-input-group">
                                <span class="view-input-label">အမိအမည်</span>
                                <input type="text" class="view-modern-input" readonly value="@SelectedDetail.MotherName" />
                            </div>
                            <div class="col-md-6 view-input-group">
                                <span class="view-input-label">အမိ၏ အလုပ်အကိုင် / ရာထူး</span>
                                <input type="text" class="view-modern-input" readonly value="@SelectedDetail.MotherOccupation" />
                            </div>
                            <div class="col-md-6 view-input-group">
                                <span class="view-input-label">အုပ်ထိန်းသူအမည် (ဆွေမျိုးတော်စပ်ပုံ)</span>
                                <input type="text" class="view-modern-input" readonly value="@SelectedDetail.GuardianName (@SelectedDetail.GuardianRelationship)" />
                            </div>
                            <div class="col-md-6 view-input-group">
                                <span class="view-input-label">အုပ်ထိန်းသူ ဖုန်းနှင့်လိပ်စာ</span>
                                <input type="text" class="view-modern-input" readonly value="@SelectedDetail.GuardianAddressPhone" />
                            </div>
                            <div class="col-md-6 view-input-group">
                                <span class="view-input-label">အုပ်ထိန်းသူ၏ အလုပ်အကိုင်</span>
                                <input type="text" class="view-modern-input" readonly value="@SelectedDetail.GuardianOccupation" />
                            </div>
                            <div class="col-md-6 view-input-group">
                                <span class="view-input-label">ပညာသင်ထောက်ပံ့ကြေး လျှောက်ထားမှု</span>
                                <input type="text" class="view-modern-input" readonly value="@(SelectedDetail.StipendRequested == true ? "ပြုလုပ်ပါသည်" : "မပြုလုပ်ပါ")" />
                            </div>
                            <div class="col-md-4 view-input-group">
                                <span class="view-input-label">အုပ်ထိန်းသူ (လက်မှတ်ပေးသူ)</span>
                                <input type="text" class="view-modern-input" readonly value="@SelectedDetail.AppGuardianName" />
                            </div>
                            <div class="col-md-4 view-input-group">
                                <span class="view-input-label">အုပ်ထိန်းသူ မှတ်ပုံတင်နံပါတ်</span>
                                <input type="text" class="view-modern-input" readonly value="@SelectedDetail.AppGuardianNrc" />
                            </div>
                            <div class="col-md-4 view-input-group">
                                <span class="view-input-label">အုပ်ထိန်းသူ ဖုန်းနံပါတ်</span>
                                <input type="text" class="view-modern-input" readonly value="@SelectedDetail.AppGuardianPhone" />
                            </div>
                            <div class="col-md-12 view-input-group">
                                <span class="view-input-label">အုပ်ထိန်းသူ နေရပ်လိပ်စာ</span>
                                <textarea class="view-modern-input" style="height:60px;" readonly>@SelectedDetail.AppGuardianAddress</textarea>
                            </div>
                            <div class="col-md-12 view-input-group">
                                <span class="view-input-label">အမြဲတမ်းနေရပ်လိပ်စာ (မြန်မာစာဖြင့်)</span>
                                <textarea class="view-modern-input" style="height:60px;" readonly>@SelectedDetail.PermanentAddressMm</textarea>
                            </div>
                            <div class="col-md-12 view-input-group">
                                <span class="view-input-label">အမြဲတမ်းနေရပ်လိပ်စာ (အင်္ဂလိပ်စာဖြင့်)</span>
                                <textarea class="view-modern-input" style="height:60px;" readonly>@SelectedDetail.PermanentAddressEn</textarea>
                            </div>
                            <div class="col-md-12 view-input-group">
                                <span class="view-input-label">လက်ရှိနေရပ်လိပ်စာ</span>
                                <textarea class="view-modern-input" style="height:60px;" readonly>@SelectedDetail.CurrentAddress</textarea>
                            </div>
                        </div>
                    }
                    else if (ActiveTab == "payment")
                    {
                        <div class="row g-4 animate-fade">
                            <div class="col-md-6">
                                <div style="background: #2b2b40; border-radius: 12px; padding: 20px; border: 1px solid #323248;">
                                    <h6 class="fw-bold text-white mb-3" style="border-bottom:1px solid #323248; padding-bottom:8px;">
                                        <i class="bi bi-receipt me-2 text-primary"></i>ကျောင်းလခနှင့် စာမေးပွဲကြေး အသေးစိတ်
                                    </h6>
                                    <div class="d-flex flex-column gap-2" style="font-size:0.88rem;">
                                        <div class="d-flex justify-content-between text-muted">
                                            <span>မှတ်ပုံတင်ကြေး</span>
                                            <span class="text-white">၂၀၀၀ Ks</span>
                                        </div>
                                        <div class="d-flex justify-content-between text-muted">
                                            <span>ကျောင်းဝင်ကြေး</span>
                                            <span class="text-white">၂၀၀၀ Ks</span>
                                        </div>
                                        <div class="d-flex justify-content-between text-muted">
                                            <span>အားကစားကြေး</span>
                                            <span class="text-white">၂၀၀၀ Ks</span>
                                        </div>
                                        <div class="d-flex justify-content-between text-muted">
                                            <span>ဓာတ်ခွဲခန်းကြေး</span>
                                            <span class="text-white">၆၀၀၀ Ks</span>
                                        </div>
                                        <div class="d-flex justify-content-between text-muted">
                                            <span>စာမေးပွဲဝင်ကြေး</span>
                                            <span class="text-white">၅၀၀၀ Ks</span>
                                        </div>
                                        <div class="d-flex justify-content-between text-muted">
                                            <span>စာကြည့်တိုက်ကြေး</span>
                                            <span class="text-white">၅၀၀၀ Ks</span>
                                        </div>
                                        <div class="d-flex justify-content-between text-muted pb-2" style="border-bottom: 1px dashed #323248;">
                                            <span>ကျောင်းလခ (@SelectedDetail.AcademicYearLevel)</span>
                                            <span class="text-white">၃၀၀၀၀ Ks</span>
                                        </div>
                                        <div class="d-flex justify-content-between fw-bold text-white pt-2 fs-6">
                                            <span>စုစုပေါင်း ကျသင့်ငွေ</span>
                                            <span class="text-success">52,000 Ks</span>
                                        </div>
                                    </div>
                                </div>

                                <div class="mt-3 row g-3">
                                    <div class="col-md-6 view-input-group">
                                        <span class="view-input-label">ပေးချေပြီးငွေပမာဏ</span>
                                        <input type="text" class="view-modern-input fw-bold text-success" readonly value="@(payment?.AmountPaid.ToString("N0") ?? "0") Ks" />
                                    </div>
                                    <div class="col-md-6 view-input-group">
                                        <span class="view-input-label">ငွေပေးချေသည့် စနစ်</span>
                                        <input type="text" class="view-modern-input" readonly value="@(payment?.PaymentMethod ?? "-")" />
                                    </div>
                                </div>
                            </div>

                            <div class="col-md-6">
                                <div style="background: #2b2b40; border-radius: 12px; padding: 20px; border: 1px solid #323248; text-align: center; height: 100%; display: flex; flex-direction: column; justify-content: center; align-items: center;">
                                    <span class="view-input-label mb-3 text-uppercase fw-bold"><i class="bi bi-image me-1"></i> ဘဏ်ပြေစာ / ငွေသွင်းစလစ်ပုံ</span>
                                    @if (payment != null && !string.IsNullOrEmpty(payment.ReceiptImage))
                                    {
                                        <a href="@payment.ReceiptImage" target="_blank" title="Click to view full image">
                                            <img src="@payment.ReceiptImage" alt="Receipt" class="img-fluid rounded shadow-sm" style="max-height: 220px; object-fit: contain; border: 1px solid #323248; padding:4px; background:#1e1e2d; cursor: pointer;" />
                                        </a>
                                        <span class="text-muted small mt-2 d-block"><i class="bi bi-zoom-in"></i> စလစ်ပုံကို ကြီးကြီးကြည့်ရန် ပုံပေါ်နှိပ်ပါ</span>
                                    }
                                    else
                                    {
                                        <div class="text-danger p-4"><i class="bi bi-exclamation-circle me-2 fs-3"></i><br>ငွေသွင်းစလစ်ပုံ တင်ထားခြင်းမရှိပါ။</div>
                                    }
                                </div>
                            </div>
                        </div>
                    }
                </div>

                <div class="modal-footer border-top border-dark px-4 py-3 bg-dark" style="border-bottom-left-radius: 12px; border-bottom-right-radius: 12px;">
                    <button type="button" class="btn btn-danger btn-action me-2 px-4"
                            disabled="@(SelectedDetail.Status != "Pending")"
                            @onclick="@(() => PromptConfirm("Rejected"))">
                        <i class="bi bi-x-circle me-1"></i> Reject
                    </button>
                    <button type="button" class="btn btn-success btn-action px-4"
                            disabled="@(SelectedDetail.Status != "Pending")"
                            @onclick="@(() => PromptConfirm("Approved"))">
                        <i class="bi bi-check-circle me-1"></i> Approve
                    </button>
                </div>
            </div>
        </div>
    </div>
}

<!-- 🔹 Confirmation Custom Modal Section -->
@if (ShowConfirmModal)
{
    <div class="modal show d-block" tabindex="-1" style="background-color: rgba(0,0,0,0.8); backdrop-filter: blur(8px); z-index: 1060;">
        <div class="modal-dialog modal-dialog-centered modal-sm" style="max-width: 380px;">
            <div class="modal-content material-card border-0 text-center p-4 position-relative">

                <button type="button" class="btn-close btn-close-white position-absolute top-0 end-0 m-3 opacity-75" style="font-size: 0.8rem;" @onclick="CancelConfirm"></button>

                <div class="mb-3 mt-2">
                    @if (ConfirmAction == "Approved")
                    {
                        <div class="d-inline-flex justify-content-center align-items-center rounded-circle bg-success bg-opacity-10" style="width: 80px; height: 80px;">
                            <i class="bi bi-check-circle-fill text-success" style="font-size: 3rem;"></i>
                        </div>
                    }
                    else
                    {
                        <div class="d-inline-flex justify-content-center align-items-center rounded-circle bg-danger bg-opacity-10" style="width: 80px; height: 80px;">
                            <i class="bi bi-exclamation-triangle-fill text-danger" style="font-size: 3rem;"></i>
                        </div>
                    }
                </div>

                <h5 class="fw-bold text-white mb-2">Are you sure?</h5>
                <p class="text-muted mb-4" style="font-size: 0.95rem;">@ConfirmMessage</p>

                <div class="d-flex justify-content-center gap-2">
                    <button type="button" class="btn btn-secondary btn-action w-50" @onclick="CancelConfirm">
                        Cancel
                    </button>
                    <button type="button" class="btn @(ConfirmAction == "Approved" ? "btn-success" : "btn-danger") btn-action w-50 text-white" @onclick="ExecuteConfirm">
                        Yes, @(ConfirmAction == "Approved" ? "Approve!" : "Reject!")
                    </button>
                </div>
            </div>
        </div>
    </div>
}