@page "/admin/student"
@layout AdminLayout
<SectionContent SectionName="NavTitle">
    Student List
</SectionContent>
<!-- Page Header -->
<div class="page-header">
    <div class="d-flex align-items-center justify-content-between flex-wrap gap-2">
        <div>
            <h3><i class="bi bi-people me-2 text-info"></i>Student Databank</h3>
            <p>Manage and review all registered students.</p>
        </div>
        <NavLink href="/admin/student/create" class="btn btn-sm btn-info text-dark fw-semibold">
            <i class="bi bi-person-plus-fill me-1"></i> Add New Student
        </NavLink>
    </div>
</div>

<!-- Student Table Card -->
<div class="tech-card">

    <div class="tech-card-header">
        <h6 class="tech-card-title">
            <i class="bi bi-table me-2 text-info"></i>All Students
        </h6>
        <span class="badge bg-info text-dark">2 Records</span>
    </div>

    <!-- Search & Filters -->
    <div class="row g-2 mb-3">
        <div class="col-12 col-md-4">
            <div class="input-group input-group-sm">
                <span class="input-group-text search-icon-bg">
                    <i class="bi bi-search"></i>
                </span>
                <input type="text" class="form-control border-start-0" placeholder="Search Roll No or Name..." />
            </div>
        </div>
        <div class="col-6 col-md-3">
            <select class="form-select form-select-sm">
                <option value="">Filter by Major...</option>
                <option>Civil Engineering</option>
                <option>Information Technology</option>
                <option>Mechanical Engineering</option>
                <option>Electrical Engineering</option>
            </select>
        </div>
        <div class="col-6 col-md-2">
            <select class="form-select form-select-sm">
                <option value="">All Status</option>
                <option>Active</option>
                <option>Suspended</option>
                <option>Graduated</option>
                <option>Leave</option>
            </select>
        </div>
        <div class="col-6 col-md-2">
            <select class="form-select form-select-sm">
                <option value="">All Years</option>
                <option>First Year</option>
                <option>Second Year</option>
                <option>Third Year</option>
                <option>Fourth Year</option>
            </select>
        </div>
    </div>

    <!-- Responsive Table -->
    <div class="table-responsive">
        <table class="table table-tech table-hover align-middle mb-0">
            <thead>
                <tr>
                    <th>#</th>
                    <th>Roll No</th>
                    <th>Student (User Account)</th>
                    <th class="d-none d-md-table-cell">Class Year</th>
                    <th class="d-none d-sm-table-cell">Major</th>
                    <th>Status</th>
                    <th class="text-end">Actions</th>
                </tr>
            </thead>
            <tbody>
                <tr>
                    <td class="text-muted">1</td>
                    <td><code class="text-info">ME-2026-001</code></td>
                    <td>
                        <div class="d-flex align-items-center gap-2">
                            <img src="https://ui-avatars.com/api/?name=Mg+Mg&background=22d3ee&color=0d1117&size=32"
                                width="32" height="32" class="rounded-circle" alt="Student" />
                            <div class="lh-1">
                                <span class="d-block fw-semibold">Mg Mg</span>
                                <span class="text-muted" style="font-size:0.72rem;">@@mg.mg (User #3)</span>
                            </div>
                        </div>
                    </td>
                    <td class="d-none d-md-table-cell text-secondary">Third Year</td>
                    <td class="d-none d-sm-table-cell text-secondary">Mechanical Engineering</td>
                    <td>
                        <span class="badge bg-success">Active</span>
                    </td>
                    <td class="text-end">
                        <div class="d-flex justify-content-end gap-1">
                            <NavLink href="/admin/student/edit/1" class="btn btn-sm btn-outline-info">
                                <i class="bi bi-pencil"></i>
                                <span class="d-none d-sm-inline ms-1">Edit</span>
                            </NavLink>
                            <button class="btn btn-sm btn-outline-danger" data-bs-toggle="modal"
                                data-bs-target="#deleteStudentModal">
                                <i class="bi bi-trash"></i>
                                <span class="d-none d-sm-inline ms-1">Delete</span>
                            </button>
                        </div>
                    </td>
                </tr>
                <tr>
                    <td class="text-muted">2</td>
                    <td><code class="text-info">CE-2026-002</code></td>
                    <td>
                        <div class="d-flex align-items-center gap-2">
                            <img src="https://ui-avatars.com/api/?name=Su+Su&background=8b5cf6&color=fff&size=32"
                                width="32" height="32" class="rounded-circle" alt="Student" />
                            <div class="lh-1">
                                <span class="d-block fw-semibold">Su Su Myat</span>
                                <span class="text-muted" style="font-size:0.72rem;">@@su.su (User #5)</span>
                            </div>
                        </div>
                    </td>
                    <td class="d-none d-md-table-cell text-secondary">Second Year</td>
                    <td class="d-none d-sm-table-cell text-secondary">Civil Engineering</td>
                    <td>
                        <span class="badge bg-success">Active</span>
                    </td>
                    <td class="text-end">
                        <div class="d-flex justify-content-end gap-1">
                            <NavLink href="/admin/student/edit/2" class="btn btn-sm btn-outline-info">
                                <i class="bi bi-pencil"></i>
                                <span class="d-none d-sm-inline ms-1">Edit</span>
                            </NavLink>
                            <button class="btn btn-sm btn-outline-danger" data-bs-toggle="modal"
                                data-bs-target="#deleteStudentModal">
                                <i class="bi bi-trash"></i>
                                <span class="d-none d-sm-inline ms-1">Delete</span>
                            </button>
                        </div>
                    </td>
                </tr>
            </tbody>
        </table>
    </div>

    <!-- Pagination -->
    <div class="d-flex align-items-center justify-content-between mt-3 flex-wrap gap-2">
        <small class="text-muted">Showing 2 of 2 records</small>
        <nav aria-label="Student pagination">
            <ul class="pagination pagination-sm mb-0">
                <li class="page-item disabled">
                    <a class="page-link" href="#" tabindex="-1"><i class="bi bi-chevron-left"></i></a>
                </li>
                <li class="page-item active"><a class="page-link" href="#">1</a></li>
                <li class="page-item disabled">
                    <a class="page-link" href="#"><i class="bi bi-chevron-right"></i></a>
                </li>
            </ul>
        </nav>
    </div>

</div>

<!-- Delete Confirmation Modal -->
<div class="modal fade" id="deleteStudentModal" tabindex="-1" aria-labelledby="deleteStudentModalLabel"
    aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered modal-sm">
        <div class="modal-content">
            <div class="modal-header border-0 pb-0">
                <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal"
                    aria-label="Close"></button>
            </div>
            <div class="modal-body text-center px-4 pb-2">
                <i class="bi bi-exclamation-triangle-fill text-danger" style="font-size:3.5rem;"></i>
                <h5 class="fw-bold mt-3 mb-1">Delete Student?</h5>
                <p class="text-muted small mb-0">This action cannot be undone. The student record will be permanently
                    removed.</p>
            </div>
            <div class="modal-footer border-0 justify-content-center gap-2 pt-2">
                <button type="button" class="btn btn-sm btn-secondary px-4" data-bs-dismiss="modal">Cancel</button>
                <button type="button" class="btn btn-sm btn-danger px-4">
                    <i class="bi bi-trash me-1"></i>Yes, Delete
                </button>
            </div>
        </div>
    </div>
</div>