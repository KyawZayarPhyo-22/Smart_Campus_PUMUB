@page "/programs"
<section id="programs" style="background:var(--bg2);margin-top: 50px;">
    <div class=" container">
        <div class="section-header" data-aos="fade-up">
            <div>
                <div class="section-tag"><i class="fas fa-book-open"></i> Academic Programs</div>
                <h2 class="section-title">Our <span>Programs</span></h2>
                <p class="section-desc">Choose from our comprehensive range of undergraduate, postgraduate, and diploma
                    programs.</p>
            </div>
        </div>
        <div class="programs-tabs" data-aos="fade-up">
            <button class="tab-btn active" onclick="filterPrograms('all')">All Programs</button>
            <button class="tab-btn" onclick="filterPrograms('undergraduate')">Undergraduate (B.E)</button>
            <button class="tab-btn" onclick="filterPrograms('postgraduate')">Postgraduate (M.E)</button>
            <button class="tab-btn" onclick="filterPrograms('diploma')">Diploma</button>
        </div>
        <div class="programs-grid" id="programsGrid">
            <div class="program-card" data-category="undergraduate" data-aos="fade-up">
                <div class="program-icon"><i class="fas fa-drafting-compass"></i></div>
                <h3>B.E Civil Engineering</h3>
                <p>5-year program covering structural design, geotechnical engineering, transportation, and water
                    resources.</p>
                <div class="program-meta">
                    <span><i class="fas fa-clock"></i> 5 Years</span>
                    <span><i class="fas fa-users"></i> 300 seats</span>
                    <span><i class="fas fa-certificate"></i> B.E Degree</span>
                </div>
            </div>
            <div class="program-card" data-category="undergraduate" data-aos="fade-up" data-aos-delay="80">
                <div class="program-icon"><i class="fas fa-cog"></i></div>
                <h3>B.E Mechanical Engineering</h3>
                <p>5-year program focusing on thermodynamics, fluid mechanics, manufacturing, and machine design.</p>
                <div class="program-meta">
                    <span><i class="fas fa-clock"></i> 5 Years</span>
                    <span><i class="fas fa-users"></i> 250 seats</span>
                    <span><i class="fas fa-certificate"></i> B.E Degree</span>
                </div>
            </div>
            <div class="program-card" data-category="undergraduate" data-aos="fade-up" data-aos-delay="160">
                <div class="program-icon"><i class="fas fa-bolt"></i></div>
                <h3>B.E Electrical Engineering</h3>
                <p>5-year program in power systems, electrical machines, control systems, and renewable energy.</p>
                <div class="program-meta">
                    <span><i class="fas fa-clock"></i> 5 Years</span>
                    <span><i class="fas fa-users"></i> 280 seats</span>
                    <span><i class="fas fa-certificate"></i> B.E Degree</span>
                </div>
            </div>
            <div class="program-card" data-category="undergraduate" data-aos="fade-up" data-aos-delay="240">
                <div class="program-icon"><i class="fas fa-microchip"></i></div>
                <h3>B.E Electronic Engineering</h3>
                <p>5-year program in digital electronics, embedded systems, telecommunications, and signal processing.
                </p>
                <div class="program-meta">
                    <span><i class="fas fa-clock"></i> 5 Years</span>
                    <span><i class="fas fa-users"></i> 220 seats</span>
                    <span><i class="fas fa-certificate"></i> B.E Degree</span>
                </div>
            </div>
            <div class="program-card" data-category="undergraduate" data-aos="fade-up" data-aos-delay="320">
                <div class="program-icon"><i class="fas fa-laptop-code"></i></div>
                <h3>B.E Information Technology</h3>
                <p>4-year program covering software engineering, networking, databases, AI, and cybersecurity.</p>
                <div class="program-meta">
                    <span><i class="fas fa-clock"></i> 4 Years</span>
                    <span><i class="fas fa-users"></i> 350 seats</span>
                    <span><i class="fas fa-certificate"></i> B.E Degree</span>
                </div>
            </div>
            <div class="program-card" data-category="postgraduate" data-aos="fade-up" data-aos-delay="0">
                <div class="program-icon"><i class="fas fa-flask"></i></div>
                <h3>M.E Structural Engineering</h3>
                <p>Advanced study in structural analysis, earthquake engineering, and advanced materials for civil
                    infrastructure.</p>
                <div class="program-meta">
                    <span><i class="fas fa-clock"></i> 2 Years</span>
                    <span><i class="fas fa-users"></i> 60 seats</span>
                    <span><i class="fas fa-certificate"></i> M.E Degree</span>
                </div>
            </div>
            <div class="program-card" data-category="postgraduate" data-aos="fade-up" data-aos-delay="80">
                <div class="program-icon"><i class="fas fa-brain"></i></div>
                <h3>M.E Computer Engineering</h3>
                <p>Advanced program in AI, machine learning, computer architecture, and intelligent systems design.</p>
                <div class="program-meta">
                    <span><i class="fas fa-clock"></i> 2 Years</span>
                    <span><i class="fas fa-users"></i> 50 seats</span>
                    <span><i class="fas fa-certificate"></i> M.E Degree</span>
                </div>
            </div>
            <div class="program-card" data-category="diploma" data-aos="fade-up" data-aos-delay="0">
                <div class="program-icon"><i class="fas fa-tools"></i></div>
                <h3>Diploma in AutoCAD & Design</h3>
                <p>1-year professional diploma in computer-aided design for engineering drafting and 3D modeling.</p>
                <div class="program-meta">
                    <span><i class="fas fa-clock"></i> 1 Year</span>
                    <span><i class="fas fa-users"></i> 100 seats</span>
                    <span><i class="fas fa-certificate"></i> Diploma</span>
                </div>
            </div>
            <div class="program-card" data-category="diploma" data-aos="fade-up" data-aos-delay="80">
                <div class="program-icon"><i class="fas fa-network-wired"></i></div>
                <h3>Diploma in Networking</h3>
                <p>1-year program covering network administration, cybersecurity, and IT infrastructure management.</p>
                <div class="program-meta">
                    <span><i class="fas fa-clock"></i> 1 Year</span>
                    <span><i class="fas fa-users"></i> 80 seats</span>
                    <span><i class="fas fa-certificate"></i> Diploma</span>
                </div>
            </div>
        </div>
    </div>
</section>