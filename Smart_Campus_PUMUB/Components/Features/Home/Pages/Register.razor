@page "/Account_Register"
@layout EmptyLayout

<div class="split-viewport-wrapper">
    <div class="split-main-card">

        <div class="split-left-panel">
            <div class="left-panel-overlay"></div>
            <div class="left-panel-content">
                <span class="welcome-text">Join Us</span>
                <div class="brand-emblem-sphere">
                    <i class="fas fa-university"></i>
                </div>
                <h2 class="brand-title">Create Account</h2>
                <p class="brand-description">
                    Unlock access to the premier knowledge gateway. Register now to manage your academic journey, access
                    resources, and connect with the campus community.
                </p>
            </div>
        </div>

        <div class="split-right-panel">
            <div class="right-panel-content">
                <h3 class="form-main-headline">Register New Account</h3>
                <p class="form-sub-headline">Please fill in your details to create an identity.</p>

                <div class="m3-form-engine">

                    <div class="modern-field-container">
                        <label class="modern-field-label">Username</label>
                        <div class="modern-input-capsule">
                            <i class="fas fa-user field-icon-accent"></i>
                            <input type="text" class="bootstrap-destroyer-input" placeholder="username" />
                        </div>
                    </div>

                    <div class="modern-field-container">
                        <label class="modern-field-label">Create Password</label>
                        <div class="modern-input-capsule">
                            <i class="fas fa-lock field-icon-accent"></i>
                            <input type="password" class="bootstrap-destroyer-input password-padding-fix"
                                placeholder="At least 8 characters" />

                            <button type="button" class="field-eye-toggler-btn" tabindex="-1">
                                <i class="fas fa-eye"></i>
                            </button>
                        </div>
                    </div>

                    <div class="modern-field-container">
                        <label class="modern-field-label">Confirm Password</label>
                        <div class="modern-input-capsule">
                            <i class="fas fa-shield-check field-icon-accent"></i>
                            <input type="password" class="bootstrap-destroyer-input password-padding-fix"
                                placeholder="Retype password" />
                        </div>
                    </div>

                    <div class="terms-checkbox-container">
                        <label class="custom-checkbox">
                            <input type="checkbox" />
                            <span class="checkmark"></span>
                            <span class="terms-text">I agree to the <a href="#">Terms of Service</a> & <a
                                    href="#">Privacy Policy</a></span>
                        </label>
                    </div>

                    <div class="luxury-error-banner alert-bounce" style="display: none;">
                        <div class="error-accent-edge"></div>
                        <i class="fas fa-circle-exclamation"></i>
                        <span>Passwords do not match.</span>
                    </div>

                    <div class="action-button-layer" style="display: flex; gap: 15px;">
                        <button type="button" class="modern-action-btn secondary-btn">
                            <a href="/" style="text-decoration: none; color: #475569;">Home Page</a>
                        </button>
                        <button type="button" class="modern-action-btn">
                            <span>Create Identity</span>
                            <i class="fas fa-user-plus arrow-slide-motion"></i>
                        </button>
                    </div>

                </div>

                <div class="split-right-footer">
                    <a href="/login" style="text-decoration: none;">
                        <p>Already have an account? <strong>Sign In here</strong></p>
                    </a>
                </div>
            </div>
        </div>

    </div>
</div>

