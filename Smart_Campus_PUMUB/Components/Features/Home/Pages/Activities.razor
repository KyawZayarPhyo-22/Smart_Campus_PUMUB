@page "/activities"
@using Microsoft.EntityFrameworkCore
@using Smart_Campus_PUMUB.Database.AppDbContext
@inject SmartCampusDbContext DbContext

<section id="events" style="background:var(--bg2);margin-top: 50px;">
    <div class="container">
        <div class="section-header" data-aos="fade-up">
            <div>
                <div class="section-tag"><i class="fas fa-calendar-alt"></i> Upcoming Events</div>
                <h2 class="section-title">Events & <span>Activities</span></h2>
            </div>
        </div>

        <div class="events-grid">
            @if (recentActivities == null)
            {
                <p><em>Loading events and activities...</em></p>
            }
            else if (recentActivities.Count == 0)
            {
                <p>No upcoming events available.</p>
            }
            else
            {
                @foreach (var activity in recentActivities)
                {
                    <div class="event-card" data-aos="fade-up" data-aos-delay="0">
                        <div class="event-header" style="background: @(string.IsNullOrEmpty(activity.Image) ? "linear-gradient(135deg, #2563EB, #3B82F6)" : $"url('{activity.Image}') center/cover no-repeat"); position: relative;">
                            <div style="position: absolute; top:0; left:0; right:0; bottom:0; background: rgba(0,0,0,0.4); border-top-left-radius: 16px; border-top-right-radius: 16px; z-index: 1;"></div>
                            <div style="position: relative; z-index: 2;">
                                <div class="event-date-big">
                                    @(activity.CreatedDateTime?.ToString("dd") ?? DateTime.Now.ToString("dd"))
                                </div>
                                <div class="event-month">
                                    @(activity.CreatedDateTime?.ToString("MMMM yyyy") ?? DateTime.Now.ToString("MMMM yyyy"))
                                </div>
                                <span class="event-type-badge">Campus Event</span>
                            </div>
                        </div>

                        <div class="event-body">
                            <h3>@activity.ActivityTitle</h3>
                            <div class="event-meta">
                                <span><i class="fas fa-map-marker-alt"></i> @(activity.Location ?? "Main Campus")</span>
                                <span><i class="fas fa-info-circle"></i> @activity.Description</span>
                                <span><i class="fas fa-user"></i> Posted by: @(activity.CreatedBy ?? "Admin")</span>
                            </div>
                            <div class="countdown" data-target="@(activity.CreatedDateTime?.ToString("yyyy-MM-dd") ?? DateTime.Now.ToString("yyyy-MM-dd"))">
                                <div class="cd-unit"><span class="cd-num" id="cd-d-@activity.ActivityId">00</span><span class="cd-label">Days</span></div>
                                <div class="cd-unit"><span class="cd-num" id="cd-h-@activity.ActivityId">00</span><span class="cd-label">Hours</span></div>
                                <div class="cd-unit"><span class="cd-num" id="cd-m-@activity.ActivityId">00</span><span class="cd-label">Mins</span></div>
                                <div class="cd-unit"><span class="cd-num" id="cd-s-@activity.ActivityId">00</span><span class="cd-label">Secs</span></div>
                            </div>
                        </div>
                    </div>
                }
            }
        </div>
    </div>
</section>

<section id="news">
    <div class="container">
        <div class="section-header" data-aos="fade-up">
            <div>
                <div class="section-tag"><i class="fas fa-newspaper"></i> Latest Updates</div>
                <h2 class="section-title">News & <span>Announcements</span></h2>
            </div>
            <a href="#" class="view-all">All News <i class="fas fa-arrow-right"></i></a>
        </div><div class="news-grid" data-aos="fade-up">
        <div>
            @if (mainNewsActivities == null)
            {
                <p><em>Loading updates...</em></p>
            }
            else if (mainNewsActivities.Count == 0)
            {
                <p>No additional updates found.</p>
            }
            else
            {
                @foreach (var newsAct in mainNewsActivities)
                {
                    <div class="news-card" style="margin-bottom:24px;">
                        <div class="news-card-img">
                            <img src="@(string.IsNullOrEmpty(newsAct.Image) ? "https://images.unsplash.com/photo-1581094794329-c8112a89af12?w=800&q=80" : newsAct.Image)" alt="News Image">
                        </div>
                        <div class="news-card-body">
                            <span class="news-badge badge-research">Announcement</span>
                            <div class="news-date"><i class="fas fa-calendar"></i> @(newsAct.CreatedDateTime?.ToString("MMMM dd, yyyy") ?? "Recent")</div>
                            <h3>@newsAct.ActivityTitle</h3>
                            <p>@newsAct.Description</p>
                        </div>
                    </div>
                }
            }
        </div>

        <div class="news-sidebar">
            @if (sidebarNewsActivities == null)
            {
                <p><em>Loading sidebar updates...</em></p>
            }
            else if (sidebarNewsActivities.Count == 0)
            {
                <p>No extra updates.</p>
            }
            else
            {
                @foreach (var sideAct in sidebarNewsActivities)
                {
                    <div class="news-sidebar-item">
                        <img class="news-thumb" src="@(string.IsNullOrEmpty(sideAct.Image) ? "https://images.unsplash.com/photo-1517077304055-6e89abbf09b0?w=200&q=80" : sideAct.Image)" alt="Thumb">
                        <div>
                            <span class="news-badge badge-research" style="font-size:0.65rem;padding:3px 8px;">Update</span>
                            <h4>@sideAct.ActivityTitle</h4>
                            <span>@(sideAct.CreatedDateTime?.ToString("MMM dd, yyyy") ?? "")</span>
                        </div>
                    </div>
                }
            }
        </div>
    </div>
</div>
</section>

@code {
    // List အားလုံးကို ကိုကို့ရဲ့ Activity Model နဲ့ပဲ ကြေညာလိုက်ပါတယ်ရှင်
    private List<Activity> recentActivities;
    private List<Activity> mainNewsActivities;
    private List<Activity> sidebarNewsActivities;

    protected override async Task OnInitializedAsync()
    {
        try
        {
            // Database ထဲက အော်တို ဖျက်မထားတဲ့ Activity အားလုံးကို အသစ်ဆုံးအတိုင်း စီပြီး ဆွဲထုတ်လိုက်ပါတယ်
            var allActivities = await DbContext.Activities
                                             .Where(a => a.IsDelete != true)
                                             .OrderByDescending(a => a.CreatedDateTime)
                                             .ToListAsync();

            // ၁။ အသစ်ဆုံး (၃) ခုကို အပေါ်က Events card မှာ ပြမယ် ကိုကို
            recentActivities = allActivities.Take(3).ToList();

            // ၂။ နောက်ထပ် ကျန်တဲ့ (၂) ခုကို News card ကြီးမှာ ပြမယ်
            mainNewsActivities = allActivities.Skip(3).Take(2).ToList();

            // ၃။ အဲဒီနောက်ပိုင်းက ကျန်တဲ့ (၅) ခုကိုတော့ News Sidebar သေးသေးလေးမှာ ပြပေးပါမယ်
            sidebarNewsActivities = allActivities.Skip(5).Take(5).ToList();
        }
        catch (Exception ex)
        {
            Console.WriteLine($"EF Core Error: {ex.Message}");
            recentActivities = new List<Activity>();
            mainNewsActivities = new List<Activity>();
            sidebarNewsActivities = new List<Activity>();
        }
    }
}