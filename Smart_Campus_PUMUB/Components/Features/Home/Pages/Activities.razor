@page "/activities"
<!-- EVENTS -->
<section id="events" style="background:var(--bg2);margin-top: 50px;">
    <div class="container">
        <div class="section-header" data-aos="fade-up">
            <div>
                <div class="section-tag"><i class="fas fa-calendar-alt"></i> Upcoming Events</div>
                <h2 class="section-title">Events & <span>Activities</span></h2>
            </div>
        </div>
        <div class="events-grid">
            <div class="event-card" data-aos="fade-up" data-aos-delay="0">
                <div class="event-header">
                    <div class="event-date-big">20</div>
                    <div class="event-month">April 2025</div>
                    <span class="event-type-badge">Conference</span>
                </div>
                <div class="event-body">
                    <h3>Annual Engineering Symposium 2025</h3>
                    <div class="event-meta">
                        <span><i class="fas fa-map-marker-alt"></i> PU Maubin Main Auditorium</span>
                        <span><i class="fas fa-clock"></i> 8:00 AM – 5:00 PM</span>
                        <span><i class="fas fa-users"></i> 500+ Expected Attendees</span>
                    </div>
                    <div class="countdown" data-target="2025-04-20">
                        <div class="cd-unit"><span class="cd-num" id="cd1-d">87</span><span class="cd-label">Days</span>
                        </div>
                        <div class="cd-unit"><span class="cd-num" id="cd1-h">14</span><span
                                class="cd-label">Hours</span></div>
                        <div class="cd-unit"><span class="cd-num" id="cd1-m">32</span><span class="cd-label">Mins</span>
                        </div>
                        <div class="cd-unit"><span class="cd-num" id="cd1-s">00</span><span class="cd-label">Secs</span>
                        </div>
                    </div>
                </div>
            </div>
            <div class="event-card" data-aos="fade-up" data-aos-delay="100">
                <div class="event-header" style="background:linear-gradient(135deg,#7C3AED,#EC4899);">
                    <div class="event-date-big">15</div>
                    <div class="event-month">March 2025</div>
                    <span class="event-type-badge">Workshop</span>
                </div>
                <div class="event-body">
                    <h3>Robotics & Automation Workshop</h3>
                    <div class="event-meta">
                        <span><i class="fas fa-map-marker-alt"></i> Electronics Lab, Block C</span>
                        <span><i class="fas fa-clock"></i> 9:00 AM – 4:00 PM</span>
                        <span><i class="fas fa-users"></i> 60 seats (limited)</span>
                    </div>
                    <div class="countdown" data-target="2025-03-15">
                        <div class="cd-unit"><span class="cd-num" id="cd2-d">51</span><span class="cd-label">Days</span>
                        </div>
                        <div class="cd-unit"><span class="cd-num" id="cd2-h">08</span><span
                                class="cd-label">Hours</span></div>
                        <div class="cd-unit"><span class="cd-num" id="cd2-m">45</span><span class="cd-label">Mins</span>
                        </div>
                        <div class="cd-unit"><span class="cd-num" id="cd2-s">00</span><span class="cd-label">Secs</span>
                        </div>
                    </div>
                </div>
            </div>
            <div class="event-card" data-aos="fade-up" data-aos-delay="200">
                <div class="event-header" style="background:linear-gradient(135deg,#059669,#0891B2);">
                    <div class="event-date-big">05</div>
                    <div class="event-month">March 2025</div>
                    <span class="event-type-badge">Sports</span>
                </div>
                <div class="event-body">
                    <h3>Inter-Department Sports Tournament 2025</h3>
                    <div class="event-meta">
                        <span><i class="fas fa-map-marker-alt"></i> University Sports Ground</span>
                        <span><i class="fas fa-clock"></i> All Day Event</span>
                        <span><i class="fas fa-users"></i> All Students Welcome</span>
                    </div>
                    <div class="countdown" data-target="2025-03-05">
                        <div class="cd-unit"><span class="cd-num" id="cd3-d">41</span><span class="cd-label">Days</span>
                        </div>
                        <div class="cd-unit"><span class="cd-num" id="cd3-h">00</span><span
                                class="cd-label">Hours</span></div>
                        <div class="cd-unit"><span class="cd-num" id="cd3-m">00</span><span class="cd-label">Mins</span>
                        </div>
                        <div class="cd-unit"><span class="cd-num" id="cd3-s">00</span><span class="cd-label">Secs</span>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</section>
<!-- NEWS -->
<section id="news">
    <div class="container">
        <div class="section-header" data-aos="fade-up">
            <div>
                <div class="section-tag"><i class="fas fa-newspaper"></i> Latest Updates</div>
                <h2 class="section-title">News & <span>Announcements</span></h2>
            </div>
            <a href="#" class="view-all">All News <i class="fas fa-arrow-right"></i></a>
        </div>
        <div class="news-grid" data-aos="fade-up">
            <div>
                <div class="news-card" style="margin-bottom:24px;">
                    <div class="news-card-img">
                        <img src="https://images.unsplash.com/photo-1581094794329-c8112a89af12?w=800&q=80"
                            alt="Tech Expo">
                    </div>
                    <div class="news-card-body">
                        <span class="news-badge badge-research">Research</span>
                        <div class="news-date"><i class="fas fa-calendar"></i> December 15, 2024</div>
                        <h3>PU Maubin Students Win Gold at National Engineering Innovation Competition 2024</h3>
                        <p>A team of five Final Year IT students from PU Maubin secured the Gold Award at the National
                            Engineering Innovation Competition held in Naypyidaw, showcasing their AI-powered flood
                            prediction system for the Ayeyarwady Delta region.</p>
                    </div>
                </div>
                <div class="news-card">
                    <div class="news-card-img">
                        <img src="https://images.unsplash.com/photo-1523050854058-8df90110c9f1?w=800&q=80"
                            alt="Scholarship">
                    </div>
                    <div class="news-card-body">
                        <span class="news-badge badge-scholarship">Scholarship</span>
                        <div class="news-date"><i class="fas fa-calendar"></i> November 28, 2024</div>
                        <h3>New STEM Excellence Scholarship Program Announced for 2025</h3>
                        <p>PU Maubin announces a full scholarship program covering tuition and accommodation for
                            top-performing students from underprivileged backgrounds in Ayeyarwady Region, sponsored by
                            the Myanmar Engineering Society.</p>
                    </div>
                </div>
            </div>
            <div class="news-sidebar">
                <div class="news-sidebar-item">
                    <img class="news-thumb"
                        src="https://images.unsplash.com/photo-1517077304055-6e89abbf09b0?w=200&q=80" alt="Lab">
                    <div>
                        <span class="news-badge badge-research"
                            style="font-size:0.65rem;padding:3px 8px;">Research</span>
                        <h4>New Renewable Energy Research Lab Opens</h4>
                        <span>Dec 10, 2024</span>
                    </div>
                </div>
                <div class="news-sidebar-item">
                    <img class="news-thumb"
                        src="https://images.unsplash.com/photo-1540575467063-178a50c2df87?w=200&q=80" alt="Seminar">
                    <div>
                        <span class="news-badge badge-events" style="font-size:0.65rem;padding:3px 8px;">Event</span>
                        <h4>International Engineering Seminar: Feb 2025</h4>
                        <span>Dec 5, 2024</span>
                    </div>
                </div>
                <div class="news-sidebar-item">
                    <img class="news-thumb"
                        src="https://images.unsplash.com/photo-1571019613454-1cb2f99b2d8b?w=200&q=80" alt="Academic">
                    <div>
                        <span class="news-badge badge-academic"
                            style="font-size:0.65rem;padding:3px 8px;">Academic</span>
                        <h4>New Curriculum for B.E IT Program Updated</h4>
                        <span>Nov 22, 2024</span>
                    </div>
                </div>
                <div class="news-sidebar-item">
                    <img class="news-thumb"
                        src="https://images.unsplash.com/photo-1524178232363-1fb2b075b655?w=200&q=80" alt="Admission">
                    <div>
                        <span class="news-badge badge-scholarship"
                            style="font-size:0.65rem;padding:3px 8px;">Admissions</span>
                        <h4>Postgraduate Applications Now Open 2025</h4>
                        <span>Nov 15, 2024</span>
                    </div>
                </div>
                <div class="news-sidebar-item">
                    <img class="news-thumb"
                        src="https://images.unsplash.com/photo-1488190211105-8b0e65b80b4e?w=200&q=80" alt="Library">
                    <div>
                        <span class="news-badge badge-academic"
                            style="font-size:0.65rem;padding:3px 8px;">Library</span>
                        <h4>Digital Library Expands with 5,000 New E-Books</h4>
                        <span>Nov 8, 2024</span>
                    </div>
                </div>
            </div>
        </div>
    </div>
</section>