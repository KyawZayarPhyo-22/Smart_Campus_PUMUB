@page "/rules"
@using Smart_Campus_PUMUB.Components.Pages
@using Smart_Campus_PUMUB.Components.Shared @* 🌟 Shared Component ပါဝင်သော Namespace *@
@inherits RulesBase

<section id="rules" style="background:var(--bg2); margin-top: 50px;">
    <div class="container">
        <div class="section-header">
            <div>
                <div class="section-tag"><i class="fas fa-calendar-alt"></i>Rules</div>
                <h2 class="section-title">Rules & <span>Regulations</span></h2>
            </div>
        </div>

        <div style="display: flex; gap: 15px; margin-bottom: 40px; align-items: center; flex-wrap: wrap;">
            <input type="date" class="form-control " style="width: 250px;" @bind="FromDate" />
            <input type="date" class="form-control " style="width: 250px;" @bind="ToDate" />

            <input type="text" style="max-width: 300px;" class="form-control" placeholder="Search Title"
                   @bind="searchQuery" />

            <button class="btn " style="background:#5A4FCF; color:white; " @onclick="ApplyFilters">
                Search & Filter
            </button>
            <button class="btn" style="background:#5A4FCF; color:white; " @onclick="ResetFilters">Reset</button>
        </div>

        <div class="rules-grid">
            @if (pagedRules != null && pagedRules.Any())
            {
                @* 🌟 Loop ပတ်ရာတွင် Rule နံပါတ်စဉ် စနစ်တကျရှိစေရန် index ပါတွဲယူပါသည် *@
                @foreach (var (rule, index) in pagedRules.Select((value, i) => (value, i)))
                {
                    // 💡 လက်ရှိ Page အလိုက် နံပါတ်စဉ် တွက်ချက်ခြင်း (ဥပမာ- Page 2 ဆိုလျှင် Rule 7 မှ စမည်)
                    int ruleDisplayNumber = ((CurrentPage - 1) * PageSize) + index + 1;

                    <div class="rule-card">
                        <div class="rule-header">
                            <span class="rule-badge">Rule @ruleDisplayNumber</span>
                            <h3 class="rule-title">@rule.Title</h3>
                        </div>
                        <div class="rule-body" style="flex-grow: 1;">
                            <p class="rule-description">
                                @(rule.Description?.Length > 100 ? rule.Description.Substring(0, 100) + "..." :
                        rule.Description)
                            </p>
                            <div class="rule-penalty mt-3">
                                <i class="fas fa-exclamation-triangle"></i>
                                <strong>Penalty:</strong> <span>@rule.Penalty</span>
                            </div>
                            <button class="btn mt-3" style="background:#5A4FCF; color:white; border-radius: 20px;"
                                    @onclick="() => OpenPopup(rule)">Read More</button>
                        </div>
                        <div class="rule-footer">
                            <span class="rule-meta">
                                <i class="fas fa-calendar-alt"></i> Updated: @rule.CreatedDateTime.ToString("dd MMM yyyy")
                            </span>
                        </div>
                    </div>
                }
            }
            else
            {
                <div class="text-center w-100 mt-5">
                    <p class="text-muted">No rules found matching your criteria.</p>
                </div>
            }
        </div>

        <div class="mt-4">
            <PaginationComponent CurrentPage="CurrentPage" TotalPages="TotalPages" OnPageChanged="OnPageChanged" />
        </div>
    </div>
</section>

@if (isPopupOpen && selectedRule != null)
{
    <div class="modal show d-block" style="background: rgba(0,0,0,0.6);">
        <div class="modal-dialog modal-dialog-centered">
            <div class="modal-content p-4" style="border-radius: 15px;">
                <h3 class="mb-3">@selectedRule.Title</h3>
                <div style="max-height: 400px; overflow-y: auto;">
                    <p style="line-height: 1.6;">@selectedRule.Description</p>
                    <div class="rule-penalty mt-4"
                         style="background: #fffbeb; color: #b45309; padding: 15px; border-radius: 10px; border: 1px solid #fde68a;">
                        <i class="fas fa-exclamation-triangle"></i>
                        <strong>Penalty:</strong> <span>@selectedRule.Penalty</span>
                    </div>
                </div>
                <button class="btn mt-4 w-100" style="background:#5A4FCF; color:white; border-radius: 20px;"
                        @onclick="ClosePopup">Close</button>
            </div>
        </div>
    </div>
}

<style>
    .rules-grid {
        display: grid;
        grid-template-columns: repeat(auto-fit, minmax(300px, 1fr));
        gap: 24px;
        margin-top: 30px;
    }

    .rule-card {
        background-color: #ffffff;
        border-radius: 12px;
        box-shadow: 0 4px 15px rgba(0, 0, 0, 0.05);
        padding: 24px;
        border-left: 5px solid #e11d48;
        display: flex;
        flex-direction: column;
        height: 100%;
        transition: transform 0.2s;
    }

    .rule-card:hover {
        transform: translateY(-2px);
    }

    .rule-header {
        display: flex;
        align-items: center;
        gap: 12px;
        margin-bottom: 12px;
    }

    .rule-badge {
        background-color: #ffe4e6;
        color: #e11d48;
        padding: 4px 10px;
        border-radius: 20px;
        font-size: 0.8rem;
        font-weight: 600;
    }

    .rule-title {
        margin: 0;
        font-size: 1.25rem;
        color: #1f2937;
    }

    .rule-description {
        color: #4b5563;
        line-height: 1.6;
    }

    .rule-penalty {
        background-color: #fffbeb;
        color: #b45309;
        padding: 12px 16px;
        border-radius: 8px;
        border: 1px solid #fde68a;
        font-size: 0.9rem;
    }

    .rule-footer {
        margin-top: 16px;
        padding-top: 16px;
        border-top: 1px solid #f3f4f6;
        color: #9ca3af;
        font-size: 0.8rem;
    }

    .modal {
        display: block;
        background: rgba(0, 0, 0, 0.6);
    }
</style>