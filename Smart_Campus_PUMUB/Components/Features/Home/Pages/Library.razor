@page "/Library"
@rendermode InteractiveServer

<section id="library" style="margin:50px;">
    <div class="container">
        <div class="section-header">
            <div>
                <div class="section-tag"><i class="fas fa-book"></i> Knowledge Hub</div>
                <h2 class="section-title">University <span>Library</span></h2>
                
            </div>
        </div>
        <div class="" style="display: flex; justify-content: space-between; align-items: center; margin-bottom: 40px;">

            <div class="">
                <div class="dropdown">

                    <button class="btn dropdown-toggle rounded-pill shadow-sm bg-white px-4 py-2" type="button"
                        @onclick="ToggleMenu" style="border: 1px solid #e0e0e0; color: #495057; font-weight: 500;">
                        Select Category
                    </button>

                    <ul class="dropdown-menu shadow-sm border-0 mt-2 py-2 @(isOpen ? "show" : "")"
                        style="border-radius: 12px; @(isOpen ? "display: block;" : "display: none;")">
                        <li><a class="dropdown-item py-2 px-3" href="#">Option 1</a></li>
                        <li><a class="dropdown-item py-2 px-3" href="#">Option 2</a></li>
                        <li><a class="dropdown-item py-2 px-3" href="#">Option 3</a></li>
                    </ul>

                </div>
            </div>

            <div class="">
                <div class="input-group rounded-pill shadow-sm bg-white"
                    style="max-width: 400px; border: 1px solid #e0e0e0; overflow: hidden;">

                    <input type="text" class="form-control border-0 shadow-none px-4 py-2" placeholder="Search"
                        aria-label="Search" style="background-color: transparent;">

                    <button class="btn border-0 shadow-none px-4" type="button"
                        style="color: #5A4FCF; background-color: transparent;">
                        <i class="fas fa-search" style="font-size: 1.2rem; font-weight: bold;"></i>
                    </button>

                </div>
            </div>

        </div>


        <div class="library-grid">
          
            <div class="book-card">
                <div class="book-cover">
                    <img src="https://images.unsplash.com/photo-1518770660439-4636190af475?w=400&h=280&q=80" alt="Book">
                </div>
                <div class="book-body">
                    <div class="book-category">Electronics</div>
                    <h4>Digital Electronics Fundamentals</h4>
                    <p class="book-author">Prof. Myo Thant</p>
                </div>
            </div>
            <div class="book-card">
                <div class="book-cover">
                    <img src="https://images.unsplash.com/photo-1585776245991-cf89dd7fc73a?w=400&h=280&q=80" alt="Book">
                </div>
                <div class="book-body">
                    <div class="book-category">IT</div>
                    <h4>Introduction to Algorithms</h4>
                    <p class="book-author">Cormen et al.</p>
                </div>
            </div>
            <div class="book-card">
                <div class="book-cover">
                    <img src="https://images.unsplash.com/photo-1504328345606-18bbc8c9d7d1?w=400&h=280&q=80" alt="Book">
                </div>
                <div class="book-body">
                    <div class="book-category">Mechanical</div>
                    <h4>Thermodynamics: An Engineering Approach</h4>
                    <p class="book-author">Cengel & Boles</p>
                </div>
            </div>
            <div class="book-card">
                <div class="book-cover">
                    <img src="https://images.unsplash.com/photo-1581092921461-eab62e97a780?w=400&h=280&q=80" alt="Book">

                </div>
                <div class="book-body">
                    <div class="book-category">Electrical</div>
                    <h4>Power Systems Engineering</h4>
                    <p class="book-author">Glover & Sarma</p>
                </div>
            </div>
            <div class="book-card">
                <div class="book-cover">
                    <img src="https://images.unsplash.com/photo-1517694712202-14dd9538aa97?w=400&h=280&q=80" alt="Book">
                    <span class="book-avail avail-no">Borrowed</span>
                </div>
                <div class="book-body">
                    <div class="book-category">IT</div>
                    <h4>Machine Learning with Python</h4>
                    <p class="book-author">Aurélien Géron</p>
                </div>
            </div>
        </div>

        <div class="d-flex justify-content-end mt-5 mb-4">
            <nav aria-label="Page navigation">
                <ul class="pagination mb-0">

                    <li class="page-item">
                        <a class="page-link rounded-pill shadow-sm border-0 mx-1 px-3" href="#" style="color: #495057;">
                            <i class="fas fa-chevron-left fa-sm"></i> Prev
                        </a>
                    </li>

                    <li class="page-item">
                        <a class="page-link rounded-pill shadow-sm border-0 mx-1" href="#" style="color: #495057;">
                            1
                        </a>
                    </li>

                    <li class="page-item active" aria-current="page">
                        <a class="page-link rounded-pill shadow-sm border-0 mx-1" href="#"
                            style="background-color: #5A4FCF; border-color: #5A4FCF; color: white;">
                            2
                        </a>
                    </li>

                    <li class="page-item">
                        <a class="page-link rounded-pill shadow-sm border-0 mx-1" href="#" style="color: #495057;">
                            3
                        </a>
                    </li>

                    <li class="page-item">
                        <a class="page-link rounded-pill shadow-sm border-0 mx-1" href="#" style="color: #495057;">
                            4
                        </a>
                    </li>

                    <li class="page-item">
                        <a class="page-link rounded-pill shadow-sm border-0 mx-1 px-3" href="#" style="color: #495057;">
                            Next <i class="fas fa-chevron-right fa-sm"></i>
                        </a>
                    </li>

                </ul>
            </nav>
        </div>
    </div>
</section>

@code
{
    private bool isOpen = false;

    private void ToggleMenu()
    {
        isOpen = !isOpen;
    }
}