@page "/Library"
<section id="library" style="background:var(--bg2);margin-top: 50px;">
    <div class="container">
        <div class="section-header" data-aos="fade-up">
            <div>
                <div class="section-tag"><i class="fas fa-book"></i> Knowledge Hub</div>
                <h2 class="section-title">University <span>Library</span></h2>
                <p class="section-desc">Access over 50,000 books, journals, and digital resources across all engineering
                    and technology disciplines.</p>
            </div>
        </div>
        <div style="display:grid;grid-template-columns:repeat(auto-fill,minmax(180px,1fr));gap:16px;margin-bottom:40px;"
            data-aos="fade-up">
            <div
                style="background:linear-gradient(135deg,var(--secondary),var(--accent));border-radius:16px;padding:24px;text-align:center;color:#fff;">
                <i class="fas fa-book" style="font-size:2rem;margin-bottom:8px;"></i>
                <div style="font-size:1.5rem;font-weight:900;font-family:'Playfair Display',serif;">50,000+</div>
                <div style="font-size:0.78rem;opacity:0.8;">Physical Books</div>
            </div>
            <div
                style="background:var(--card-bg);border-radius:16px;padding:24px;text-align:center;border:1px solid var(--border);">
                <i class="fas fa-tablet-alt" style="font-size:2rem;margin-bottom:8px;color:var(--secondary);"></i>
                <div style="font-size:1.5rem;font-weight:900;font-family:'Playfair Display',serif;color:var(--text);">
                    15,000+</div>
                <div style="font-size:0.78rem;color:var(--text2);">E-Books</div>
            </div>
            <div
                style="background:var(--card-bg);border-radius:16px;padding:24px;text-align:center;border:1px solid var(--border);">
                <i class="fas fa-file-alt" style="font-size:2rem;margin-bottom:8px;color:var(--accent);"></i>
                <div style="font-size:1.5rem;font-weight:900;font-family:'Playfair Display',serif;color:var(--text);">
                    8,000+</div>
                <div style="font-size:0.78rem;color:var(--text2);">Research Papers</div>
            </div>
            <div
                style="background:var(--card-bg);border-radius:16px;padding:24px;text-align:center;border:1px solid var(--border);">
                <i class="fas fa-journal-whills" style="font-size:2rem;margin-bottom:8px;color:var(--gold);"></i>
                <div style="font-size:1.5rem;font-weight:900;font-family:'Playfair Display',serif;color:var(--text);">
                    200+</div>
                <div style="font-size:0.78rem;color:var(--text2);">Journals</div>
            </div>
        </div>
        <div class="library-grid" data-aos="fade-up">
            <div class="book-card">
                <div class="book-cover">
                    <img src="https://images.unsplash.com/photo-1507003211169-0a1dd7228f2d?w=400&h=280&q=80" alt="Book">
                    <span class="book-avail avail-yes">Available</span>
                </div>
                <div class="book-body">
                    <div class="book-category">Civil Engineering</div>
                    <h4>Structural Analysis & Design</h4>
                    <p class="book-author">Dr. Aung Kyaw Zin</p>
                </div>
            </div>
            <div class="book-card">
                <div class="book-cover">
                    <img src="https://images.unsplash.com/photo-1518770660439-4636190af475?w=400&h=280&q=80" alt="Book">
                    <span class="book-avail avail-yes">Available</span>
                </div>
                <div class="book-body">
                    <div class="book-category">Electronics</div>
                    <h4>Digital Electronics Fundamentals</h4>
                    <p class="book-author">Prof. Myo Thant</p>
                </div>
            </div>
            <div class="book-card">
                <div class="book-cover">
                    <img src="https://images.unsplash.com/photo-1585776245991-cf89dd7fc73a?w=400&h=280&q=80" alt="Book">
                    <span class="book-avail avail-no">Borrowed</span>
                </div>
                <div class="book-body">
                    <div class="book-category">IT</div>
                    <h4>Introduction to Algorithms</h4>
                    <p class="book-author">Cormen et al.</p>
                </div>
            </div>
            <div class="book-card">
                <div class="book-cover">
                    <img src="https://images.unsplash.com/photo-1504328345606-18bbc8c9d7d1?w=400&h=280&q=80" alt="Book">
                    <span class="book-avail avail-yes">Available</span>
                </div>
                <div class="book-body">
                    <div class="book-category">Mechanical</div>
                    <h4>Thermodynamics: An Engineering Approach</h4>
                    <p class="book-author">Cengel & Boles</p>
                </div>
            </div>
            <div class="book-card">
                <div class="book-cover">
                    <img src="https://images.unsplash.com/photo-1581092921461-eab62e97a780?w=400&h=280&q=80" alt="Book">
                    <span class="book-avail avail-yes">Available</span>
                </div>
                <div class="book-body">
                    <div class="book-category">Electrical</div>
                    <h4>Power Systems Engineering</h4>
                    <p class="book-author">Glover & Sarma</p>
                </div>
            </div>
            <div class="book-card">
                <div class="book-cover">
                    <img src="https://images.unsplash.com/photo-1517694712202-14dd9538aa97?w=400&h=280&q=80" alt="Book">
                    <span class="book-avail avail-no">Borrowed</span>
                </div>
                <div class="book-body">
                    <div class="book-category">IT</div>
                    <h4>Machine Learning with Python</h4>
                    <p class="book-author">Aurélien Géron</p>
                </div>
            </div>
        </div>
    </div>
</section>