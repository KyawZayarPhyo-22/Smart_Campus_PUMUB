@page "/contact"
<!-- CONTACT -->
<section id="contact">
    <div class="container">
        <div style="text-align:start;margin-bottom:60px; margin-top: 50px;" data-aos="fade-up">
            <div class="section-tag"><i class="fas fa-envelope"></i> Get In Touch</div>
            <h2 class="section-title">Contact <span>Us</span></h2>
        </div>
        <div class="contact-grid" data-aos="fade-up">
            <div>
                <h3>Reach Us Directly</h3>
                <div class="contact-item">
                    <div class="contact-icon"><i class="fas fa-map-marker-alt"></i></div>
                    <div>
                        <h4>Address</h4>
                        <p>Polytechnic University (Maubin)<br>Maubin Township, Ayeyarwady Region<br>Myanmar</p>
                    </div>
                </div>
                <div class="contact-item">
                    <div class="contact-icon"><i class="fas fa-phone"></i></div>
                    <div>
                        <h4>Phone</h4>
                        <p>+95-45-24XXX<br>+95-45-24XXX (Admissions)</p>
                    </div>
                </div>
                <div class="contact-item">
                    <div class="contact-icon"><i class="fas fa-envelope"></i></div>
                    <div>
                        <h4>Email</h4>
                        <p>info@pu-maubin.edu.mm<br>admissions@pu-maubin.edu.mm</p>
                    </div>
                </div>
                <div class="contact-item">
                    <div class="contact-icon"><i class="fas fa-clock"></i></div>
                    <div>
                        <h4>Office Hours</h4>
                        <p>Monday – Friday: 9:00 AM – 4:30 PM<br>Saturday: 9:00 AM – 12:00 PM</p>
                    </div>
                </div>
                <div class="social-links">
                    <a href="#" class="social-link"><i class="fab fa-facebook-f"></i></a>
                    <a href="#" class="social-link"><i class="fab fa-youtube"></i></a>
                    <a href="#" class="social-link"><i class="fab fa-telegram-plane"></i></a>
                    <a href="#" class="social-link"><i class="fab fa-linkedin-in"></i></a>
                    <a href="#" class="social-link"><i class="fab fa-twitter"></i></a>
                </div>
                <div class="map-container">
                    <iframe
                        src="https://www.google.com/maps/embed?pb=!1m18!1m12!1m3!1d30348.62!2d95.6536!3d16.7287!2m3!1f0!2f0!3f0!3m2!1i1024!2i768!4f13.1!3m3!1m2!1s0x30c1d3d7de1e3e33%3A0x1234567890abcdef!2sMaubin%2C%20Myanmar!5e0!3m2!1sen!2smm!4v1234567890"
                        allowfullscreen loading="lazy">
                    </iframe>
                </div>
            </div>
            <div class="contact-form">
                <h3>
                    <i class="fas fa-paper-plane" style="color:var(--secondary);"></i>
                    Send Us a Message
                </h3>

                <div class="form-grid">
                    <div class="form-group">
                        <label>Full Name</label>
                        <input type="text" placeholder="Your Name">
                    </div>

                    <div class="form-group">
                        <label>Email Address</label>
                        <input type="email" placeholder="your@email.com">
                    </div>

                    <div class="form-group">
                        <label>Phone</label>
                        <input type="tel" placeholder="+95 9 XXXXXXXXX">
                    </div>

                    <div class="form-group">
                        <label>Subject</label>
                        <select>
                            <option>Admissions Inquiry</option>
                            <option>Academic Information</option>
                            <option>Scholarship Information</option>
                            <option>General Inquiry</option>
                            <option>Research Collaboration</option>
                        </select>
                    </div>
                </div>

                <div class="form-group message-group">
                    <label>Message</label>
                    <textarea placeholder="How can we help you? Please describe your inquiry in detail..."></textarea>
                </div>

                <button class="btn-next send-btn"
                    onclick="alert('Thank you for your message! We will reply within 1-2 business days.')">
                    <i class="fas fa-paper-plane"></i> Send Message
                </button>
            </div>
        </div>
    </div>
</section>