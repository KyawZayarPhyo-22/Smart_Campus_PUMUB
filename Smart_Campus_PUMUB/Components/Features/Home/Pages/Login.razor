@page "/login"
@layout EmptyLayout
@using Microsoft.EntityFrameworkCore
@using Smart_Campus_PUMUB.Database.AppDbContext
@using Smart_Campus_PUMUB.Components.Features.Services
@using Smart_Campus_PUMUB.Components.Shared.Layout
@using Microsoft.AspNetCore.Components.Authorization
@inject SmartCampusDbContext DbContext
@inject AuthenticationStateProvider AuthStateProvider
@inject NavigationManager NavManager
@rendermode InteractiveServer

<link href="https://fonts.googleapis.com/css2?family=Plus+Jakarta+Sans:wght@300;400;500;600;700;800&display=swap" rel="stylesheet">
<link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.0/css/all.min.css">

<div class="split-viewport-wrapper">
    <div class="split-main-card">

        <div class="split-left-panel">
            <div class="left-panel-overlay"></div>
            <div class="left-panel-content">
                <span class="welcome-text">Welcome to</span>
                <div class="brand-emblem-sphere">
                    <i class="fas fa-university"></i>
                </div>
                <h2 class="brand-title">Smart Campus</h2>
                <p class="brand-description">
                    A premier knowledge gateway dedicated to advancing technologies and empowering future innovations.
                </p>
                <div class="brand-meta-tags">
                    <span>CREATOR MODE</span>
                    <span>·</span>
                    <span>DESIGNER MODE</span>
                </div>
            </div>
        </div>

        <div class="split-right-panel">
            <div class="right-panel-content">
                <h3 class="form-main-headline">Sign In to Account</h3>
                <p class="form-sub-headline">Please enter your campus credentials below.</p>

                <div class="m3-form-engine">
                    <div class="modern-field-container">
                        <label class="modern-field-label">Username Identity</label>
                        <div class="modern-input-capsule">
                            <i class="fas fa-user-shield field-icon-accent"></i>
                            <input type="text" class="bootstrap-destroyer-input"
                                   placeholder="Enter your account username"
                                   @bind="username" @bind:event="oninput" @onkeydown="HandleKeyDown" />
                        </div>
                    </div>

                    <div class="modern-field-container">
                        <label class="modern-field-label">Security Credentials</label>
                        <div class="modern-input-capsule">
                            <i class="fas fa-key field-icon-accent"></i>
                            <input type="@PasswordInputType" class="bootstrap-destroyer-input password-padding-fix"
                                   placeholder="Enter secure password"
                                   @bind="password" @bind:event="oninput" @onkeydown="HandleKeyDown" />

                            <button type="button" class="field-eye-toggler-btn" @onclick="TogglePasswordVisibility" tabindex="-1">
                                <i class="fas @(isPasswordRenderedText ? "fa-eye-slash" : "fa-eye")"></i>
                            </button>
                        </div>
                    </div>

                    @if (!string.IsNullOrEmpty(errorMessage))
                    {
                        <div class="luxury-error-banner alert-bounce">
                            <div class="error-accent-edge"></div>
                            <i class="fas fa-circle-exclamation"></i>
                            <span>@errorMessage</span>
                        </div>
                    }

                    <div class="action-button-layer">
                        @if (isLoggingIn)
                        {
                            <button class="modern-action-btn-processing" disabled>
                                <div class="btn-spinner-loader"></div> Authenticating user session...
                            </button>
                        }
                        else
                        {
                            <button class="modern-action-btn" @onclick="HandleLogin">
                                <span>Sign In Portal</span>
                                <i class="fas fa-arrow-right-long arrow-slide-motion"></i>
                            </button>
                        }
                    </div>
                </div>

                <div class="split-right-footer">
                    <p>&copy; @DateTime.Now.Year PUMUB Subsystem. All Rights Reserved.</p>
                </div>
            </div>
        </div>

    </div>
</div>

<style>
    .split-viewport-wrapper {
        font-family: 'Plus Jakarta Sans', sans-serif !important;
        background: #090d16 !important; /* Premium Midnight Dark Blue */
        min-height: 100vh;
        display: flex;
        align-items: center;
        justify-content: center;
        padding: 40px 24px;
    }

    /* পিনমပင် ပင်မ ကတ်ထူဘောင်ကြီး */
    .split-main-card {
        width: 100%;
        max-width: 960px;
        min-height: 560px;
        background: #ffffff !important;
        border-radius: 28px !important;
        box-shadow: 0 25px 60px -15px rgba(0, 0, 0, 0.4);
        display: flex;
        overflow: hidden;
    }

    /* 🌟 ဘယ်ဘက် အပြာရောင် PANEL ဒီဇိုင်း */
    .split-left-panel {
        flex: 1.1;
        background: url('/images/university-bg.jpg') no-repeat center center/cover; /* ကိုကို့ Background ပုံရှိရင် ထည့်နိုင်ပါတယ်ရှင် */
        background-color: #1e40af; /* Fallback Solid Premium Blue */
        position: relative;
        display: flex;
        align-items: center;
        padding: 48px;
    }

    .left-panel-overlay {
        position: absolute;
        top: 0;
        left: 0;
        width: 100%;
        height: 100%;
        background: linear-gradient(135deg, rgba(29, 78, 216, 0.95), rgba(3, 105, 161, 0.9));
        z-index: 1;
    }

    .left-panel-content {
        position: relative;
        z-index: 2;
        color: #ffffff !important;
        display: flex;
        flex-direction: column;
        gap: 18px;
    }

    .welcome-text {
        font-size: 1.1rem;
        font-weight: 500;
        color: rgba(255, 255, 255, 0.8);
        letter-spacing: 0.02em;
    }

    .brand-emblem-sphere {
        width: 64px;
        height: 64px;
        background: rgba(255, 255, 255, 0.15);
        backdrop-filter: blur(8px);
        border: 1px solid rgba(255, 255, 255, 0.25);
        border-radius: 20px;
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 1.6rem;
    }

    .brand-title {
        font-size: 2.2rem;
        font-weight: 800;
        letter-spacing: -0.02em;
        margin: 0;
    }

    .brand-description {
        font-size: 0.92rem;
        color: rgba(255, 255, 255, 0.75);
        line-height: 1.6;
        margin: 0;
        max-width: 360px;
    }

    .brand-meta-tags {
        display: flex;
        gap: 10px;
        font-size: 0.7rem;
        font-weight: 700;
        color: rgba(255,255,255,0.4);
        letter-spacing: 0.08em;
        margin-top: 24px;
    }

    /* 🌟 ညာဘက် FORM PANEL ဒီဇိုင်း */
    .split-right-panel {
        flex: 1;
        background: #ffffff !important;
        display: flex;
        align-items: center;
        padding: 54px;
    }

    .right-panel-content {
        width: 100%;
        display: flex;
        flex-direction: column;
        gap: 24px;
    }

    .form-main-headline {
        font-size: 1.5rem;
        font-weight: 800;
        color: #0f172a !important;
        margin: 0;
        letter-spacing: -0.01em;
    }

    .form-sub-headline {
        font-size: 0.88rem;
        color: #64748b !important;
        margin: 0;
    }

    .m3-form-engine {
        display: flex;
        flex-direction: column;
        gap: 20px;
    }

    .modern-field-container {
        display: flex;
        flex-direction: column;
        gap: 8px;
    }

    .modern-field-label {
        font-size: 0.82rem;
        font-weight: 600;
        color: #475569 !important;
        padding-left: 2px;
    }

    /* 🌟 THE HIGH-INSET CAPSULE BAR (အဖြူတုံးလုံးဝမထွက်စေရမည့် နည်းပညာ) */
    .modern-input-capsule {
        background: #f8fafc !important; /* Premium Soft Cream White */
        border: 1px solid #e2e8f0 !important;
        border-radius: 50px !important; /* ဝိုင်းစက်သော ဆေးတောင့်ပုံစံ */
        padding: 0 20px !important;
        display: flex !important;
        align-items: center !important;
        position: relative !important;
        width: 100% !important;
        height: 52px !important;
        box-shadow: inset 0 2px 4px rgba(0, 0, 0, 0.04) !important;
        transition: all 0.2s ease;
    }

        .modern-input-capsule:focus-within {
            border-color: #2563eb !important;
            background: #ffffff !important;
            box-shadow: inset 0 1px 2px rgba(0, 0, 0, 0.02), 0 0 0 3px rgba(37, 99, 235, 0.15) !important;
        }

    .field-icon-accent {
        font-size: 0.95rem;
        color: #94a3b8 !important;
        margin-right: 12px !important;
    }

    .modern-input-capsule:focus-within .field-icon-accent {
        color: #2563eb !important;
    }

    /* 🌟 BOOTSTRAP OVERRIDE ANNIHILATION LAUNCHER */
    /* (ကိုကို့စက်ထဲက Input စာသားအကွက်တွေ လေးထောင့်အဖြူတုံးကြီး ဖြစ်မသွားအောင် တိုက်ရိုက် Override လုပ်ပိတ်ချလိုက်တာပါ) */
    .modern-input-capsule input,
    .modern-input-capsule input[type="text"],
    .modern-input-capsule input[type="password"],
    .bootstrap-destroyer-input {
        flex: 1 !important;
        width: 100% !important;
        height: 100% !important;
        background: transparent !important; /* 💡 မလိုအပ်သော နောက်ခံ အဖြူတုံးကြီးကို ဖျောက်ချခြင်း */
        background-color: transparent !important;
        border: none !important; /* 💡 Bootstrap Default Border ကို ဖြုတ်ချခြင်း */
        color: #0f172a !important; /* စာသားအရောင် အမည်းရင့် */
        font-size: 0.92rem !important;
        font-weight: 550 !important;
        outline: none !important;
        box-shadow: none !important; /* 💡 Bootstrap Hover/Focus Glow ကိုပါ သတ်ပစ်ခြင်း */
        padding: 0 !important;
        margin: 0 !important;
    }

        .bootstrap-destroyer-input::placeholder {
            color: #94a3b8 !important;
            font-weight: 400;
        }

    .password-padding-fix {
        padding-right: 30px !important;
    }

    /* 👁️ PASSWORD TOGGLER EYE */
    .field-eye-toggler-btn {
        position: absolute !important;
        right: 20px !important;
        top: 50% !important;
        transform: translateY(-50%) !important;
        background: transparent !important;
        border: none !important;
        color: #94a3b8 !important;
        cursor: pointer !important;
        padding: 0 !important;
        font-size: 0.95rem !important;
        display: flex !important;
        align-items: center !important;
        justify-content: center !important;
        z-index: 5 !important;
    }

        .field-eye-toggler-btn:hover {
            color: #475569 !important;
        }

    /* PREMIUM GLOW ACTION BUTTON */
    .modern-action-btn {
        width: 100% !important;
        height: 50px !important;
        background: linear-gradient(135deg, #1d4ed8, #2563eb) !important;
        color: #ffffff !important;
        border: none !important;
        border-radius: 50px !important;
        font-size: 0.95rem !important;
        font-weight: 700 !important;
        cursor: pointer !important;
        display: flex !important;
        align-items: center !important;
        justify-content: center !important;
        gap: 8px !important;
        box-shadow: 0 4px 14px rgba(37, 99, 235, 0.25) !important;
        transition: all 0.2s ease;
    }

        .modern-action-btn:hover {
            background: linear-gradient(135deg, #2563eb, #3b82f6) !important;
            box-shadow: 0 6px 18px rgba(37, 99, 235, 0.35) !important;
            transform: translateY(-1px) !important;
        }

    .arrow-slide-motion {
        transition: transform 0.2s ease;
        font-size: 0.85rem;
    }

    .modern-action-btn:hover .arrow-slide-motion {
        transform: translateX(4px);
    }

    .modern-action-btn-processing {
        width: 100% !important;
        height: 50px !important;
        background: #e2e8f0 !important;
        color: #94a3b8 !important;
        border: none !important;
        border-radius: 50px !important;
        font-weight: 600 !important;
        display: flex !important;
        align-items: center !important;
        justify-content: center !important;
        gap: 10px !important;
        cursor: not-allowed !important;
    }

    /* ERROR RESPONSE TOAST */
    .luxury-error-banner {
        background: #fef2f2 !important;
        border: 1px solid #fca5a5 !important;
        color: #991b1b !important;
        padding: 12px 16px !important;
        border-radius: 12px !important;
        font-size: 0.85rem !important;
        display: flex !important;
        align-items: center !important;
        gap: 10px !important;
        font-weight: 500 !important;
        position: relative !important;
        overflow: hidden !important;
    }

    .error-accent-edge {
        position: absolute;
        left: 0;
        top: 0;
        bottom: 0;
        width: 4px;
        background: #ef4444 !important;
    }

    .split-right-footer {
        text-align: center;
        font-size: 0.72rem;
        color: #94a3b8 !important;
        font-weight: 600;
        margin-top: 12px;
    }

    /* RESPONSIVE DESIGN ARCHITECTURE (မိုဘိုင်းဖုန်းဖြင့်ကြည့်လျှင်လည်း အော်တို ကွက်တိညှိပေးမည့်စနစ်ပါ ကိုကို) */
    @@media (max-width: 768px) {
        .split-main-card {
            flex-direction: column !important;
            min-height: auto !important;
            border-radius: 20px !important;
        }

        .split-left-panel {
            padding: 36px 24px !important;
            text-align: center !important;
        }

        .left-panel-content {
            align-items: center !important;
        }

        .brand-description {
            max-width: 100% !important;
        }

        .split-right-panel {
            padding: 36px 24px !important;
        }

        .brand-meta-tags {
            display: none !important;
        }
    }

    /* Animations core */
    .alert-bounce {
        animation: miniBounce 0.2s cubic-bezier(0.34, 1.56, 0.64, 1);
    }

    @@keyframes miniBounce {
        0% {
            transform: scale(0.97);
            opacity: 0;
        }

        100% {
            transform: scale(1);
            opacity: 1;
        }
    }

    .btn-spinner-loader {
        width: 16px;
        height: 16px;
        border: 2px solid rgba(0,0,0,0.1);
        border-top-color: #94a3b8;
        border-radius: 50%;
        animation: m3Spin 0.7s linear infinite;
    }

    @@keyframes m3Spin {
        to {
            transform: rotate(360deg);
        }
    }
</style>

@code {
    private string username = "";
    private string password = "";
    private string errorMessage = "";
    private bool isLoggingIn = false;

    // PASSWORD VISIBILITY ENGINE STATE
    private bool isPasswordRenderedText = false;
    private string PasswordInputType => isPasswordRenderedText ? "text" : "password";

    private void TogglePasswordVisibility()
    {
        isPasswordRenderedText = !isPasswordRenderedText;
    }

    private async Task HandleLogin()
    {
        if (isLoggingIn) return;
        if (string.IsNullOrWhiteSpace(username) || string.IsNullOrWhiteSpace(password))
        {
            errorMessage = "Please enter your username and security key.";
            return;
        }

        try
        {
            isLoggingIn = true;
            errorMessage = "";

            var user = await DbContext.Users
                .Include(u => u.Role)
                .FirstOrDefaultAsync(u => u.UserName == username && u.IsDelete != true);

            if (user != null && user.Password == password)
            {
                var customAuth = (CustomAuthStateProvider)AuthStateProvider;
                await customAuth.UpdateAuthenticationState(new UserSession
                {
                    Username = user.UserName,
                    Role = user.Role.RoleName
                });

                string roleName = user.Role.RoleName.ToLower();

                if (roleName.Contains("admin")) NavManager.NavigateTo("/admin/dashboard", true);
                else if (roleName.Contains("tutor")) NavManager.NavigateTo("/", true);
                else if (roleName.Contains("student")) NavManager.NavigateTo("/", true);
                else NavManager.NavigateTo("/", true);
            }
            else
            {
                errorMessage = "Invalid login credentials. Please re-check.";
            }
        }
        catch (Exception ex)
        {
            errorMessage = $"Database Connection Error: {ex.Message}";
        }
        finally
        {
            isLoggingIn = false;
        }
    }

    private async Task HandleKeyDown(KeyboardEventArgs e)
    {
        if (e.Key == "Enter") await HandleLogin();
    }
}