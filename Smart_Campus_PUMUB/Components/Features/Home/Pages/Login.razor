@page "/login"
@layout EmptyLayout
@using Microsoft.EntityFrameworkCore
@using Smart_Campus_PUMUB.Database.AppDbContext
@using Smart_Campus_PUMUB.Components.Features.Services
@using Smart_Campus_PUMUB.Components.Shared.Layout
@using Microsoft.AspNetCore.Components.Authorization
@inject SmartCampusDbContext DbContext
@inject AuthenticationStateProvider AuthStateProvider

@rendermode InteractiveServer

@inject IJSRuntime JS
@inject NavigationManager NavigationManager
@inject IHttpClientFactory HttpClientFactory

<link href="https://fonts.googleapis.com/css2?family=Plus+Jakarta+Sans:wght@300;400;500;600;700;800&display=swap"
      rel="stylesheet">
<link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.0/css/all.min.css">

<div class="split-viewport-wrapper">
    <div class="split-main-card @(activeTab == "register" ? "register-expanded" : "")">

        <div class="split-left-panel">
            <div class="left-panel-overlay"></div>
            <div class="left-panel-content">
                <span class="welcome-text">Welcome to</span>
                <div class="brand-emblem-sphere">
                    <i class="fas fa-university"></i>
                </div>
                <h2 class="brand-title">Smart Campus</h2>
                <p class="brand-description">
                    A premier knowledge gateway dedicated to advancing technologies and empowering future innovations.
                </p>
                <div class="brand-meta-tags">
                    <span>CREATOR MODE</span>
                    <span>·</span>
                    <span>DESIGNER MODE</span>
                </div>
            </div>
        </div>

        <div class="split-right-panel">
            <div class="right-panel-content">

                @if (isChangePasswordMode)
                {
                    <h3 class="form-main-headline">Change Password Required</h3>
                    <p class="form-sub-headline">Please update your temporary password to secure your account.</p>

                    <div class="m3-form-engine">
                        <div class="modern-field-container">
                            <label class="modern-field-label">New Password</label>
                            <div class="modern-input-capsule">
                                <i class="fas fa-key field-icon-accent"></i>
                                <input type="@NewPasswordInputType" class="bootstrap-destroyer-input password-padding-fix"
                                       placeholder="Enter new secure password" @bind="newPassword" @bind:event="oninput"
                                       @onkeydown="HandleChangePasswordKeyDown" />

                                <button type="button" class="field-eye-toggler-btn" @onclick="ToggleNewPasswordVisibility"
                                        tabindex="-1">
                                    <i class="fas @(isNewPasswordRenderedText ? "fa-eye-slash" : "fa-eye")"></i>
                                </button>
                            </div>
                        </div>

                        <div class="modern-field-container">
                            <label class="modern-field-label">Confirm New Password</label>
                            <div class="modern-input-capsule">
                                <i class="fas fa-key field-icon-accent"></i>
                                <input type="@ConfirmPasswordInputType" class="bootstrap-destroyer-input password-padding-fix"
                                       placeholder="Re-enter new password to confirm" @bind="confirmPassword" @bind:event="oninput"
                                       @onkeydown="HandleChangePasswordKeyDown" />

                                <button type="button" class="field-eye-toggler-btn" @onclick="ToggleConfirmPasswordVisibility"
                                        tabindex="-1">
                                    <i class="fas @(isConfirmPasswordRenderedText ? "fa-eye-slash" : "fa-eye")"></i>
                                </button>
                            </div>
                        </div>

                        @if (!string.IsNullOrEmpty(errorMessage))
                        {
                            <div class="luxury-error-banner alert-bounce">
                                <div class="error-accent-edge"></div>
                                <i class="fas fa-circle-exclamation"></i>
                                <span>@errorMessage</span>
                            </div>
                        }

                        <div class="action-button-layer" style="display: flex; gap: 12px;">
                            @if (isChangingPassword)
                            {
                                <button class="modern-action-btn-processing" disabled style="flex: 1;">
                                    <div class="btn-spinner-loader"></div> Changing password...
                                </button>
                            }
                            else
                            {
                                <button class="modern-action-btn" @onclick="HandleChangePassword" style="flex: 1;">
                                    <span>Update Password</span>
                                    <i class="fas fa-check-circle"></i>
                                </button>
                                <button class="modern-action-btn" @onclick="CancelChangePassword" style="flex: 1; background: #64748b !important; box-shadow: none !important;">
                                    <span>Cancel</span>
                                </button>
                            }
                        </div>
                    </div>
                }
                else
                {
                    <!-- ── Tab switcher ─────────────────────── -->
                    <div class="auth-tab-bar">
                        <button class="auth-tab @(activeTab == "login" ? "active" : "")"
                                @onclick='() => SwitchTab("login")'>
                            <i class="fas fa-sign-in-alt"></i> Sign In
                        </button>
                        <button class="auth-tab @(activeTab == "register" ? "active" : "")"
                                @onclick='() => SwitchTab("register")'>
                            <i class="fas fa-user-plus"></i> Register Account
                        </button>
                    </div>

                    <!-- ── LOGIN FORM ─────────────────────────── -->
                    @if (activeTab == "login")
                    {
                        <h3 class="form-main-headline">Sign In to Account</h3>
                        <p class="form-sub-headline">Please enter your campus credentials below.</p>

                        <div class="m3-form-engine">
                            <div class="modern-field-container">
                                <label class="modern-field-label">Username Identity</label>
                                <div class="modern-input-capsule">
                                    <i class="fas fa-user-shield field-icon-accent"></i>
                                    <input type="text" class="bootstrap-destroyer-input"
                                           placeholder="Enter your account username" @bind="username" @bind:event="oninput"
                                           @onkeydown="HandleKeyDown" />
                                </div>
                            </div>

                            <div class="modern-field-container">
                                <label class="modern-field-label">Security Credentials</label>
                                <div class="modern-input-capsule">
                                    <i class="fas fa-key field-icon-accent"></i>
                                    <input type="@PasswordInputType" class="bootstrap-destroyer-input password-padding-fix"
                                           placeholder="Enter secure password" @bind="password" @bind:event="oninput"
                                           @onkeydown="HandleKeyDown" />

                                    <button type="button" class="field-eye-toggler-btn" @onclick="TogglePasswordVisibility"
                                            tabindex="-1">
                                        <i class="fas @(isPasswordRenderedText ? "fa-eye-slash" : "fa-eye")"></i>
                                    </button>
                                </div>
                            </div>

                            @if (!string.IsNullOrEmpty(successMessage))
                            {
                                <div class="luxury-error-banner alert-bounce" style="background: #ecfdf5 !important; border-color: #10b981 !important; color: #065f46 !important;">
                                    <div class="error-accent-edge" style="background: #10b981 !important;"></div>
                                    <i class="fas fa-check-circle" style="color: #10b981 !important;"></i>
                                    <span>@successMessage</span>
                                </div>
                            }

                            @if (!string.IsNullOrEmpty(errorMessage))
                            {
                                <div class="luxury-error-banner alert-bounce">
                                    <div class="error-accent-edge"></div>
                                    <i class="fas fa-circle-exclamation"></i>
                                    <span>@errorMessage</span>
                                </div>
                            }
                            <div class="action-button-layer">
                                @if (isLoggingIn)
                                {
                                    <button class="modern-action-btn-processing" disabled>
                                        <div class="btn-spinner-loader"></div> Authenticating user session...
                                    </button>
                                }
                                else
                                {
                                    <button class="modern-action-btn" @onclick="HandleLogin">
                                        <span>Sign In Portal</span>
                                        <i class="fas fa-arrow-right-long arrow-slide-motion"></i>
                                    </button>
                                }
                            </div>
                        </div>
                    }

                    <!-- ── REGISTER FORM ───────────────────────── -->
                    @if (activeTab == "register")
                    {
                        @if (!registerSubmitted)
                        {
                            <h3 class="form-main-headline">Request Account</h3>
                            <p class="form-sub-headline">Semester I ကျောင်းသားများ Account Request တင်ပြပေးပါ။ Admin မှ စစ်ဆေးပြီး Email ဖြင့် အကြောင်းကြားမည်။</p>

                            <div class="m3-form-engine">
                                <!-- Full Name -->
                                <div class="modern-field-container">
                                    <label class="modern-field-label">Full Name <span style="color:#ef4444">*</span></label>
                                    <div class="modern-input-capsule">
                                        <i class="fas fa-user field-icon-accent"></i>
                                        <input type="text" class="bootstrap-destroyer-input"
                                               placeholder="Enter your full name" @bind="reg_FullName" @bind:event="oninput" />
                                    </div>
                                </div>

                                <!-- Email -->
                                <div class="modern-field-container">
                                    <label class="modern-field-label">Email Address <span style="color:#ef4444">*</span></label>
                                    <div class="modern-input-capsule">
                                        <i class="fas fa-envelope field-icon-accent"></i>
                                        <input type="email" class="bootstrap-destroyer-input"
                                               placeholder="Enter your email address" @bind="reg_Email" @bind:event="oninput" />
                                    </div>
                                </div>

                                <!-- Phone -->
                                <div class="modern-field-container">
                                    <label class="modern-field-label">Phone Number</label>
                                    <div class="modern-input-capsule">
                                        <i class="fas fa-phone field-icon-accent"></i>
                                        <input type="text" class="bootstrap-destroyer-input"
                                               placeholder="e.g. 09xxxxxxxxx" @bind="reg_Phone" @bind:event="oninput" />
                                    </div>
                                </div>

                                <!-- Form No & Exam Seat No — side by side -->
                                <div style="display:grid; grid-template-columns:1fr 1fr; gap:14px;">
                                    <div class="modern-field-container">
                                        <label class="modern-field-label">Form No <span style="color:#ef4444">*</span></label>
                                        <div class="modern-input-capsule">
                                            <i class="fas fa-file-alt field-icon-accent"></i>
                                            <input type="text" class="bootstrap-destroyer-input"
                                                   placeholder="တက္ကသိုလ်ဝင် Form No" @bind="reg_FormNo" @bind:event="oninput" />
                                        </div>
                                    </div>
                                    <div class="modern-field-container">
                                        <label class="modern-field-label">Exam Seat No <span style="color:#ef4444">*</span></label>
                                        <div class="modern-input-capsule">
                                            <i class="fas fa-id-card field-icon-accent"></i>
                                            <input type="text" class="bootstrap-destroyer-input"
                                                   placeholder="ဝင်ခုံနံပါတ်" @bind="reg_ExamSeatNo" @bind:event="oninput" />
                                        </div>
                                    </div>
                                </div>

                                @if (!string.IsNullOrEmpty(registerError))
                                {
                                    <div class="luxury-error-banner alert-bounce">
                                        <div class="error-accent-edge"></div>
                                        <i class="fas fa-circle-exclamation"></i>
                                        <span>@registerError</span>
                                    </div>
                                }

                                <div class="action-button-layer">
                                    @if (isRegistering)
                                    {
                                        <button class="modern-action-btn-processing" disabled>
                                            <div class="btn-spinner-loader"></div> Submitting request...
                                        </button>
                                    }
                                    else
                                    {
                                        <button class="modern-action-btn" @onclick="HandleRegister">
                                            <span>Submit Request</span>
                                            <i class="fas fa-paper-plane arrow-slide-motion"></i>
                                        </button>
                                    }
                                </div>
                            </div>
                        }
                        else
                        {
                            <!-- Success state after submission -->
                            <div class="register-success-state">
                                <div class="success-icon-ring">
                                    <i class="fas fa-check"></i>
                                </div>
                                <h3 class="form-main-headline" style="text-align:center; color:#10b981 !important;">Request Submitted!</h3>
                                <p class="form-sub-headline" style="text-align:center;">
                                    Account Request တင်ပြမှု အောင်မြင်ပါသည်။<br />
                                    Admin မှ စစ်ဆေးပြီးနောက် <strong style="color:#2563eb;">@reg_Email</strong> သို့ Email ဖြင့် အကြောင်းကြားပါမည်။
                                </p>
                                <button class="modern-action-btn" @onclick='() => SwitchTab("login")' style="margin-top:8px;">
                                    <span>Back to Sign In</span>
                                    <i class="fas fa-sign-in-alt"></i>
                                </button>
                            </div>
                        }
                    }
                }

                <div class="split-right-footer">
                    <p>&copy; @DateTime.Now.Year PUMUB Subsystem. All Rights Reserved.</p>
                </div>
            </div>
        </div>

    </div>
</div>

<style>
    .split-viewport-wrapper {
        font-family: 'Plus Jakarta Sans', sans-serif !important;
        background: linear-gradient(135deg, #f8fafc 0%, #e2e8f0 100%) !important;
        min-height: 100vh;
        display: flex;
        align-items: center;
        justify-content: center;
        padding: 40px 24px;
    }

    /* ─── Main Card ─────────────────────────────── */
    .split-main-card {
        width: 100%;
        max-width: 960px;
        min-height: 560px;
        background: #ffffff !important;
        border-radius: 28px !important;
        box-shadow: 0 25px 60px -15px rgba(0, 0, 0, 0.4);
        display: flex;
        overflow: hidden;
        transition: max-width 0.35s ease;
    }

    .split-main-card.register-expanded {
        max-width: 1040px;
    }

    /* ─── Left Blue Panel ───────────────────────── */
    .split-left-panel {
        flex: 1.1;
        background: url('/images/university-bg.jpg') no-repeat center center/cover;
        background-color: #1e40af;
        position: relative;
        display: flex;
        align-items: center;
        padding: 48px;
    }

    .left-panel-overlay {
        position: absolute;
        top: 0; left: 0;
        width: 100%; height: 100%;
        background: linear-gradient(135deg, rgba(29, 78, 216, 0.95), rgba(3, 105, 161, 0.9));
        z-index: 1;
    }

    .left-panel-content {
        position: relative;
        z-index: 2;
        color: #ffffff !important;
        display: flex;
        flex-direction: column;
        gap: 18px;
    }

    .welcome-text {
        font-size: 1.1rem;
        font-weight: 500;
        color: rgba(255, 255, 255, 0.8);
        letter-spacing: 0.02em;
    }

    .brand-emblem-sphere {
        width: 64px; height: 64px;
        background: rgba(255, 255, 255, 0.15);
        backdrop-filter: blur(8px);
        border: 1px solid rgba(255, 255, 255, 0.25);
        border-radius: 20px;
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 1.6rem;
    }

    .brand-title {
        font-size: 2.2rem;
        font-weight: 800;
        letter-spacing: -0.02em;
        margin: 0;
    }

    .brand-description {
        font-size: 0.92rem;
        color: rgba(255, 255, 255, 0.75);
        line-height: 1.6;
        margin: 0;
        max-width: 360px;
    }

    .brand-meta-tags {
        display: flex;
        gap: 10px;
        font-size: 0.7rem;
        font-weight: 700;
        color: rgba(255, 255, 255, 0.4);
        letter-spacing: 0.08em;
        margin-top: 24px;
    }

    /* ─── Right Panel ───────────────────────────── */
    .split-right-panel {
        flex: 1;
        background: #ffffff !important;
        display: flex;
        align-items: center;
        padding: 40px 48px;
        overflow-y: auto;
    }

    .right-panel-content {
        width: 100%;
        display: flex;
        flex-direction: column;
        gap: 20px;
    }

    /* ─── Auth Tab Bar ──────────────────────────── */
    .auth-tab-bar {
        display: flex;
        gap: 4px;
        background: #f1f5f9;
        border-radius: 14px;
        padding: 5px;
    }

    .auth-tab {
        flex: 1;
        padding: 9px 16px;
        border: none;
        border-radius: 10px;
        font-size: 0.85rem;
        font-weight: 600;
        color: #64748b;
        background: transparent;
        cursor: pointer;
        transition: all 0.2s ease;
        display: flex;
        align-items: center;
        justify-content: center;
        gap: 6px;
    }

    .auth-tab.active {
        background: #ffffff;
        color: #1d4ed8;
        box-shadow: 0 2px 8px rgba(0, 0, 0, 0.08);
    }

    .auth-tab:hover:not(.active) {
        color: #475569;
        background: rgba(255,255,255,0.6);
    }

    /* ─── Form Headline ─────────────────────────── */
    .form-main-headline {
        font-size: 1.5rem;
        font-weight: 800;
        color: #0f172a !important;
        margin: 0;
        letter-spacing: -0.01em;
    }

    .form-sub-headline {
        font-size: 0.87rem;
        color: #64748b !important;
        margin: 0;
        line-height: 1.55;
    }

    .m3-form-engine {
        display: flex;
        flex-direction: column;
        gap: 18px;
    }

    .modern-field-container {
        display: flex;
        flex-direction: column;
        gap: 7px;
    }

    .modern-field-label {
        font-size: 0.82rem;
        font-weight: 600;
        color: #475569 !important;
        padding-left: 2px;
    }

    .modern-input-capsule {
        background: #f8fafc !important;
        border: 1px solid #e2e8f0 !important;
        border-radius: 50px !important;
        padding: 0 20px !important;
        display: flex !important;
        align-items: center !important;
        position: relative !important;
        width: 100% !important;
        height: 50px !important;
        box-shadow: inset 0 2px 4px rgba(0, 0, 0, 0.04) !important;
        transition: all 0.2s ease;
    }

    .modern-input-capsule:focus-within {
        border-color: #2563eb !important;
        background: #ffffff !important;
        box-shadow: inset 0 1px 2px rgba(0, 0, 0, 0.02), 0 0 0 3px rgba(37, 99, 235, 0.15) !important;
    }

    .field-icon-accent {
        font-size: 0.95rem;
        color: #94a3b8 !important;
        margin-right: 12px !important;
    }

    .modern-input-capsule:focus-within .field-icon-accent {
        color: #2563eb !important;
    }

    .modern-input-capsule input,
    .modern-input-capsule input[type="text"],
    .modern-input-capsule input[type="password"],
    .modern-input-capsule input[type="email"],
    .bootstrap-destroyer-input {
        flex: 1 !important;
        width: 100% !important;
        height: 100% !important;
        background: transparent !important;
        background-color: transparent !important;
        border: none !important;
        color: #0f172a !important;
        font-size: 0.92rem !important;
        font-weight: 550 !important;
        outline: none !important;
        box-shadow: none !important;
        padding: 0 !important;
        margin: 0 !important;
    }

    .bootstrap-destroyer-input::placeholder {
        color: #94a3b8 !important;
        font-weight: 400;
    }

    .password-padding-fix {
        padding-right: 30px !important;
    }

    .field-eye-toggler-btn {
        position: absolute !important;
        right: 20px !important;
        top: 50% !important;
        transform: translateY(-50%) !important;
        background: transparent !important;
        border: none !important;
        color: #94a3b8 !important;
        cursor: pointer !important;
        padding: 0 !important;
        font-size: 0.95rem !important;
        display: flex !important;
        align-items: center !important;
        justify-content: center !important;
        z-index: 5 !important;
    }

    .field-eye-toggler-btn:hover {
        color: #475569 !important;
    }

    /* ─── Action Button ─────────────────────────── */
    .modern-action-btn {
        width: 100% !important;
        height: 50px !important;
        background: linear-gradient(135deg, #1d4ed8, #2563eb) !important;
        color: #ffffff !important;
        border: none !important;
        border-radius: 50px !important;
        font-size: 0.95rem !important;
        font-weight: 700 !important;
        cursor: pointer !important;
        display: flex !important;
        align-items: center !important;
        justify-content: center !important;
        gap: 8px !important;
        box-shadow: 0 4px 14px rgba(37, 99, 235, 0.25) !important;
        transition: all 0.2s ease;
    }

    .modern-action-btn:hover {
        background: linear-gradient(135deg, #2563eb, #3b82f6) !important;
        box-shadow: 0 6px 18px rgba(37, 99, 235, 0.35) !important;
        transform: translateY(-1px) !important;
    }

    .arrow-slide-motion {
        transition: transform 0.2s ease;
        font-size: 0.85rem;
    }

    .modern-action-btn:hover .arrow-slide-motion {
        transform: translateX(4px);
    }

    .modern-action-btn-processing {
        width: 100% !important;
        height: 50px !important;
        background: #e2e8f0 !important;
        color: #94a3b8 !important;
        border: none !important;
        border-radius: 50px !important;
        font-weight: 600 !important;
        display: flex !important;
        align-items: center !important;
        justify-content: center !important;
        gap: 10px !important;
        cursor: not-allowed !important;
    }

    /* ─── Error Banner ──────────────────────────── */
    .luxury-error-banner {
        background: #fef2f2 !important;
        border: 1px solid #fca5a5 !important;
        color: #991b1b !important;
        padding: 12px 16px !important;
        border-radius: 12px !important;
        font-size: 0.85rem !important;
        display: flex !important;
        align-items: center !important;
        gap: 10px !important;
        font-weight: 500 !important;
        position: relative !important;
        overflow: hidden !important;
    }

    .error-accent-edge {
        position: absolute;
        left: 0; top: 0; bottom: 0;
        width: 4px;
        background: #ef4444 !important;
    }

    /* ─── Register Success State ────────────────── */
    .register-success-state {
        display: flex;
        flex-direction: column;
        align-items: center;
        gap: 16px;
        text-align: center;
        padding: 20px 0;
    }

    .success-icon-ring {
        width: 72px; height: 72px;
        background: linear-gradient(135deg, #10b981, #059669);
        border-radius: 50%;
        display: flex;
        align-items: center;
        justify-content: center;
        color: white;
        font-size: 1.8rem;
        box-shadow: 0 8px 24px rgba(16, 185, 129, 0.4);
        animation: popIn 0.4s cubic-bezier(0.34, 1.56, 0.64, 1);
    }

    @@keyframes popIn {
        from { transform: scale(0.5); opacity: 0; }
        to   { transform: scale(1);   opacity: 1; }
    }

    /* ─── Footer ────────────────────────────────── */
    .split-right-footer {
        text-align: center;
        font-size: 0.72rem;
        color: #94a3b8 !important;
        font-weight: 600;
        margin-top: 8px;
    }

    /* ─── Responsive ────────────────────────────── */
    @@media (max-width: 768px) {
        .split-main-card {
            flex-direction: column !important;
            min-height: auto !important;
            border-radius: 20px !important;
        }

        .split-left-panel {
            padding: 36px 24px !important;
            text-align: center !important;
        }

        .left-panel-content { align-items: center !important; }
        .brand-description  { max-width: 100% !important; }
        .split-right-panel  { padding: 32px 20px !important; }
        .brand-meta-tags    { display: none !important; }
    }

    /* ─── Animations ────────────────────────────── */
    .alert-bounce {
        animation: miniBounce 0.2s cubic-bezier(0.34, 1.56, 0.64, 1);
    }

    @@keyframes miniBounce {
        0%   { transform: scale(0.97); opacity: 0; }
