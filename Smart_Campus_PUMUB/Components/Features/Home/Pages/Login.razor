@page "/login"
@layout EmptyLayout
@using Microsoft.EntityFrameworkCore
@using Smart_Campus_PUMUB.Database.AppDbContext
@using Smart_Campus_PUMUB.Components.Shared.Layout
@using Microsoft.AspNetCore.Components.Authorization
@using Smart_Campus_PUMUB.Components.Features.Services
@inject SmartCampusDbContext DbContext
@inject AuthenticationStateProvider AuthStateProvider
@inject NavigationManager NavigationManager
@inject IJSRuntime JSRuntime

<link href="https://fonts.googleapis.com/css2?family=Plus+Jakarta+Sans:wght@300;400;500;600;700;800&display=swap"
      rel="stylesheet">
<link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.0/css/all.min.css">

<div class="split-viewport-wrapper">
    <div class="split-main-card">
        <div class="split-left-panel"
             style="display: flex; flex-direction: column; align-items: center; justify-content: center; text-align: center;">
            <div class="left-panel-overlay"></div>
            <div class="left-panel-content" style="z-index: 1;">
                <span class="welcome-text">Welcome to</span>
                <div class="nav-brand" style="margin: 20px 0;">
                    <div class="logo"
                         style="background-color: white; border-radius: 50%; width: 120px; height: 120px; display: flex; align-items: center; justify-content: center; margin: 0 auto;">
                        <img src="/puu.png" alt="logo" style="width: 100px; height: 100px;">
                    </div>
                </div>
                <h2 class="brand-title">Polytechnic University</h2>
                <p class="brand-description">
                    A premier knowledge gateway dedicated to advancing technologies and
                    empowering future innovations.
                </p>
                <div class="brand-meta-tags">
                    <span>MAUBIN CAMPUS</span> · <span>PORTAL V2.0</span>
                </div>
            </div>
        </div>

        <div class="split-right-panel">
            <div class="right-panel-content">
                <h3 class="form-main-headline">Sign In to Account</h3>
                <p class="form-sub-headline">Please enter your campus credentials below.</p>

                <div class="m3-form-engine">
                    <div class="modern-field-container">
                        <label class="modern-field-label">Username</label>
                        <div class="modern-input-capsule">
                            <i class="fas fa-user-shield field-icon-accent"></i>
                            <input type="text" class="bootstrap-destroyer-input" placeholder="Enter your username"
                                   @bind="username" @onkeydown="HandleKeyDown" />
                        </div>
                    </div>

                    <div class="modern-field-container">
                        <label class="modern-field-label">Password</label>
                        <div class="modern-input-capsule">
                            <i class="fas fa-key field-icon-accent"></i>
                            <input type="@PasswordInputType" class="bootstrap-destroyer-input password-padding-fix"
                                   placeholder="••••••••" @bind="password" @onkeydown="HandleKeyDown" />
                            <button type="button" class="field-eye-toggler-btn" @onclick="TogglePasswordVisibility"
                                    tabindex="-1">
                                <i class="fas @(isPasswordRenderedText ? "fa-eye-slash" : "fa-eye")"></i>
                            </button>
                        </div>
                    </div>

                    @if (!string.IsNullOrEmpty(errorMessage))
                    {
                        <div class="luxury-error-banner alert-bounce">
                            <i class="fas fa-circle-exclamation"></i> <span>@errorMessage</span>
                        </div>
                    }

                    <div class="action-button-layer" style="display: flex; gap: 15px; margin-top: 20px;">
                        <a href="/" class="modern-action-btn"
                           style="text-decoration: none; text-align: center; background: #6b7280;">Home Page</a>

                        @if (isLoggingIn)
                        {
                            <button class="modern-action-btn" disabled>Authenticating...</button>
                        }
                        else
                        {
                            <button type="button" class="modern-action-btn" @onclick="HandleLogin">
                                <span>Sign In</span> <i class="fas fa-arrow-right"></i>
                            </button>
                        }
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

<style>
    /* Home Page Button Style to match Sign In */
    .modern-action-btn1 {
        display: inline-flex;
        align-items: center;
        justify-content: center;
        padding: 12px 24px;
        border-radius: 8px;
        font-weight: 600;
        transition: all 0.3s ease;
        background-color: #6c757d;
        /* Gray color for Home */
        color: white;
    }

        .modern-action-btn1:hover {
            background-color: #5a6268;
        }
</style>

@code {
    private string username = "";
    private string password = "";
    private string errorMessage = "";
    private bool isLoggingIn = false;
    private bool isPasswordRenderedText = false;
    private string PasswordInputType => isPasswordRenderedText ? "text" : "password";

    private void TogglePasswordVisibility() => isPasswordRenderedText = !isPasswordRenderedText;

    @* private async Task HandleLogin()
    {
