@using Smart_Campus_PUMUB.BlazorServer.Frontend.Services
@inject HttpClientService HttpClientService

@code {
    private string username = "";
    private string password = "";
    private string newPassword = "";
    private string confirmPassword = "";
    private string errorMessage = "";
    private string successMessage = "";
    private bool isLoggingIn = false;
    private bool isChangePasswordMode = false;
    private bool isChangingPassword = false;

    // Tab: "login" or "register"
    private string activeTab = "login";

    // Register fields
    private string reg_FullName = "";
    private string reg_Email = "";
    private string reg_Phone = "";
    private string reg_FormNo = "";
    private string reg_ExamSeatNo = "";
    private string registerError = "";
    private bool isRegistering = false;
    private bool registerSubmitted = false;

    // PASSWORD VISIBILITY ENGINE STATE
    private bool isPasswordRenderedText = false;
    private bool isNewPasswordRenderedText = false;
    private bool isConfirmPasswordRenderedText = false;

    private string PasswordInputType => isPasswordRenderedText ? "text" : "password";
    private string NewPasswordInputType => isNewPasswordRenderedText ? "text" : "password";
    private string ConfirmPasswordInputType => isConfirmPasswordRenderedText ? "text" : "password";

    private void TogglePasswordVisibility()    => isPasswordRenderedText = !isPasswordRenderedText;
    private void ToggleNewPasswordVisibility() => isNewPasswordRenderedText = !isNewPasswordRenderedText;
    private void ToggleConfirmPasswordVisibility() => isConfirmPasswordRenderedText = !isConfirmPasswordRenderedText;

    private void SwitchTab(string tab)
    {
        activeTab = tab;
        errorMessage = "";
        successMessage = "";
        registerError = "";
        registerSubmitted = false;
    }

    private void CancelChangePassword()
    {
        isChangePasswordMode = false;
        errorMessage = "";
        newPassword = "";
        confirmPassword = "";
    }

    protected override async Task OnInitializedAsync()
    {
        var authState = await AuthStateProvider.GetAuthenticationStateAsync();
        var user = authState.User;

        if (user.Identity != null && user.Identity.IsAuthenticated)
        {
            if (user.IsInRole("Admin") || user.IsInRole("Tutor") || user.IsInRole("admin") || user.IsInRole("tutor"))
                NavigationManager.NavigateTo("/admin/dashboard");
            else
                NavigationManager.NavigateTo("/");
        }
    }

    // ── Login ──────────────────────────────────────────────────────────────
    public class LoginResponseModel
    {
        public bool IsSuccess { get; set; }
        public bool MustChangePassword { get; set; }
        public string Message { get; set; } = string.Empty;
        public int UserId { get; set; }
        public string FullName { get; set; } = string.Empty;
        public int RoleId { get; set; }
        public string Role { get; set; } = string.Empty;
        public string Token { get; set; } = string.Empty;
        public List<string> Permissions { get; set; } = new();
    }

    private async Task HandleLogin()
    {
        if (isLoggingIn) return;
        if (string.IsNullOrWhiteSpace(username) || string.IsNullOrWhiteSpace(password))
        {
            errorMessage = "Please enter your username and security key.";
            successMessage = "";
            return;
        }

        try
        {
            isLoggingIn = true;
            errorMessage = "";
            successMessage = "";

            var requestModel = new { UserName = username, Password = password };
            var response = await HttpClientService.ExecuteAsync<LoginResponseModel>(
                "auth/login",
                EnumHttpMethod.Post,
                requestModel
            );

            if (response != null && response.IsSuccess)
            {
                if (response.MustChangePassword)
                {
                    isChangePasswordMode = true;
                    errorMessage = response.Message;
                    return;
                }

                Console.WriteLine($"====== ဒီ User ရဲ့ Role က {response.Role} ပါ ======");
                Console.WriteLine($"====== DB ထဲကနေ Permission ({response.Permissions.Count}) ခု တွေ့ပါတယ် ======");

                var customAuth = (CustomAuthStateProvider)AuthStateProvider;
                await customAuth.UpdateAuthenticationState(new UserSession
                {
                    UserId = response.UserId,
                    Username = username,
                    Role = response.Role,
                    Permissions = response.Permissions,
                    Token = response.Token
                });

                await JS.InvokeVoidAsync("sessionStorage.setItem", "islogined", "true");
                await JS.InvokeVoidAsync("sessionStorage.setItem", "rolename", response.Role);

                string roleName = response.Role.ToLower();
                if (roleName.Contains("admin") || roleName.Contains("tutor"))
                    NavigationManager.NavigateTo("/admin/dashboard");
                else
                    NavigationManager.NavigateTo("/");
            }
            else
            {
                errorMessage = response?.Message ?? "Invalid login credentials. Please re-check.";
            }
        }
        catch (Exception ex)
        {
            errorMessage = $"System Error: {ex.Message}";
        }
        finally
        {
            isLoggingIn = false;
        }
    }

    // ── Register ───────────────────────────────────────────────────────────
    private class RegisterAccResponse
    {
        public bool IsSuccess { get; set; }
        public string? Message { get; set; }
    }

    private async Task HandleRegister()
    {
        if (isRegistering) return;
        registerError = "";

        if (string.IsNullOrWhiteSpace(reg_FullName))       { registerError = "Full Name ထည့်ပေးပါ။"; return; }
        if (string.IsNullOrWhiteSpace(reg_Email))           { registerError = "Email ထည့်ပေးပါ။"; return; }
        if (!reg_Email.Contains("@"))                       { registerError = "မှန်ကန်သော Email ထည့်ပေးပါ။"; return; }
        if (string.IsNullOrWhiteSpace(reg_FormNo))          { registerError = "Form No ထည့်ပေးပါ။"; return; }
        if (string.IsNullOrWhiteSpace(reg_ExamSeatNo))      { registerError = "Exam Seat No ထည့်ပေးပါ။"; return; }

        try
        {
            isRegistering = true;

            var payload = new
            {
                FullName = reg_FullName.Trim(),
                Email = reg_Email.Trim(),
                Phone = reg_Phone.Trim(),
                FormNo = reg_FormNo.Trim(),
                ExamSeatNo = reg_ExamSeatNo.Trim()
            };

            // Use HttpClientFactory directly — no auth token needed for public endpoint
            var client = HttpClientFactory.CreateClient("SmartCampusApi");
            var jsonStr = System.Text.Json.JsonSerializer.Serialize(payload);
            var httpContent = new System.Net.Http.StringContent(jsonStr, System.Text.Encoding.UTF8, "application/json");
            var httpResponse = await client.PostAsync("registeracc", httpContent);
            var resJson = await httpResponse.Content.ReadAsStringAsync();

            RegisterAccResponse? response = null;
            if (!string.IsNullOrWhiteSpace(resJson))
            {
                try
                {
                    response = System.Text.Json.JsonSerializer.Deserialize<RegisterAccResponse>(
                        resJson,
                        new System.Text.Json.JsonSerializerOptions { PropertyNameCaseInsensitive = true }
                    );
                }
                catch (System.Text.Json.JsonException jsonEx)
                {
                    var preview = resJson.Length > 200 ? resJson[..200] + "..." : resJson;
                    registerError = $"API returned non-JSON response: \"{preview}\" (Error: {jsonEx.Message})";
                    return;
                }
            }

            if (response != null && response.IsSuccess)
            {
                registerSubmitted = true;
            }
            else
            {
                registerError = response?.Message
                    ?? $"Request တင်ရာတွင် အမှားဖြစ်ပါသည်။ (HTTP {(int)httpResponse.StatusCode})";
            }
        }
        catch (Exception ex)
        {
            registerError = $"System Error: {ex.Message}";
        }
        finally
        {
            isRegistering = false;
        }
    }

    // ── Change Password ────────────────────────────────────────────────────
    private async Task HandleChangePassword()
    {
        if (isChangingPassword) return;
        if (string.IsNullOrWhiteSpace(newPassword) || string.IsNullOrWhiteSpace(confirmPassword))
        {
            errorMessage = "Please enter and confirm your new password.";
            return;
        }

        if (newPassword != confirmPassword)
        {
            errorMessage = "Passwords do not match.";
            return;
        }

        if (newPassword.Length < 8)
        {
            errorMessage = "Password သည် အနည်းဆုံး ၈ လုံး ရှိရမည်။";
            return;
        }

        try
        {
            isChangingPassword = true;
            errorMessage = "";
            successMessage = "";

            var changeRequest = new
            {
                UserName = username,
                CurrentPassword = password,
                NewPassword = newPassword
            };

            var changeResponse = await HttpClientService.ExecuteAsync<LoginResponseModel>(
                "auth/change-password",
                EnumHttpMethod.Post,
                changeRequest
            );

            if (changeResponse != null && changeResponse.IsSuccess)
            {
                successMessage = changeResponse.Message;
                isChangePasswordMode = false;
                password = "";
                newPassword = "";
                confirmPassword = "";
            }
            else
            {
                errorMessage = changeResponse?.Message ?? "Failed to change password. Please try again.";
            }
        }
        catch (Exception ex)
        {
            errorMessage = $"System Error: {ex.Message}";
        }
        finally
        {
            isChangingPassword = false;
        }
    }

    private async Task HandleKeyDown(KeyboardEventArgs e)
    {
        if (e.Key == "Enter") await HandleLogin();
    }

    private async Task HandleChangePasswordKeyDown(KeyboardEventArgs e)
    {
        if (e.Key == "Enter") await HandleChangePassword();
    }
}