    private async Task HandleLogin()
    {
        if (string.IsNullOrWhiteSpace(username) || string.IsNullOrWhiteSpace(password))
        {
            errorMessage = "Please enter username and password.";
            return;
        }

        isLoggingIn = true;
        try
        {
            var user = await DbContext.Users
                .Include(u => u.Role)
                .FirstOrDefaultAsync(u => u.UserName == username && u.IsDelete != true);

            if (user != null && BCrypt.Net.BCrypt.Verify(password, user.Password))
            {
                var customAuth = (CustomAuthStateProvider)AuthStateProvider;
                await customAuth.UpdateAuthenticationState(new UserSession
                {
                    Username = user.UserName,
                    Role = user.Role.RoleName,
                    UserId = user.UserId
                });

                // Role ကို စစ်ပြီး Redirect လုပ်ခြင်း
                string roleName = user.Role.RoleName.ToLower();

                // Admin ဖြစ်လျှင် Admin Dashboard သို့
                if (roleName.Contains("admin"))
                {
                    NavigationManager.NavigateTo("/admin/dashboard", true);
                }
                // ကျောင်းသား (Student) သို့မဟုတ် အခြားသူများဖြစ်လျှင် Home Page သို့
                else
                {
                    NavigationManager.NavigateTo("/", true);
                }

                await JSRuntime.InvokeVoidAsync("localStorage.setItem", "isLoggedIn", "true");
            }
            else
            {
                errorMessage = "Invalid credentials!";
            }
        }
        catch (Exception ex)
        {
            errorMessage = $"Error: {ex.Message}";
        }
        finally
        {
            isLoggingIn = false;
        }
    }

    private async Task HandleKeyDown(KeyboardEventArgs e) { if (e.Key == "Enter") await HandleLogin(); }
}