                        <i class="fas fa-undo"></i> Clear
                    </button>
                }
            </div>
        </div>

        
        <div class="faculties-grid" data-aos="fade-up">
            @* 🌟 [FIXED BY KHIN KHIN]: API ကနေ ဒေတာမကျလာခင် Modern Neon Shimmer Skeleton ကတ်ပြားလေးတွေ အရင်ပြထားမည့်စနစ် *@
            @if (filteredFaculties == null || masterFaculties == null || !masterFaculties.Any())
            {
                @for (int i = 0; i < 3; i++) // 💡 ကတ်ပြား ၃ ကတ်စာ Skeleton Loading အပြိုင်ပွင့်နေပါမည်
                {
                    <div class="skeleton-faculty-card">
                        <div class="skeleton-img-glow">
                            <div class="skeleton-shimmer-line"></div>
                        </div>
                        <div class="skeleton-body-glow">
                            <div class="skeleton-title-line">
                                <div class="skeleton-shimmer-line"></div>
                            </div>
                            <div class="skeleton-meta-line">
                                <div class="skeleton-shimmer-line"></div>
                            </div>
                        </div>
                    </div>
                }
            }
            else if (filteredFaculties.Count == 0)
            {
                <p class="status-msg-text">No faculties match your search.</p>
            }
            else
            {
                @foreach (var faculty in filteredFaculties)
                {
                    <div class="faculty-card" data-aos="fade-up">
                        <div class="faculty-img">
                            <img src="@GetDefaultFacultyImage(faculty.FacultyName)" alt="@faculty.FacultyName">
                            <div class="faculty-overlay"></div>
                            <div class="faculty-icon">
                                <i class="@GetFacultyIcon(faculty.FacultyName)"></i>
                            </div>
                        </div>
                        <div class="faculty-body">
                            <h3>@faculty.FacultyName</h3>

                            <div class="faculty-meta" style="margin-top: 20px;">
                                <span class="faculty-students">
                                    <i class="fas fa-graduation-cap"></i> Academic Portal Verified
                                </span>
                                @* <a href="#programs" class="btn-sm">Learn More</a> *@
                            </div>
                        </div>
                    </div>
                }
            }
        </div>
        

    </div>
</section>

