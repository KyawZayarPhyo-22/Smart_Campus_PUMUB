@using Microsoft.AspNetCore.Mvc.RazorPages
@page "/faculties"

<!-- FACULTIES -->
<section id="faculties" style="margin-top:50px">
  <div class="container">
    <div class="section-header" data-aos="fade-up">
      <div>
        <div class="section-tag"><i class="fas fa-building"></i> Academic Excellence</div>
        <h2 class="section-title">Our <span>Departments</span></h2>
        <p class="section-desc">World-class engineering and technology departments led by distinguished academics and
          industry experts.</p>
      </div>
      <a href="#programs" class="view-all">View All Programs <i class="fas fa-arrow-right"></i></a>
    </div>
    <div class="faculties-grid">
      <div class="faculty-card" data-aos="fade-up" data-aos-delay="0">
        <div class="faculty-img">
          <img src="https://images.unsplash.com/photo-1504328345606-18bbc8c9d7d1?w=600&q=80" alt="Civil Engineering">
          <div class="faculty-overlay"></div>
          <div class="faculty-icon"><i class="fas fa-drafting-compass"></i></div>
        </div>
        <div class="faculty-body">
          <h3>Civil Engineering</h3>
          <p>Designing sustainable infrastructure and structures. Specializations in structural, geotechnical, and water
            resources engineering.</p>
          <div class="faculty-meta">
            <span class="faculty-students"><i class="fas fa-user-graduate"></i> 1,800 Students</span>
            <a href="#programs" class="btn-sm">Learn More</a>
          </div>
        </div>
      </div>
      <div class="faculty-card" data-aos="fade-up" data-aos-delay="80">
        <div class="faculty-img">
          <img src="https://images.unsplash.com/photo-1581092921461-eab62e97a780?w=600&q=80"
            alt="Mechanical Engineering">
          <div class="faculty-overlay"></div>
          <div class="faculty-icon"><i class="fas fa-cog"></i></div>
        </div>
        <div class="faculty-body">
          <h3>Mechanical Engineering</h3>
          <p>From thermodynamics to machine design, our graduates power Myanmar's manufacturing and industrial sectors.
          </p>
          <div class="faculty-meta">
            <span class="faculty-students"><i class="fas fa-user-graduate"></i> 1,500 Students</span>
            <a href="#programs" class="btn-sm">Learn More</a>
          </div>
        </div>
      </div>
      <div class="faculty-card" data-aos="fade-up" data-aos-delay="160">
        <div class="faculty-img">
          <img src="https://images.unsplash.com/photo-1473341304170-971dccb5ac1e?w=600&q=80"
            alt="Electrical Engineering">
          <div class="faculty-overlay"></div>
          <div class="faculty-icon"><i class="fas fa-bolt"></i></div>
        </div>
        <div class="faculty-body">
          <h3>Electrical Engineering</h3>
          <p>Power systems, renewable energy, and electrical machines. Powering the future of Myanmar's energy sector.
          </p>
          <div class="faculty-meta">
            <span class="faculty-students"><i class="fas fa-user-graduate"></i> 1,600 Students</span>
            <a href="#programs" class="btn-sm">Learn More</a>
          </div>
        </div>
      </div>
      <div class="faculty-card" data-aos="fade-up" data-aos-delay="240">
        <div class="faculty-img">
          <img src="https://images.unsplash.com/photo-1518770660439-4636190af475?w=600&q=80"
            alt="Electronic Engineering">
          <div class="faculty-overlay"></div>
          <div class="faculty-icon"><i class="fas fa-microchip"></i></div>
        </div>
        <div class="faculty-body">
          <h3>Electronic Engineering</h3>
          <p>Circuits, embedded systems, and telecommunications. Developing the engineers behind modern electronics.</p>
          <div class="faculty-meta">
            <span class="faculty-students"><i class="fas fa-user-graduate"></i> 1,200 Students</span>
            <a href="#programs" class="btn-sm">Learn More</a>
          </div>
        </div>
      </div>
      <div class="faculty-card" data-aos="fade-up" data-aos-delay="320">
        <div class="faculty-img">
          <img src="https://images.unsplash.com/photo-1517694712202-14dd9538aa97?w=600&q=80"
            alt="Information Technology">
          <div class="faculty-overlay"></div>
          <div class="faculty-icon"><i class="fas fa-laptop-code"></i></div>
        </div>
        <div class="faculty-body">
          <h3>Information Technology</h3>
          <p>Software development, networking, AI and data science. Preparing IT professionals for the digital economy.
          </p>
          <div class="faculty-meta">
            <span class="faculty-students"><i class="fas fa-user-graduate"></i> 2,000 Students</span>
            <a href="#programs" class="btn-sm">Learn More</a>
          </div>
        </div>
      </div>
      <div class="faculty-card" data-aos="fade-up" data-aos-delay="400">
        <div class="faculty-img">
          <img src="https://images.unsplash.com/photo-1507003211169-0a1dd7228f2d?w=600&q=80" alt="Chemical Engineering">
          <div class="faculty-overlay"></div>
          <div class="faculty-icon"><i class="fas fa-flask"></i></div>
        </div>
        <div class="faculty-body">
          <h3>Chemical Engineering</h3>
          <p>Process engineering, materials science and environmental engineering for sustainable development.</p>
          <div class="faculty-meta">
            <span class="faculty-students"><i class="fas fa-user-graduate"></i> 800 Students</span>
            <a href="#programs" class="btn-sm">Learn More</a>
          </div>
        </div>
      </div>
    </div>
  </div>
</section>