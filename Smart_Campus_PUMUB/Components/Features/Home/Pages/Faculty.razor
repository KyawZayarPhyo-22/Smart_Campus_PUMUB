<section id="faculties" style="margin-top:50px">
  <div class="container">
    <div class="section-header">
      <div>
        <div class="section-tag"><i class="fas fa-building"></i> Academic Excellence</div>
        <h2 class="section-title">University <span>Departments</span></h2>

      </div>
    </div>
    <div class="" style="display: flex;justify-content: space-between;">
      <div class="programs-tabs">
        <button class="tab-btn active" onclick="filterPrograms('all')">All Departments</button>
        <button class="tab-btn" onclick="filterPrograms('undergraduate')">Faculty of Computing</button>
        <button class="tab-btn" onclick="filterPrograms('postgraduate')">Faculty of Engineering</button>

      </div>
      <div class="">
        <div class="input-group rounded-pill shadow-sm bg-white"
          style="max-width: 400px; border: 1px solid #e0e0e0; overflow: hidden;">

          <input type="text" class="form-control border-0 shadow-none px-4" placeholder="Search" aria-label="Search"
            style="background-color: transparent;">

          <button class="btn border-0 shadow-none px-4" type="button"
            style="color: #5A4FCF; background-color: transparent;">
            <i class="fas fa-search" style="font-size: 1.2rem; font-weight: bold;"></i>
          </button>

        </div>
      </div>
    </div>

    <div class="faculties-grid">
      <div class="faculty-card" data-aos-delay="0">
        <div class="faculty-img">
          <img src="https://images.unsplash.com/photo-1504328345606-18bbc8c9d7d1?w=600&q=80" alt="Civil Engineering">
          <div class="faculty-overlay"></div>

        </div>
        <div class="faculty-body">
          <h3>Civil Engineering</h3>
          <p class="truncate-text">Designing sustainable infrastructure and structures. Specializations in structural,
            geotechnical, and water
            resources engineering.Designing sustainable infrastructure and structures. Specializations in structural,
            geotechnical, and water
            resources engineering.</p>
          <div class="faculty-meta">
            <span class="faculty-students"></span>
            <a href="#programs" class="btn-sm">Learn More</a>
          </div>
        </div>
      </div>
      <div class="faculty-card" data-aos-delay="80">
        <div class="faculty-img">
          <img src="https://images.unsplash.com/photo-1581092921461-eab62e97a780?w=600&q=80"
            alt="Mechanical Engineering">
          <div class="faculty-overlay"></div>

        </div>
        <div class="faculty-body">
          <h3>Mechanical Engineering</h3>
          <p>From thermodynamics to machine design, our graduates power Myanmar's manufacturing and industrial sectors.
          </p>
          <div class="faculty-meta">
            <span class="faculty-students"></span>
            <a href="#programs" class="btn-sm">Learn More</a>
          </div>
        </div>
      </div>
      <div class="faculty-card" data-aos-delay="160">
        <div class="faculty-img">
          <img src="https://images.unsplash.com/photo-1473341304170-971dccb5ac1e?w=600&q=80"
            alt="Electrical Engineering">
          <div class="faculty-overlay"></div>

        </div>
        <div class="faculty-body">
          <h3>Electrical Engineering</h3>
          <p>Power systems, renewable energy, and electrical machines. Powering the future of Myanmar's energy sector.
          </p>
          <div class="faculty-meta">
            <span class="faculty-students"><i class="fas fa-user-graduate"></i> 1,600 Students</span>
            <a href="#programs" class="btn-sm">Learn More</a>
          </div>
        </div>
      </div>
      <div class="faculty-card" data-aos-delay="240">
        <div class="faculty-img">
          <img src="https://images.unsplash.com/photo-1518770660439-4636190af475?w=600&q=80"
            alt="Electronic Engineering">
          <div class="faculty-overlay"></div>

        </div>
        <div class="faculty-body">
          <h3>Electronic Engineering</h3>
          <p>Circuits, embedded systems, and telecommunications. Developing the engineers behind modern electronics.</p>
          <div class="faculty-meta">
            <span class="faculty-students"><i class="fas fa-user-graduate"></i> 1,200 Students</span>
            <a href="#programs" class="btn-sm">Learn More</a>
          </div>
        </div>
      </div>


    </div>

    <div class="d-flex justify-content-end mt-5 mb-4">
      <nav aria-label="Page navigation">
        <ul class="pagination mb-0">

          <li class="page-item">
            <a class="page-link rounded-pill shadow-sm border-0 mx-1 px-3" href="#" style="color: #495057;">
              <i class="fas fa-chevron-left fa-sm"></i> Prev
            </a>
          </li>

          <li class="page-item">
            <a class="page-link rounded-pill shadow-sm border-0 mx-1" href="#" style="color: #495057;">
              1
            </a>
          </li>

          <li class="page-item active" aria-current="page">
            <a class="page-link rounded-pill shadow-sm border-0 mx-1" href="#"
              style="background-color: #5A4FCF; border-color: #5A4FCF; color: white;">
              2
            </a>
          </li>

          <li class="page-item">
            <a class="page-link rounded-pill shadow-sm border-0 mx-1" href="#" style="color: #495057;">
              3
            </a>
          </li>

          <li class="page-item">
            <a class="page-link rounded-pill shadow-sm border-0 mx-1" href="#" style="color: #495057;">
              4
            </a>
          </li>

          <li class="page-item">
            <a class="page-link rounded-pill shadow-sm border-0 mx-1 px-3" href="#" style="color: #495057;">
              Next <i class="fas fa-chevron-right fa-sm"></i>
            </a>
          </li>

        </ul>
      </nav>
    </div>
  </div>
</section>