@page "/department"
@using Smart_Campus_PUMUB.Components.Pages
@inherits DepartmentBase

<section id="faculties" style="margin-top:50px">
    <div class="container">
        <div class="section-header mb-4">
            <h2 class="section-title">University <span>Departments</span></h2>
        </div>

        <div class="d-flex justify-content-between align-items-center mb-4">
            <div class="programs-tabs">
                <button class="tab-btn @(SelectedFacultyId == 0 ? "active" : "")"
                        @onclick="() => OnFacultySelected(0)">All</button>

                @foreach (var faculty in Faculties)
                {
                    <button class="tab-btn @(SelectedFacultyId == faculty.FacultyId ? "active" : "")"
                            @onclick="() => OnFacultySelected(faculty.FacultyId)">
                        @faculty.FacultyName
                    </button>
                }
            </div>

            <div class="input-group rounded-pill shadow-sm bg-white "
                 style="max-width: 400px; border: 1px solid #e0e0e0; overflow: hidden;margin-top:-35px;">

                <input type="text" class="form-control border-0 shadow-none px-4" placeholder="Search Departments"
                       @bind="searchQuery" />

                <button class="btn border-0 shadow-none px-4" type="button" style="color: #5A4FCF;"
                        @onclick="isSearching ? ClearSearch : FilterData">
                    @if (isSearching)
                    {
                        <i class="fas fa-times"></i>
                    }
                    else
                    {
                        <i class="fas fa-search"></i>
                    }
                </button>
            </div>
        </div>

        <div class="faculties-grid">
            @if (FilteredDepartments != null && FilteredDepartments.Any())
            {
                @foreach (var dept in FilteredDepartments)
                {
                    <div class="faculty-card">
                        <div class="faculty-body">
                            <h3>@dept.DepartmentName</h3>
                            @* <p>@(dept.Description ?? "No description available.")</p> *@
                            <p>Lorem ipsum dolor, sit amet consectetur adipisicing elit. Quibusdam inventore dolores facilis? Ab
                                facilis dolores autem aspernatur totam voluptas, corporis nihil ullam quas voluptatem cum
                                recusandae ad quos numquam eum!</p>
                            </div>
                        </div>
                    }
                }
            else
                {
                    <div class="w-100 text-center mt-5">
                        <p>No departments found matching your criteria.</p>
                    </div>
                }
            </div>
        </div>
    </section>