@page "/department"
@using Smart_Campus_PUMUB.Components.Pages
@using Smart_Campus_PUMUB.Components.Shared @* 🌟 Shared Component ပါဝင်သော Namespace *@
@inherits DepartmentBase

<section id="faculties" style="margin-top:50px">
    <div class="container">
        <div class="section-header">
            <div>
                <div class="section-tag"><i class="fas fa-building"></i> Academic Excellence</div>
                <h2 class="section-title">University<span>Departments</span></h2>
            </div>
        </div>

        <div class="d-flex justify-content-between align-items-center mb-4 flex-wrap gap-3">
            <div class="programs-tabs">
                <button class="tab-btn @(SelectedFacultyId == 0 ? "active" : "")"
                        @onclick="() => OnFacultySelected(0)">All</button>

                @foreach (var faculty in Faculties)
                {
                    <button class="tab-btn @(SelectedFacultyId == faculty.FacultyId ? "active" : "")"
                            @onclick="() => OnFacultySelected(faculty.FacultyId)">
                        @faculty.FacultyName
                    </button>
                }
            </div>

            <div class="input-group rounded-pill shadow-sm bg-white"
                 style="max-width: 400px; border: 1px solid #e0e0e0; overflow: hidden;">

                <input type="text" class="form-control border-0 shadow-none px-4" placeholder="Search Departments"
                       @bind="searchQuery" />

                <button class="btn border-0 shadow-none px-4" type="button" style="color: #5A4FCF;"
                        @onclick="isSearching ? ClearSearch : () => { CurrentPage = 1; FilterData(); }">
                    @if (isSearching)
                    {
                        <i class="fas fa-times"></i>
                    }
                    else
                    {
                        <i class="fas fa-search"></i>
                    }
                </button>
            </div>
        </div>

        <div class="faculties-grid">
            @* 🌟 FilteredDepartments နေရာတွင် Pagination ဖြတ်ပြီးသား PagedDepartments ကို ပြောင်းလဲအသုံးပြုထားပါသည် *@
            @if (PagedDepartments != null && PagedDepartments.Any())
            {
                @foreach (var dept in PagedDepartments)
                {
                    <div class="faculty-card">
                        <div class="faculty-body">
                            <h3>@dept.DepartmentName</h3>
                            @* <p>@(dept.Description ?? "Lorem ipsum dolor, sit amet consectetur adipisicing elit. Quibusdam
                    inventore dolores facilis? Ab facilis dolores autem aspernatur totam voluptas, corporis nihil ullam
                    quas voluptatem cum recusandae ad quos numquam eum!")</p> *@
                            <p>Lorem ipsum dolor sit amet, consectetur adipisicing elit. Accusamus est natus omnis incidunt vero
                                laborum autem quidem velit minima maxime?</p>
                            </div>
                        </div>
                    }
                }
            else
                {
                    <div class="w-100 text-center mt-5">
                        <p class="text-muted">No departments found matching your criteria.</p>
                    </div>
                }
            </div>

            <div class="mt-4">
                <PaginationComponent CurrentPage="CurrentPage" TotalPages="TotalPages" OnPageChanged="OnPageChanged" />
            </div>

        </div>
    </section>