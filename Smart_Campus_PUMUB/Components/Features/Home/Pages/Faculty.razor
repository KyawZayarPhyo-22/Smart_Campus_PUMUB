@* @page "/faculties"
@using Microsoft.EntityFrameworkCore
@using Smart_Campus_PUMUB.Database.AppDbContext
@inject SmartCampusDbContext DbContext
@rendermode InteractiveServer

<link href="https://fonts.googleapis.com/css2?family=Roboto:wght@300;400;500;700&family=Inter:wght@400;500;600;700&display=swap" rel="stylesheet">

<section id="faculties" style="background:var(--bg2); margin-top:20px; padding-bottom: 80px;">
    <div class="container">

        <div class="section-header" data-aos="fade-up">
            <div>
                <div class="section-tag"><i class="fas fa-building"></i> Academic Excellence</div>
                <h2 class="section-title">Our <span>Departments</span></h2>
                <p class="section-desc">World-class engineering and technology departments led by distinguished academics and industry experts.</p>
            </div>
            <a href="#programs" class="view-all">View All Programs <i class="fas fa-arrow-right"></i></a>
        </div>

        <div class="library-filter-right-wrapper" data-aos="fade-up">
            <div class="material-inset-filter-bar">
                <div class="compact-field">
                    <i class="fas fa-search field-icon-medium"></i>
                    <input type="text" class="compact-filter-input-extended"
                           placeholder="Search departments by name..."
                           @bind="searchQuery" @bind:event="oninput" @onkeyup="ApplyFilter" />
                </div>

                @if (!string.IsNullOrWhiteSpace(searchQuery))
                {
                    <button class="compact-reset-btn" @onclick="ResetFilter">
                        <i class="fas fa-undo"></i> Clear
                    </button>
                }
            </div>
        </div>

        <div class="faculties-grid" data-aos="fade-up">
            @if (filteredFaculties == null)
            {
                <p class="status-msg-text"><em>Loading academic departments...</em></p>
            }
            else if (filteredFaculties.Count == 0)
            {
                <p class="status-msg-text">No departments match your search.</p>
            }
            else
            {
                @foreach (var faculty in filteredFaculties)
                {
                    <div class="faculty-card" data-aos="fade-up">
                        <div class="faculty-img">
                            <img src="@GetDefaultFacultyImage(faculty.FacultyName)" alt="@faculty.FacultyName">
                            <div class="faculty-overlay"></div>
                            <div class="faculty-icon">
                                <i class="@GetFacultyIcon(faculty.FacultyName)"></i>
                            </div>
                        </div>
                        <div class="faculty-body">
                            <h3>@faculty.FacultyName</h3>

                            <div class="single-line-desc-container">
                                <i class="fas fa-info-circle info-icon-fixed"></i>
                                <span class="ellipsis-text" title="@GetDepartmentsString(faculty.Departments)">
                                    Departments: @GetDepartmentsString(faculty.Departments)
                                </span>
                            </div>

                            <div class="faculty-meta">
                                <span class="faculty-students">
                                    <i class="fas fa-graduation-cap"></i> @(faculty.Departments?.Count ?? 0) Specializations
                                </span>
                                <a href="#programs" class="btn-sm">Learn More</a>
                            </div>
                        </div>
                    </div>
                }
            }
        </div>

    </div>
</section>

