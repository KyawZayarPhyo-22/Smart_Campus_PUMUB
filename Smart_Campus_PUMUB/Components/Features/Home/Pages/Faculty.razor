    }

    /* ✨ ULTRA-FAST SHIMMER EFFECT (အလင်းတန်း ဖြတ်ပြေးသည့် စနစ်) */
    .skeleton-shimmer-line {
        position: absolute;
        top: 0;
        left: 0;
        width: 100%;
        height: 100%;
        background: linear-gradient( 90deg, rgba(255, 255, 255, 0) 0%, rgba(255, 255, 255, 0.08) 50%, rgba(255, 255, 255, 0) 100% );
