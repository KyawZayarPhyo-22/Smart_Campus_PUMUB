@page "/registerpayment"
@using Smart_Campus_PUMUB.Components.Shared.Layout
@using Smart_Campus_PUMUB.Database.AppDbContext
@using Microsoft.EntityFrameworkCore
@using Microsoft.AspNetCore.Hosting
@using Microsoft.AspNetCore.Components.Forms
@using System.IO
@layout MainLayout
@inject SmartCampusDbContext DbContext
@inject NavigationManager NavManager
@inject IWebHostEnvironment Environment
@rendermode InteractiveServer

<link href="https://fonts.googleapis.com/css2?family=Plus+Jakarta+Sans:wght@400;500;600;700;800&display=swap" rel="stylesheet">

<div class="payment-viewport">
    <div class="payment-card">

        <div class="payment-header">
            <div class="pay-icon-wrapper">
                <i class="fas fa-shield-check"></i>
            </div>
            <h2>Secure Payment</h2>
            <div class="reg-id-badge">Registration ID: <strong>@TargetRegistrationId</strong></div>
        </div>

        <div class="payment-body">

            <div class="bank-info-widget">
                <div class="widget-header">
                    <i class="fas fa-university"></i> တရားဝင် ငွေသွင်းရန် အကောင့်များ
                </div>
                <div class="widget-content">
                    <div class="bank-row">
                        <span class="bank-label">KBZ Pay / Wave Pay</span>
                        <span class="bank-value">09-777888999</span>
                    </div>
                    <div class="bank-row mt-2">
                        <span class="bank-label">KBZ Bank Account</span>
                        <span class="bank-value">123-456-789012345</span>
                    </div>
                </div>
                <div class="widget-footer">
                    <i class="fas fa-info-circle"></i> ငွေလွှဲပြေစာ (Screenshot) အား အောက်တွင် တင်ပေးရပါမည်။
                </div>
            </div>

            <div class="form-vertical-layout">

                <div class="pay-form-group">
                    <label>ပေးချေရမည့် ငွေပမာဏ (Kyats)</label>
                    <div class="input-wrapper inner-shadow-box">
                        <span class="input-icon text-success fw-bold">Ks</span>
                        <input type="number" class="pay-input" @bind="paymentModel.AmountPaid" placeholder="50000" />
                    </div>
                </div>

                <div class="pay-form-group">
                    <label>ငွေပေးချေသည့် စနစ် (Method)</label>
                    <div class="input-wrapper inner-shadow-box">
                        <span class="input-icon text-primary"><i class="fas fa-credit-card"></i></span>
                        <select class="pay-input" @bind="paymentModel.PaymentMethod" style="cursor: pointer;">
                            <option value="KBZPay">KBZ Pay</option>
                            <option value="WavePay">Wave Pay</option>
                            <option value="KBZ Bank">KBZ Bank Transfer</option>
                            <option value="Cash">Cash at University Office</option>
                        </select>
                    </div>
                </div>

            </div>

            <div class="pay-form-group mt-2">
                <label>ငွေသွင်းပြေစာ / စလစ်ပုံ (Receipt Image)</label>
                <div class="upload-zone inner-shadow-box @(imagePreview != null ? "has-image" : "")">
                    <InputFile OnChange="HandleFileSelected" accept="image/png, image/jpeg, image/jpg" class="file-input-hidden" id="receiptUpload" />
                    <label for="receiptUpload" class="upload-label-overlay"></label>

                    @if (imagePreview != null)
                    {
                        <img src="@imagePreview" class="preview-image" />
                        <div class="change-image-badge"><i class="fas fa-sync-alt"></i> ပုံပြောင်းရန် နှိပ်ပါ</div>
                    }
                    else
                    {
                        <div class="upload-placeholder">
                            <div class="upload-icon-circle"><i class="fas fa-cloud-upload-alt"></i></div>
                            <span class="fw-bold text-dark mt-3" style="font-size: 0.95rem;">ပြေစာပုံတင်ရန် နှိပ်ပါ</span>
                            <span class="text-muted small mt-1">PNG, JPG up to 5MB</span>
                        </div>
                    }
                </div>
            </div>

            @if (!string.IsNullOrEmpty(statusMessage))
            {
                <div class="pay-toast @(statusMessage.Contains("အောင်မြင်") ? "success-toast" : "error-toast")">
                    @statusMessage
                </div>
            }

            <button class="btn-submit-payment mt-2" @onclick="SubmitPaymentData" disabled="@isSavingPayment">
                @if (isSavingPayment)
                {
                    <span class="spinner-border spinner-border-sm me-2" role="status"></span> <span>အတည်ပြုနေပါသည်...</span>
                }
                else
                {
                    <i class="fas fa-check-circle me-2"></i> <span>ငွေသွင်းစလစ် အတည်ပြုမည်</span>
                }
            </button>
        </div>
    </div>
</div>

<style>
    .payment-viewport {
        font-family: 'Plus Jakarta Sans', sans-serif;
        background: #e2e8f0;
        min-height: 100vh;
        display: flex;
        align-items: center;
        justify-content: center;
        padding: 40px 20px;
    }

    .payment-card {
        background: #ffffff;
        width: 100%;
        max-width: 520px;
        border-radius: 28px;
        box-shadow: 0 25px 50px -12px rgba(0, 0, 0, 0.15);
        border: 1px solid #ffffff;
        overflow: hidden;
    }

    /* Header Design */
    .payment-header {
        background: linear-gradient(135deg, #0f172a, #1e293b);
        padding: 40px 30px 30px;
        text-align: center;
        position: relative;
    }

    .pay-icon-wrapper {
        width: 65px;
        height: 65px;
        background: linear-gradient(135deg, #10b981, #059669);
        color: white;
        font-size: 1.8rem;
        border-radius: 50%;
        display: flex;
        align-items: center;
        justify-content: center;
        margin: 0 auto 16px;
        box-shadow: 0 10px 25px rgba(16, 185, 129, 0.4);
        border: 4px solid #1e293b;
    }

    .payment-header h2 {
        font-size: 1.5rem;
        font-weight: 800;
        color: #ffffff;
        margin: 0 0 10px 0;
        letter-spacing: -0.5px;
    }

    .reg-id-badge {
        display: inline-block;
        background: rgba(255,255,255,0.1);
        padding: 6px 16px;
        border-radius: 20px;
        font-size: 0.85rem;
        color: #cbd5e1;
        border: 1px solid rgba(255,255,255,0.05);
    }

        .reg-id-badge strong {
            color: #38bdf8;
            font-family: monospace;
            font-size: 1rem;
            margin-left: 4px;
        }

    .payment-body {
        padding: 35px 30px;
        display: flex;
        flex-direction: column;
        gap: 24px;
    }

    /* Material Bank Info Widget */
    .bank-info-widget {
        background: #ffffff;
        border-radius: 16px;
        overflow: hidden;
        border: 1px solid #e2e8f0;
        box-shadow: 0 4px 6px rgba(0,0,0,0.02);
    }

    .widget-header {
        background: #f8fafc;
        padding: 14px 18px;
        font-weight: 800;
        color: #334155;
        font-size: 0.95rem;
        border-bottom: 1px solid #e2e8f0;
    }

        .widget-header i {
            color: #3b82f6;
            margin-right: 8px;
        }

    .widget-content {
        padding: 18px;
        display: flex;
        flex-direction: column;
        gap: 4px;
    }

    .bank-row {
        display: flex;
        justify-content: space-between;
        align-items: center;
    }

    .bank-label {
        font-size: 0.85rem;
        color: #64748b;
        font-weight: 600;
    }

    .bank-value {
        font-size: 0.95rem;
        color: #0f172a;
        font-weight: 800;
        font-family: monospace;
    }

    .widget-footer {
        background: #fffbf1;
        padding: 12px 18px;
        font-size: 0.8rem;
        color: #d97706;
        font-weight: 700;
        border-top: 1px dashed #fde68a;
    }

    /* 💡 Inputs & Inner Shadows (Vertical Layout for Space) */
    .form-vertical-layout {
        display: flex;
        flex-direction: column;
        gap: 20px;
    }

    .pay-form-group {
        display: flex;
        flex-direction: column;
        gap: 8px;
    }

        .pay-form-group label {
            font-size: 0.88rem;
            font-weight: 800;
            color: #334155;
            margin-left: 4px;
        }

    .inner-shadow-box {
        background: #f8fafc;
        border-radius: 14px;
        border: 1px solid #e2e8f0;
        box-shadow: inset 0 2px 5px rgba(0,0,0,0.04);
        transition: all 0.2s ease;
    }

        .inner-shadow-box:focus-within {
            border-color: #3b82f6;
            box-shadow: inset 0 2px 5px rgba(0,0,0,0.02), 0 0 0 3px rgba(59, 130, 246, 0.15);
            background: #ffffff;
        }

    /* Input Fields Padding Tweak */
    .input-wrapper {
        display: flex;
        align-items: center;
        height: 52px;
        overflow: hidden;
    }

    .input-icon {
        width: 50px;
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 1.05rem;
        background: transparent;
    }

    .pay-input {
        flex-grow: 1;
        height: 100%;
        border: none;
        background: transparent;
        outline: none;
        font-size: 0.95rem;
        font-weight: 700;
        color: #1e293b;
        padding-right: 16px;
    }

    /* Select Dropdown specific styling */
    select.pay-input {
        appearance: none;
        -webkit-appearance: none;
        background-image: url("data:image/svg+xml;charset=UTF-8,%3csvg xmlns='http://www.w3.org/2000/svg' viewBox='0 0 24 24' fill='none' stroke='%2364748b' stroke-width='2' stroke-linecap='round' stroke-linejoin='round'%3e%3cpolyline points='6 9 12 15 18 9'%3e%3c/polyline%3e%3c/svg%3e");
        background-repeat: no-repeat;
        background-position: right 16px center;
        background-size: 16px;
    }

    /* Smart Image Upload Zone */
    .upload-zone {
        position: relative;
        height: 180px;
        display: flex;
        align-items: center;
        justify-content: center;
        border: 2px dashed #cbd5e1;
        overflow: hidden;
        cursor: pointer;
        border-radius: 14px;
    }

        .upload-zone:hover {
            border-color: #3b82f6;
            background: #f1f5f9;
        }

        .upload-zone.has-image {
            border: none;
            box-shadow: 0 4px 15px rgba(0,0,0,0.08);
        }

    .file-input-hidden {
        position: absolute;
        width: 0;
        height: 0;
        opacity: 0;
        z-index: -1;
    }

    .upload-label-overlay {
        position: absolute;
        top: 0;
        left: 0;
        right: 0;
        bottom: 0;
        cursor: pointer;
        z-index: 10;
        margin: 0;
    }

    .upload-placeholder {
        display: flex;
        flex-direction: column;
        align-items: center;
        pointer-events: none;
    }

    .upload-icon-circle {
        width: 55px;
        height: 55px;
        background: #e0f2fe;
        color: #0284c7;
        border-radius: 50%;
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 1.6rem;
    }

    .preview-image {
        width: 100%;
        height: 100%;
        object-fit: cover;
        z-index: 1;
    }

    .change-image-badge {
        position: absolute;
        bottom: 12px;
        background: rgba(15, 23, 42, 0.7);
        color: white;
        padding: 6px 16px;
        border-radius: 20px;
        font-size: 0.8rem;
        font-weight: 700;
        z-index: 5;
        backdrop-filter: blur(4px);
    }

    /* Button & Toasts */
    .btn-submit-payment {
        width: 100%;
        height: 56px;
        background: linear-gradient(135deg, #2563eb, #1d4ed8);
        color: white;
        border: none;
        border-radius: 16px;
        font-size: 1.05rem;
        font-weight: 800;
        cursor: pointer;
        transition: all 0.2s;
        box-shadow: 0 8px 25px rgba(37, 99, 235, 0.3);
        display: flex;
        align-items: center;
        justify-content: center;
    }

        .btn-submit-payment:hover {
            transform: translateY(-2px);
            box-shadow: 0 12px 30px rgba(37, 99, 235, 0.4);
        }

        .btn-submit-payment:disabled {
            background: #94a3b8;
            box-shadow: none;
            transform: none;
            cursor: not-allowed;
        }

    .pay-toast {
        padding: 16px;
        border-radius: 12px;
        font-size: 0.95rem;
        font-weight: 700;
        text-align: center;
    }

    .success-toast {
        background: #f0fdf4;
        color: #047857;
        border: 1px solid #bbf7d0;
    }

    .error-toast {
        background: #fef2f2;
        color: #b91c1c;
        border: 1px solid #fecaca;
    }
</style>

@code {
    [SupplyParameterFromQuery(Name = "id")]
    public int TargetRegistrationId { get; set; }

    private RegistrationPayment paymentModel = new RegistrationPayment()
    {
        AmountPaid = 50000,
        PaymentMethod = "KBZPay",
        Status = "Pending"
    };

    private string statusMessage = "";
    private bool isSavingPayment = false;

    // 🌟 IMAGE UPLOAD HANDLING PROPERTIES
    private IBrowserFile? selectedImageFile;
    private string? imagePreview;

    private async Task HandleFileSelected(InputFileChangeEventArgs e)
    {
        var file = e.File;
        if (file != null)
        {
            selectedImageFile = file;

            var resizedImage = await file.RequestImageFileAsync(file.ContentType, 800, 800);
            var buffer = new byte[resizedImage.Size];
            await resizedImage.OpenReadStream(1024 * 1024 * 5).ReadAsync(buffer);
            imagePreview = $"data:{file.ContentType};base64,{Convert.ToBase64String(buffer)}";
        }
    }

    private async Task SubmitPaymentData()
    {
        if (TargetRegistrationId == 0)
        {
            statusMessage = "မှားယွင်းနေပါသည်။ ကျောင်းအပ်ဖောင် ID မရှိပါ ကိုကို။";
            return;
        }

        if (selectedImageFile == null)
        {
            statusMessage = "ကျေးဇူးပြု၍ ငွေသွင်းပြေစာ (စလစ်ပုံ) အား ရွေးချယ်တင်သွင်းပေးပါ။";
            return;
        }

        try
        {
            isSavingPayment = true;
            statusMessage = "";

            string uploadFolder = Path.Combine(Environment.WebRootPath, "uploads", "receipts");
            if (!Directory.Exists(uploadFolder)) Directory.CreateDirectory(uploadFolder);

            string fileExtension = Path.GetExtension(selectedImageFile.Name).ToLower();
            string fileName = $"rcpt_{TargetRegistrationId}_{Guid.NewGuid().ToString().Substring(0, 8)}{fileExtension}";
            string filePath = Path.Combine(uploadFolder, fileName);

            await using (var stream = new FileStream(filePath, FileMode.Create))
            {
                await selectedImageFile.OpenReadStream(1024 * 1024 * 5).CopyToAsync(stream);
            }

            paymentModel.ReceiptImage = $"uploads/receipts/{fileName}";
            paymentModel.RegistrationId = TargetRegistrationId;
            paymentModel.PaymentDate = DateTime.Now;
            paymentModel.CreatedDateTime = DateTime.Now;

            DbContext.RegistrationPayments.Add(paymentModel);
            await DbContext.SaveChangesAsync();

            statusMessage = "🎉 ငွေသွင်းစလစ် တင်သွင်းမှု အောင်မြင်ပါပြီ ကိုကို။ ရုံးအဖွဲ့မှ အမြန်ဆုံး စစ်ဆေးပေးပါမည်။";

            await Task.Delay(3000);
            NavManager.NavigateTo("/");
        }
        catch (Exception ex)
        {
            statusMessage = $"Error: {ex.Message}";
        }
        finally
        {
            isSavingPayment = false;
        }
    }
}