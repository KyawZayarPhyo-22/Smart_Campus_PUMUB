    border-radius: 4px;
    background: var(--white);
    color: var(--text-muted);
  }
  .photo-area svg { width: 36px; height: 36px; opacity: 0.4; }
  .photo-box p { font-size: 10px; color: var(--text-muted); line-height: 1.5; } */


        /* ── PHOTO BOX ── */
        .photo-box {
            float: right;
            width: 120px;
            border: 1px solid var(--border);
            padding: 10px;
            text-align: center;
            margin-left: 1.5rem;
            margin-bottom: 1rem;
            border-radius: 8px;
            background: var(--primary-light);
            position: relative;
            /* Adds layer depth control */
            z-index: 10;
            /* Forces it to stay on top of everything else */
        }

        .photo-area {
            width: 96px;
            height: 120px;
            border: 1.5px dashed var(--border);
            display: flex;
            align-items: center;
            justify-content: center;
            margin: 0 auto 6px;
            border-radius: 4px;
            background: var(--white);
            color: var(--text-muted);
            cursor: pointer;
            background-size: cover;
            background-position: center;
            background-repeat: no-repeat;
        }

        .photo-area svg {
            width: 36px;
            height: 36px;
            opacity: 0.4;
            pointer-events: none;
        }

        .photo-box p {
            font-size: 10px;
            color: var(--text-muted);
            line-height: 1.5;
            pointer-events: none;
        }

        /* ── SECTION LABEL ── */
        .section-label {
            font-size: 13px;
            font-weight: 700;
            color: var(--primary);
            margin: 14px 0 10px;
            padding-left: 10px;
            border-left: 3px solid var(--accent);
        }

        /* ── FORM FIELDS ── */
        .form-grid {
            display: grid;
            gap: 10px;
            margin-bottom: 12px;
        }

        .form-grid-2 {
            grid-template-columns: 1fr 1fr;
        }

        .form-grid-3 {
            grid-template-columns: 1fr 1fr 1fr;
        }

        .form-grid-4 {
            grid-template-columns: 1fr 1fr 1fr 1fr;
        }

        .field {
            display: flex;
            flex-direction: column;
            gap: 4px;
        }

        .field label {
            font-size: 11px;
            color: var(--text-muted);
            font-weight: 500;
        }

        /* Input element formatting */
        .field input.line,
        .parent-block input.line {
            border: none;
            border-bottom: 1px solid var(--border);
            padding: 5px 2px;
            font-size: 13px;
            color: var(--text);
            background: transparent;
            min-height: 26px;
            width: 100%;
            font-family: inherit;
            transition: border-color 0.2s;
        }

        .field input.line:focus,
        .parent-block input.line:focus {
            outline: none;
            border-bottom-color: var(--accent);
            background-color: rgba(90, 79, 207, 0.02);
        }

        /* Inline template inputs */
        .inline-input {
            border: none;
            border-bottom: 1px solid var(--border);
            background: transparent;
            font-size: 13px;
            font-family: inherit;
            color: var(--text);
            padding: 0 4px;
            text-align: center;
        }

        .inline-input:focus {
            outline: none;
            border-bottom-color: var(--accent);
        }

        /* ── NATIONALITY PILLS ── */
        .nat-row {
            display: flex;
            gap: 6px;
            flex-wrap: wrap;
            margin-top: 4px;
        }

        .nat-pill {
            font-size: 11px;
            color: var(--primary);
            border: 1px solid var(--primary);
            padding: 3px 10px;
            border-radius: 20px;
            cursor: pointer;
            background: transparent;
            transition: all 0.2s;
        }

        .nat-pill:hover,
        .nat-pill.active {
            background: var(--primary);
            color: var(--white);
        }

        /* ── TABLE ── */
        table.exam-table {
            width: 100%;
            border-collapse: collapse;
            font-size: 12px;
            margin-top: 8px;
        }

        table.exam-table th {
            background: var(--primary-light);
            padding: 7px 10px;
            font-weight: 700;
            font-size: 11px;
            color: var(--primary);
            border: 1px solid var(--border-light);
            text-align: left;
        }

        table.exam-table td {
            padding: 2px 5px;
            border: 1px solid var(--border-light);
            height: 34px;
        }

        table.exam-table td input {
            width: 100%;
            height: 100%;
            border: none;
            background: transparent;
            font-family: inherit;
            font-size: 12px;
            padding: 4px;
        }

        table.exam-table td input:focus {
            outline: none;
            background: rgba(90, 79, 207, 0.02);
        }

        /* ── DIVIDER ── */
        hr.divider {
            border: none;
            border-top: 1px solid var(--border-light);
            margin: 16px 0;
        }

        /* ── DECLARATION BOX ── */
        .declaration-box {
            border: 1px solid var(--border-light);
            border-radius: 8px;
            padding: 14px 16px;
            margin: 14px 0;
            background: var(--primary-light);
        }

        .declaration-box .decl-title {
            font-size: 12px;
            font-weight: 700;
            color: var(--primary);
            margin-bottom: 8px;
        }

        .rules-list {
            list-style: none;
        }

        .rules-list li {
            font-size: 12px;
            color: var(--text);
            line-height: 1.9;
            padding: 4px 0;
            border-bottom: 1px solid var(--border-light);
            display: flex;
            gap: 10px;
        }

        .rules-list li:last-child {
            border-bottom: none;
        }

        .rules-list li .num {
            font-weight: 700;
            color: var(--accent);
            min-width: 20px;
        }

        .fee-highlight {
            font-weight: 700;
            color: var(--fee-color);
        }

        /* ── SIGNATURE ── */
        .sig-row {
            display: grid;
            grid-template-columns: 1fr 1fr;
            gap: 2rem;
            margin-top: 2rem;
        }

        .sig-block {
            text-align: center;
            display: flex;
            flex-direction: column;
            justify-content: flex-end;
        }

        .sig-line-input {
            border: none;
            border-bottom: 1px solid var(--border);
            background: transparent;
            width: 80%;
            margin: 0 auto 6px;
            text-align: center;
            font-family: inherit;
            padding: 4px;
            font-size: 13px;
        }

        .sig-line-input:focus {
            outline: none;
            border-bottom-color: var(--accent);
        }

        .sig-line {
            border-bottom: 1px solid var(--border);
            height: 36px;
            margin-bottom: 6px;
        }

        .sig-block p {
            font-size: 11px;
            color: var(--text-muted);
        }

        /* ── OFFICE BOX ── */
        .office-box {
            border: 1px dashed var(--border);
            border-radius: 8px;
            padding: 14px;
            margin-top: 1rem;
            background: #fafafa;
        }

        .office-title {
            font-size: 11px;
            font-weight: 700;
            color: var(--text-muted);
            text-align: right;
            margin-bottom: 10px;
        }

        /* ── YEAR BADGE ── */
        .year-tag {
            display: inline-block;
            background: var(--accent-light);
            color: var(--accent);
            font-size: 12px;
            padding: 4px 12px;
            border-radius: 20px;
            font-weight: 700;
            margin-bottom: 8px;
        }

        .page-badge {
            display: inline-block;
            background: var(--primary-light);
            color: var(--primary);
            border: 1px solid var(--border-light);
            border-radius: 6px;
            font-size: 11px;
            font-weight: 700;
            padding: 3px 10px;
            margin-bottom: 14px;
        }

        /* ── YEAR CARDS ── */
        .year-cards {
            display: grid;
            grid-template-columns: 1fr 1fr;
            gap: 1rem;
        }

        .year-card {
            background: var(--primary-light);
            border-radius: 8px;
            padding: 14px;
            border: 1px solid var(--border-light);
            transition: box-shadow 0.2s;
        }

        .year-card:hover {
            box-shadow: 0 4px 16px rgba(44, 62, 122, 0.1);
        }

        .year-card .year-sub {
            font-size: 11px;
            color: var(--text-muted);
            margin-bottom: 10px;
        }

        .year-card .fee-row {
            margin-top: 10px;
            font-size: 12px;
        }

        /* ── REF PERSON ── */
        .ref-person {
            background: #fafafa;
            border-radius: 8px;
            padding: 14px;
            margin-bottom: 14px;
            border: 1px solid var(--border-light);
        }

        .ref-title {
            font-size: 12px;
            font-weight: 700;
            color: var(--primary);
            margin-bottom: 10px;
        }

        /* ── RULES PAGE HEADER ── */
        .rules-header {
            text-align: center;
            padding-bottom: 1.2rem;
            margin-bottom: 1.5rem;
            border-bottom: 2px solid var(--gold);
        }

        .rules-header .gov-text {
            font-size: 13px;
            font-weight: 700;
            color: var(--text);
        }

        .rules-header .dept-text {
            font-size: 12px;
            color: var(--text-muted);
            margin-top: 4px;
        }

        .rules-header .title-text {
            font-size: 15px;
            font-weight: 700;
            color: var(--gold);
            margin-top: 10px;
            padding: 6px 16px;
            border: 1.5px solid var(--gold);
            border-radius: 6px;
            display: inline-block;
            background: var(--gold-light);
        }

        .address-area {
            border: 1px solid var(--border);
            border-radius: 6px;
            padding: 10px;
            min-height: 60px;
            margin-top: 4px;
            width: 100%;
            font-family: inherit;
            font-size: 13px;
            resize: vertical;
            background: transparent;
        }

        .address-area:focus {
            outline: none;
            border-color: var(--accent);
            background-color: rgba(90, 79, 207, 0.02);
        }

        .two-col-parent {
            display: grid;
            grid-template-columns: 1fr 1fr;
            gap: 2rem;
            margin-top: 1.5rem;
        }

        .parent-block label {
            font-size: 11px;
            color: var(--text-muted);
        }

        .parent-block .line {
            border: none;
            border-bottom: 1px solid var(--border);
            display: block;
            width: 100%;
            min-height: 24px;
            margin-bottom: 8px;
            font-size: 12px;
        }

        .parent-block .sig-line {
            border-bottom: 1px solid var(--border);
            height: 32px;
            margin-bottom: 8px;
        }

        .parent-block .block-title {
            font-size: 12px;
            font-weight: 700;
            color: var(--primary);
            margin-bottom: 10px;
        }

        .clearfix::after {
            content: "";
            display: table;
            clear: both;
        }

        @@media print {
            body {
                background: white;
                padding: 0;
            }

            .page {
                box-shadow: none;
                border: none;
                margin: 0;
                border-radius: 0;
                page-break-after: always;
            }

            input::placeholder {
                color: transparent;
            }
        }

        @@media (max-width: 600px) {
            body {
                padding: 0.75rem;
            }

            .page {
                padding: 1.25rem;
            }

            .form-grid-2,
            .form-grid-3,
            .form-grid-4 {
                grid-template-columns: 1fr;
            }

            .year-cards {
                grid-template-columns: 1fr;
            }

            .sig-row,
            .two-col-parent {
                grid-template-columns: 1fr;
            }

            .photo-box {
                float: none;
                margin: 0 auto 1rem;
                display: block;
            }
        }
    </style>
</head>



