@page "/Register"
@using Smart_Campus_PUMUB.Components.Shared.Layout
@using Smart_Campus_PUMUB.Database.AppDbContext
@using Microsoft.AspNetCore.Components.Authorization
@using Microsoft.EntityFrameworkCore
@inject AuthenticationStateProvider AuthStateProvider
@inject SmartCampusDbContext DbContext
@inject NavigationManager NavManager
@rendermode InteractiveServer
@layout MainLayout
<!DOCTYPE html>
<html lang="my">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>POLYTECHNIC UNIVERSITY (MAUBIN) — ပညာသင်ခွင့်လျောက်လွှာ</title>
    <link href="https://fonts.googleapis.com/css2?family=Noto+Serif+Myanmar:wght@400;500;700&family=Noto+Sans+Myanmar:wght@400;500;700&display=swap"
          rel="stylesheet">
    <style>
            *,
            *::before,
            *::after {
                box-sizing: border-box;
                margin: 0;
                padding: 0;
            }

            :root {
                --primary: #2C3E7A;
                --primary-light: #EEF1FB;
                --accent: #5A4FCF;
                --accent-light: #EEEDFE;
                --text: #1a1a2e;
                --text-muted: #5a5a72;
                --border: #c8c8d8;
                --border-light: #e8e8f0;
                --bg: #f4f4f8;
                --white: #ffffff;
                --gold: #B8953A;
                --gold-light: #FDF6E3;
                --fee-color: #185FA5;
                --success: #1D9E75;
            }

            body {
                font-family: 'Noto Sans Myanmar', sans-serif;
                background: var(--bg);
                color: var(--text);
                min-height: 100vh;
            }

            .page {
                background: var(--white);
                border: 1px solid var(--border);
                border-radius: 10px;
                padding: 2.5rem;
                margin-bottom: 2rem;
                max-width: 900px;
                margin-left: auto;
                margin-right: auto;
                box-shadow: 0 2px 16px rgba(44, 62, 122, 0.07);
                page-break-after: always;
            }

            /* ── HEADER ── */
            .uni-header {
                text-align: center;
                padding-bottom: 1.2rem;
                margin-bottom: 1.5rem;
                border-bottom: 2px solid var(--primary);
                position: relative;
            }

                .uni-header .gov-line {
                    font-size: 12px;
                    color: var(--text-muted);
                    letter-spacing: 0.5px;
                    margin-bottom: 4px;
                }

                .uni-header h1 {
                    font-size: 17px;
                    font-weight: 700;
                    color: var(--primary);
                    letter-spacing: 0.5px;
                }

                .uni-header h2 {
                    font-size: 14px;
                    font-weight: 500;
                    color: var(--accent);
                    margin-top: 3px;
                }

                .uni-header .form-title {
                    font-size: 15px;
                    font-weight: 700;
                    color: var(--text);
                    margin-top: 10px;
                }

                .uni-header .form-sub {
                    font-size: 13px;
                    color: var(--text-muted);
                    margin-top: 3px;
                }

            /* ── PHOTO BOX ── */
            .photo-box {
                float: right;
                width: 120px;
                border: 1px solid var(--border);
                padding: 10px;
                text-align: center;
                margin-left: 1.5rem;
                margin-bottom: 1rem;
                border-radius: 8px;
                background: var(--primary-light);
                position: relative;
                z-index: 10;
            }

            .photo-area {
                width: 96px;
                height: 120px;
                border: 1.5px dashed var(--border);
                display: flex;
                align-items: center;
                justify-content: center;
                margin: 0 auto 6px;
                border-radius: 4px;
                background: var(--white);
                color: var(--text-muted);
                cursor: pointer;
                background-size: cover;
                background-position: center;
                background-repeat: no-repeat;
            }

                .photo-area svg {
                    width: 36px;
                    height: 36px;
                    opacity: 0.4;
                    pointer-events: none;
                }

            .photo-box p {
                font-size: 10px;
                color: var(--text-muted);
                line-height: 1.5;
                pointer-events: none;
            }

            /* ── SECTION LABEL ── */
            .section-label {
                font-size: 13px;
                font-weight: 700;
                color: var(--primary);
                margin: 14px 0 10px;
                padding-left: 10px;
                border-left: 3px solid var(--accent);
            }

            /* ── FORM FIELDS ── */
            .form-grid {
                display: grid;
                gap: 10px;
                margin-bottom: 12px;
            }

            .form-grid-2 {
                grid-template-columns: 1fr 1fr;
            }

            .form-grid-3 {
                grid-template-columns: 1fr 1fr 1fr;
            }

            .form-grid-4 {
                grid-template-columns: 1fr 1fr 1fr 1fr;
            }

            .field {
                display: flex;
                flex-direction: column;
                gap: 4px;
            }

                .field label {
                    font-size: 11px;
                    color: var(--text-muted);
                    font-weight: 500;
                }

                /* Input element formatting */
                .field input.line,
                .parent-block input.line {
                    border: none;
                    border-bottom: 1px solid var(--border);
                    padding: 5px 2px;
                    font-size: 13px;
                    color: var(--text);
                    background: transparent;
                    min-height: 26px;
                    width: 100%;
                    font-family: inherit;
                    transition: border-color 0.2s;
                }

                    .field input.line:focus,
                    .parent-block input.line:focus {
                        outline: none;
                        border-bottom-color: var(--accent);
                        background-color: rgba(90, 79, 207, 0.02);
                    }

            /* Inline template inputs */
            .inline-input {
                border: none;
                border-bottom: 1px solid var(--border);
                background: transparent;
                font-size: 13px;
                font-family: inherit;
                color: var(--text);
                padding: 0 4px;
                text-align: center;
            }

                .inline-input:focus {
                    outline: none;
                    border-bottom-color: var(--accent);
                }

            /* ── NATIONALITY PILLS ── */
            .nat-row {
                display: flex;
                gap: 14px;
                flex-wrap: wrap;
                margin-top: 4px;
            }

            .nat-item {
                font-size: 12px;
                display: inline-flex;
                align-items: center;
                gap: 6px;
                cursor: pointer;
                color: var(--text);
            }

            /* ── TABLE ── */
            table.exam-table {
                width: 100%;
                border-collapse: collapse;
                font-size: 12px;
                margin-top: 8px;
            }

                table.exam-table th {
                    background: var(--primary-light);
                    padding: 7px 10px;
                    font-weight: 700;
                    font-size: 11px;
                    color: var(--primary);
                    border: 1px solid var(--border-light);
                    text-align: left;
                }

                table.exam-table td {
                    padding: 2px 5px;
                    border: 1px solid var(--border-light);
                    height: 34px;
                }

                    table.exam-table td input {
                        width: 100%;
                        height: 100%;
                        border: none;
                        background: transparent;
                        font-family: inherit;
                        font-size: 12px;
                        padding: 4px;
                    }

                        table.exam-table td input:focus {
                            outline: none;
                            background: rgba(90, 79, 207, 0.02);
                        }

            /* ── DIVIDER ── */
            hr.divider {
                border: none;
                border-top: 1px solid var(--border-light);
                margin: 16px 0;
            }

            /* ── DECLARATION BOX ── */
            .declaration-box {
                border: 1px solid var(--border-light);
                border-radius: 8px;
                padding: 14px 16px;
                margin: 14px 0;
                background: var(--primary-light);
            }

                .declaration-box .decl-title {
                    font-size: 12px;
                    font-weight: 700;
                    color: var(--primary);
                    margin-bottom: 8px;
                }

            .rules-list {
                list-style: none;
            }

                .rules-list li {
                    font-size: 12px;
                    color: var(--text);
                    line-height: 1.9;
                    padding: 4px 0;
                    border-bottom: 1px solid var(--border-light);
                    display: flex;
                    gap: 10px;
                }

                    .rules-list li:last-child {
                        border-bottom: none;
                    }

                    .rules-list li .num {
                        font-weight: 700;
                        color: var(--accent);
                        min-width: 20px;
                    }

            .fee-highlight {
                font-weight: 700;
                color: var(--fee-color);
            }

            /* ── SIGNATURE ── */
            .sig-row {
                display: grid;
                grid-template-columns: 1fr 1fr;
                gap: 2rem;
                margin-top: 2rem;
            }

            .sig-block {
                text-align: center;
                display: flex;
                flex-direction: column;
                justify-content: flex-end;
            }

            .sig-line-input {
                border: none;
                border-bottom: 1px solid var(--border);
                background: transparent;
                width: 80%;
                margin: 0 auto 6px;
                text-align: center;
                font-family: inherit;
                padding: 4px;
                font-size: 13px;
            }

                .sig-line-input:focus {
                    outline: none;
                    border-bottom-color: var(--accent);
                }

            .sig-block p {
                font-size: 11px;
                color: var(--text-muted);
            }

            /* ── OFFICE BOX ── */
            .office-box {
                border: 1px dashed var(--border);
                border-radius: 8px;
                padding: 14px;
                margin-top: 1rem;
                background: #fafafa;
            }

            .office-title {
                font-size: 11px;
                font-weight: 700;
                color: var(--text-muted);
                text-align: right;
                margin-bottom: 10px;
            }

            /* ── YEAR BADGE ── */
            .year-tag {
                display: inline-block;
                background: var(--accent-light);
                color: var(--accent);
                font-size: 12px;
                padding: 4px 12px;
                border-radius: 20px;
                font-weight: 700;
                margin-bottom: 8px;
            }

            .page-badge {
                display: inline-block;
                background: var(--primary-light);
                color: var(--primary);
                border: 1px solid var(--border-light);
                border-radius: 6px;
                font-size: 11px;
                font-weight: 700;
                padding: 3px 10px;
                margin-bottom: 14px;
            }

            .address-area {
                border: 1px solid var(--border);
                border-radius: 6px;
                padding: 10px;
                min-height: 60px;
                margin-top: 4px;
                width: 100%;
                font-family: inherit;
                font-size: 13px;
                resize: vertical;
                background: transparent;
            }

                .address-area:focus {
                    outline: none;
                    border-color: var(--accent);
                    background-color: rgba(90, 79, 207, 0.02);
                }

            .two-col-parent {
                display: grid;
                grid-template-columns: 1fr 1fr;
                gap: 2rem;
                margin-top: 1.5rem;
            }

            .parent-block label {
                font-size: 11px;
                color: var(--text-muted);
            }

            .parent-block .line {
                border: none;
                border-bottom: 1px solid var(--border);
                display: block;
                width: 100%;
                min-height: 24px;
                margin-bottom: 8px;
                font-size: 12px;
            }

            .parent-block .block-title {
                font-size: 12px;
                font-weight: 700;
                color: var(--primary);
                margin-bottom: 10px;
            }

            .clearfix::after {
                content: "";
                display: table;
                clear: both;
            }

            @@media print {
                body {
                    background: white;
                    padding: 0;
                }

                .page {
                    box-shadow: none;
                    border: none;
                    margin: 0;
                    border-radius: 0;
                    page-break-after: always;
                }

                input::placeholder {
                    color: transparent;
                }

                .submit-action-footer-container, .validation-summary-alert {
                    display: none !important;
                }
            }

            @@media (max-width: 600px) {
                body {
                    padding: 0.75rem;
                }

                .page {
                    padding: 1.25rem;
                }

                .form-grid-2, .form-grid-3, .form-grid-4 {
                    grid-template-columns: 1fr;
                }

                .sig-row, .two-col-parent {
                    grid-template-columns: 1fr;
                }

                .photo-box {
                    float: none;
                    margin: 0 auto 1rem;
                    display: block;
                }
            }
    </style>
</head>

<body>

    <div class="page clearfix" style="margin-top:150px">
        <div class="container">
            <div class="row align-items-center">
                <div class="col-12 col-md-9 order-1 order-md-1 text-center text-md-start mb-4 mb-md-0">
                    <div class="uni-header" style="border-bottom:none; padding-bottom:0; margin-bottom:0;">
                        <div class="gov-line">ပြည်ထောင်စုသမ္မတ မြန်မာနိုင်ငံတော်အစိုးရ</div>
                        <div class="gov-line">သိပ္ပံနှင့်နည်းပညာဝန်ကြီးဌာန</div>
                        <h1>POLYTECHNIC UNIVERSITY (MAUBIN)</h1>
                        <h2>FACULTY OF COMPUTING</h2>
                        <div class="form-title" style="margin-top:10px;">
                            ၂၀၂၅-၂၀၂၆ ပညာသင်နှစ်
                        </div>
                        <div class="form-sub mt-2">ကျောင်းသား၊ ကျောင်းသူများ ပညာသင်ခွင့်လျှောက်လွှာ</div>
                    </div>
                </div>

                <div class="col-12 col-md-3 order-2 order-md-2 d-flex flex-column align-items-center align-items-md-end" style="margin-top: 30px;">
                    <div class="photo-box text-center">
                        <label class="photo-area" id="photoLabel">
                            <input type="file" accept="image/*" style="display: none;" onchange="previewImage(this)">
                            <svg id="photoIcon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" width="40" height="40">
                                <circle cx="12" cy="8" r="4" />
                                <path d="M4 20c0-4 3.6-7 8-7s8 3 8 7" />
                            </svg>
                        </label>
                        <p class="mt-2 mb-0">ဓါတ်ပုံ ၄ ပုံနှင့်<br>တင်သွင်းပါ</p>
                    </div>
                </div>
            </div>
        </div>
        <hr class="divider" style="clear:both; margin-top:72px;">

        <div class="form-grid form-grid-3">
            <div class="field"><label>သင်တန်းနှစ်</label><input type="text" class="line" @bind="regModel.AcademicYearLevel"></div>
            <div class="field"><label>အထူးပြုဘာသာ</label><input type="text" class="line" @bind="regModel.Major"></div>
            <div class="field"><label>ခုံအမှတ်</label><input type="text" class="line" @bind="regModel.RollNo"></div>
        </div>
        <div class="form-grid form-grid-2">
            <div class="field"><label>တက္ကသိုလ်မှတ်ပုံတင်အမှတ်</label><input type="text" class="line" @bind="regModel.UniversityRegNo"></div>
            <div class="field"><label>တက္ကသိုလ်ဝင်ရောက်သည့်နှစ် (ခုနှစ်)</label><input type="number" class="line" @bind="regModel.AdmissionYear"></div>
        </div>

        <div>
            <div class="section-label">၁။ ပညာဆည်းပူးဆက်လက်သင်ခွင့်တောင်းသူ ကျောင်းသား၊ ကျောင်းသူ</div>
            <div class="form-grid form-grid-2">
                <div class="field"><label>အမည် (မြန်မာစာဖြင့်)</label><input type="text" class="line" @bind="regModel.StudentNameMm"></div>
                <div class="field"><label>အမည် (အင်္ဂလိပ်စာဖြင့်)</label><input type="text" class="line" @bind="regModel.StudentNameEn"></div>
                <div class="field"><label>လူမျိုး</label><input type="text" class="line" @bind="regModel.Ethnicity"></div>
                <div class="field"><label>ကိုးကွယ်သည့်ဘာသာ</label><input type="text" class="line" @bind="regModel.Religion"></div>
                <div class="field"><label>မွေးဖွားရာဇာတိ</label><input type="text" class="line" @bind="regModel.Pob"></div>
                <div class="field"><label>မြို့နယ် / ပြည်နယ် / တိုင်း</label><input type="text" class="line" @bind="regModel.BirthPlaceRegion"></div>
                <div class="field"><label>မှတ်ပုံတင်အမှတ်</label><input type="text" class="line" @bind="regModel.StudentNrcNo"></div>
                <div class="field"><label>မွေးသက္ကရာဇ်</label><input type="date" class="line" @bind="dobBridge"></div>
                <div class="field"><label>Email</label><input type="email" class="line" @bind="regModel.Email"></div>
                <div class="field"><label>သွေးအုပ်စု</label><input type="text" class="line" @bind="regModel.BloodType"></div>
                <div class="field"><label>ကိုဗစ်ကာကွယ်ရေးထိုးနှံမှု — ထိုး/မထိုး ပြီးစီးသည့်ရက်</label><input type="text" class="line" @bind="regModel.CovidVaccineStatus"></div>
                <div class="field">
                    <label>နိုင်ငံသား အမျိုးအစား</label>
                    <div class="nat-row" style="margin-top: 12px;">
                        <label class="nat-item">
                            <input type="radio" name="nationality" value="နိုင်ငံခြားသား" checked="@(regModel.NationalityStatus == "နိုင်ငံခြားသား")" @onclick='() => regModel.NationalityStatus = "နိုင်ငံခြားသား"'> နိုင်ငံခြားသား
                        </label>
                        <label class="nat-item">
                            <input type="radio" name="nationality" value="တိုင်းရင်းသား" checked="@(regModel.NationalityStatus == "တိုင်းရင်းသား")" @onclick='() => regModel.NationalityStatus = "တိုင်းရင်းသား"'> တိုင်းရင်းသား
                        </label>
                    </div>
                </div>
            </div>
        </div>
        <div class="form-grid form-grid-3" style="margin-top: 50px;">
            <div class="field"><label>တက္ကသိုလ်ဝင်တန်း ခုံအမှတ်</label><input type="text" class="line" @bind="regModel.MatricRollNo"></div>
            <div class="field"><label>အောင်မြင်သည့် ခုနှစ်</label><input type="number" class="line" @bind="regModel.MatricPassedYear"></div>
            <div class="field"><label>စာစစ်ဌာန </label><input type="text" class="line" @bind="regModel.ExamCenter"></div>
        </div>

        <div class="form-grid form-grid-2">
            <div class="field"><label>အဘ အုပ်ထိန်းသူ၏ အလုပ်အကိုင်၊ ရာထူး၊ ဌาန (မြန်မာ)</label><input type="text" class="line" style="margin-top:4px;" @bind="regModel.FatherOccupation"></div>
            <div class="field"><label>အမိ အုပ်ထိန်းသူ၏ အလုပ်အကိုင်၊ ရာထူး၊ ဌာန (အင်္ဂလိပ်)</label><input type="text" class="line" style="margin-top:4px;" @bind="regModel.MotherOccupation"></div>
        </div>
        <div class="form-grid form-grid-2">
            <div class="field"><label>အမြဲတမ်းနေရပ်လိပ်စာ(အပြည့်အစုံ) (မြန်မာစာဖြင့်)</label><input type="text" class="line" style="margin-top:4px;" @bind="regModel.PermanentAddressMm"></div>
            <div class="field"><label>အမြဲတမ်းနေရပ်လိပ်စာ(အပြည့်အစုံ) (အင်္ဂလိပ်စာဖြင့်)</label><input type="text" class="line" style="margin-top:4px;" @bind="regModel.PermanentAddressEn"></div>
        </div>
    </div>

    <hr class="divider">

    <div class="page clearfix">
        <div class="section-label">၂။ ဖြေဆိုသည့်စာမေးပွဲများ</div>
        <table class="exam-table">
            <thead>
                <tr>
                    <th>ဖြေဆိုသည့်စာမေးပွဲများ</th>
                    <th>အဓိကဘာသာ</th>
                    <th>ခုံအမှတ်</th>
                    <th>ခုနှစ်</th>
                    <th>အောင် / ကျ</th>
                </tr>
            </thead>
            <tbody>
                <tr>
                    <td><input type="text" @bind="regModel.PastExamMajor"></td>
                    <td><input type="text" value="Computgit er Science" readonly></td>
                    <td><input type="text" @bind="regModel.PastExamRollNo"></td>
                    <td><input type="number" @bind="regModel.PastExamYear"></td>
                    <td><input type="text" @bind="regModel.PastExamStatus"></td>
                </tr>
            </tbody>
        </table>
        <div class="" style="margin-bottom: 50px;margin-top: 30px;">
            <div class="section-label">အမိ</div>
            <div class="form-grid form-grid-2">
                <div class="field"><label>အမည် (မြန်မာစာဖြင့်)</label><input type="text" class="line" @bind="regModel.MotherName"></div>
                <div class="field"><label>ဆွေမျိုးတော်စပ်ပုံ</label><input type="text" class="line" @bind="regModel.GenderRelation"></div>
            </div>
        </div>
        <hr class="divider">

        <div class="" style="margin-top: 30px;">
            <div class="section-label">အဘ</div>
            <div class="form-grid form-grid-2">
                <div class="field"><label>အမည် (မြန်မာစာဖြင့်)</label><input type="text" class="line" @bind="regModel.FatherName"></div>
                <div class="field"><label>ယခင်နှစ်ခုံအမှတ်</label><input type="text" class="line" @bind="regModel.PreviousYearRollNo"></div>
            </div>
        </div>
    </div>

    <div class="page">
        <div class="section-label">၃။ ကျောင်းနေရန်အထောက်အပံ့ပြုမည့် ပုဂ္ဂိုလ်</div>
        <div class="ref-person">
            <div class="form-grid form-grid-2">
                <div class="field"><label>အမည်</label><input type="text" class="line" @bind="regModel.GuardianName"></div>
                <div class="field"><label>ဆွေမျိုးတော်စပ်ပုံ</label><input type="text" class="line" @bind="regModel.GuardianRelationship"></div>
            </div>
            <div class="form-grid form-grid-2">
                <div class="field"><label>အလုပ်အကိုင်</label><input type="text" class="line" @bind="regModel.GuardianOccupation"></div>
                <div class="field"><label>ဆက်သွယ်ရန်လိပ်စာနှင့် ဖုန်းနံပါတ်</label><input type="text" class="line" @bind="regModel.GuardianAddressPhone"></div>
            </div>
            <div class="form-grid" style="margin-top:20px;">
                <div class="field">
                    <label>ပညာသင်ထောက်ပံ့ကြေးပေးရန်မေတ္တာရပ်ခံခြင်း ပြု/မပြု</label>
                    <div class="nat-row" style="margin-top: 12px;">
                        <label class="nat-item">
                            <input type="radio" name="prize" checked="@(regModel.StipendRequested == true)" @onclick="() => regModel.StipendRequested = true"> ပြု
                        </label>
                        <label class="nat-item">
                            <input type="radio" name="prize" checked="@(regModel.StipendRequested != true)" @onclick="() => regModel.StipendRequested = false"> မပြု
                        </label>
                    </div>
                </div>
            </div>
        </div>

        <div class="declaration-box">
            <div class="decl-title">ကိုယ်ပိုင်ဝန်ခံချက်</div>
            <ul class="rules-list">
                <li><span class="num">၁</span>အထက်ဖော်ပြပါ အချက်များအားလုံး မှန်ကန်ပါသည်။</li>
                <li><span class="num">၂</span>ဤတက္ကသိုလ်၌ ကိုယ်တိုင်ပညာသင်ခွင့် တောင်းသည်ကို မိဘ (သို့မဟုတ်) အုပ်ထိန်းသူက သဘောတူကြောင်း ဖြစ်ပါသည်။</li>
                <li><span class="num">၃</span>တက္ကသိုလ်ကျောင်းသားတစ်ဦးပီသစွာ တက္ကသိုလ် / ကောလိပ်က ချမှတ်သည့် စည်းမျဉ်းစည်းကမ်းနှင့်အညီ လိုက်နာကျင့်သုံးနေထိုင်ပါမည်။</li>
            </ul>
        </div>

        <div style="display:flex; gap:8px; align-items:baseline; justify-content:flex-start; margin-bottom:1rem; font-size:13px; width:100%; flex-wrap:wrap;">
            <span>ရက်စွဲ။</span>
            <input type="date" class="inline-input" style="width:160px; max-width:100%;" @bind="dateTimeBridge">
        </div>

        <div class="form-grid form-grid-2">
            <div class="field" style="margin-bottom:2.5rem;">
                <label>ယခုဆက်သွယ်ရန်လိပ်စာ</label>
                <textarea class="address-area" style="height: 120px;" @bind="regModel.CurrentAddress"></textarea>
            </div>
            <div class="sig-block" style="margin-bottom:2.5rem;">
                <input type="text" class="sig-line-input" placeholder="(အမည်ရိုက်ရန်)" @bind="regModel.AppStudentName">
                <p>ပညာသင်ခွင့်လျောက်ထားသူ၏ လက်မှတ်</p>
            </div>
        </div>

        <div class="ref-person" style="background:#fff7ed; border-color:#fed7aa;">
            <div class="form-grid form-grid-3">
                <div class="field"><label>အုပ်ထိန်းသူအမည်</label><input type="text" class="line" @bind="regModel.AppGuardianName"></div>
                <div class="field"><label>မှတ်ပုံတင်အမှတ်</label><input type="text" class="line" @bind="regModel.AppGuardianNrc"></div>
                <div class="field"><label>ဖုန်းနံပါတ်</label><input type="text" class="line" @bind="regModel.AppGuardianPhone"></div>
            </div>
            <div class="field" style="margin-top:6px;"><label>နေရပ်လိပ်စာ</label><input type="text" class="line" @bind="regModel.AppGuardianAddress"></div>
        </div>
    </div>

    @if (!string.IsNullOrEmpty(validationMessage))
    {
        <div class="validation-summary-alert" style="max-width: 900px; margin: 10px auto; padding: 12px 20px; background: #fef2f2; border: 1px solid #fca5a5; border-radius: 12px; color: #991b1b; font-size: 0.88rem; font-weight: 500; display: flex; align-items: center; gap: 10px;">
            <i class="fas fa-triangle-exclamation"></i>
            <span>@validationMessage</span>
        </div>
    }

    <div class="submit-action-footer-container" style="max-width: 900px; margin: 20px auto 50px auto; padding: 0 20px; text-align: right;">
        @if (isSubmittingForm)
        {
            <button class="btn-m3-submit-form" disabled style="background: #94a3b8; color: #cbd5e1; border: none; padding: 14px 36px; font-size: 1rem; font-weight: 700; border-radius: 50px; cursor: not-allowed; display: inline-flex; align-items: center; gap: 10px;">
                <i class="fas fa-spinner fa-spin"></i> အချက်အလက်များ သိမ်းဆည်းနေပါသည်...
            </button>
        }
        else
        {
            <button type="button" class="btn-m3-submit-form" @onclick="HandleFormSubmission" style="background: linear-gradient(135deg, #1D9E75, #10b981); color: white; border: none; padding: 14px 36px; font-size: 1rem; font-weight: 700; border-radius: 50px; cursor: pointer; display: inline-flex; align-items: center; gap: 10px; box-shadow: 0 8px 20px rgba(16, 185, 129, 0.25);">
                <span>ငွေပေးချေမှုစနစ်သို့ သွားရန်</span>
                <i class="fas fa-credit-card"></i>
            </button>
        }
    </div>

</body>

@code {
    // 🌟 DATABASE ထဲသို့ တိုက်ရိုက်ဝင်မည့် StudentRegistration Instance Carrier
    private StudentRegistration regModel = new StudentRegistration()
    {
        AcademicYearRange = "2025-2026",
        NationalityStatus = "တိုင်းရင်းသား",
        StipendRequested = false,
        Status = "Pending"
    };

    private DateTime? dateTimeBridge = DateTime.Now;

    // 🌟 [RESOLVED CS1061] DateOnly နှင့် DateTime ကြား အလိုအလျောက် ပြောင်းလဲပေးသည့် တံတား
    private DateTime dobBridge
    {
        get => regModel.Dob.ToDateTime(TimeOnly.MinValue);
        set => regModel.Dob = DateOnly.FromDateTime(value);
    }

    private string validationMessage = "";
    private bool isSubmittingForm = false;

    protected override async Task OnInitializedAsync()
    {
        var authState = await AuthStateProvider.GetAuthenticationStateAsync();
        var user = authState.User;

        if (user.Identity?.IsAuthenticated == true)
        {
            regModel.CreatedBy = user.Identity.Name;

            // 🌟 [RESOLVED CS1061] Email မရှိသောကြောင့် ဝင်ရောက်စွက်ဖက်ခြင်း မပြုတော့ဘဲ UserId သီးသန့်ကိုသာ ချိတ်ဆက်ပါသည်
            var sysUser = await DbContext.Users.FirstOrDefaultAsync(u => u.UserName == user.Identity.Name);
            if (sysUser != null)
            {
                regModel.UserId = sysUser.UserId;
            }
        }
    }

    private async Task HandleFormSubmission()
    {
        if (isSubmittingForm) return;

        // 💡 ကိုကို့ဖောင်ထဲက အမည် (မြန်မာ) နှင့် မှတ်ပုံတင် ထည့်သွင်းထားခြင်း ရှိမရှိ စစ်ဆေးခြင်း
        if (string.IsNullOrWhiteSpace(regModel.StudentNameMm) || string.IsNullOrWhiteSpace(regModel.StudentNrcNo))
        {
            validationMessage = "ကျောင်းသားအမည် (မြန်မာ) နှင့် မှတ်ပုံတင်အမှတ်များကို မဖြစ်မနေ ထည့်သွင်းပေးရပါမည်။";
            return;
        }

        try
        {
            isSubmittingForm = true;
            validationMessage = "";

            if (dateTimeBridge.HasValue)
            {
                regModel.ApplicationDate = dateTimeBridge.Value;
            }
            regModel.CreatedDatetime = DateTime.Now;

            // 🚀 DATABASE TRANSMISSION (Entity Framework ဒေတာသိမ်းဆည်းခြင်း စနစ်)
            DbContext.StudentRegistrations.Add(regModel);
            await DbContext.SaveChangesAsync();

            // 🚀 SUCCESS REDIRECTION (ငွေသွင်းမျက်နှာပြင် ဒုတိယဖိုင်ဆီသို့ ID သယ်ဆောင်ပြီး လမ်းကြောင်းချိတ်ဆက်ခြင်း)
            NavManager.NavigateTo($"/registerpayment?id={regModel.RegistrationId}", true);
        }
        catch (Exception ex)
        {
            validationMessage = $"Error: {ex.Message}";
        }
        finally
        {
            isSubmittingForm = false;
        }
    }
}

<script>
    function previewImage(input) {
        const file = input.files[0];
        const label = document.getElementById('photoLabel');
        const icon = document.getElementById('photoIcon');

        if (file) {
            const reader = new FileReader();
            reader.onload = function (e) {
                label.style.backgroundImage = "url('" + e.target.result + "')";
                if (icon) icon.style.opacity = '0';
            }
            reader.readAsDataURL(file);
        }
    }
</script>

</html>