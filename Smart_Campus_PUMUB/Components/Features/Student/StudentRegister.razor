@page "/Register"
@using Smart_Campus_PUMUB.Components.Shared.Layout
@using Smart_Campus_PUMUB.Database.AppDbContext
@inject SmartCampusDbContext DbContext
@using Microsoft.EntityFrameworkCore
@layout MainLayout
<!DOCTYPE html>
<html lang="my">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>POLYTECHNIC UNIVERSITY (MAUBIN) — ပညာသင်ခွင့်လျောက်လွှာ</title>
    <link
        href="https://fonts.googleapis.com/css2?family=Noto+Serif+Myanmar:wght@400;500;700&family=Noto+Sans+Myanmar:wght@400;500;700&display=swap"
        rel="stylesheet">
    <style>
        *,
        *::before,
        *::after {
            box-sizing: border-box;
            margin: 0;
            padding: 0;
        }

        :root {
            --primary: #2C3E7A;
            --primary-light: #EEF1FB;
            --accent: #5A4FCF;
            --accent-light: #EEEDFE;
            --text: #1a1a2e;
            --text-muted: #5a5a72;
            --border: #c8c8d8;
            --border-light: #e8e8f0;
            --bg: #f4f4f8;
            --white: #ffffff;
            --gold: #B8953A;
            --gold-light: #FDF6E3;
            --fee-color: #185FA5;
            --success: #1D9E75;
        }

        body {
            font-family: 'Noto Sans Myanmar', sans-serif;
            background: var(--bg);
            color: var(--text);
            padding: 2rem;
            min-height: 100vh;
        }

        .page {
            background: var(--white);
            border: 1px solid var(--border);
            border-radius: 10px;
            padding: 2.5rem;
            margin-bottom: 2rem;
            max-width: 900px;
            margin-left: auto;
            margin-right: auto;
            box-shadow: 0 2px 16px rgba(44, 62, 122, 0.07);
            page-break-after: always;
        }

        /* ── HEADER ── */
        .uni-header {
            text-align: center;
            padding-bottom: 1.2rem;
            margin-bottom: 1.5rem;
            border-bottom: 2px solid var(--primary);
            position: relative;
        }

        .uni-header .gov-line {
            font-size: 12px;
            color: var(--text-muted);
            letter-spacing: 0.5px;
            margin-bottom: 4px;
        }

        .uni-header h1 {
            font-size: 17px;
            font-weight: 700;
            color: var(--primary);
            letter-spacing: 0.5px;
        }

        .uni-header h2 {
            font-size: 14px;
            font-weight: 500;
            color: var(--accent);
            margin-top: 3px;
        }

        .uni-header .form-title {
            font-size: 15px;
            font-weight: 700;
            color: var(--text);
            margin-top: 10px;
        }

        .uni-header .form-sub {
            font-size: 13px;
            color: var(--text-muted);
            margin-top: 3px;
        }

        /* ── PHOTO BOX ── */
        /* .photo-box {
    float: right;
    width: 120px;
    border: 1px solid var(--border);
    padding: 10px;
    text-align: center;
    margin-left: 1.5rem;
    margin-bottom: 1rem;
    border-radius: 8px;
    background: var(--primary-light);
  }
  .photo-area {
    width: 96px; height: 120px;
    border: 1.5px dashed var(--border);
    display: flex; align-items: center; justify-content: center;
