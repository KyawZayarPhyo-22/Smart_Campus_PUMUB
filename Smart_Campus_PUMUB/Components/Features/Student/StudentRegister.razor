@page "/Register"
@layout MainLayout
@using Smart_Campus_PUMUB.WebApi.Models
@using Microsoft.AspNetCore.Components.Authorization
@using Microsoft.AspNetCore.Authorization
@attribute [Authorize]
@rendermode InteractiveServer

<style>
    @@import url('https://fonts.googleapis.com/css2?family=Plus+Jakarta+Sans:wght@400;500;600;700&display=swap');

    .modern-form-card {
        background: #ffffff;
        width: 100%;
        min-width: 1000px;
        border-radius: 16px;
        box-shadow: 0 10px 30px rgba(0, 0, 0, 0.05);
        padding: 40px 150px;
        margin-bottom: 50px;
    }

    .form-header {
        display: flex;
        align-items: center;
        gap: 12px;
        margin-bottom: 40px;
    }

        .form-header i {
            color: #2563EB;
            font-size: 1.5rem;
        }

        .form-header h2 {
            margin: 0;
            font-size: 1.4rem;
            color: #0f172a;
            font-weight: 700;
        }

    .stepper-wrapper {
        display: flex;
        align-items: flex-start;
        justify-content: space-between;
        margin-bottom: 50px;
        position: relative;
    }

        .stepper-wrapper::before {
            content: '';
            position: absolute;
            top: 18px;
            left: 5%;
            right: 5%;
            height: 2px;
            background: #e2e8f0;
            z-index: 1;
        }

    .stepper-progress {
        position: absolute;
        top: 18px;
        left: 5%;
        height: 2px;
        background: #2563EB;
        z-index: 2;
        transition: width 0.3s ease;
    }

    .step-block {
        display: flex;
        flex-direction: column;
        align-items: center;
        gap: 10px;
        position: relative;
        z-index: 3;
        width: 120px;
    }

    .step-circle {
        width: 38px;
        height: 38px;
        border-radius: 50%;
        background: #ffffff;
        border: 2px solid #e2e8f0;
        display: flex;
        align-items: center;
        justify-content: center;
        font-weight: 700;
        color: #94a3b8;
        font-size: 0.9rem;
        transition: all 0.3s ease;
    }

    .step-block.active .step-circle {
        background: #2563EB;
        border-color: #2563EB;
        color: white;
        box-shadow: 0 0 0 4px rgba(14, 165, 233, 0.2);
    }

    .step-label {
        font-size: 0.8rem;
        font-weight: 600;
        color: #64748b;
        text-align: center;
    }

    .step-block.active .step-label {
        color: #2563EB;
    }

    .photo-upload-wrapper {
        grid-column: span 2;
        display: flex;
        justify-content: center;
        margin-bottom: 24px;
    }

    .photo-box {
        width: 130px;
        height: 160px;
        border: 2px dashed #94a3b8;
        border-radius: 8px;
        display: flex;
        flex-direction: column;
        align-items: center;
        justify-content: center;
        background-color: #f8fafc;
        cursor: pointer;
        transition: all 0.2s ease;
        overflow: hidden;
        position: relative;
        box-shadow: 0 4px 6px rgba(0,0,0,0.02);
    }

        .photo-box:hover {
            border-color: #2563EB;
            background-color: #f0f9ff;
        }

        .photo-box img {
            width: 100%;
            height: 100%;
            object-fit: cover;
        }

        .photo-box i {
            font-size: 2rem;
            color: #94a3b8;
            margin-bottom: 8px;
        }

    .photo-text {
        font-size: 0.75rem;
        color: #64748b;
        text-align: center;
        padding: 0 8px;
        line-height: 1.4;
    }

    .input-grid {
        display: grid;
        grid-template-columns: 1fr 1fr;
        gap: 24px;
        animation: fadeIn 0.4s ease-in-out;
    }
    @@keyframes fadeIn {
        from {
            opacity: 0;
            transform: translateY(10px);
        }

        to {
            opacity: 1;
            transform: translateY(0);
        }
    }

    .input-group {
        display: flex;
        flex-direction: column;
        gap: 8px;
    }

        .input-group.full-width {
            grid-column: span 2;
        }

    .input-label {
        font-size: 0.85rem;
        font-weight: 700;
        color: #334155;
    }

    .modern-input {
        width: 100%;
        padding: 14px 16px;
        border: 1px solid #cbd5e1;
        border-radius: 10px;
        font-size: 0.95rem;
        color: #0f172a;
        font-family: inherit;
        background: #ffffff;
        transition: all 0.2s ease;
        box-sizing: border-box;
    }

        .modern-input:focus {
            outline: none;
            border-color: #2563EB;
            box-shadow: 0 0 0 3px rgba(14, 165, 233, 0.1);
        }

        .modern-input::placeholder {
            color: #94a3b8;
        }

    select.modern-input {
        cursor: pointer;
    }

    textarea.modern-input {
        resize: vertical;
        min-height: 80px;
    }

    .radio-group {
        display: flex;
        gap: 20px;
        margin-top: 5px;
    }

    .radio-item {
        display: flex;
        align-items: center;
        gap: 8px;
        font-size: 0.9rem;
        color: #475569;
        cursor: pointer;
    }

    .table-responsive {
        overflow-x: auto;
        border: 1px solid #e2e8f0;
        border-radius: 10px;
        margin-top: 10px;
    }

    .modern-table {
        width: 100%;
        border-collapse: collapse;
        text-align: left;
    }

        .modern-table th {
            background-color: #f8fafc;
            color: #475569;
            font-size: 0.85rem;
            font-weight: 700;
            padding: 12px 16px;
            border-bottom: 1px solid #e2e8f0;
        }

        .modern-table td {
            padding: 10px 16px;
            border-bottom: 1px solid #e2e8f0;
        }

            .modern-table td .modern-input {
                padding: 8px 12px;
                border-radius: 6px;
            }

    .form-footer {
        display: flex;
        justify-content: flex-end;
        margin-top: 40px;
        padding-top: 20px;
        border-top: 1px solid #f1f5f9;
    }

    .btn-next, .btn-submit {
        background: #2563EB;
        color: white;
        border: none;
        padding: 12px 28px;
        font-size: 0.95rem;
        font-weight: 600;
        border-radius: 50px;
        cursor: pointer;
        display: inline-flex;
        align-items: center;
        gap: 8px;
        transition: background 0.2s;
    }

        .btn-next:hover, .btn-submit:hover {
            background: #0284c7;
        }

        .btn-submit:disabled {
            opacity: 0.7;
            cursor: not-allowed;
        }

    .btn-prev {
        background: #f1f5f9;
        color: #475569;
        border: none;
        padding: 12px 28px;
        font-size: 0.95rem;
        font-weight: 600;
        border-radius: 50px;
        cursor: pointer;
        margin-right: auto;
        transition: background 0.2s;
    }

        .btn-prev:hover {
            background: #e2e8f0;
        }

    /* Modal CSS */
    .modal-overlay {
        position: fixed;
        top: 0;
        left: 0;
        width: 100%;
        height: 100%;
        background: rgba(15, 23, 42, 0.6);
        display: flex;
        align-items: center;
        justify-content: center;
        z-index: 9999;
        backdrop-filter: blur(4px);
    }

    .modal-content {
        background: #ffffff;
        padding: 30px 40px;
        border-radius: 20px;
        text-align: center;
        box-shadow: 0 20px 40px rgba(0, 0, 0, 0.15);
        max-width: 400px;
        width: 90%;
        animation: popIn 0.3s cubic-bezier(0.16, 1, 0.3, 1);
    }

    .modal-icon {
        font-size: 3.5rem;
        margin-bottom: 15px;
    }

        .modal-icon.error {
            color: #ef4444;
        }

        .modal-icon.success {
            color: #10b981;
        }

    .modal-content h3 {
        margin: 0 0 10px 0;
        color: #0f172a;
        font-size: 1.3rem;
        font-weight: 700;
    }

    .modal-content p {
        color: #475569;
        margin-bottom: 24px;
        font-size: 0.95rem;
        line-height: 1.6;
    }

    .btn-modal {
        background: #2563EB;
        color: white;
        border: none;
        padding: 12px 30px;
        font-size: 0.95rem;
        font-weight: 600;
        border-radius: 50px;
        cursor: pointer;
        transition: background 0.2s;
        width: 100%;
    }

        .btn-modal:hover {
            background: #1d4ed8;
        }

        .btn-modal.success {
            background: #10b981;
        }

            .btn-modal.success:hover {
                background: #059669;
            }

    @@keyframes popIn {
        0% {
            transform: scale(0.9);
            opacity: 0;
        }

        100% {
            transform: scale(1);
            opacity: 1;
        }
    }
</style>

<div class="modern-form-card" style="margin-top: 80px;">
    <div class="form-header">
        <i class="fas fa-file-alt"></i>
        <h2>Online Registration Form</h2>
    </div>

    <div class="stepper-wrapper">
        <div class="stepper-progress" style="width: @((CurrentStep - 1) * 33.33)%"></div>
        <div class="step-block @(CurrentStep >= 1 ? "active" : "")"><div class="step-circle">1</div><div class="step-label">Personal Info</div></div>
        <div class="step-block @(CurrentStep >= 2 ? "active" : "")"><div class="step-circle">2</div><div class="step-label">Academic Info</div></div>
        <div class="step-block @(CurrentStep >= 3 ? "active" : "")"><div class="step-circle">3</div><div class="step-label">Family Info</div></div>
        <div class="step-block @(CurrentStep >= 4 ? "active" : "")"><div class="step-circle">4</div><div class="step-label">Submit</div></div>
    </div>

    @if (CurrentStep == 1)
    {
        <div class="input-grid">
            <div class="photo-upload-wrapper">
                <label for="photoUpload" class="photo-box">
                    @if (!string.IsNullOrEmpty(PreviewImageUrl))
                    {
                        <img src="@PreviewImageUrl" alt="Student Photo" />
                    }
                    else
                    {
                        <i class="far fa-user"></i>
                        <span class="photo-text">ပတ်စပို့စ်အရွယ်<br>ဓာတ်ပုံ</span>
                    }
                </label>
                <InputFile @key="PreviewImageUrl" id="photoUpload" OnChange="OnPhotoSelected" accept="image/*" style="display: none;" />
            </div>

            <!-- 💡 User ID ကို ဖောင်တွင် မပြတော့ဘဲ နောက်ကွယ်မှ Auto ခေါ်ယူရန် ပြန်ဖျောက်ထားပါသည် 💡 -->
            <input type="hidden" @bind="RegModel.UserId" />

            <!-- User ID Status Display -->
            <div class="input-group" style="grid-column: span 2;">
                @if (RegModel.UserId.HasValue && RegModel.UserId > 0)
                {
                    <div style="background: #f0f9ff; padding: 12px 16px; border-radius: 10px; border: 1px solid #0ea5e9; color: #0369a1; font-size: 0.85rem; display: flex; align-items: center;">
                        <i class="fas fa-user-check me-2"></i>
                        <div>
                            <strong>User ID auto-filled:</strong> @RegModel.UserId<br>
                            <small style="opacity: 0.8;">Logged in user ID automatically loaded</small>
                        </div>
                    </div>
                }
                else
                {
                    <div style="background: #fef2f2; padding: 12px 16px; border-radius: 10px; border: 1px solid #ef4444; color: #991b1b; font-size: 0.85rem; display: flex; align-items: center;">
                        <i class="fas fa-exclamation-triangle me-2"></i>
                        <div>
                            <strong>User ID not found</strong><br>
                            <small>Please <a href="/login" style="color: #dc2626; text-decoration: underline;">login</a> first to access registration form.</small>
                        </div>
                    </div>
                }
            </div>

            <div class="input-group">
                <label class="input-label">အမည် (မြန်မာစာဖြင့်) <span style="color:red;">*</span></label>
                <input type="text" class="modern-input" placeholder="ကိုအောင်မင်း" @bind="RegModel.student_name_mm" oninput="this.value = this.value.replace(/[^\u1000-\u109F\s]/g, '')" required disabled="@(!(RegModel.UserId.HasValue && RegModel.UserId > 0))">
            </div>

            <div class="input-group">
                <label class="input-label">အမည် (အင်္ဂလိပ်စာဖြင့်)</label>
                <input type="text" class="modern-input" placeholder="Ko Aung Min" @bind="RegModel.student_name_en" oninput="this.value = this.value.replace(/[^a-zA-Z\s]/g, '')" disabled="@(!(RegModel.UserId.HasValue && RegModel.UserId > 0))">
            </div>

            <div class="input-group">
                <label class="input-label">မှတ်ပုံတင် (NRC) <span style="color:red;">*</span></label>
                <div style="display:flex; gap:8px; align-items:center;">
                    <select class="modern-input" style="width:80px; padding: 14px 8px; appearance: auto;" @onchange="OnNrcStateChanged" required>
                        <option value="">တိုင်း</option>
                        @for (int i = 1; i <= 14; i++)
                        {
                            <option value="@i" selected="@(RegModel.nrc_state == i.ToString())">@i</option>
                        }
                    </select>
                    <span style="font-weight:bold; color:#334155;">/</span>
                    <select class="modern-input" style="flex:1; padding: 14px 8px;" @bind="RegModel.nrc_township" required>
                        <option value="">မြို့နယ်</option>
                        @foreach (var town in CurrentTownshipList)
                        {
                            <option value="@town">@town</option>
                        }
                    </select>
                    <select class="modern-input" style="width:85px; padding: 14px 8px;" @bind="NrcType">
                        <option value="(နိုင်)">(နိုင်)</option>
                        <option value="(ဧည့်)">(ဧည့်)</option>
                        <option value="(ပြု)">(ပြု)</option>
                        <option value="(စ)">(စ)</option>
                        <option value="(သီ)">(သီ)</option>
                        <option value="(သ)">(သ)</option>
                    </select>
                    <input type="text" class="modern-input" style="width:100px; padding: 14px 8px;" placeholder="123456" @bind="RegModel.nrc_number" maxlength="6" required>
                </div>
            </div>

            <div class="input-group">
                <label class="input-label">မွေးသက္ကရာဇ် <span style="color:red;">*</span></label>
                <input type="date" class="modern-input" @bind="DobDate" required>
            </div>

            <div class="input-group">
                <label class="input-label">ကျား / မ</label>
                <select class="modern-input" @bind="RegModel.gender_relation">
                    <option value="ကျား">ကျား</option>
                    <option value="မ">မ</option>
                </select>
            </div>
            <div class="input-group">
                <label class="input-label">သွေးအုပ်စု</label>
                <select class="modern-input" @bind="RegModel.blood_type">
                    <option value="A">A</option>
                    <option value="B">B</option>
                    <option value="AB">AB</option>
                    <option value="O">O</option>
                </select>
            </div>

            <div class="input-group">
                <label class="input-label">လူမျိုး နှင့် ကိုးကွယ်သည့်ဘာသာ</label>
                <div style="display: flex; gap:10px;">
                    <select class="modern-input" @bind="RegModel.ethnicity">
                        <option value="">-- လူမျိုး ရွေးပါ --</option>
                        <option value="ဗမာ">ဗမာ</option>
                        <option value="ကချင်">ကချင်</option>
                        <option value="ကယား">ကယား</option>
                        <option value="ကရင်">ကရင်</option>
                        <option value="ချင်း">ချင်း</option>
                        <option value="မွန်">မွန်</option>
                        <option value="ရခိုင်">ရခိုင်</option>
                        <option value="ရှမ်း">ရှမ်း</option>
                    </select>
                    <select class="modern-input" @bind="RegModel.religion">
                        <option value="">-- ဘာသာ ရွေးပါ --</option>
                        <option value="ဗုဒ္ဓဘာသာ">ဗုဒ္ဓဘာသာ</option>
                        <option value="ခရစ်ယာန်ဘာသာ">ခရစ်ယာန်ဘာသာ</option>
                        <option value="အစ္စလာမ်ဘာသာ">အစ္စလာမ်ဘာသာ</option>
                        <option value="ဟိန္ဒူဘာသာ">ဟိန္ဒူဘာသာ</option>
                    </select>
                </div>
            </div>
            <div class="input-group">
                <label class="input-label">နိုင်ငံသား အမျိုးအစား</label>
                <div class="radio-group" style="padding: 10px 0;">
                    <label class="radio-item"><input type="radio" name="nationality" checked="@(RegModel.nationality_status == "တိုင်းရင်းသား")" @onchange='() => RegModel.nationality_status = "တိုင်းရင်းသား"'> တိုင်းရင်းသား</label>
                    <label class="radio-item"><input type="radio" name="nationality" checked="@(RegModel.nationality_status == "နိုင်ငံခြားသား")" @onchange='() => RegModel.nationality_status = "နိုင်ငံခြားသား"'> နိုင်ငံခြားသား</label>
                </div>
            </div>

            <div class="input-group">
                <label class="input-label">မွေးဖွားရာ ဇာတိမြို့နယ်</label>
                <input type="text" class="modern-input" placeholder="မွေးဖွားရာဇာတိမြို့" @bind="RegModel.pob">
            </div>
            <div class="input-group">
                <label class="input-label">မွေးဖွားရာ တိုင်းဒေသကြီး/ပြည်နယ်</label>
                <input type="text" class="modern-input" placeholder="ဥပမာ - ရန်ကုန်တိုင်း" @bind="RegModel.birth_place_region">
            </div>

            <div class="input-group">
                <label class="input-label">ဖုန်းနံပါတ် (09XXXXXXXXX) <span style="color:red;">*</span></label>
                <input type="text" class="modern-input" placeholder="09765432100" @bind="RegModel.app_student_phone" maxlength="11" oninput="this.value = this.value.replace(/[^0-9]/g, '')" required>
            </div>
            <div class="input-group">
                <label class="input-label">Email</label>
                <input type="email" class="modern-input" placeholder="student@example.com" @bind="RegModel.email">
            </div>

            <div class="input-group">
                <label class="input-label">ကိုဗစ်ကာကွယ်ရေးထိုးနှံမှုပြီးစီးသည့်ရက်</label>
                <input type="date" class="modern-input" @bind="CovidDate">
            </div>
        </div>

        <div class="form-footer">
            <button class="btn-next" @onclick="NextStep">Next: Academic Info <i class="fas fa-arrow-right"></i></button>
        </div>
    }

    @if (CurrentStep == 2)
    {
        <div class="input-grid">
            <div class="input-group full-width">
                <label class="input-label">အမြဲတမ်းနေရပ်လိပ်စာ(အပြည့်အစုံ) (မြန်မာစာဖြင့်) <span style="color:red;">*</span></label>
                <textarea class="modern-input" placeholder="နေရပ်လိပ်စာ အပြည့်အစုံ ရေးရန်..." @bind="RegModel.permanent_address_mm" oninput="this.value = this.value.replace(/[^\u1000-\u109F0-9\s.,/-]/g, '')" required></textarea>
            </div>
            <div class="input-group full-width">
                <label class="input-label">အမြဲတမ်းနေရပ်လိပ်စာ(အပြည့်အစုံ) (အင်္ဂလိပ်စာဖြင့်)</label>
                <textarea class="modern-input" placeholder="Full permanent address..." @bind="RegModel.permanent_address_en" oninput="this.value = this.value.replace(/[^a-zA-Z0-9\s.,/-]/g, '')"></textarea>
            </div>

            <div class="input-group">
                <label class="input-label">ပညာသင်နှစ် (Academic Year Range) <span style="color:red;">*</span></label>
                <input type="text" class="modern-input" placeholder="ဥပမာ - 2023-2024" @bind="RegModel.academic_year_range" required>
            </div>

            <div class="input-group">
                <label class="input-label">သင်တန်းနှစ် (Semester) <span style="color:red;">*</span></label>
                <select class="modern-input" @bind="RegModel.academic_year_level" required>
                    <option value="">-- သင်တန်းနှစ် ရွေးချယ်ပါ --</option>
                    @if (SemesterList != null && SemesterList.Any())
                    {
                        @foreach (var sem in SemesterList)
                        {
                            <option value="@sem.SemesterName">@sem.SemesterName</option>
                        }
                    }
                </select>
            </div>

            <div class="input-group">
                <label class="input-label">အထူးပြုဘာသာ</label>
                <select class="modern-input" @bind="RegModel.major">
                    <option value="">-- အထူးပြုဘာသာ ရွေးချယ်ပါ --</option>
                    <optgroup label="Computer University (ကွန်ပျူတာတက္ကသိုလ်)">
                        <option value="Computer Science">Computer Science</option>
                        <option value="Computer Technology">Computer Technology</option>
                        <option value="Information Technology">Information Technology</option>
                    </optgroup>
                    <optgroup label="GTC / Polytechnic (နည်းပညာတက္ကသိုလ်)">
                        <option value="Civil Engineering">Civil Engineering</option>
                        <option value="Electronic Engineering">Electronic Engineering</option>
                        <option value="Electrical Power Engineering">Electrical Power Engineering</option>
                        <option value="Mechanical Engineering">Mechanical Engineering</option>
                        <option value="Information Technology Engineering">Information Technology Engineering</option>
                    </optgroup>
                </select>
            </div>
            <div class="input-group">
                <label class="input-label">ခုံအမှတ်</label>
                <input type="text" class="modern-input" placeholder="ခုံအမှတ် ရိုတ်ထည့်ပါ" @bind="RegModel.roll_no">
            </div>

            <div class="input-group">
                <label class="input-label">တက္ကသိုလ်မှတ်ပုံတင်အမှတ်</label>
                <input type="text" class="modern-input" placeholder="မှတ်ပုံတင်အမှတ် ရိုက်ထည့်ပါ" @bind="RegModel.university_reg_no">
            </div>
            <div class="input-group">
                <label class="input-label">တက္ကသိုလ်ဝင်ရောက်သည့်နှစ် (ခုနှစ်)</label>
                <input type="number" class="modern-input" placeholder="e.g. 2024" @bind="RegModel.admission_year">
            </div>

            <div class="input-group">
                <label class="input-label">အောင်မြင်သည့် ခုနှစ်</label>
                <input type="number" class="modern-input" placeholder="e.g. 2022" @bind="RegModel.matric_passed_year">
            </div>
            <div class="input-group">
                <label class="input-label">တက္ကသိုလ်ဝင်တန်း ခုံအမှတ်</label>
                <input type="text" class="modern-input" placeholder="e.g. အမ-၁၂၃၄" @bind="RegModel.matric_roll_no">
            </div>

            <div class="input-group">
                <label class="input-label">စာစစ်ဌာန</label>
                <input type="text" class="modern-input" placeholder="စာစစ်ဌာန အမည်" @bind="RegModel.exam_center">
            </div>
        </div>

        <div class="form-footer">
            <button class="btn-prev" @onclick="PrevStep"><i class="fas fa-arrow-left"></i> Back</button>
            <button class="btn-next" @onclick="NextStep">Next: Family Info <i class="fas fa-arrow-right"></i></button>
        </div>
    }

    @if (CurrentStep == 3)
    {
        <div class="input-grid">
            <div class="input-group full-width" style="border-bottom: 1px dashed #e2e8f0; padding-bottom: 20px; margin-bottom: 10px;">
                <label class="input-label">၂။ ဖြေဆိုသည့်စာမေးပွဲများ</label>
                <div class="table-responsive">
                    <table class="modern-table">
                        <thead>
                            <tr>
                                <th>ဖြေဆိုသည့်စာမေးပွဲများ</th>
                                <th>အဓိကဘာသာ</th>
                                <th>ခုံအမှတ်</th>
                                <th>ခုနှစ်</th>
                                <th>အောင် / ကျ</th>
                            </tr>
                        </thead>
                        <tbody>
                            <tr>
                                <td>
                                    <select class="modern-input" @bind="PastExamSemester">
                                        <option value="">-- ရွေးချယ်ပါ --</option>
                                        @if (SemesterList != null && SemesterList.Any())
                                        {
                                            @foreach (var sem in SemesterList)
                                            {
                                                <option value="@sem.SemesterName">@sem.SemesterName</option>
                                            }
                                        }
                                    </select>
                                </td>
                                <td><input type="text" class="modern-input" @bind="RegModel.past_exam_major"></td>
                                <td><input type="text" class="modern-input" @bind="RegModel.past_exam_roll_no"></td>
                                <td><input type="date" class="modern-input" @bind="PastExamDate"></td>
                                <td><input type="text" class="modern-input" @bind="RegModel.past_exam_status"></td>
                            </tr>
                        </tbody>
                    </table>
                </div>
            </div>

            <div class="input-group">
                <label class="input-label">အဘ အမည် (မြန်မာစာဖြင့်) <span style="color:red;">*</span></label>
                <input type="text" class="modern-input" placeholder="အဘ အမည်" @bind="RegModel.father_name" oninput="this.value = this.value.replace(/[^\u1000-\u109F\s]/g, '')" required>
            </div>

            <div class="input-group">
                <label class="input-label">အဘ မှတ်ပုံတင်အမှတ် (NRC)</label>
                <div style="display:flex; gap:8px; align-items:center;">
                    <select class="modern-input" style="width:80px; padding: 14px 8px; appearance: auto;" @onchange="OnFatherNrcStateChanged">
                        <option value="">တိုင်း</option>
                        @for (int i = 1; i <= 14; i++)
                        {
                            <option value="@i" selected="@(FatherNrcState == i.ToString())">@i</option>
                        }
                    </select>
                    <span style="font-weight:bold; color:#334155;">/</span>
                    <select class="modern-input" style="flex:1; padding: 14px 8px;" @bind="FatherNrcTownship">
                        <option value="">မြို့နယ်</option>
                        @foreach (var town in FatherTownshipList)
                        {
                            <option value="@town">@town</option>
                        }
                    </select>
                    <select class="modern-input" style="width:85px; padding: 14px 8px;" @bind="FatherNrcType">
                        <option value="(နိုင်)">(နိုင်)</option>
                        <option value="(ဧည့်)">(ဧည့်)</option>
                        <option value="(ပြု)">(ပြု)</option>
                        <option value="(စ)">(စ)</option>
                        <option value="(သီ)">(သီ)</option>
                        <option value="(သ)">(သ)</option>
                    </select>
                    <input type="text" class="modern-input" style="width:100px; padding: 14px 8px;" placeholder="123456" @bind="FatherNrcNumber" maxlength="6">
                </div>
            </div>

            <div class="input-group">
                <label class="input-label">အဘ အလုပ်အကိုင်၊ ရာထူး၊ ဌာန</label>
                <input type="text" class="modern-input" placeholder="အလုပ်အကိုင်" @bind="RegModel.father_occupation">
            </div>
            <div class="input-group"></div>

            <div class="input-group">
                <label class="input-label">အမိ အမည် (မြန်မာစာဖြင့်)</label>
                <input type="text" class="modern-input" placeholder="အမိ အမည်" @bind="RegModel.mother_name" oninput="this.value = this.value.replace(/[^\u1000-\u109F\s]/g, '')">
            </div>
            <div class="input-group">
                <label class="input-label">အမိ အလုပ်အကိုင်၊ ရာထူး၊ ဌာန</label>
                <input type="text" class="modern-input" placeholder="အလုပ်အကိုင်" @bind="RegModel.mother_occupation">
            </div>

            <div class="input-group full-width" style="border-top: 1px dashed #e2e8f0; padding-top: 20px; margin-top: 10px;">
                <label class="input-label" style="font-size: 1rem;">၃။ ကျောင်းနေရန်အထောက်အပံ့ပြုမည့် ပုဂ္ဂိုလ်</label>
            </div>

            <div class="input-group">
                <label class="input-label">အမည် <span style="color:red;">*</span></label>
                <input type="text" class="modern-input" placeholder="အုပ်ထိန်းသူ အမည်" @bind="RegModel.guardian_name" required>
            </div>
            <div class="input-group">
                <label class="input-label">ဆွေမျိုးတော်စပ်ပုံ</label>
                <input type="text" class="modern-input" placeholder="e.g. ဦးလေး / အဒေါ်" @bind="RegModel.guardian_relationship">
            </div>

            <div class="input-group">
                <label class="input-label">အလုပ်အကိုင်</label>
                <input type="text" class="modern-input" placeholder="အလုပ်အကိုင်" @bind="RegModel.guardian_occupation">
            </div>
            <div class="input-group">
                <label class="input-label">ဆက်သွယ်ရန်လိပ်စာနှင့် ဖုန်းနံပါတ် <span style="color:red;">*</span></label>
                <input type="text" class="modern-input" placeholder="လိပ်စာ နှင့် ဖုန်း" @bind="RegModel.guardian_address_phone" required>
            </div>
        </div>

        <div class="form-footer">
            <button class="btn-prev" @onclick="PrevStep"><i class="fas fa-arrow-left"></i> Back</button>
            <button class="btn-next" @onclick="NextStep">Next: Submit <i class="fas fa-arrow-right"></i></button>
        </div>
    }

    @if (CurrentStep == 4)
    {
        <div class="input-grid">
            <div class="input-group full-width">
                <label class="input-label">ပညာသင်ထောက်ပံ့ကြေးပေးရန်မေတ္တာရပ်ခံခြင်း</label>
                <div class="radio-group" style="padding: 10px 0;">
                    <label class="radio-item"><input type="radio" name="prize" checked="@(RegModel.stipend_requested == true)" @onchange="@(() => RegModel.stipend_requested = true)"> ပြုမည်</label>
                    <label class="radio-item"><input type="radio" name="prize" checked="@(RegModel.stipend_requested == false)" @onchange="@(() => RegModel.stipend_requested = false)"> မပြုပါ</label>
                </div>
            </div>

            <div class="input-group full-width">
                <div style="background: #f8fafc; padding: 20px; border-radius: 12px; border: 1px solid #e2e8f0;">
                    <h4 style="margin: 0 0 15px 0; color: #0f172a;">ကိုယ်ပိုင်ဝန်ခံချက်</h4>
                    <ul style="font-size: 0.9rem; color: #475569; padding-left: 20px; margin: 0; line-height: 1.8;">
                        <li>၁။ အထက်ဖော်ပြပါ အချက်များအားလုံး မှန်ကန်ပါသည်။</li>
                        <li>၂။ ဤတက္ကသိုလ်၌ ကိုယ်တိုင်ပညာသင်ခွင့် တောင်းသည်ကို မိဘ (သို့မဟုတ်) အုပ်ထိန်းသူက သဘောတူကြောင်း ဖြစ်ပါသည်။</li>
                        <li>၃။ တက္ကသိုလ်ကျောင်းသားတစ်ဦးပီသစွာ တက္ကသိုလ် / ကောလိပ်က ချမှတ်သည့် စည်းမျဉ်းစည်းကမ်းနှင့်အညီ လိုက်နာကျင့်သုံးနေထိုင်ပါမည်။</li>
                    </ul>
                </div>
            </div>

            <div class="input-group">
                <label class="input-label">ပညာသင်ခွင့်လျောက်ထားသူ၏ လက်မှတ် (အမည်ရိုက်ရန်)</label>
                <input type="text" class="modern-input" placeholder="အမည် အပြည့်အစုံ ရိုက်ထည့်ပါ" @bind="RegModel.app_student_name">
            </div>
            <div class="input-group">
                <label class="input-label">ဖုန်းနံပါတ် (ကျောင်းသား)</label>
                <input type="text" class="modern-input" placeholder="ဥပမာ - 09765432100" @bind="RegModel.app_student_phone" maxlength="11">
            </div>

            <div class="input-group">
                <label class="input-label">ရက်စွဲ (Auto System Date)</label>
                <input type="date" class="modern-input" disabled @bind="SignDate">
            </div>

            <div class="input-group">
                <label class="input-label">အုပ်ထိန်းသူအမည်</label>
                <input type="text" class="modern-input" placeholder="အုပ်ထိန်းသူအမည် အပြည့်အစုံ ရိုက်ထည့်ပါ" @bind="RegModel.app_guardian_name">
            </div>
            <div class="input-group">
                <label class="input-label">မှတ်ပုံတင်အမှတ် (အုပ်ထိန်းသူ)</label>
                <div style="display:flex; gap:8px; align-items:center;">
                    <select class="modern-input" style="width:80px; padding: 14px 8px; appearance: auto;" @onchange="OnGuardianNrcStateChanged">
                        <option value="">တိုင်း</option>
                        @for (int i = 1; i <= 14; i++)
                        {
                            <option value="@i" selected="@(GuardianNrcState == i.ToString())">@i</option>
                        }
                    </select>
                    <span style="font-weight:bold; color:#334155;">/</span>
                    <select class="modern-input" style="flex:1; padding: 14px 8px;" @bind="GuardianNrcTownship">
                        <option value="">မြို့နယ်</option>
                        @foreach (var town in GuardianTownshipList)
                        {
                            <option value="@town">@town</option>
                        }
                    </select>
                    <select class="modern-input" style="width:85px; padding: 14px 8px;" @bind="GuardianNrcType">
                        <option value="(နိုင်)">(နိုင်)</option>
                        <option value="(ဧည့်)">(ဧည့်)</option>
                        <option value="(ပြု)">(ပြု)</option>
                        <option value="(စ)">(စ)</option>
                        <option value="(သီ)">(သီ)</option>
                        <option value="(သ)">(သ)</option>
                    </select>
                    <input type="text" class="modern-input" style="width:100px; padding: 14px 8px;" placeholder="123456" @bind="GuardianNrcNumber" maxlength="6">
                </div>
            </div>

            <div class="input-group">
                <label class="input-label">ဖုန်းနံပါတ် (အုပ်ထိန်းသူ)</label>
                <input type="text" class="modern-input" placeholder="ဖုန်းနံပါတ် အပြည့်အစုံ ရိုက်ထည့်ပါ" @bind="RegModel.app_guardian_phone">
            </div>
            <div class="input-group">
            </div>

            <div class="input-group full-width">
                <label class="input-label">ယခုဆက်သွယ်ရန်လိပ်စာ</label>
                <textarea class="modern-input" placeholder="ယခုလက်ရှိ နေထိုင်သောလိပ်စာ..." @bind="RegModel.current_address"></textarea>
            </div>
        </div>

        <div class="form-footer">
            <button class="btn-prev" @onclick="PrevStep"><i class="fas fa-arrow-left"></i> Back</button>
            <button class="btn-submit" style="background: #10b981;" disabled="@IsSubmitting" @onclick="SubmitRegistrationForm">
                @if (IsSubmitting)
                {
                    <span>Submitting... <i class="fas fa-spinner fa-spin ms-1"></i></span>
                }
                else
                {
                    <span>ငွေပေးချေမှုစနစ်သို့ သွားရန် <i class="fas fa-credit-card"></i></span>
                }
            </button>
        </div>
    }
</div>

@if (ShowModal)
{
    <div class="modal-overlay" @onclick="CloseModal">
        <div class="modal-content" @onclick:stopPropagation="true">
            @if (IsSuccessModal)
            {
                <i class="fas fa-check-circle modal-icon success"></i>
                <h3>အောင်မြင်ပါသည်</h3>
            }
            else
            {
                <i class="fas fa-exclamation-circle modal-icon error"></i>
                <h3>အသိပေးချက်</h3>
            }

            <p>@ModalMessage</p>
            <button class="btn-modal @(IsSuccessModal ? "success" : "")" @onclick="CloseModal">အိုကေ</button>
        </div>
    </div>
}