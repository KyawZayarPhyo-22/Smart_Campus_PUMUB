        </div>
        <hr class="divider" style="clear:both; margin-top:72px;">

        <div class="form-grid form-grid-3">
            <div class="field"><label>သင်တန်းနှစ်</label><input type="text" bind="Reg.AcademicYearLevel" class="line"></div>
            <div class="field"><label>အထူးပြုဘာသာ</label><input type="text" @bind="Reg.Major" class="line"></div>
            <div class="field"><label>ခုံအမှတ်</label><input type="text" @bind="Reg.RollNo" class="line"></div>
        </div>
        <div class="form-grid form-grid-2">
            <div class="field"><label>တက္ကသိုလ်မှတ်ပုံတင်အမှတ်</label><input type="text" @bind="Reg.UniversityRegNo" class="line"></div>
            <div class="field"><label>တက္ကသိုလ်ဝင်ရောက်သည့်နှစ်</label><input type="number" @bind="Reg.AdmissionYear" class="line"></div>
        </div>

        <div class="">
            <div class="section-label">၁။ ပညာဆည်းပူးဆက်လက်သင်ခွင့်တောင်းသူ ကျောင်းသား၊ ကျောင်းသူ</div>
            <div class="form-grid form-grid-2">
                <div class="field"><label>အမည် (မြန်မာစာဖြင့်)</label><input type="text" @bind="Reg.StudentNameMm" class="line"></div>
                <div class="field"><label>အမည် (အင်္ဂလိပ်စာဖြင့်)</label><input type="text" @bind="Reg.StudentNameEn" class="line"></div>
                <div class="field"><label>လူမျိုး</label><input type="text" @bind="Reg.Ethnicity" class="line"></div>
                <div class="field"><label>ကိုးကွယ်သည့်ဘာသာ</label><input type="text" @bind="Reg.Religion" class="line"></div>
                <div class="field"><label>မွေးဖွားရာဇာတိ</label><input type="text" @bind="Reg.Pob" class="line"></div>
                <div class="field"><label>မြို့နယ် / ပြည်နယ် / တိုင်း</label><input type="text" @bind="Reg.BirthPlaceRegion" class="line"></div>
                <div class="field"><label>မှတ်ပုံတင်အမှတ်</label><input type="text" @bind="Reg.StudentNrcNo" class="line"></div>
                <div class="field"><label>မွေးသက္ကရာဇ်</label><input type="date" @bind="Reg.Dob" class="line"
                        placeholder="ရက် / လ / ခုနှစ်"></div>
                <div class="field"><label>Email</label><input type="email" @bind="Reg.Email" class="line"></div>
                <div class="field"><label>သွေးအုပ်စု</label><input type="text" @bind="Reg.BloodType" class="line"></div>
                <div class="field"><label>ကိုဗစ်ကာကွယ်ရေးထိုးနှံမှု — ထိုး/မထိုး ပြီးစီးသည့်ရက်</label><input
                        type="number" @bind="Reg.CovidVaccineStatus" class="line">
                </div>
                <div class="field">
                    <label>နိုင်ငံသား အမျိုးအစား</label>
                    <div class="nat-row" style="margin-top: 12px;">
                    <InputRadioGroup @bind-Value="Reg.NationalityStatus">
                        <label class="nat-item">
                            <InputRadio Value="@("foreign")" /> နိုင်ငံခြားသား
                        </label>
                        <label class="nat-item">
                            <InputRadio Value="@("local")" /> တိုင်းရင်းသား
                        </label>
                    </InputRadioGroup>
                    </div>
                </div>

            </div>
        </div>
        <div class="form-grid form-grid-3" style="margin-top: 50px;">
            <div class="field"><label>တက္ကသိုလ်ဝင်တန်း ခုံအမှတ်</label><input type="text" @bind="Reg.MatricRollNo" class="line"></div>
            <div class="field"><label>အောင်မြင်သည့် ခုနှစ်</label><input type="text" @bind="Reg.MatricPassedYear" class="line"></div>
            <div class="field"><label>စာစစ်ဌာန </label><input type="text" @bind="Reg.ExamCenter" class="line"></div>


        </div>

        <!-- <hr class="divider"> -->

        <div class="form-grid form-grid-2">
            <div class="field">
                <label>အဘ အုပ်ထိန်းသူ၏ အလုပ်အကိုင်၊ ရာထူး၊ ဌာန </label>
                <input type="text" class="line" @bind="Reg.FatherOccupation" style="margin-top:4px;">
