<div id="ai-widget">
    <div class="ai-widget-popup" id="aiWidgetPopup">
        <div class="widget-header">
            <h4>🤖 PU Maubin Assistant</h4>
            <button class="widget-close" onclick="toggleWidget()"><i class="fas fa-times"></i></button>
        </div>
        <div class="widget-msgs" id="widgetMsgs">
            <div class="widget-msg bot">Hi! 👋 How can I help you with PU Maubin today?</div>
        </div>
        <div class="widget-input-row">
            <input class="widget-input" id="widgetInput" placeholder="Ask a question..."
                onkeypress="if(event.key==='Enter')sendWidgetMsg()">
            <button class="widget-send" onclick="sendWidgetMsg()"><i class="fas fa-paper-plane"></i></button>
        </div>
    </div>
    <button class="ai-fab" onclick="toggleWidget()"><i class="fas fa-robot"></i></button>
</div>