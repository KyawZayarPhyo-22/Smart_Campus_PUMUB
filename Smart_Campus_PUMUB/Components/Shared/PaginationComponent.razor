<div class="d-flex justify-content-between align-items-center px-3" style="margin-top: 50px;">
    <div class="text-muted" style="font-size: 0.9rem;">
        Page <span class="fw-bold" style="color: #5A4FCF;">@CurrentPage</span> of <span
        class="text-dark fw-bold">@TotalPages</span>
    </div>

    <nav aria-label="Page navigation">
        <ul class="pagination pagination-sm mb-0">
            <li class="page-item @(CurrentPage <= 1 ? "disabled" : "")">
                <button class="page-link border-secondary-subtle px-3"
                        style="background-color: #ffffff; color: #5A4FCF; border: 1px solid #dee2e6; cursor: @(CurrentPage <= 1 ? "not-allowed" : "pointer");"
                        @onclick="() => ChangePage(CurrentPage - 1)">
                    <span>&laquo; Prev</span>
                </button>
            </li>

            @foreach (var pageNumber in GetPageNumbers())
            {
                if (pageNumber == null)
                {
                    <li class="page-item disabled">
                        <span class="page-link px-3" style="background-color: #ffffff; color: #6c757d; border: 1px solid #dee2e6;">...</span>
                    </li>
                }
                else
                {
                    var p = pageNumber.Value;
                    <li class="page-item @(CurrentPage == p ? "active" : "")">
                        <button class="page-link px-3"
                                style="@(CurrentPage == p ? "background-color: #5A4FCF; border-color:#5A4FCF; color: white;" : "background-color: #ffffff; color: #5A4FCF; border: 1px solid #dee2e6;")"
                                @onclick="() => ChangePage(p)">
                            @p
                        </button>
                    </li>
                }
            }

            <li class="page-item @(CurrentPage >= TotalPages ? "disabled" : "")">
                <button class="page-link border-secondary-subtle px-3"
                        style="background-color: #ffffff; color: #5A4FCF; border: 1px solid #dee2e6; cursor: @(CurrentPage >= TotalPages ? "not-allowed" : "pointer");"
                        @onclick="() => ChangePage(CurrentPage + 1)">
                    <span>Next &raquo;</span>
                </button>
            </li>
        </ul>
    </nav>
</div>

@code {
    [Parameter] public int CurrentPage { get; set; } = 1;
    [Parameter] public int TotalPages { get; set; } = 1;
    [Parameter] public EventCallback<int> OnPageChanged { get; set; }

    private async Task ChangePage(int newPage)
    {
        if (newPage >= 1 && newPage <= TotalPages && newPage != CurrentPage)
        {
            await OnPageChanged.InvokeAsync(newPage);
        }
    }

    private List<int?> GetPageNumbers()
    {
        var pages = new List<int?>();
        if (TotalPages <= 7)
        {
            for (int i = 1; i <= TotalPages; i++)
            {
                pages.Add(i);
            }
        }
        else
        {
            pages.Add(1);

            int start = Math.Max(2, CurrentPage - 1);
            int end = Math.Min(TotalPages - 1, CurrentPage + 1);

            if (start > 2)
            {
                pages.Add(null);
            }

            for (int i = start; i <= end; i++)
            {
                pages.Add(i);
            }

            if (end < TotalPages - 1)
            {
                pages.Add(null);
            }

            pages.Add(TotalPages);
        }
        return pages;
    }
}