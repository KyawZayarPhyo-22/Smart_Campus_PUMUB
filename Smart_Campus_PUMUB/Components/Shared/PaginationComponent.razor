<style>
    .custom-pagination {
        display: flex;
        align-items: center;
        gap: 6px;
        list-style: none;
        padding-left: 0;
        margin-bottom: 0;
    }

    .custom-page-item {
        display: inline-block;
    }

    /* Base styling for all pagination boxes (numbers, dots, arrows) */
    .custom-page-btn, .custom-page-dots, .custom-page-nav-btn {
        display: flex;
        align-items: center;
        justify-content: center;
        width: 36px;
        height: 36px;
        border-radius: 8px;
        border: 1px solid #e2e8f0;
        background-color: #ffffff;
        color: #1e293b;
        font-weight: 600;
        font-size: 0.95rem;
        cursor: pointer;
        transition: all 0.2s ease;
        padding: 0;
        box-sizing: border-box;
    }

    /* Hover effect for enabled elements */
    .custom-page-btn:hover:not(:disabled), .custom-page-nav-btn:hover:not(:disabled) {
        border-color: #cbd5e1;
        background-color: #f8fafc;
    }

    /* Active page style: Purple border, Purple text, White background */
    .custom-page-item.active .custom-page-btn {
        background-color: #ffffff;
        border: 2px solid #5A4FCF; /* Purple theme border */
        color: #5A4FCF; /* Purple text */
    }

    /* Arrow icon color in active navigation buttons */
    .custom-page-nav-btn {
        color: #94a3b8; /* gray arrow color */
        font-size: 1.1rem;
    }

    /* Disabled Prev/Next button styling (Solid light-gray background with white arrow) */
    .custom-page-nav-btn:disabled {
        background-color: #cbd5e1 !important;
        border-color: #cbd5e1 !important;
        color: #ffffff !important;
        cursor: not-allowed;
    }

    /* Dots representation inside identical box format */
    .custom-page-dots {
        color: #1e293b;
        cursor: default;
    }
</style>

<div class="d-flex justify-content-between align-items-center px-3" style="margin-top: 50px;">
    <div class="text-muted" style="font-size: 0.9rem;">
        Page <span class="fw-bold" style="color: #5A4FCF;">@CurrentPage</span> of <span
        class="text-dark fw-bold">@TotalPages</span>
    </div>

    <nav aria-label="Page navigation">
        <ul class="custom-pagination">
            <!-- Prev Button -->
            <li class="custom-page-item">
                <button class="custom-page-nav-btn"
                        disabled="@(CurrentPage <= 1)"
                        @onclick="() => ChangePage(CurrentPage - 1)">
                    <i class="bi bi-chevron-left" style="font-size: 0.85rem; -webkit-text-stroke: 1px;"></i>
                </button>
            </li>

            <!-- Page Numbers -->
            @foreach (var pageNumber in GetPageNumbers())
            {
                if (pageNumber == null)
                {
                    <li class="custom-page-item">
                        <span class="custom-page-dots">...</span>
                    </li>
                }
                else
                {
                    var p = pageNumber.Value;
                    <li class="custom-page-item @(CurrentPage == p ? "active" : "")">
                        <button class="custom-page-btn" @onclick="() => ChangePage(p)">
                            @p
                        </button>
                    </li>
                }
            }

            <!-- Next Button -->
            <li class="custom-page-item">
                <button class="custom-page-nav-btn"
                        disabled="@(CurrentPage >= TotalPages)"
                        @onclick="() => ChangePage(CurrentPage + 1)">
                    <i class="bi bi-chevron-right" style="font-size: 0.85rem; -webkit-text-stroke: 1px;"></i>
                </button>
            </li>
        </ul>
    </nav>
</div>

@code {
    [Parameter] public int CurrentPage { get; set; } = 1;
    [Parameter] public int TotalPages { get; set; } = 1;
    [Parameter] public EventCallback<int> OnPageChanged { get; set; }

    private async Task ChangePage(int newPage)
    {
        if (newPage >= 1 && newPage <= TotalPages && newPage != CurrentPage)
        {
            await OnPageChanged.InvokeAsync(newPage);
        }
    }

    private List<int?> GetPageNumbers()
    {
        var pages = new List<int?>();
        if (TotalPages <= 5)
        {
            for (int i = 1; i <= TotalPages; i++)
            {
                pages.Add(i);
            }
        }
        else
        {
            if (CurrentPage <= 3)
            {
                pages.Add(1);
                pages.Add(2);
                pages.Add(3);
                pages.Add(null);
                pages.Add(TotalPages);
            }
            else if (CurrentPage >= TotalPages - 2)
            {
                pages.Add(1);
                pages.Add(null);
                pages.Add(TotalPages - 2);
                pages.Add(TotalPages - 1);
                pages.Add(TotalPages);
            }
            else
            {
                pages.Add(1);
                pages.Add(null);
                pages.Add(CurrentPage - 1);
                pages.Add(CurrentPage);
                pages.Add(CurrentPage + 1);
                pages.Add(null);
                pages.Add(TotalPages);
            }
        }
        return pages;
    }
}