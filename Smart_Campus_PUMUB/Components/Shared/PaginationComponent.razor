<div class="d-flex justify-content-between align-items-center px-3" style="margin-top: 50px;">
    <div class="text-muted" style="font-size: 0.9rem;">
        Page <span class="fw-bold" style="color: #5A4FCF;">@CurrentPage</span> of <span
        class="text-dark fw-bold">@TotalPages</span>
    </div>

    <nav aria-label="Page navigation">
        <ul class="pagination pagination-sm mb-0">
            <li class="page-item @(CurrentPage <= 1 ? "disabled" : "")">
                <button class="page-link border-secondary-subtle px-3"
                        style="background-color: #ffffff; color: #5A4FCF; border: 1px solid #dee2e6; cursor: @(CurrentPage <= 1 ? "not-allowed" : "pointer");"
                        @onclick="() => ChangePage(CurrentPage - 1)">
                    <span>&laquo; Prev</span>
                </button>
            </li>

            @for (int i = 1; i <= TotalPages; i++)
            {
                var pageNumber = i;
                <li class="page-item @(CurrentPage == pageNumber ? "active" : "")">
                    <button class="page-link px-3"
                            style="@(CurrentPage == pageNumber ? "background-color: #5A4FCF; border-color:#5A4FCF; color: white;" : "background-color: #ffffff; color: #5A4FCF; border: 1px solid #dee2e6;")"
                            @onclick="() => ChangePage(pageNumber)">
                        @pageNumber
                    </button>
                </li>
            }

            <li class="page-item @(CurrentPage >= TotalPages ? "disabled" : "")">
                <button class="page-link border-secondary-subtle px-3"
                        style="background-color: #ffffff; color: #5A4FCF; border: 1px solid #dee2e6; cursor: @(CurrentPage >= TotalPages ? "not-allowed" : "pointer");"
                        @onclick="() => ChangePage(CurrentPage + 1)">
                    <span>Next &raquo;</span>
                </button>
            </li>
        </ul>
    </nav>
</div>

@code {
    [Parameter] public int CurrentPage { get; set; } = 1;
    [Parameter] public int TotalPages { get; set; } = 1;
    [Parameter] public EventCallback<int> OnPageChanged { get; set; }

    private async Task ChangePage(int newPage)
    {
        if (newPage >= 1 && newPage <= TotalPages && newPage != CurrentPage)
        {
            await OnPageChanged.InvokeAsync(newPage);
        }
    }
}