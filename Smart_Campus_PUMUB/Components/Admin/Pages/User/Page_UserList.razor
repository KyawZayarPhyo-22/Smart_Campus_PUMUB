@page "/admin/users"
@layout AdminLayout
@namespace Smart_Campus_PUMUB.Components.Admin.Pages.User
@using Smart_Campus_PUMUB.WebApi.Models
@rendermode InteractiveServer

<style>
    .custom-table {
        background: rgba(20, 24, 33, 0.6);
        border-radius: 12px;
        overflow: hidden;
        border: 1px solid rgba(255, 255, 255, 0.05);
    }

    .custom-table thead {
        background: rgba(13, 110, 253, 0.1);
        border-bottom: 2px solid rgba(13, 110, 253, 0.2);
    }

    .custom-table th {
        font-weight: 600;
        text-transform: uppercase;
        font-size: 0.85rem;
        color: #0d6efd;
        padding: 16px 20px;
    }

    .custom-table td {
        padding: 16px 20px;
        color: #e2e8f0;
        border-bottom: 1px solid rgba(255, 255, 255, 0.05);
    }

    .table-row-hover:hover {
        background: rgba(255, 255, 255, 0.02);
        box-shadow: inset 4px 0 0 #0d6efd;
    }

    .btn-action-edit {
        background: rgba(13, 110, 253, 0.1);
        color: #39b5ff;
        border: 1px solid rgba(13, 110, 253, 0.3);
        border-radius: 6px;
        padding: 4px 10px;
        font-size: 0.85rem;
        transition: all 0.2s;
    }

    .btn-action-edit:hover {
        background: #0d6efd;
        color: #fff;
    }

    .btn-action-delete {
        background: rgba(220, 53, 69, 0.1);
        color: #ff6b6b;
        border: 1px solid rgba(220, 53, 69, 0.3);
        border-radius: 6px;
        padding: 4px 10px;
        font-size: 0.85rem;
        transition: all 0.2s;
    }

    .btn-action-delete:hover {
        background: #dc3545;
        color: #fff;
    }
</style>

<div class="mb-4">
    <h3 class="fw-bold mb-1" style="color: #ffffff;">User Management</h3>
</div>

<div class="tech-card p-4">
    <div class="row g-3 mb-4 align-items-center">
        <div class="col-md-5">
            <div class="input-group">
                <span class="input-group-text search-icon-bg border-end-0"><i
                    class="bi bi-search text-muted"></i></span>
                    <input type="text" class="form-control border-start-0 text-white"
                           placeholder="Search by Username or Name..." @bind="SearchTerm" @bind:event="oninput">
                </div>
            </div>
            <div class="col-md-7 text-end">
                <NavLink href="/admin/user/create" class="btn btn-primary text-white"><i class="bi bi-person-plus me-1"></i>
                    Add User</NavLink>
                </div>
            </div>

            @if (IsLoading)
            {
                <div class="text-center my-5">
                    <div class="spinner-border text-primary"></div>
                </div>
            }
            else
            {
                <div class="table-responsive custom-table">
                    <table class="table align-middle mb-0">
                        <thead>
                            <tr>
                                <th>No.</th>
                                <th>User</th>
                                <th>Username</th>
                                <th>Role</th>
                                <th>Created</th>
                                <th class="text-center">Actions</th>
                            </tr>
                        </thead>
                        <tbody>
                            @{
                                int count = 1;
                            }
                            @foreach (var user in FilteredUsers)
                            {
                                <tr class="table-row-hover">
                                    <td class="fw-bold text-muted">@count.ToString("D2")</td>
                                    <td>
                                        <div class="d-flex align-items-center gap-2">
                                            <img src="https://ui-avatars.com/api/?name=@user.FullName&size=32" class="rounded-circle"
                                                 width="32" />
                                            <span class="fw-semibold text-white">@user.FullName</span>
                                        </div>
                                    </td>
                                    <td><code class="text-info">@user.UserName</code></td>
                                    <td>
                                        <span
                                            class="badge bg-primary bg-opacity-10 text-primary border border-primary border-opacity-25">
                                            @user.RoleName
                                        </span>
                                    </td>
                                    <td class="text-secondary">@user.CreatedDateTime?.ToString("MMM dd, yyyy")</td>
                                    <td>
                                        <div class="d-flex justify-content-center align-items-center gap-2">
                                            <NavLink href="@($"/admin/user/edit/{user.UserId}")" class="btn btn-action-edit">
                                                <i class="bi bi-pencil me-1"></i> Edit
                                            </NavLink>
                                            <button class="btn btn-action-delete" @onclick="() => OpenDeleteModal(user)">
                                                <i class="bi bi-trash me-1"></i> Delete
                                            </button>
                                        </div>
                                    </td>
                                </tr>
                                count++;
                            }
                        </tbody>
                    </table>
                </div>
            }
        </div>

        @* Delete Modal (Department ပုံစံအတိုင်း ပြင်ထားသည်) *@
        <div class="modal fade @(ShowModal ? "show d-block" : "")" tabindex="-1"
             style="background: @(ShowModal ? "rgba(10, 14, 22, 0.85)" : "none"); backdrop-filter: blur(4px);">
            <div class="modal-dialog modal-dialog-centered">
                <div class="modal-content tech-card" style="border: 1px solid rgba(220, 53, 69, 0.2);">
                    <div class="modal-header border-0 pb-0">
                        <h5 class="modal-title text-danger fw-bold"><i class="bi bi-exclamation-triangle-fill me-2"></i> Confirm
                            Delete</h5>
                        </div>
                        <div class="modal-body text-center py-4">
                            <i class="bi bi-person-x-fill text-danger display-3 mb-3"></i>
                            <h4 class="fw-bold text-white">Delete User?</h4>
                            <p class="text-light opacity-75">ဒီ User ကို ဖျက်ရန် သေချာပါသလား?<br /> Name: <strong
                                class="text-info">@SelectedUser?.FullName</strong></p>
                            </div>
                            <div class="modal-footer border-0 justify-content-center pt-0">
                                <button class="btn btn-secondary px-4" @onclick="CloseDeleteModal">Cancel</button>
                                <button class="btn btn-danger px-4" @onclick="DeleteUser" disabled="@IsProcessing">
                                    @(IsProcessing ? "Deleting..." : "Yes, Delete")
                                </button>
                            </div>
                        </div>
                    </div>
                </div>