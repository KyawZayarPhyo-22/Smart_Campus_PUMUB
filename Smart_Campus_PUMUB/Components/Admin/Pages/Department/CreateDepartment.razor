@page "/admin/department/create"
@layout AdminLayout

<div class="page-header">
    <div class="d-flex align-items-center gap-2">
        <NavLink href="/admin/departments" class="btn btn-sm btn-outline-secondary">
            <i class="bi bi-arrow-left"></i>
        </NavLink>
        <div>
            <h3><i class="bi bi-diagram-3 me-2 text-info"></i>Add New Department</h3>
            <p>Create a new department and link it to a faculty.</p>
        </div>
    </div>
</div>

<div class="row justify-content-center">
    <div class="col-12 col-md-8 col-lg-6">
        <div class="tech-card">

            <div class="mb-4 pb-3 border-bottom" style="border-color: var(--border) !important;">
                <h5 class="fw-bold mb-0">
                    <i class="bi bi-plus-circle me-2 text-info"></i>Department Details
                </h5>
                <p class="text-muted small mb-0 mt-1">Fields marked with <span class="text-danger">*</span> are required.</p>
            </div>

            <div class="row g-3">

                <!-- Faculty FK Dropdown -->
                <div class="col-12">
                    <label class="form-label">
                        Faculty <span class="text-danger">*</span>
                    </label>
                    <select class="form-select">
                        <option value="">-- Select Faculty --</option>
                        <option value="1">Engineering</option>
                        <option value="2">Science and Technology</option>
                        <option value="3">Arts</option>
                        <option value="4">Social Science</option>
                    </select>
                    <div class="form-text">Select the faculty this department belongs to.</div>
                </div>

                <!-- Department Name -->
                <div class="col-12">
                    <label class="form-label">
                        Department Name <span class="text-danger">*</span>
                    </label>
                    <input type="text"
                           class="form-control"
                           placeholder="e.g., Civil Engineering, Information Technology" />
                    <div class="form-text">Enter the full name of the department (max 150 characters).</div>
                </div>

            </div>

            <!-- Actions -->
            <div class="d-flex justify-content-end gap-2 mt-4 pt-3 border-top" style="border-color: var(--border) !important;">
                <NavLink href="/admin/departments" class="btn btn-secondary">
                    <i class="bi bi-x-lg me-1"></i>Cancel
                </NavLink>
                <button type="button" class="btn btn-info text-dark fw-semibold">
                    <i class="bi bi-save me-1"></i>Create Department
                </button>
            </div>

        </div>
    </div>
</div>
