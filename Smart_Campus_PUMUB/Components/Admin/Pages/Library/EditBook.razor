@page "/admin/book/edit/{id:int}"
@layout AdminLayout

<div class="page-header">
    <div class="d-flex align-items-center gap-2">
        <NavLink href="/admin/books" class="btn btn-sm btn-outline-secondary">
            <i class="bi bi-arrow-left"></i>
        </NavLink>
        <div>
            <h3><i class="bi bi-book me-2 text-warning"></i>Edit Book</h3>
            <p>Update book details and category assignment.</p>
        </div>
    </div>
</div>

<div class="row justify-content-center">
    <div class="col-12 col-md-8 col-lg-7">
        <div class="tech-card">

            <div class="mb-4 pb-3 border-bottom" style="border-color: var(--border) !important;">
                <h5 class="fw-bold mb-0">
                    <i class="bi bi-pencil-square me-2 text-warning"></i>Book Details
                </h5>
                <p class="text-muted small mb-0 mt-1">Fields marked with <span class="text-danger">*</span> are required.</p>
            </div>

            <div class="row g-3">

                <!-- Category FK Dropdown -->
                <div class="col-12">
                    <label class="form-label">
                        Category <span class="text-danger">*</span>
                    </label>
                    <select class="form-select">
                        <option value="">-- Select Category --</option>
                        <option value="1" selected>Engineering</option>
                        <option value="2">Mathematics</option>
                        <option value="3">Science</option>
                        <option value="4">Literature</option>
                        <option value="5">History</option>
                    </select>
                    <div class="form-text">Select the category this book belongs to.</div>
                </div>

                <!-- Book Name -->
                <div class="col-12">
                    <label class="form-label">
                        Book Name <span class="text-danger">*</span>
                    </label>
                    <input type="text"
                           class="form-control"
                           value="Advanced Engineering Mathematics"
                           placeholder="e.g., Advanced Engineering Mathematics" />
                    <div class="form-text">Enter the full title of the book (max 150 characters).</div>
                </div>

                <!-- Cover Image -->
                <div class="col-12">
                    <label class="form-label">Cover Image</label>
                    <!-- Current image preview -->
                    <div class="mb-2 d-flex align-items-center gap-3">
                        <img src="https://via.placeholder.com/48x64/1c2333/22d3ee?text=B"
                             width="48" height="64"
                             class="rounded border"
                             style="border-color: var(--border) !important; object-fit:cover;"
                             alt="Current Cover" />
                        <div>
                            <p class="mb-0 small fw-semibold">Current cover</p>
                            <p class="mb-0 text-muted" style="font-size:0.75rem;">engineering_math.jpg</p>
                        </div>
                    </div>
                    <input type="file"
                           class="form-control"
                           accept="image/png, image/jpeg, image/webp" />
                    <div class="form-text">Upload a new cover to replace the current one. Leave empty to keep existing. Max 2 MB.</div>
                </div>

            </div>

            <!-- Actions -->
            <div class="d-flex justify-content-end gap-2 mt-4 pt-3 border-top" style="border-color: var(--border) !important;">
                <NavLink href="/admin/books" class="btn btn-secondary">
                    <i class="bi bi-x-lg me-1"></i>Cancel
                </NavLink>
                <button type="button" class="btn btn-warning text-dark fw-semibold">
                    <i class="bi bi-save me-1"></i>Save Changes
                </button>
            </div>

        </div>
    </div>
</div>

@code {
    [Parameter] public int Id { get; set; }
}
