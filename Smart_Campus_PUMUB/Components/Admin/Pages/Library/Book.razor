@page "/admin/books"
@layout AdminLayout

<div class="page-header">
    <div class="d-flex align-items-center justify-content-between flex-wrap gap-2">
        <div>
            <h3><i class="bi bi-book me-2 text-info"></i>Book Directory</h3>
            <p>Manage all e-books and library resources.</p>
        </div>
        <NavLink href="/admin/book/create" class="btn btn-sm btn-info text-dark fw-semibold">
            <i class="bi bi-plus-lg me-1"></i> Add Book
        </NavLink>
    </div>
</div>

<div class="tech-card">

    <div class="tech-card-header">
        <h6 class="tech-card-title">
            <i class="bi bi-table me-2 text-info"></i>All Books
        </h6>
        <span class="badge bg-info text-dark">3 Records</span>
    </div>

    <!-- Search & Filter -->
    <div class="row g-2 mb-3">
        <div class="col-12 col-md-5">
            <div class="input-group input-group-sm">
                <span class="input-group-text search-icon-bg">
                    <i class="bi bi-search"></i>
                </span>
                <input type="text" class="form-control border-start-0"
                       placeholder="Search by Book ID or Name..." />
            </div>
        </div>
        <div class="col-12 col-md-4">
            <select class="form-select form-select-sm">
                <option value="">Filter by Category...</option>
                <option>Engineering</option>
                <option>Mathematics</option>
                <option>Science</option>
            </select>
        </div>
    </div>

    <!-- Table -->
    <div class="table-responsive">
        <table class="table table-tech table-hover align-middle mb-0">
            <thead>
                <tr>
                    <th>ID</th>
                    <th>Book Name</th>
                    <th class="d-none d-md-table-cell">Category</th>
                    <th class="d-none d-md-table-cell">Cover</th>
                    <th class="d-none d-sm-table-cell">Created Date</th>
                    <th class="text-end">Actions</th>
                </tr>
            </thead>
            <tbody>
                <tr>
                    <td class="text-muted">1</td>
                    <td class="fw-semibold">Advanced Engineering Mathematics</td>
                    <td class="d-none d-md-table-cell">
                        <span class="badge bg-primary bg-opacity-25 text-info border border-info border-opacity-25">
                            Engineering
                        </span>
                    </td>
                    <td class="d-none d-md-table-cell">
                        <img src="https://via.placeholder.com/36x48/1c2333/22d3ee?text=B"
                             width="36" height="48"
                             class="rounded" style="object-fit:cover;" alt="Cover" />
                    </td>
                    <td class="d-none d-sm-table-cell text-secondary">Jun 10, 2026</td>
                    <td class="text-end">
                        <div class="d-flex justify-content-end gap-1">
                            <NavLink href="/admin/book/edit/1" class="btn btn-sm btn-outline-info">
                                <i class="bi bi-pencil"></i>
                                <span class="d-none d-sm-inline ms-1">Edit</span>
                            </NavLink>
                            <button class="btn btn-sm btn-outline-danger"
                                    data-bs-toggle="modal"
                                    data-bs-target="#deleteBookModal">
                                <i class="bi bi-trash"></i>
                                <span class="d-none d-sm-inline ms-1">Delete</span>
                            </button>
                        </div>
                    </td>
                </tr>
                <tr>
                    <td class="text-muted">2</td>
                    <td class="fw-semibold">Calculus and Linear Algebra</td>
                    <td class="d-none d-md-table-cell">
                        <span class="badge bg-success bg-opacity-25 text-success border border-success border-opacity-25">
                            Mathematics
                        </span>
                    </td>
                    <td class="d-none d-md-table-cell">
                        <img src="https://via.placeholder.com/36x48/1c2333/10b981?text=B"
                             width="36" height="48"
                             class="rounded" style="object-fit:cover;" alt="Cover" />
                    </td>
                    <td class="d-none d-sm-table-cell text-secondary">Jun 10, 2026</td>
                    <td class="text-end">
                        <div class="d-flex justify-content-end gap-1">
                            <NavLink href="/admin/book/edit/2" class="btn btn-sm btn-outline-info">
                                <i class="bi bi-pencil"></i>
                                <span class="d-none d-sm-inline ms-1">Edit</span>
                            </NavLink>
                            <button class="btn btn-sm btn-outline-danger"
                                    data-bs-toggle="modal"
                                    data-bs-target="#deleteBookModal">
                                <i class="bi bi-trash"></i>
                                <span class="d-none d-sm-inline ms-1">Delete</span>
                            </button>
                        </div>
                    </td>
                </tr>
                <tr>
                    <td class="text-muted">3</td>
                    <td class="fw-semibold">Physics Fundamentals</td>
                    <td class="d-none d-md-table-cell">
                        <span class="badge bg-warning bg-opacity-25 text-warning border border-warning border-opacity-25">
                            Science
                        </span>
                    </td>
                    <td class="d-none d-md-table-cell">
                        <img src="https://via.placeholder.com/36x48/1c2333/f59e0b?text=B"
                             width="36" height="48"
                             class="rounded" style="object-fit:cover;" alt="Cover" />
                    </td>
                    <td class="d-none d-sm-table-cell text-secondary">Jun 10, 2026</td>
                    <td class="text-end">
                        <div class="d-flex justify-content-end gap-1">
                            <NavLink href="/admin/book/edit/3" class="btn btn-sm btn-outline-info">
                                <i class="bi bi-pencil"></i>
                                <span class="d-none d-sm-inline ms-1">Edit</span>
                            </NavLink>
                            <button class="btn btn-sm btn-outline-danger"
                                    data-bs-toggle="modal"
                                    data-bs-target="#deleteBookModal">
                                <i class="bi bi-trash"></i>
                                <span class="d-none d-sm-inline ms-1">Delete</span>
                            </button>
                        </div>
                    </td>
                </tr>
            </tbody>
        </table>
    </div>

    <!-- Pagination -->
    <div class="d-flex align-items-center justify-content-between mt-3 flex-wrap gap-2">
        <small class="text-muted">Showing 3 of 3 records</small>
        <nav aria-label="Book pagination">
            <ul class="pagination pagination-sm mb-0">
                <li class="page-item disabled">
                    <a class="page-link" href="#"><i class="bi bi-chevron-left"></i></a>
                </li>
                <li class="page-item active"><a class="page-link" href="#">1</a></li>
                <li class="page-item disabled">
                    <a class="page-link" href="#"><i class="bi bi-chevron-right"></i></a>
                </li>
            </ul>
        </nav>
    </div>
</div>

<!-- Delete Modal -->
<div class="modal fade" id="deleteBookModal" tabindex="-1" aria-labelledby="deleteBookModalLabel" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered modal-sm">
        <div class="modal-content">
            <div class="modal-header border-0 pb-0">
                <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>
            <div class="modal-body text-center px-4 pb-2">
                <i class="bi bi-exclamation-triangle-fill text-danger" style="font-size:3.5rem;"></i>
                <h5 class="fw-bold mt-3 mb-1">Delete Book?</h5>
                <p class="text-muted small mb-0">This action cannot be undone. The book record will be permanently removed.</p>
            </div>
            <div class="modal-footer border-0 justify-content-center gap-2 pt-2">
                <button type="button" class="btn btn-sm btn-secondary px-4" data-bs-dismiss="modal">Cancel</button>
                <button type="button" class="btn btn-sm btn-danger px-4">
                    <i class="bi bi-trash me-1"></i>Yes, Delete
                </button>
            </div>
        </div>
    </div>
</div>
