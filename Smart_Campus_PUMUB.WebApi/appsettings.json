    "Audience": "SmartCampusClient"
  },
  "Email": {
    "SmtpHost": "smtp.gmail.com",
    "SmtpPort": 587,
    "EnableSsl": true,
    "SenderEmail": "YOUR_EMAIL@gmail.com",
    "SenderName": "Smart Campus PUMUB",
    "SenderPassword": "YOUR_GMAIL_APP_PASSWORD"
  }
}
